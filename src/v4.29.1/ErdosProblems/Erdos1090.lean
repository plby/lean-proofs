/-
A projection from the hypercube (Fin k)^ι to R^2 given by a linear combination of vectors v_i.
-/
def Proj {ι : Type*} [Fintype ι] (k : ℕ) (v : ι → Fin 2 → ℝ) (x : ι → Fin k) : Fin 2 → ℝ :=
  ∑ i, (x i : ℕ) • v i

/-
The image of a combinatorial line under the projection is a set of collinear points.
-/
lemma image_of_line_is_collinear {ι : Type*} [Fintype ι] (k : ℕ) (v : ι → Fin 2 → ℝ) (l : Combinatorics.Line (Fin k) ι) :
  Collinear ℝ (Set.range (fun x => Proj k v (l x))) := by
    obtain ⟨c, d, hcd⟩ : ∃ (c d : Fin 2 → ℝ), ∀ x ∈ Set.range (fun x : Fin k => Proj k v (l x)), x ∈ setOf (fun x => ∃ t : ℝ, x = c + t • d) := by
      obtain ⟨c, d, hcd⟩ : ∃ (c d : Fin 2 → ℝ), ∀ x ∈ Set.range (fun x : Fin k => Proj k v (l x)), x ∈ setOf (fun x => ∃ t : ℝ, x = c + t • d) := by
        have h_proj : ∀ x : Fin k, Proj k v (l x) = ∑ i, (l x i : ℕ) • v i := by
          exact fun x => rfl
        -- Let $c$ be the sum of the fixed coordinates of $l$ and $d$ be the sum of the moving coordinates of $l$.
        obtain ⟨c, d, hcd⟩ : ∃ c d : Fin 2 → ℝ, ∀ x : Fin k, ∑ i, (l x i : ℕ) • v i = c + x.val • d := by
          obtain ⟨ c, d, hcd ⟩ := l;
          refine ⟨ ∑ i : ι, if h : c i = Option.none then 0 else ( c i |> Option.get! : ℕ ) • v i, ∑ i : ι, if h : c i = Option.none then v i else 0, fun x => ?_ ⟩ ; simp +decide [ Finset.sum_ite ] ; ring_nf;
          simp +decide [ Finset.sum_filter, Finset.mul_sum ];
          rw [ ← Finset.sum_add_distrib ] ; congr ; ext i ; cases c i <;> simp +decide [ * ] ;
        exact ⟨ c, d, by rintro _ ⟨ x, rfl ⟩ ; exact ⟨ x, by aesop ⟩ ⟩;
      use c, d;
    -- Since the range of the projection is contained in a one-dimensional subspace, its rank is at most 1.
    have h_subspace : vectorSpan ℝ (Set.range (fun x : Fin k => Proj k v (l x))) ≤ Submodule.span ℝ {d} := by
      refine Submodule.span_le.mpr ?_;
      rintro x ⟨ y, z, hy, hz, rfl ⟩;
      rcases hcd y z with ⟨ t, rfl ⟩ ; rcases hcd hy hz with ⟨ u, rfl ⟩ ; exact Submodule.mem_span_singleton.mpr ⟨ t - u, by ext i; simp +decide ; ring ⟩;
    refine le_trans ( Submodule.rank_mono h_subspace ) ?_;
    exact le_trans ( rank_span_le _ ) ( by simp +decide )

/-
A projection is generic if it is injective and maps no point outside a combinatorial line $l$ to the affine line spanned by the image of $l$.
-/
def IsGenericProj {ι : Type*} [Fintype ι] (k : ℕ) (v : ι → Fin 2 → ℝ) : Prop :=
  Function.Injective (Proj k v) ∧
  ∀ (l : Combinatorics.Line (Fin k) ι),
    ∀ (x : ι → Fin k), Proj k v x ∈ affineSpan ℝ (Set.range (fun t => Proj k v (l t))) →
    x ∈ Set.range l

/-
For any distinct points $x, y$, there is a projection separating them.
-/
lemma exists_proj_sep {ι : Type*} [Fintype ι] (k : ℕ) (x y : ι → Fin k) (h : x ≠ y) :
  ∃ v : ι → Fin 2 → ℝ, Proj k v x ≠ Proj k v y := by
    classical
    contrapose! h with hxy;
    ext i; specialize hxy ( fun j t => if t = 0 then if j = i then 1 else 0 else 0 ) ; simp_all +decide [ funext_iff, Fin.forall_fin_two ] ;
    unfold Proj at hxy ; aesop;

/-
If a point in the hypercube lies on the affine line generated by a combinatorial line, it must be in the range of that combinatorial line.
-/
lemma mem_affine_span_line_implies_mem_range {ι : Type*} [Finite ι] (k : ℕ) (l : Combinatorics.Line (Fin k) ι) (x : ι → Fin k) :
  (fun i => (x i : ℝ)) ∈ affineSpan ℝ (Set.range (fun (t : Fin k) => (fun i => (l t i : ℝ)))) → x ∈ Set.range l := by
    letI := Fintype.ofFinite ι
    intro hx
    obtain ⟨t, ht⟩ : ∃ t : Fin k, x = l t := by
      -- Since $l$ is a combinatorial line, there exists a coordinate $j$ such that $l(\cdot)_j$ is the identity map (active coordinate).
      obtain ⟨j, hj⟩ : ∃ j : ι, ∀ t : Fin k, (l t j : ℝ) = t := by
        rcases l with ⟨f, hf⟩;
        obtain ⟨ j, hj ⟩ := hf; use j; aesop;
      -- Since $x$ is in the affine span of the image of $l$, we can write $x$ as a linear combination of the points in the image of $l$.
      obtain ⟨c, hc⟩ : ∃ c : Fin k → ℝ, ∑ t ∈ Finset.univ, c t = 1 ∧ (fun i => (x i : ℝ)) = ∑ t ∈ Finset.univ, c t • (fun i => (l t i : ℝ)) := by
        rw [ mem_affineSpan_iff_eq_affineCombination ] at hx;
        obtain ⟨ s, w, hw₁, hw₂ ⟩ := hx; use fun t => if t ∈ s then w t else 0; simp_all +decide
      -- Since $x$ is in the affine span of the image of $l$, we can write $x_j$ as a linear combination of the points in the image of $l$.
      have hx_j : (x j : ℝ) = ∑ t ∈ Finset.univ, c t * (t : ℝ) := by
        convert congr_fun hc.2 j using 1 ; aesop;
      -- Since $x_j$ is an integer between $0$ and $k-1$, and $\sum_{t=0}^{k-1} c_t t$ is a weighted average of the integers $0, 1, \ldots, k-1$, it follows that $x_j$ must be one of these integers.
      obtain ⟨t, ht⟩ : ∃ t : Fin k, (x j : ℝ) = t := by
        exact ⟨ x j, rfl ⟩;
      -- Since $x_j = t$, we have $x = l t$.
      use t
      ext i
      have := congr_fun hc.2 i
      simp_all +decide [ Finset.sum_apply, smul_eq_mul ];
      -- Since $l$ is a combinatorial line, for each coordinate $i$, $l(\cdot)_i$ is either constant or the identity map.
      by_cases h_const : l.idxFun i = none;
      · simp_all +decide
        exact_mod_cast this.trans hx_j.symm;
      · obtain ⟨t', ht'⟩ : ∃ t' : Fin k, l.idxFun i = some t' := by
          exact Option.ne_none_iff_exists'.mp h_const |> fun ⟨ t', ht' ⟩ => ⟨ t', ht' ⟩
        generalize_proofs at *; (
        simp_all +decide [← Finset.sum_mul _ _ _])
    use t;
    exact ht.symm

/-
If two vectors are linearly independent, there is a linear map to the plane preserving their independence.
-/
lemma exists_linear_map_preserving_independence {V : Type*} [AddCommGroup V] [Module ℝ V] (u w : V) (h : LinearIndependent ℝ ![u, w]) :
  ∃ (f : V →ₗ[ℝ] Fin 2 → ℝ), LinearIndependent ℝ ![f u, f w] := by
    -- Since $u$ and $w$ are linearly independent, there exists a linear functional $f$ such that $f(u) \neq 0$ and $f(w) \neq 0$.
    obtain ⟨f, hf⟩ : ∃ f : V →ₗ[ℝ] ℝ, f u ≠ 0 ∧ f w ≠ 0 := by
      obtain ⟨f, hf⟩ : ∃ f : V →ₗ[ℝ] ℝ, f u ≠ 0 := by
        by_cases hu : u = 0;
        · simpa [ hu ] using h.ne_zero 0;
        · have := ( Module.Free.chooseBasis ℝ V );
          -- Since $u \neq 0$, there exists a basis element $e_i$ such that the coefficient of $e_i$ in the expansion of $u$ is non-zero.
          obtain ⟨i, hi⟩ : ∃ i : Module.Free.ChooseBasisIndex ℝ V, (this.repr u) i ≠ 0 := by
            exact not_forall.mp fun h' => hu <| this.ext_elem <| by simp +decide [ h' ] ;
          exact ⟨ this.coord i, by simpa using hi ⟩;
      obtain ⟨g, hg⟩ : ∃ g : V →ₗ[ℝ] ℝ, g w ≠ 0 := by
        by_contra h_contra;
        -- If no such $g$ exists, then $w$ must be the zero vector.
        have hw_zero : w = 0 := by
          contrapose! h_contra;
          have := ( Module.Free.chooseBasis ℝ V );
          obtain ⟨ i, hi ⟩ := Finsupp.ne_iff.mp ( show ( this.repr w ) ≠ 0 from by simpa [ this.repr_self ] using h_contra ) ; use this.coord i; simp_all +decide ;
        simpa [ hw_zero ] using h.ne_zero 1;
      by_cases h_cases : f w = 0 ∧ g u = 0;
      · refine ⟨ f + g, ?_, ?_ ⟩ <;> simp_all +decide;
      · grind;
    obtain ⟨g, hg⟩ : ∃ g : V →ₗ[ℝ] ℝ, g u ≠ 0 ∧ g w = 0 := by
      have h_dual : ∃ g : V →ₗ[ℝ] ℝ, g u ≠ 0 ∧ g w = 0 := by
        have h_subspace : ∃ S : Submodule ℝ V, u∉ S ∧ w ∈ S := by
          use Submodule.span ℝ {w};
          simp_all +decide [ linearIndependent_fin2, Submodule.mem_span_singleton ]
        obtain ⟨ S, huS, hwS ⟩ := h_subspace;
        have h_dual : ∃ g : V →ₗ[ℝ] ℝ, g u ≠ 0 ∧ ∀ v ∈ S, g v = 0 := by
          exact Submodule.exists_le_ker_of_notMem huS;
        obtain ⟨ g, hg₁, hg₂ ⟩ := h_dual;
        use g;
        aesop;
      exact h_dual;
    refine ⟨ ?_, ?_ ⟩
    · exact ( LinearMap.pi fun i => if i = 0 then g else f )
    · refine Fintype.linearIndependent_iff.2 ?_
      simp_all +decide [ Fin.forall_fin_two, funext_iff ]

/-
The projection defined by a linear map on basis vectors acts as the linear map on the whole vector.
-/
open Classical in
lemma proj_eq_linear_map_apply {ι : Type*} [Fintype ι] (k : ℕ) (f : (ι → ℝ) →ₗ[ℝ] Fin 2 → ℝ) (x : ι → Fin k) :
  Proj k (fun i => f (Pi.single i 1)) x = f (fun i => (x i : ℝ)) := by
    classical
    unfold Proj
    convert f.pi_apply_eq_sum_univ _ using 1
    focus convert f.pi_apply_eq_sum_univ _ using 1
    focus rw [ f.pi_apply_eq_sum_univ ]
    focus congr! 2
    any_goals exact fun i => ( x i : ℝ );
    · ext; simp +decide
    · exact congr_arg f ( funext fun j => by aesop );
    · convert f.pi_apply_eq_sum_univ _ using 1;
    · convert f.pi_apply_eq_sum_univ _ using 2

/-
If three points form a non-degenerate triangle in the hypercube, there is a projection that maps them to a non-degenerate triangle in the plane.
-/
lemma exists_proj_preserving_independence {ι : Type*} [Fintype ι] (k : ℕ) (x y z : ι → Fin k)
  (h : LinearIndependent ℝ ![fun i => (y i : ℝ) - (x i : ℝ), fun i => (z i : ℝ) - (x i : ℝ)]) :
  ∃ v : ι → Fin 2 → ℝ, LinearIndependent ℝ ![Proj k v y - Proj k v x, Proj k v z - Proj k v x] := by
    classical
    -- By `exists_linear_map_preserving_independence`, there exists a linear map $f$ such that $f(u)$ and $f(w)$ are linearly independent.
    obtain ⟨f, hf⟩ : ∃ f : (ι → ℝ) →ₗ[ℝ] (Fin 2 → ℝ), LinearIndependent ℝ ![f (fun i => (y i : ℝ) - (x i : ℝ)), f (fun i => (z i : ℝ) - (x i : ℝ))] := by
      convert exists_linear_map_preserving_independence _ _ h using 1;
    refine ⟨ fun i => f ( Pi.single i 1 ), ?_ ⟩;
    convert hf using 2 <;> simp +decide [ proj_eq_linear_map_apply ];
    · rw [ ← map_sub ];
      rfl;
    · rw [ ← map_sub ];
      rfl

/-
The affine span of the projection of a line is the line through the projections of its first two points.
-/
lemma affine_span_image_line_eq_span_pair {ι : Type*} [Fintype ι] (k : ℕ) (hk : 3 ≤ k) (v : ι → Fin 2 → ℝ) (l : Combinatorics.Line (Fin k) ι) :
  affineSpan ℝ (Set.range (fun t => Proj k v (l t))) = affineSpan ℝ {Proj k v (l ⟨0, by linarith⟩), Proj k v (l ⟨1, by linarith⟩)} := by
    classical
    refine le_antisymm ?_ ?_ <;> simp_all +decide [ affineSpan_le ];
    · rintro _ ⟨ t, rfl ⟩ ; simp +decide [ spanPoints ] ; (
      -- By definition of $Proj$, we know that $Proj k v (l t) = Proj k v (l ⟨0, by linarith⟩) + t \cdot (Proj k v (l ⟨1, by linarith⟩) - Proj k v (l ⟨0, by linarith⟩))$.
      have h_proj : ∀ t : Fin k, Proj k v (l t) = Proj k v (l ⟨0, by linarith⟩) + t.val • (Proj k v (l ⟨1, by linarith⟩) - Proj k v (l ⟨0, by linarith⟩)) := by
        intro t; exact (by
        obtain ⟨l_val, hl⟩ := l
        generalize_proofs at *;
        simp +decide [ Proj, smul_sub ];
        rw [ Finset.mul_sum _ _ _, Finset.mul_sum _ _ _ ] ; rw [ ← Finset.sum_sub_distrib ] ; rw [ ← Finset.sum_add_distrib ] ; congr ; ext x ; cases h : l_val x <;> aesop;);
      refine Or.inl ⟨ ?_, ?_, ?_ ⟩ <;> norm_num [ h_proj t ]
      · exact ( t : ℝ ) • ( Proj k v ( l ⟨ 1, by linarith ⟩ ) - Proj k v ( l ⟨ 0, by linarith ⟩ ) )
      · exact Submodule.smul_mem _ _ ( Submodule.subset_span ( Set.mem_vsub.mpr ⟨ _, Set.mem_insert_of_mem _ ( Set.mem_singleton _ ), _, Set.mem_insert _ _, rfl ⟩ ) );
      · exact add_comm _ _);
    · rintro x ( rfl | rfl ) <;> [ exact subset_affineSpan ℝ _ ⟨ _, rfl ⟩ ; exact subset_affineSpan ℝ _ ⟨ _, rfl ⟩ ]


/-
Given a finite set of non-zero polynomials over an infinite domain, there is a point where none of them are zero.
-/
lemma exists_not_root_of_finite_product {σ R : Type*} [CommRing R] [IsDomain R] [Infinite R] [Finite σ] (s : Finset (MvPolynomial σ R)) (h : ∀ p ∈ s, p ≠ 0) :
  ∃ x : σ → R, ∀ p ∈ s, MvPolynomial.eval x p ≠ 0 := by
    letI := Fintype.ofFinite σ
    by_contra! h_contra;
    -- The product of non-zero polynomials is non-zero.
    have h_prod_nonzero : ∏ p ∈ s, p ≠ 0 := by
      exact Finset.prod_ne_zero_iff.mpr h;
    refine h_prod_nonzero ( MvPolynomial.funext fun x => ?_ );
    simp +decide [ Finset.prod_eq_zero_iff, h_contra x ]


/-
Polynomials representing the failure of injectivity and the failure of the line condition.
-/
noncomputable def ProjPoly {ι : Type*} [Fintype ι] (k : ℕ) (x : ι → Fin k) (j : Fin 2) : MvPolynomial (ι × Fin 2) ℝ :=
  ∑ i, (x i : ℝ) • MvPolynomial.X (i, j)

noncomputable def InjectivityPoly {ι : Type*} [Fintype ι] (k : ℕ) (x y : ι → Fin k) : MvPolynomial (ι × Fin 2) ℝ :=
  (ProjPoly k x 0 - ProjPoly k y 0)^2 + (ProjPoly k x 1 - ProjPoly k y 1)^2

noncomputable def CollinearityPoly {ι : Type*} [Fintype ι] (k : ℕ) (hk : 3 ≤ k) (l : Combinatorics.Line (Fin k) ι) (x : ι → Fin k) : MvPolynomial (ι × Fin 2) ℝ :=
  let a := l ⟨0, by linarith⟩
  let b := l ⟨1, by linarith⟩
  (ProjPoly k b 0 - ProjPoly k a 0) * (ProjPoly k x 1 - ProjPoly k a 1) -
  (ProjPoly k b 1 - ProjPoly k a 1) * (ProjPoly k x 0 - ProjPoly k a 0)

/-
The polynomial measuring the distance between the projections of two distinct points is not identically zero.
-/
lemma injectivity_poly_ne_zero {ι : Type*} [Fintype ι] (k : ℕ) (x y : ι → Fin k) (h : x ≠ y) :
  InjectivityPoly k x y ≠ 0 := by
    -- By contradiction, assume that InjectivityPoly k x y is the zero polynomial.
    by_contra h_zero_poly;
    -- By definition of InjectivityPoly, we have that for all $v$, $(Proj v x - Proj v y)^2 = 0$.
    have h_proj_eq : ∀ v : ι → Fin 2 → ℝ, (Proj k v x - Proj k v y) = 0 := by
      intro v
      have h_eval_zero : (Proj k v x 0 - Proj k v y 0)^2 + (Proj k v x 1 - Proj k v y 1)^2 = 0 := by
        convert congr_arg ( MvPolynomial.eval ( fun p => v p.1 p.2 ) ) h_zero_poly using 1;
        unfold InjectivityPoly ProjPoly; simp +decide ;
        unfold Proj; simp +decide [Finset.sum_apply] ;
      ext i; fin_cases i <;> norm_num <;> nlinarith! only [ h_eval_zero ] ;
    exact absurd ( exists_proj_sep k x y h ) ( by rintro ⟨ v, hv ⟩ ; exact hv ( sub_eq_zero.mp ( h_proj_eq v ) ) )

/-
Evaluating the projection polynomial gives the projection coordinate.
-/
lemma eval_proj_poly {ι : Type*} [Fintype ι] (k : ℕ) (x : ι → Fin k) (j : Fin 2) (v : ι → Fin 2 → ℝ) :
  MvPolynomial.eval (fun p : ι × Fin 2 => v p.1 p.2) (ProjPoly k x j) = Proj k v x j := by
    unfold ProjPoly Proj; aesop;

/-
Evaluating the collinearity polynomial gives the determinant of the vectors formed by the projected points.
-/
lemma eval_collinearity_poly {ι : Type*} [Fintype ι] (k : ℕ) (hk : 3 ≤ k) (l : Combinatorics.Line (Fin k) ι) (x : ι → Fin k) (v : ι → Fin 2 → ℝ) :
  MvPolynomial.eval (fun p : ι × Fin 2 => v p.1 p.2) (CollinearityPoly k hk l x) =
  let a := l ⟨0, by linarith⟩
  let b := l ⟨1, by linarith⟩
  (Proj k v b 0 - Proj k v a 0) * (Proj k v x 1 - Proj k v a 1) -
  (Proj k v b 1 - Proj k v a 1) * (Proj k v x 0 - Proj k v a 0) := by
    -- By definition of `CollinearityPoly`, we can expand it using the `eval_proj_poly` lemma.
    simp [CollinearityPoly, eval_proj_poly]

/-
The set of combinatorial lines is finite.
-/
instance instFiniteLine {α ι : Type*} [Finite α] [Finite ι] : Finite (Combinatorics.Line α ι) := by
  exact Finite.of_injective ( fun f => f.1 ) ( by aesop_cat )

noncomputable instance instFintypeLine {α ι : Type*} [Finite α] [Finite ι] : Fintype (Combinatorics.Line α ι) := Fintype.ofFinite (Combinatorics.Line α ι)

/-
There exists a projection that maps the first two points of a line and a point not on the line to an affinely independent set in the plane.
-/
lemma exists_good_proj_for_line {ι : Type*} [Fintype ι] (k : ℕ) (hk : 3 ≤ k) (l : Combinatorics.Line (Fin k) ι) (x : ι → Fin k) (hx : x ∉ Set.range l) :
  ∃ v : ι → Fin 2 → ℝ, LinearIndependent ℝ ![Proj k v (l ⟨1, by linarith⟩) - Proj k v (l ⟨0, by linarith⟩), Proj k v x - Proj k v (l ⟨0, by linarith⟩)] := by
    convert exists_proj_preserving_independence k ( l ⟨ 0, by linarith ⟩ ) ( l ⟨ 1, by linarith ⟩ ) x _ using 1;
    have h_affine_indep : ¬(fun i => (x i : ℝ)) ∈ affineSpan ℝ (Set.range (fun (t : Fin k) => (fun i => (l t i : ℝ)))) := by
      intro h;
      exact hx ( mem_affine_span_line_implies_mem_range k l x h );
    refine linearIndependent_fin2.mpr ⟨ ?_, ?_ ⟩;
    · exact sub_ne_zero_of_ne fun h => h_affine_indep <| h.symm ▸ mem_affineSpan ℝ ( Set.mem_range_self _ );
    · intro a ha;
      by_cases ha : a = 0 <;> simp_all +decide;
      · rename_i h;
        rw [ eq_comm ] at h;
        simp_all +decide [ funext_iff, sub_eq_zero ];
        rcases l with ⟨l, hl⟩;
        grind;
      · refine h_affine_indep ?_;
        refine ⟨ ?_, ?_, ?_ ⟩
        · exact fun i => ( l.idxFun i |> Option.getD ) ⟨ 0, by linarith ⟩
        · exact ⟨ ⟨ 0, by linarith ⟩, rfl ⟩;
        · refine ⟨ fun i => ( a⁻¹ : ℝ ) • ( ( l.idxFun i |> Option.getD ) ⟨ 1, by linarith ⟩ - ( l.idxFun i |> Option.getD ) ⟨ 0, by linarith ⟩ ), ?_, ?_ ⟩ <;> simp_all +decide [ funext_iff, vectorSpan ];
          · exact Submodule.smul_mem _ _
              (Submodule.subset_span ⟨ _, Set.mem_range_self ⟨ 1, by linarith ⟩, _, Set.mem_range_self ⟨ 0, by linarith ⟩, rfl ⟩);
          · grind

/-
If two vectors in $\mathbb{R}^2$ are linearly independent, their determinant is non-zero.
-/
lemma det_ne_zero_of_linear_independent_fin2 (u w : Fin 2 → ℝ) (h : LinearIndependent ℝ ![u, w]) :
  u 0 * w 1 - u 1 * w 0 ≠ 0 := by
    rw [ linearIndependent_fin2 ] at h;
    contrapose! h;
    by_cases hu0 : u 0 = 0 <;> by_cases hw0 : w 0 = 0 <;> simp_all +decide [ sub_eq_iff_eq_add, funext_iff, Fin.forall_fin_two ];
    · exact fun hw1 => ⟨ u 1 / w 1, div_mul_cancel₀ _ hw1 ⟩;
    · exact ⟨ u 0 / w 0, by rw [ div_mul_cancel₀ _ hw0 ], by rw [ div_mul_eq_mul_div, div_eq_iff hw0 ] ; linarith ⟩

/-
The collinearity polynomial is not identically zero.
-/
lemma collinearity_poly_ne_zero {ι : Type*} [Fintype ι] (k : ℕ) (hk : 3 ≤ k) (l : Combinatorics.Line (Fin k) ι) (x : ι → Fin k) (hx : x ∉ Set.range l) :
  CollinearityPoly k hk l x ≠ 0 := by
    -- By `exists_good_proj_for_line`, there exists `v` such that `u = Proj k v (l 1) - Proj k v (l 0)` and `w = Proj k v x - Proj k v (l 0)` are linearly independent.
    obtain ⟨v, hv⟩ : ∃ v : ι → Fin 2 → ℝ, LinearIndependent ℝ ![Proj k v (l ⟨1, by linarith⟩) - Proj k v (l ⟨0, by linarith⟩), Proj k v x - Proj k v (l ⟨0, by linarith⟩)] := by
      exact exists_good_proj_for_line k hk l x hx;
    -- By `det_ne_zero_of_linear_independent_fin2`, `u 0 * w 1 - u 1 * w 0 ≠ 0`.
    have h_det_ne_zero : (Proj k v (l ⟨1, by linarith⟩) 0 - Proj k v (l ⟨0, by linarith⟩) 0) * (Proj k v x 1 - Proj k v (l ⟨0, by linarith⟩) 1) - (Proj k v (l ⟨1, by linarith⟩) 1 - Proj k v (l ⟨0, by linarith⟩) 1) * (Proj k v x 0 - Proj k v (l ⟨0, by linarith⟩) 0) ≠ 0 := by
      convert det_ne_zero_of_linear_independent_fin2 _ _ hv using 1;
    contrapose! h_det_ne_zero;
    convert congr_arg ( fun p => MvPolynomial.eval ( fun p' : ι × Fin 2 => v p'.1 p'.2 ) p ) h_det_ne_zero using 1 ; simp +decide [ eval_collinearity_poly ]

/-
There exists a generic projection from the hypercube to the plane.
-/
set_option maxHeartbeats 1000000 in
-- The generic projection argument needs extra heartbeats for polynomial evaluation simplification.
lemma exists_generic_proj {ι : Type*} [Fintype ι] (k : ℕ) (hk : 3 ≤ k) : ∃ v : ι → Fin 2 → ℝ, IsGenericProj k v := by
  classical
  by_contra h_contra;
  -- Apply `exists_not_root_of_finite_product` to find such a point `v_raw`.
  obtain ⟨v_raw, hv_raw⟩ : ∃ v_raw : ι × Fin 2 → ℝ, (∀ x y : ι → Fin k, x ≠ y → (InjectivityPoly k x y).eval v_raw ≠ 0) ∧ (∀ l : Combinatorics.Line (Fin k) ι, ∀ x : ι → Fin k, x∉Set.range l → (CollinearityPoly k hk l x).eval v_raw ≠ 0) := by
    have h_finite : Set.Finite {p : MvPolynomial (ι × Fin 2) ℝ | ∃ x y : ι → Fin k, x ≠ y ∧ p = InjectivityPoly k x y ∨ ∃ l : Combinatorics.Line (Fin k) ι, ∃ x : ι → Fin k, x∉Set.range l ∧ p = CollinearityPoly k hk l x} := by
      exact Set.Finite.subset ( Set.toFinite ( Finset.image ( fun p : ( ι → Fin k ) × ( ι → Fin k ) => InjectivityPoly k p.1 p.2 ) ( Finset.univ ) ∪ Finset.image ( fun p : Combinatorics.Line ( Fin k ) ι × ( ι → Fin k ) => CollinearityPoly k hk p.1 p.2 ) ( Finset.univ ) ) ) fun p hp => by aesop;
    obtain ⟨S, hS⟩ : ∃ S : Finset (MvPolynomial (ι × Fin 2) ℝ), {p : MvPolynomial (ι × Fin 2) ℝ | ∃ x y : ι → Fin k, x ≠ y ∧ p = InjectivityPoly k x y ∨ ∃ l : Combinatorics.Line (Fin k) ι, ∃ x : ι → Fin k, x∉Set.range l ∧ p = CollinearityPoly k hk l x} = (S : Set (MvPolynomial (ι × Fin 2) ℝ)) := by
      exact ⟨ h_finite.toFinset, h_finite.coe_toFinset.symm ⟩;
    obtain ⟨ v_raw, hv_raw ⟩ := exists_not_root_of_finite_product S ( by
      intro p hp
      by_cases h_inj : ∃ x y : ι → Fin k, x ≠ y ∧ p = InjectivityPoly k x y;
      · obtain ⟨ x, y, hxy, rfl ⟩ := h_inj; exact injectivity_poly_ne_zero k x y hxy;
      · obtain ⟨ l, x, hx, rfl ⟩ := hS.symm.subset hp |> fun ⟨ x, y, hxy ⟩ => hxy.resolve_left fun h => h_inj ⟨ x, y, h ⟩;
        exact collinearity_poly_ne_zero k hk l x hx );
    exact ⟨ v_raw, fun x y hxy => hv_raw _ <| hS.subset ⟨ x, y, Or.inl ⟨ hxy, rfl ⟩ ⟩, fun l x hx => hv_raw _ <| hS.subset ⟨ x, x, Or.inr ⟨ l, x, hx, rfl ⟩ ⟩ ⟩;
  refine h_contra ⟨ fun i j => v_raw ( i, j ), ?_, ?_ ⟩;
  · intro x y hxy
    have h_eval : (InjectivityPoly k x y).eval v_raw = 0 := by
      unfold InjectivityPoly; simp_all +decide [ funext_iff, Fin.forall_fin_two ] ;
      simp_all +decide [ ProjPoly, Proj ]
    have h_contra : x = y := by
      exact Classical.not_not.1 fun h => hv_raw.1 x y h h_eval
    exact h_contra;
  · intro l x hx
    by_cases hx_range : x ∈ Set.range l
    · exact hx_range
    · have h_det_nonzero : (Proj k (fun i j => v_raw (i, j)) (l ⟨1, by linarith⟩) 0 - Proj k (fun i j => v_raw (i, j)) (l ⟨0, by linarith⟩) 0) * (Proj k (fun i j => v_raw (i, j)) x 1 - Proj k (fun i j => v_raw (i, j)) (l ⟨0, by linarith⟩) 1) - (Proj k (fun i j => v_raw (i, j)) (l ⟨1, by linarith⟩) 1 - Proj k (fun i j => v_raw (i, j)) (l ⟨0, by linarith⟩) 1) * (Proj k (fun i j => v_raw (i, j)) x 0 - Proj k (fun i j => v_raw (i, j)) (l ⟨0, by linarith⟩) 0) ≠ 0 := by
        convert hv_raw.2 l x hx_range using 1;
        convert eval_collinearity_poly k hk l x ( fun i j => v_raw ( i, j ) ) |> Eq.symm using 1;
      -- Since the determinant is non-zero, the points are affinely independent, and thus $x$ cannot be in the affine span of the image of $l$.
      have h_affine_indep : ¬(Proj k (fun i j => v_raw (i, j)) x ∈ affineSpan ℝ {Proj k (fun i j => v_raw (i, j)) (l ⟨0, by linarith⟩), Proj k (fun i j => v_raw (i, j)) (l ⟨1, by linarith⟩)}) := by
        rw [ affineSpan ];
        simp +decide [ spanPoints ];
        simp +decide [ vectorSpan_pair ];
        simp +decide [ Submodule.mem_span_singleton ] at *;
        rintro ( ⟨ a, ha ⟩ | ⟨ a, ha ⟩ ) <;> simp_all +decide [ sub_eq_iff_eq_add ];
        · exact h_det_nonzero ( by ring );
        · exact h_det_nonzero ( by ring );
      exact False.elim ( h_affine_indep <| by rw [ affine_span_image_line_eq_span_pair k hk ( fun i j => v_raw ( i, j ) ) l ] at hx; exact hx )

/-
For any $k \ge 3$, there exists a finite set $A \subset \mathbb{R}^2$ such that for any 2-coloring of $A$, there exists a line containing at least $k$ points of $A$, all of which have the same color.
-/
theorem exists_set_with_monochromatic_line_property (k : ℕ) (hk : 3 ≤ k) :
  ∃ (A : Finset (Fin 2 → ℝ)), ∀ (C : A → Fin 2),
    ∃ (S : Finset (Fin 2 → ℝ)), ∃ (hSA : S ⊆ A), Collinear ℝ (S : Set (Fin 2 → ℝ)) ∧ S.card ≥ k ∧
      ∃ c, ∀ x (hx : x ∈ S), C ⟨x, hSA hx⟩ = c := by
        classical
        by_contra h;
        -- Use `Combinatorics.Line.exists_mono_in_high_dimension` with `α = Fin k` and `κ = Fin 2` to find a dimension `ι` (and `Fintype ι`) such that any 2-coloring of `(Fin k)^ι` has a monochromatic line.
        obtain ⟨ι, hι⟩ : ∃ (ι : Type) (x : Fintype ι), ∀ (C : (ι → Fin k) → Fin 2), ∃ (l : Combinatorics.Line (Fin k) ι), Combinatorics.Line.IsMono C l := by
          exact Combinatorics.Line.exists_mono_in_high_dimension (Fin k) (Fin 2);
        obtain ⟨ _, hι ⟩ := hι;
        -- Use `exists_generic_proj` to find a generic projection `v : ι → Fin 2 → ℝ`.
        obtain ⟨v, hv⟩ : ∃ v : ι → Fin 2 → ℝ, IsGenericProj k v := exists_generic_proj k hk;
        refine h ⟨ Finset.image ( fun x : ι → Fin k => ∑ i, ( x i : ℕ ) • v i ) Finset.univ, fun C => ?_ ⟩;
        obtain ⟨ l, hl ⟩ := hι ( fun x => C ⟨ ∑ i, ( x i : ℕ ) • v i, Finset.mem_image_of_mem _ ( Finset.mem_univ _ ) ⟩ );
        refine ⟨ Finset.image ( fun x => ∑ i, ( l x i : ℕ ) • v i ) Finset.univ, ?_, ?_, ?_, ?_ ⟩
        · exact Finset.image_subset_iff.mpr fun x _ => Finset.mem_image.mpr ⟨ l x, Finset.mem_univ _, rfl ⟩
        · convert image_of_line_is_collinear k v l using 1;
          ext; simp [Proj];
        · rw [ Finset.card_image_of_injective ];
          · simp +decide [ Finset.card_univ ];
          · have := hv.1;
            convert this.comp ( show Function.Injective ( fun x : Fin k => l x ) from ?_ ) using 1;
            intro x y hxy;
            have := l.2;
            obtain ⟨ i, hi ⟩ := this; have := congr_fun hxy i; aesop;
        · obtain ⟨ c, hc ⟩ := hl;
          exact ⟨ c, fun x hx => by obtain ⟨ y, hy, rfl ⟩ := Finset.mem_image.mp hx; exact hc y ⟩

/-
The stronger version of the theorem: not only is there a monochromatic set of $k$ points on a line,
but ALL points of $A$ on that line have the same color.
This is guaranteed by the `IsGenericProj` property, which ensures that the image of a
combinatorial line $l$ contains all points of $A$ that lie on the affine line spanned by $Proj(l)$.

Generated by Gemini 3.0 Flash
-/
theorem exists_set_with_strict_monochromatic_line_property (k : ℕ) (hk : 3 ≤ k) :
  ∃ (A : Finset (Fin 2 → ℝ)), ∀ (C : A → Fin 2),
    ∃ (S : Finset (Fin 2 → ℝ)), ∃ (hSA : S ⊆ A),
      Collinear ℝ (S : Set (Fin 2 → ℝ)) ∧ S.card ≥ k ∧
      (∀ y ∈ A, y ∈ affineSpan ℝ (S : Set (Fin 2 → ℝ)) → y ∈ S) ∧
      ∃ c, ∀ x (hx : x ∈ S), C ⟨x, hSA hx⟩ = c := by
  classical
  -- 1. Find a dimension ι such that (Fin k)^ι has the Hales-Jewett property for 2 colors.
  obtain ⟨ι, inst, hι⟩ := Combinatorics.Line.exists_mono_in_high_dimension (Fin k) (Fin 2)
  -- 2. Find a generic projection from (Fin k)^ι to R^2.
  obtain ⟨v, hv_gen⟩ := @exists_generic_proj ι inst k hk
  -- 3. Define A as the image of the hypercube under the generic projection.
  letI : Fintype ι := inst
  let A_set : Finset (Fin 2 → ℝ) := Finset.univ.image (Proj k v)
  use A_set
  intro C
  -- 4. Define a coloring C' on the hypercube by pulling back C.
  let C' : (ι → Fin k) → Fin 2 := fun x => C ⟨Proj k v x, Finset.mem_image_of_mem _ (Finset.mem_univ x)⟩
  -- 5. By Hales-Jewett, there exists a monochromatic combinatorial line l.
  obtain ⟨l, c, hl_mono⟩ := hι C'
  -- 6. Define S as the image of the combinatorial line l.
  let S_set : Finset (Fin 2 → ℝ) := Finset.univ.image (fun t => Proj k v (l t))
  use S_set
  -- S_set is a subset of A_set.
  have hSA : S_set ⊆ A_set := by
    intro x hx
    obtain ⟨t, _, rfl⟩ := Finset.mem_image.mp hx
    exact Finset.mem_image_of_mem _ (Finset.mem_univ (l t))
  use hSA
  -- 7. Verify the properties:
  constructor
  · -- a) S_set is collinear (since it's the image of a combinatorial line).
    convert image_of_line_is_collinear k v l using 1
    ext; simp [S_set]
  constructor
  · -- b) S_set has cardinality k (since projection is injective on the line).
    rw [Finset.card_image_of_injective]
    · simp
    · intro x y hxy
      have h_proj_eq := hv_gen.1 hxy
      -- A combinatorial line is injective because it has at least one moving coordinate.
      obtain ⟨i, hi⟩ := l.proper
      have hx : l x i = x := by
        simp [hi]
      have hy : l y i = y := by
        simp [hi]
      have h_coord := congr_fun h_proj_eq i
      rwa [hx, hy] at h_coord
  constructor
  · -- c) Exhaustion: Any point of A on the line through S_set must be in S_set.
    intro y hyA hySpan
    obtain ⟨x, _, rfl⟩ := Finset.mem_image.mp hyA
    -- Since the projection is generic, if Proj(x) is on the line of Proj(l), x is in the range of l.
    have hx_range : x ∈ Set.range l := by
      apply hv_gen.2 l x
      -- S_set is the image of the combinatorial line, its affine span is the same.
      convert hySpan using 1
      ext p
      simp [S_set]
    obtain ⟨t, ht⟩ := hx_range
    rw [← ht]
    exact Finset.mem_image_of_mem _ (Finset.mem_univ t)
  · -- d) S_set is monochromatic.
    use c
    intro x hx
    obtain ⟨t, _, rfl⟩ := Finset.mem_image.mp hx
    exact hl_mono t

end Erdos1090

