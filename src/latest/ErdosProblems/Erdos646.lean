private lemma zmod_two_eq_zero_or_one (a : ZMod 2) : a = 0 ∨ a = 1 := by
  have hlt : a.val < 2 := ZMod.val_lt a
  have hval : a.val = 0 ∨ a.val = 1 := by omega
  rcases hval with hval | hval
  · left
    exact (ZMod.val_eq_zero a).mp hval
  · right
    exact (ZMod.val_eq_one (by norm_num) a).mp hval

/-
Given k+1 elements in (Z/2Z)^k, there exists a non-empty subset summing to 0.
-/
lemma exists_subset_sum_zero {k : ℕ} (v : Fin (k + 1) → (Fin k → ZMod 2)) :
  ∃ (I : Finset (Fin (k + 1))), I.Nonempty ∧ ∑ i ∈ I, v i = 0 := by
    classical
    -- Consider the $k+1$ vectors $v_1, v_2, \ldots, v_{k+1}$ in the $k$-dimensional vector space $(\mathbb{Z}/2\mathbb{Z})^k$.
    have h_linear_dep : ¬ LinearIndependent (ZMod 2) v := by
      intro h
      have hle := linearIndependent_le_basis (Pi.basisFun (ZMod 2) (Fin k)) v h
      simp_all +decide
      exact absurd hle (by norm_cast; linarith)
    rw [Fintype.not_linearIndependent_iff] at h_linear_dep
    obtain ⟨g, hg₁, i, hi⟩ := h_linear_dep
    let I : Finset (Fin (k + 1)) := Finset.univ.filter fun j => g j = 1
    refine ⟨I, ?_, ?_⟩
    · have hgi : g i = 1 := by
        rcases zmod_two_eq_zero_or_one (g i) with h0 | h1
        · exact (hi h0).elim
        · exact h1
      exact ⟨i, by simp [I, hgi]⟩
    · calc
        ∑ i ∈ I, v i = ∑ j, (if g j = 1 then v j else 0) := by
          simp [I, Finset.sum_filter]
        _ = ∑ j, g j • v j := by
          apply Finset.sum_congr rfl
          intro j _
          by_cases hgj : g j = 1
          · simp [hgj]
          · have hgj0 : g j = 0 := by
              rcases zmod_two_eq_zero_or_one (g j) with h0 | h1
              · exact h0
              · exact (hgj h1).elim
            simp [hgj0]
        _ = 0 := hg₁

/-
If n > 0 and v_p(n) <= M, then v_p(n + k * p^(M+1)) = v_p(n).
-/
lemma padicValNat_periodic_pos (p : ℕ) (hp : p.Prime) (n k M : ℕ) (hn : n > 0) (h : padicValNat p n ≤ M) :
  padicValNat p (n + k * p ^ (M + 1)) = padicValNat p n := by
    -- Let $v = v_p(n)$. We have $v \le M$.
    set v : ℕ := padicValNat p n with hv_def
    have hv_le_M : v ≤ M := h;
    -- Write $n = p^v \cdot u$ where $p \nmid u$.
    obtain ⟨u, hu⟩ : ∃ u : ℕ, n = p^v * u ∧ ¬ p ∣ u := by
      use n / p^v, by
        rw [ Nat.mul_div_cancel' ];
        exact pow_padicValNat_dvd, by
        rw [ Nat.dvd_div_iff_mul_dvd ];
        · rw [ ← pow_succ ];
          haveI := Fact.mk hp; rw [ padicValNat_dvd_iff_le ] ; aesop;
          positivity;
        · exact pow_padicValNat_dvd;
    -- Then $n + k p^{M+1} = p^v u + k p^{M+1} = p^v (u + k p^{M+1-v})$.
    have h_factor : n + k * p^(M + 1) = p^v * (u + k * p^(M + 1 - v)) := by
      rw [ hu.1, mul_add, mul_left_comm, ← pow_add, add_tsub_cancel_of_le ( by linarith ) ];
    -- Since $v \le M$, $M+1-v \ge 1$, so $p \mid p^{M+1-v}$.
    have h_div : ¬ p ∣ (u + k * p^(M + 1 - v)) := by
      rw [ Nat.dvd_add_left ( dvd_mul_of_dvd_right ( dvd_pow_self _ ( Nat.sub_ne_zero_of_lt ( by linarith ) ) ) _ ) ] ; tauto;
    haveI := Fact.mk hp; rw [ h_factor, padicValNat.mul ] <;> norm_num [ h_div ] ;
    · exact fun h => absurd h hp.ne_zero;
    · exact fun h => absurd h ( by rintro rfl; simp_all +singlePass )

/-
If the maximum valuation M is attained at least twice in a range of length b, then p^M < b.
-/
lemma padicValNat_max_attained_twice_implies_pow_lt_b (p : ℕ) (hp : p.Prime) (b m : ℕ) (hb : b > 0)
  (M : ℕ) (hM : M = Finset.sup (Finset.range b) (fun k => padicValNat p (m + k)))
  (h_not_unique : ∃ k1 k2, k1 < b ∧ k2 < b ∧ k1 ≠ k2 ∧ padicValNat p (m + k1) = M ∧ padicValNat p (m + k2) = M) :
  p ^ M < b := by
    obtain ⟨ k1, k2, hk1, hk2, hk_ne, hk1_eq, hk2_eq ⟩ := h_not_unique;
    -- Since $p^M \mid (m + k1)$ and $p^M \mid (m + k2)$, we have $p^M \mid (k2 - k1)$.
    have h_div : p ^ M ∣ Int.natAbs (k2 - k1) := by
      have h_div : p ^ M ∣ (m + k1) ∧ p ^ M ∣ (m + k2) := by
        haveI := Fact.mk hp; simp_all +decide [ padicValNat_dvd_iff ] ;
      simpa [ ← Int.natCast_dvd_natCast ] using dvd_sub ( Int.natCast_dvd_natCast.mpr h_div.2 ) ( Int.natCast_dvd_natCast.mpr h_div.1 );
    cases abs_cases ( k2 - k1 : ℤ ) <;> linarith [ Nat.le_of_dvd ( by omega ) h_div ]

/-
If v_p(n) <= M, then v_p(n + p^(M+1)) = v_p(n).
-/
lemma lemma_2_case_1_equality (p : ℕ) (hp : p.Prime) (n M : ℕ) (hn : n > 0) (h_le : padicValNat p n ≤ M) :
  padicValNat p (n + p ^ (M + 1)) = padicValNat p n := by
    -- Apply the periodicity lemma with $k=1$.
    have := padicValNat_periodic_pos p hp n 1 M hn h_le; aesop

/-
If v_p(n) = M, then v_p(n + p^(M+1)) = M.
-/
lemma padicValNat_add_pow_succ_eq_self (p : ℕ) (hp : p.Prime) (n M : ℕ) (hn : n > 0) (h_eq : padicValNat p n = M) :
  padicValNat p (n + p ^ (M + 1)) = M := by
    convert padicValNat_periodic_pos p hp n 1 M hn _ using 1 ; aesop;
    · exact h_eq.symm;
    · rw [h_eq]

/-
If the maximum valuation M is attained at least twice, then there exists a shift s <= 2*p^2*b such that the block repeats.
-/
lemma lemma_2_case_1 (p : ℕ) (hp : p.Prime) (b m : ℕ) (hb : b > 0) (hm : m > 0)
  (M : ℕ) (hM : M = Finset.sup (Finset.range b) (fun k => padicValNat p (m + k)))
  (h_not_unique : ∃ k1 k2, k1 < b ∧ k2 < b ∧ k1 ≠ k2 ∧ padicValNat p (m + k1) = M ∧ padicValNat p (m + k2) = M) :
  ∃ s, 0 < s ∧ s ≤ 2 * p^2 * b ∧
  ∀ k < b, (padicValNat p (m + k)) % 2 = (padicValNat p (m + s + k)) % 2 := by
    -- By `padicValNat_max_attained_twice_implies_pow_lt_b`, we have `p^M < b`.
    have h_pow_lt_b : p ^ M < b := by
      exact padicValNat_max_attained_twice_implies_pow_lt_b p hp b m hb M hM h_not_unique
    refine' ⟨ p ^ ( M + 1 ), pow_pos hp.pos _, _, _ ⟩;
    · nlinarith [ Nat.mul_le_mul_left b hp.two_le, pow_succ' p M ];
    · intro k hk; rw [ show m + p ^ ( M + 1 ) + k = m + k + p ^ ( M + 1 ) by ring ] ; rw [ lemma_2_case_1_equality p hp ( m + k ) M ( by linarith ) ] ;
      exact hM.symm ▸ Finset.le_sup ( f := fun k => padicValNat p ( m + k ) ) ( Finset.mem_range.mpr hk )

/-
If M is the unique maximum valuation, and M_next is the maximum of the remaining valuations, then p^M_next < b.
-/
lemma second_largest_valuation_bound (p : ℕ) (hp : p.Prime) (b m : ℕ) (hb : b > 0)
  (M : ℕ) (hM : M = Finset.sup (Finset.range b) (fun k => padicValNat p (m + k)))
  (k0 : ℕ) (hk0 : k0 < b) (hk0_val : padicValNat p (m + k0) = M)
  (h_unique : ∀ k < b, k ≠ k0 → padicValNat p (m + k) < M)
  (M_next : ℕ) (hM_next : M_next = Finset.sup (Finset.erase (Finset.range b) k0) (fun k => padicValNat p (m + k)))
  (h_exists_next : (Finset.erase (Finset.range b) k0).Nonempty) :
  p ^ M_next < b := by
    -- Let $k_{next}$ be an index where $M_{next}$ is attained.
    obtain ⟨k_next, hk_next⟩ : ∃ k_next, k_next < b ∧ k_next ≠ k0 ∧ padicValNat p (m + k_next) = M_next := by
      obtain ⟨k_next, hk_next⟩ : ∃ k_next ∈ Finset.erase (Finset.range b) k0, ∀ k ∈ Finset.erase (Finset.range b) k0, padicValNat p (m + k) ≤ padicValNat p (m + k_next) := by
        exact Finset.exists_max_image _ _ h_exists_next;
      exact ⟨ k_next, Finset.mem_range.mp ( Finset.mem_of_mem_erase hk_next.1 ), by aesop, hM_next ▸ le_antisymm ( Finset.le_sup ( f := fun k => padicValNat p ( m + k ) ) hk_next.1 ) ( Finset.sup_le fun k hk => hk_next.2 k hk ) ⟩;
    -- Since $M > M_{next}$, $p^{M_{next}} \mid p^M \mid (m+k_0)$.
    have h_div : p ^ M_next ∣ (m + k0) ∧ p ^ M_next ∣ (m + k_next) := by
      have h_div : p ^ (padicValNat p (m + k0)) ∣ (m + k0) ∧ p ^ (padicValNat p (m + k_next)) ∣ (m + k_next) := by
        haveI := Fact.mk hp; simp +decide [ padicValNat_dvd_iff ] ;
      exact ⟨ dvd_trans ( pow_dvd_pow _ ( by linarith [ h_unique k_next hk_next.1 hk_next.2.1 ] ) ) h_div.1, dvd_trans ( pow_dvd_pow _ ( by linarith [ h_unique k_next hk_next.1 hk_next.2.1 ] ) ) h_div.2 ⟩;
    -- Therefore, $p^{M_{next}} \mid (k_0 - k_{next})$.
    have h_div_diff : p ^ M_next ∣ Int.natAbs (k0 - k_next) := by
      simpa [ ← Int.natCast_dvd_natCast ] using dvd_sub ( Int.natCast_dvd_natCast.mpr h_div.1 ) ( Int.natCast_dvd_natCast.mpr h_div.2 );
    cases abs_cases ( k0 - k_next : ℤ ) <;> linarith [ Nat.le_of_dvd ( by omega ) h_div_diff ]

/-
For any u and target parity, there exists t in [1, 2p] such that v_p(u+t) has that parity.
-/
lemma exists_shift_with_parity (p : ℕ) (hp : p.Prime) (u : ℕ) (target_parity : ZMod 2) :
  ∃ t ∈ Finset.Icc 1 (2 * p), (padicValNat p (u + t)) % 2 = target_parity := by
    -- Consider two cases: target_parity = 0 and target_parity = 1.
    by_cases h_case : target_parity = 0;
    · by_contra h_contra;
      -- If no such $t$ exists, then for all $t \in \{1, 2, \ldots, 2p\}$, $v_p(u+t)$ is odd.
      have h_odd : ∀ t ∈ Finset.Icc 1 (2 * p), Odd (padicValNat p (u + t)) := by
        intro t ht; specialize h_contra; simp_all +decide ;
        specialize h_contra t ht.1 ht.2; rcases Nat.even_or_odd' ( padicValNat p ( u + t ) ) with ⟨ k, hk | hk ⟩ <;> simp_all +decide ;
        grind;
      -- This implies that $p \mid (u + t)$ for all $t \in \{1, 2, \ldots, 2p\}$.
      have h_div : ∀ t ∈ Finset.Icc 1 (2 * p), p ∣ (u + t) := by
        intro t ht; specialize h_odd t ht; contrapose! h_odd; simp_all +decide [ padicValNat.eq_zero_of_not_dvd ] ;
      have h_dvd_one : p ∣ 1 := by
        convert Nat.dvd_sub ( h_div 2 ( Finset.mem_Icc.mpr ⟨ by linarith [ hp.two_le ], by linarith [ hp.two_le ] ⟩ ) ) ( h_div 1 ( Finset.mem_Icc.mpr ⟨ by linarith [ hp.two_le ], by linarith [ hp.two_le ] ⟩ ) ) using 1
        omega
      exact (hp.not_dvd_one h_dvd_one).elim
    · -- For the case when target_parity = 1, we need to find t in [1, 2p] such that v_p(u + t) is odd.
      -- We can choose t such that u + t is divisible by p but not by p^2.
      obtain ⟨t, ht1, ht2⟩ : ∃ t ∈ Finset.Icc 1 (2 * p), p ∣ (u + t) ∧ ¬(p ^ 2 ∣ (u + t)) := by
        -- In the range $t \in \{1, \dots, 2p\}$, there are exactly two values $t_1, t_2$ such that $p \mid (u+t)$.
        obtain ⟨t1, ht1⟩ : ∃ t1 ∈ Finset.Icc 1 (2 * p), p ∣ (u + t1) := by
          use p - u % p;
          exact ⟨ Finset.mem_Icc.mpr ⟨ Nat.sub_pos_of_lt ( Nat.mod_lt _ hp.pos ), Nat.sub_le_of_le_add <| by linarith [ Nat.zero_le ( u % p ), Nat.mod_lt u hp.pos ] ⟩, ⟨ u / p + 1, by linarith [ Nat.div_add_mod u p, Nat.sub_add_cancel ( Nat.mod_lt u hp.pos |> Nat.le_of_lt ) ] ⟩ ⟩
        obtain ⟨t2, ht2, ht2_ne⟩ : ∃ t2 ∈ Finset.Icc 1 (2 * p), p ∣ (u + t2) ∧ t2 ≠ t1 := by
          by_cases ht1_le_p : t1 ≤ p;
          · exact ⟨ t1 + p, Finset.mem_Icc.mpr ⟨ by linarith [ Finset.mem_Icc.mp ht1.1 ], by linarith [ Finset.mem_Icc.mp ht1.1 ] ⟩, by simpa [ Nat.dvd_iff_mod_eq_zero, Nat.add_mod, Nat.mod_eq_of_lt hp.one_lt ] using ht1.2, by linarith [ hp.two_le ] ⟩;
          · refine' ⟨ t1 - p, _, _, _ ⟩ <;> norm_num at * <;> try omega;
            convert Nat.dvd_sub ht1.2 ( dvd_refl p ) using 1 ; omega;
        by_contra h_contra
        push Not at h_contra
        have h_div_p2 : p^2 ∣ (u + t1) ∧ p^2 ∣ (u + t2) := by
          aesop
        have h_diff : p^2 ∣ Int.natAbs (t1 - t2) := by
          simpa [ ← Int.natCast_dvd_natCast ] using dvd_sub ( Int.natCast_dvd_natCast.mpr h_div_p2.1 ) ( Int.natCast_dvd_natCast.mpr h_div_p2.2 ) |> fun x => by simpa [ add_comm ] using x;
        have h_absurd : Int.natAbs (t1 - t2) < p^2 := by
          cases abs_cases ( t1 - t2 : ℤ ) <;> nlinarith [ Finset.mem_Icc.mp ht1.1, Finset.mem_Icc.mp ht2, hp.two_le ] ;
        exact absurd h_diff (by
        exact Nat.not_dvd_of_pos_of_lt ( Int.natAbs_pos.mpr ( sub_ne_zero_of_ne <| by aesop ) ) h_absurd);
      -- Since $p \mid (u + t)$ and $\neg(p^2 \mid (u + t))$, we have $v_p(u + t) = 1$.
      have ht_val : padicValNat p (u + t) = 1 := by
        rw [ ← Nat.factorization_def ];
        · exact le_antisymm ( Nat.le_of_not_lt fun h => ht2.2 <| Nat.dvd_trans ( pow_dvd_pow _ h ) <| Nat.ordProj_dvd _ _ ) ( Nat.pos_of_ne_zero <| Finsupp.mem_support_iff.mp <| by aesop );
        · assumption;
      have htarget : target_parity = 1 := by
        rcases zmod_two_eq_zero_or_one target_parity with h0 | h1
        · exact (h_case h0).elim
        · exact h1
      refine ⟨t, ht1, ?_⟩
      rw [ht_val, htarget]
      decide

/-
If the maximum valuation M is attained exactly once, then there exists a shift s <= 2*p^2*b such that the block repeats.
-/
lemma lemma_2_case_2 (p : ℕ) (hp : p.Prime) (b m : ℕ) (hb : b > 0) (hm : m > 0)
  (M : ℕ) (hM : M = Finset.sup (Finset.range b) (fun k => padicValNat p (m + k)))
  (k0 : ℕ) (hk0 : k0 < b) (hk0_val : padicValNat p (m + k0) = M)
  (h_unique : ∀ k < b, k ≠ k0 → padicValNat p (m + k) < M)
  (M_next : ℕ) (hM_next : M_next = Finset.sup (Finset.erase (Finset.range b) k0) (fun k => padicValNat p (m + k))) :
  ∃ s, 0 < s ∧ s ≤ 2 * p^2 * b ∧
  ∀ k < b, (padicValNat p (m + k)) % 2 = (padicValNat p (m + s + k)) % 2 := by
    by_cases hb1 : b > 1;
    · -- Let $Q = p^{M_{next}+1}$. Then $Q \le p b$.
      obtain ⟨Q, hQ⟩ : ∃ Q, Q = p ^ (M_next + 1) ∧ Q ≤ p * b := by
        have hQ_le : p ^ M_next < b := by
          apply second_largest_valuation_bound p hp b m hb M hM k0 hk0 hk0_val h_unique M_next hM_next;
          exact Finset.card_pos.mp ( by rw [ Finset.card_erase_of_mem ( Finset.mem_range.mpr hk0 ), Finset.card_range ] ; omega );
        exact ⟨ _, rfl, by rw [ pow_succ' ] ; nlinarith [ hp.two_le ] ⟩;
      -- Since $M > M_{next}$, $v_p(m+k_0) \ge M_{next}+1$.
      have h_val_ge : padicValNat p (m + k0) ≥ M_next + 1 := by
        have h_val_ge : ∃ k < b, k ≠ k0 ∧ padicValNat p (m + k) = M_next := by
          have h_exists_k : ∃ k ∈ Finset.erase (Finset.range b) k0, padicValNat p (m + k) = M_next := by
            have h_exists_k : ∃ k ∈ Finset.erase (Finset.range b) k0, ∀ j ∈ Finset.erase (Finset.range b) k0, padicValNat p (m + j) ≤ padicValNat p (m + k) := by
              apply_rules [ Finset.exists_max_image ];
              exact ⟨ if k0 = 0 then 1 else 0, by aesop ⟩;
            obtain ⟨ k, hk₁, hk₂ ⟩ := h_exists_k; exact ⟨ k, hk₁, le_antisymm ( hM_next.symm ▸ Finset.le_sup ( f := fun k => padicValNat p ( m + k ) ) hk₁ ) ( hM_next.symm ▸ Finset.sup_le fun j hj => hk₂ j hj ) ⟩ ;
          aesop;
        grind;
      -- Thus $Q \mid (m+k_0)$. Let $m+k_0 = u Q$.
      obtain ⟨u, hu⟩ : ∃ u, m + k0 = u * Q := by
        use (m + k0) / Q;
        rw [ Nat.div_mul_cancel ];
        rw [ ← Nat.factorization_le_iff_dvd ] <;> norm_num [ hp.ne_zero, hp.ne_one ];
        · intro q; by_cases hq : p = q <;> simp_all +decide [ Nat.factorization_pow ] ;
          simp_all +decide [ Nat.factorization ];
        · exact hQ.1.symm ▸ pow_ne_zero _ hp.ne_zero;
        · aesop;
      -- We want to find $s = t Q$ such that $v_p(m+k_0+s) \equiv M \pmod 2$.
      obtain ⟨t, ht⟩ : ∃ t ∈ Finset.Icc 1 (2 * p), (padicValNat p (u + t)) % 2 = (M - (M_next + 1)) % 2 := by
        convert exists_shift_with_parity p hp u ( ( M - ( M_next + 1 ) ) % 2 ) using 1;
        norm_num [ ← ZMod.natCast_eq_natCast_iff' ];
        ext; norm_num [ two_mul, add_assoc ] ;
        intro _ _; erw [ Nat.cast_sub ( by linarith ) ] ; norm_num;
        grind +ring;
      refine' ⟨ t * Q, _, _, _ ⟩ <;> norm_num at *;
      · exact ⟨ ht.1.1, hQ.1.symm ▸ pow_pos hp.pos _ ⟩;
      · nlinarith [ pow_succ' p M_next ];
      · intro k hk
        by_cases hk_eq_k0 : k = k0;
        · -- Using the properties of p-adic valuations, we can simplify the expression for the valuation of $m + k0 + t * Q$.
          have h_val_simplified : padicValNat p (m + k0 + t * Q) = padicValNat p (u + t) + (M_next + 1) := by
            haveI := Fact.mk hp; rw [ hu ] ; ring_nf;
            rw [ show u * Q + Q * t = Q * ( u + t ) by ring, padicValNat.mul ] <;> norm_num [ hQ.1, hp.ne_zero ] ; ring_nf;
            grind +ring;
          grind +ring;
        · -- Since $k \ne k0$, we have $v_p(m+k) \le M_{next}$.
          have h_val_le : padicValNat p (m + k) ≤ M_next := by
            exact hM_next.symm ▸ Finset.le_sup ( f := fun k => padicValNat p ( m + k ) ) ( Finset.mem_erase_of_ne_of_mem hk_eq_k0 ( Finset.mem_range.mpr hk ) );
          -- Since $s$ is a multiple of $Q = p^{M_{next}+1}$, by `padicValNat_periodic_pos`, $v_p(m+k+s) = v_p(m+k)$.
          have h_val_eq : padicValNat p (m + k + t * Q) = padicValNat p (m + k) := by
            convert padicValNat_periodic_pos p hp ( m + k ) t M_next ( by linarith ) ( by linarith ) using 1;
            rw [ hQ.1 ];
          rw [ add_right_comm, h_val_eq ];
    · interval_cases b ; simp_all +decide;
      -- By `exists_shift_with_parity`, there exists $t \in \{1, \dots, 2p\}$ such that $v_p(m+t)$ has the same parity as $v_p(m)$.
      obtain ⟨t, ht⟩ : ∃ t ∈ Finset.Icc 1 (2 * p), (padicValNat p (m + t)) % 2 = (padicValNat p m) % 2 := by
        convert exists_shift_with_parity p hp m _;
        erw [ ← ZMod.natCast_eq_natCast_iff' ] ; norm_num;
        erw [ show ( 2 : ZMod 2 ) = 0 by rfl ] ; norm_num;
        convert Iff.rfl;
      exact ⟨ t, Finset.mem_Icc.mp ht.1 |>.1, by nlinarith [ Finset.mem_Icc.mp ht.1 |>.2, hp.two_le ], ht.2.symm ⟩

/-
For any prime p and block of length b, there is a shift s <= 2*p^2*b that preserves parity of valuations.
-/
lemma lemma_2 (p : ℕ) (hp : p.Prime) (b m : ℕ) (hb : b > 0) (hm : m > 0) :
  ∃ s, 0 < s ∧ s ≤ 2 * p^2 * b ∧
  ∀ k < b, (padicValNat p (m + k)) % 2 = (padicValNat p (m + s + k)) % 2 := by
    by_cases h_unique : ∃ k1 k2, k1 < b ∧ k2 < b ∧ k1 ≠ k2 ∧ padicValNat p (m + k1) = Finset.sup (Finset.range b) (fun k => padicValNat p (m + k)) ∧ padicValNat p (m + k2) = Finset.sup (Finset.range b) (fun k => padicValNat p (m + k));
    · convert lemma_2_case_1 p hp b m hb hm _ rfl h_unique using 1;
    · obtain ⟨k0, hk0⟩ : ∃ k0, k0 < b ∧ padicValNat p (m + k0) = Finset.sup (Finset.range b) (fun k => padicValNat p (m + k)) := by
        have h_sup : ∃ k0 ∈ Finset.range b, ∀ k ∈ Finset.range b, padicValNat p (m + k) ≤ padicValNat p (m + k0) := by
          exact Finset.exists_max_image _ _ ⟨ _, Finset.mem_range.mpr hb ⟩;
        exact ⟨ h_sup.choose, Finset.mem_range.mp h_sup.choose_spec.1, le_antisymm ( Finset.le_sup ( f := fun k => padicValNat p ( m + k ) ) h_sup.choose_spec.1 ) ( Finset.sup_le fun k hk => h_sup.choose_spec.2 k hk ) ⟩;
      apply lemma_2_case_2 p hp b m hb hm (Finset.sup (Finset.range b) (fun k => padicValNat p (m + k))) (by
      rfl) k0 hk0.left hk0.right (by
      exact fun k hk hk' => lt_of_le_of_ne ( Finset.le_sup ( f := fun k => padicValNat p ( m + k ) ) ( Finset.mem_range.mpr hk ) ) fun h => h_unique ⟨ k, k0, hk, hk0.1, hk', h, hk0.2 ⟩) (Finset.sup (Finset.erase (Finset.range b) k0) (fun k => padicValNat p (m + k))) (by
      rfl)

/-
If the maximum valuation M is attained at least twice in a block, then there exists an arithmetic progression of starts preserving parity.
-/
lemma lemma_block_recurrence_AP_case1 (p : ℕ) (hp : p.Prime) (b m : ℕ) (hb : b > 0) (hm : m > 0)
  (M : ℕ) (hM : M = Finset.sup (Finset.range b) (fun k => padicValNat p (m + k)))
  (h_not_unique : ∃ k1 k2, k1 < b ∧ k2 < b ∧ k1 ≠ k2 ∧ padicValNat p (m + k1) = M ∧ padicValNat p (m + k2) = M) :
  ∃ a d, a > 0 ∧ d > 0 ∧ d ≤ p^3 * b ∧ ∀ r : ℕ, ∀ k < b, (padicValNat p (a + r * d + k)) % 2 = (padicValNat p (m + k)) % 2 := by
    -- By `padicValNat_max_attained_twice_implies_pow_lt_b`, we have `p^M < b`.
    have h_pow_lt_b : p ^ M < b := by
      exact padicValNat_max_attained_twice_implies_pow_lt_b p hp b m hb M hM h_not_unique
    use m, p ^ ( M + 1 );
    refine' ⟨ hm, pow_pos hp.pos _, _, _ ⟩;
    · rw [ pow_succ' ] ; nlinarith [ Nat.mul_le_mul_left ( p ^ M ) ( show p ≥ 2 by exact hp.two_le ), pow_pos hp.pos 2, pow_pos hp.pos 3 ] ;
    · intro r k hk_lt_b
      have h_val_le_M : padicValNat p (m + k) ≤ M := by
        exact hM.symm ▸ Finset.le_sup ( f := fun k => padicValNat p ( m + k ) ) ( Finset.mem_range.mpr hk_lt_b );
      rw [ show m + r * p ^ ( M + 1 ) + k = m + k + r * p ^ ( M + 1 ) by ring, padicValNat_periodic_pos ] <;> aesop

/-
Case b=1 of Lemma 2 Case 2.
-/
lemma lemma_block_recurrence_AP_case2_b_eq_1 (p : ℕ) (hp : p.Prime) (b m : ℕ) (hb : b = 1) (hm : m > 0)
  (M : ℕ) (hM : M = Finset.sup (Finset.range b) (fun k => padicValNat p (m + k)))
  (k0 : ℕ) (hk0 : k0 < b) (hk0_val : padicValNat p (m + k0) = M) :
  ∃ a d, a > 0 ∧ d > 0 ∧ d ≤ p^3 * b ∧ ∀ r : ℕ, ∀ k < b, (padicValNat p (a + r * d + k)) % 2 = (padicValNat p (m + k)) % 2 := by
    obtain ⟨M', hM'_pos, hM'_eq, hM'_le⟩ : ∃ M' ∈ ({1, 2} : Finset ℕ), M' % 2 = M % 2 ∧ M' ≤ 2 := by
      cases Nat.mod_two_eq_zero_or_one M <;> simp +decide [ * ];
      · aesop;
      · grind +ring;
    refine' ⟨ p ^ M' + p ^ ( M' + 1 ), p ^ ( M' + 1 ), _, _, _, _ ⟩ <;> simp_all +decide [ Nat.pow_succ ];
    · exact Or.inl ( pow_pos hp.pos _ );
    · exact ⟨ pow_pos hp.pos _, hp.pos ⟩;
    · interval_cases M' <;> nlinarith [ hp.two_le ];
    · -- Let's simplify the expression for the valuation.
      have h_val : ∀ r : ℕ, padicValNat p (p ^ M' * (p + 1 + r * p)) = M' := by
        intro r; haveI := Fact.mk hp; rw [ padicValNat.mul ] <;> norm_num [ hp.ne_zero ] ;
        norm_num [ Nat.dvd_iff_mod_eq_zero, Nat.add_mod, Nat.mul_mod ];
        exact em _;
      intro r; rw [ show p ^ M' + p ^ M' * p + r * ( p ^ M' * p ) = p ^ M' * ( p + 1 + r * p ) by ring ] ; aesop;

/-
Existence of a start value a such that the valuation of a + r*d + k0 is constant M'.
-/
lemma lemma_exists_a_case2 (p : ℕ) (hp : p.Prime) (b k0 M' : ℕ) (hb : b > 0) (hk0 : k0 < b) (hM' : M' > 0) :
  ∃ a > 0, ∀ r : ℕ, padicValNat p (a + r * p^(M'+1) + k0) = M' := by
    -- Choose $a = p^{M'} + p^{M'+1} \cdot b - k0$.
    use p^M' + p^(M'+1) * b - k0
    constructor
    ·
      exact Nat.sub_pos_of_lt ( by nlinarith [ pow_pos hp.pos M', pow_pos hp.pos ( M' + 1 ) ] )
    ·
      intro r
      have h_factor : p ^ M' + p ^ (M' + 1) * b + r * p ^ (M' + 1) = p ^ M' * (1 + p * b + r * p) := by
        ring;
      have h_val : padicValNat p (p ^ M' * (1 + p * b + r * p)) = M' := by
        haveI := Fact.mk hp; rw [ padicValNat.mul ] <;> norm_num [ hp.ne_zero, hp.ne_one ] ;
        norm_num [ Nat.dvd_iff_mod_eq_zero, Nat.add_mod, Nat.mul_mod, Nat.pow_mod ] at * ; aesop;
      convert h_val using 2 ; linarith [ Nat.sub_add_cancel ( show k0 ≤ p ^ M' + p ^ ( M' + 1 ) * b from by nlinarith [ pow_pos hp.pos M', pow_pos hp.pos ( M' + 1 ) ] ) ]

/-
If M is the unique maximum valuation at k0, then the valuation of the distance to k0 is less than M.
-/
lemma lemma_valuation_diff_lt_max (p : ℕ) (hp : p.Prime) (b m : ℕ) (hm : m > 0) (k0 : ℕ) (hk0 : k0 < b)
  (M : ℕ) (hM : padicValNat p (m + k0) = M)
  (h_unique : ∀ k < b, k ≠ k0 → padicValNat p (m + k) < M) :
  ∀ k < b, k ≠ k0 → padicValNat p (if k > k0 then k - k0 else k0 - k) < M := by
    intro k hk hk_ne_k0
    by_contra h_contra
    have h_div : p^M ∣ (if k > k0 then k - k0 else k0 - k) := by
      -- By definition of p-adic valuation, if $padicValNat p x \geq M$, then $p^M \mid x$.
      have h_div : ∀ x : ℕ, 0 < x → padicValNat p x ≥ M → p^M ∣ x := by
        intro x hx_pos hx_val
        have h_div : p ^ (padicValNat p x) ∣ x := by
          exact pow_padicValNat_dvd
        exact dvd_trans ( pow_dvd_pow p hx_val ) h_div
      exact h_div _ ( Nat.pos_of_ne_zero ( by split_ifs <;> omega ) ) ( le_of_not_gt h_contra )
    have h_div_mk : p^M ∣ m + k := by
      have h_div_mk : p^M ∣ m + k0 := by
        rw [ ← hM ];
        exact pow_padicValNat_dvd;
      split_ifs at h_div <;> simp_all +decide [ ← ZMod.natCast_eq_zero_iff ] ; cases le_total k k0 <;> simp_all +decide [ Nat.cast_sub ] ;
      · linear_combination' h_div_mk + h_div;
      · grind
    have h_contra' : padicValNat p (m + k) ≥ M := by
      haveI := Fact.mk hp; rw [ padicValNat_dvd_iff ] at *; aesop;
    linarith [h_unique k hk hk_ne_k0]

/-
If M is the unique maximum valuation at k0, then the valuation of the distance to k0 is less than M.
-/
lemma lemma_valuation_diff_lt_max' (p : ℕ) (hp : p.Prime) (b m : ℕ) (hm : m > 0) (k0 : ℕ) (hk0 : k0 < b)
  (M : ℕ) (hM : padicValNat p (m + k0) = M)
  (h_unique : ∀ k < b, k ≠ k0 → padicValNat p (m + k) < M) :
  ∀ k < b, k ≠ k0 → padicValNat p (if k > k0 then k - k0 else k0 - k) < M := by
    exact fun k hk hk_ne => lemma_valuation_diff_lt_max p hp b m hm k0 hk0 M hM h_unique k hk hk_ne

/-
If M is the unique maximum valuation at k0, then for other k, the valuation depends only on the distance to k0.
-/
lemma lemma_valuation_near_max (p : ℕ) (hp : p.Prime) (b m : ℕ) (hm : m > 0) (k0 : ℕ) (hk0 : k0 < b)
  (M : ℕ) (hM : padicValNat p (m + k0) = M)
  (h_unique : ∀ k < b, k ≠ k0 → padicValNat p (m + k) < M) :
  ∀ k < b, k ≠ k0 → padicValNat p (m + k) = padicValNat p (if k > k0 then k - k0 else k0 - k) := by
    intro k hk_lt hk_ne_k0
    by_cases hk_gt_k0 : k > k0;
    · have h_val_eq : padicValNat p (m + k) = padicValNat p ((m + k0) + (k - k0)) := by
        rw [ add_assoc, Nat.add_sub_of_le hk_gt_k0.le ];
      have h_val_eq : padicValNat p ((m + k0) + (k - k0)) = padicValNat p (k - k0) := by
        have h_div : p ^ (padicValNat p (k - k0)) ∣ (m + k0) + (k - k0) := by
          have h_div : p ^ (padicValNat p (k - k0)) ∣ (k - k0) := by
            convert Nat.ordProj_dvd ( k - k0 ) p using 1;
            rw [ Nat.factorization_def ] ; aesop;
          have h_div : p ^ (padicValNat p (k - k0)) ∣ (m + k0) := by
            have h_div : padicValNat p (k - k0) < M := by
              have := lemma_valuation_diff_lt_max p hp b m hm k0 hk0 M hM h_unique k hk_lt hk_ne_k0; aesop;
            have h_div : p ^ (padicValNat p (m + k0)) ∣ (m + k0) := by
              haveI := Fact.mk hp; rw [ padicValNat_dvd_iff ] ; aesop;
            exact dvd_trans ( pow_dvd_pow _ ( by linarith ) ) h_div;
          exact dvd_add h_div ‹_›
        have h_not_div : ¬(p ^ (padicValNat p (k - k0) + 1) ∣ (m + k0) + (k - k0)) := by
          rw [ Nat.dvd_add_right ];
          · rw [ Nat.Prime.pow_dvd_iff_le_factorization ] <;> norm_num [ hp ];
            · rw [ Nat.factorization ] ; aesop;
            · exact Nat.sub_ne_zero_of_lt hk_gt_k0;
          · have h_not_div : padicValNat p (m + k0) > padicValNat p (k - k0) := by
              have := lemma_valuation_diff_lt_max p hp b m hm k0 hk0 M hM ( fun k hk_lt hk_ne_k0 => h_unique k hk_lt hk_ne_k0 ) k hk_lt hk_ne_k0; aesop;
            have h_not_div : padicValNat p (m + k0) = Nat.factorization (m + k0) p := by
              rw [ Nat.factorization_def ] ; aesop;
            exact Nat.dvd_trans ( pow_dvd_pow _ ( Nat.succ_le_of_lt ‹_› ) ) ( h_not_div.symm ▸ Nat.ordProj_dvd _ _ )
        have h_val_eq : padicValNat p (m + k0 + (k - k0)) = Nat.factorization (m + k0 + (k - k0)) p := by
          rw [ Nat.factorization_def ] ; aesop;
        have h_val_eq : Nat.factorization (m + k0 + (k - k0)) p = padicValNat p (k - k0) := by
          exact le_antisymm ( Nat.le_of_not_lt fun h => h_not_div <| Nat.dvd_trans ( pow_dvd_pow _ h ) <| Nat.ordProj_dvd _ _ ) ( Nat.le_of_not_lt fun h => by exact absurd ( dvd_trans ( pow_dvd_pow _ h ) h_div ) <| Nat.pow_succ_factorization_not_dvd ( by linarith [ Nat.sub_pos_of_lt hk_gt_k0 ] ) hp );
        grind;
      aesop;
    · have h_val : padicValNat p (m + k0 - (k0 - k)) = padicValNat p (k0 - k) := by
        have h_div : p ^ (padicValNat p (k0 - k)) ∣ (m + k0 - (k0 - k)) := by
          have h_div : p ^ (padicValNat p (k0 - k)) ∣ (m + k0) := by
            have h_div : padicValNat p (k0 - k) < M := by
              convert lemma_valuation_diff_lt_max p hp b m hm k0 hk0 M hM h_unique k hk_lt hk_ne_k0 using 1 ; split_ifs ; omega;
            have h_div : p ^ (padicValNat p (m + k0)) ∣ (m + k0) := by
              convert Nat.ordProj_dvd ( m + k0 ) p using 1;
              rw [ Nat.factorization ] ; aesop;
            exact dvd_trans ( pow_dvd_pow _ ( by linarith ) ) h_div;
          refine Nat.dvd_sub h_div ?_;
          convert Nat.ordProj_dvd ( k0 - k ) p using 1;
          rw [ Nat.factorization_def ] ; aesop
        have h_not_div : ¬(p ^ (padicValNat p (k0 - k) + 1) ∣ (m + k0 - (k0 - k))) := by
          intro h_div';
          have h_contra : p ^ (padicValNat p (k0 - k) + 1) ∣ (k0 - k) := by
            have h_contra : padicValNat p (k0 - k) < M := by
              convert lemma_valuation_diff_lt_max p hp b m hm k0 hk0 M hM ( fun k hk_lt hk_ne_k0 => h_unique k hk_lt hk_ne_k0 ) k hk_lt hk_ne_k0 using 1;
              rw [ if_neg hk_gt_k0 ];
            have h_contra : p ^ (padicValNat p (k0 - k) + 1) ∣ (m + k0) := by
              have h_contra : p ^ M ∣ (m + k0) := by
                rw [ ← hM ];
                convert Nat.ordProj_dvd ( m + k0 ) p using 1;
                rw [ Nat.factorization_def ] ; aesop;
              exact dvd_trans ( pow_dvd_pow _ ( by linarith ) ) h_contra;
            convert Nat.dvd_sub h_contra h_div' using 1 ; rw [ Nat.sub_sub_self ( show k0 - k ≤ m + k0 from Nat.sub_le_of_le_add <| by linarith ) ];
          have := Nat.factorization_le_iff_dvd ( by aesop ) ( Nat.sub_ne_zero_of_lt ( lt_of_le_of_ne ( le_of_not_gt hk_gt_k0 ) hk_ne_k0 ) ) |>.2 h_contra ; simp_all +decide [ Nat.factorization_pow ] ;
          replace := this p ; simp_all +decide [ Nat.factorization ]
        have h_val : padicValNat p (m + k0 - (k0 - k)) = Nat.factorization (m + k0 - (k0 - k)) p := by
          rw [ Nat.factorization_def ] ; aesop;
        have h_val : Nat.factorization (m + k0 - (k0 - k)) p = padicValNat p (k0 - k) := by
          exact le_antisymm ( Nat.le_of_not_lt fun h => h_not_div <| dvd_trans ( pow_dvd_pow _ h ) <| Nat.ordProj_dvd _ _ ) ( Nat.le_of_not_lt fun h => by exact absurd ( dvd_trans ( pow_dvd_pow _ h ) h_div ) <| Nat.pow_succ_factorization_not_dvd ( Nat.sub_ne_zero_of_lt <| by omega ) hp );
        linarith;
      grind +ring

/-
Definitions for the vector of valuations and the partial sum vector.
-/
def val_vec (k : ℕ) (p : Fin k → ℕ) (n : ℕ) : Fin k → ZMod 2 :=
  fun i => padicValNat (p i) n

def partial_sum (k : ℕ) (p : Fin k → ℕ) (n : ℕ) : Fin k → ZMod 2 :=
  fun i => padicValNat (p i) (Nat.factorial n)

/-
The sequence of valuation vectors is recurrent.
-/
lemma val_vec_recurrent (k : ℕ) (p : Fin k → ℕ) (hp : ∀ i, (p i).Prime) (b m : ℕ) (hb : b > 0) (hm : m > 0) :
  ∃ s > 0, ∀ j < b, val_vec k p (m + j) = val_vec k p (m + s + j) := by
    revert k p hp b m hb hm;
    -- Let's choose the maximum valuation $M_i$ for each prime $p_i$.
    intros k p hp b m hb hm
    set M := fun i => Finset.sup (Finset.range (b + m)) (fun n => padicValNat (p i) (n + 1)) with hM_def;
    -- Let $S = \prod_{i=1}^k p_i^{M_i + 1}$.
    set S := Finset.prod Finset.univ (fun i => p i ^ (M i + 1)) with hS_def;
    refine' ⟨ S, Finset.prod_pos fun i _ => pow_pos ( Nat.Prime.pos ( hp i ) ) _, fun j hj => _ ⟩ ; ext i ; simp +decide [ add_right_comm, val_vec ];
    -- By the properties of the p-adic valuation, we have that $v_{p_i}(m + j + S) = v_{p_i}(m + j)$ since $S$ is divisible by $p_i^{M_i + 1}$.
    have h_val_eq : padicValNat (p i) (m + j + S) = padicValNat (p i) (m + j) := by
      have h_val_eq : padicValNat (p i) (m + j) ≤ M i := by
        convert Finset.le_sup ( f := fun n => padicValNat ( p i ) ( n + 1 ) ) ( Finset.mem_range.mpr ( show m + j - 1 < b + m from by omega ) ) using 1 ; rw [ Nat.sub_add_cancel ( by linarith ) ];
      convert padicValNat_periodic_pos ( p i ) ( hp i ) ( m + j ) ( S / p i ^ ( M i + 1 ) ) ( M i ) _ using 1;
      · rw [ Nat.div_mul_cancel ( show p i ^ ( M i + 1 ) ∣ S from Finset.dvd_prod_of_mem _ ( Finset.mem_univ _ ) ) ] ; aesop;
      · linarith;
    rw [ h_val_eq ]

/-
Any sequence with values in a finite type has a repeating block of any length.
-/
lemma exists_repeating_block {A : Type} [Finite A] [DecidableEq A] (f : ℕ → A) (b : ℕ) :
  ∃ n m, n < m ∧ ∀ k < b, f (n + k) = f (m + k) := by
    by_contra! h;
    -- Consider the sequence of blocks $B_n = (f(n), \dots, f(n+b-1))$. Each block $B_n$ belongs to the set $A^b$, which is finite since $A$ is finite.
    have h_blocks_finite : Set.Finite (Set.range (fun n => fun k : Fin b => f (n + k.val))) := by
      exact Set.toFinite _;
    exact h_blocks_finite.not_infinite <| Set.infinite_range_of_injective fun m n hmn => le_antisymm ( le_of_not_gt fun hmn' => by obtain ⟨ k, hk₁, hk₂ ⟩ := h _ _ hmn'; have := congr_fun hmn ⟨ k, hk₁ ⟩ ; aesop ) ( le_of_not_gt fun hmn' => by obtain ⟨ k, hk₁, hk₂ ⟩ := h _ _ hmn'; have := congr_fun hmn.symm ⟨ k, hk₁ ⟩ ; aesop )

/-
Definition of a recurrent sequence.
-/
def is_recurrent_seq {A : Type} (f : ℕ → A) :=
  ∀ b m, ∃ s > 0, ∀ k < b, f (m + k) = f (m + s + k)

/-
The valuation vector sequence is recurrent for positive indices.
-/
def is_recurrent_seq_pos {A : Type} (f : ℕ → A) :=
  ∀ b, ∀ m > 0, ∃ s > 0, ∀ k < b, f (m + k) = f (m + s + k)

lemma val_vec_is_recurrent_pos (k : ℕ) (p : Fin k → ℕ) (hp : ∀ i, (p i).Prime) :
  is_recurrent_seq_pos (val_vec k p) := by
    intro b m hm;
    convert val_vec_recurrent k p hp b m using 1;
    cases b <;> aesop

/-
For any m, there exists a length L and vectors f_0, ..., f_{m-1} such that any subset sum of f_i's is realizable as a prefix sum of the valuation vector sequence starting at N+1.
-/
lemma exists_prefix_sums (k : ℕ) (p : Fin k → ℕ) (hp : ∀ i, (p i).Prime) (N : ℕ) (m : ℕ) :
  ∃ (L : ℕ) (f : Fin m → Fin k → ZMod 2),
    ∀ (S : Finset (Fin m)), ∃ (l : ℕ), l ≤ L ∧ ∑ i ∈ Finset.range l, val_vec k p (N + 1 + i) = ∑ i ∈ S, f i := by
      by_contra! h_contra;
      obtain ⟨ S, hS ⟩ := h_contra 0 ( fun _ => 0 ) ; specialize hS 0 ; aesop;

/-
Inductive step for constructing a rich block. Given a block of length L that generates all subset sums of f, we can extend it to a block of length L' that generates all subset sums of f extended with a new vector.
-/
lemma rich_block_inductive_step (k : ℕ) (p : Fin k → ℕ) (hp : ∀ i, (p i).Prime) (N : ℕ) (m : ℕ) (L : ℕ) (f : Fin m → Fin k → ZMod 2)
  (h : ∀ (S : Finset (Fin m)), S.Nonempty → ∃ (l : ℕ), 0 < l ∧ l ≤ L ∧ ∑ i ∈ Finset.range l, val_vec k p (N + 1 + i) = ∑ i ∈ S, f i) :
  ∃ (L' : ℕ) (f' : Fin (m + 1) → Fin k → ZMod 2),
    ∀ (S : Finset (Fin (m + 1))), S.Nonempty → ∃ (l : ℕ), 0 < l ∧ l ≤ L' ∧ ∑ i ∈ Finset.range l, val_vec k p (N + 1 + i) = ∑ i ∈ S, f' i := by
      by_contra h_contra;
      obtain ⟨s, hs_pos, hs⟩ : ∃ s > 0, ∀ j < L, val_vec k p (N + 1 + j) = val_vec k p (N + 1 + s + j) := by
        by_cases hL : L = 0;
        · exact ⟨ 1, by norm_num, by norm_num [ hL ] ⟩;
        · convert val_vec_recurrent k p hp L ( N + 1 ) ( Nat.pos_of_ne_zero hL ) ( Nat.succ_pos _ ) using 1;
      refine' h_contra ⟨ s + L, Fin.snoc f ( ∑ i ∈ Finset.range s, val_vec k p ( N + 1 + i ) ), _ ⟩;
      intro S hS_nonempty
      by_cases hm : Fin.last m ∈ S;
      · -- Let $S' = S \setminus \{m\}$.
        obtain ⟨S', hS'⟩ : ∃ S' : Finset (Fin m), S = Finset.image (Fin.castSucc) S' ∪ {Fin.last m} := by
          use Finset.univ.filter (fun i => Fin.castSucc i ∈ S);
          ext i; by_cases hi : i = Fin.last m <;> simp +decide [ hi, hm ] ;
          exact ⟨ fun hi' => ⟨ ⟨ i.val, lt_of_le_of_ne ( Fin.le_last _ ) ( by simpa [ Fin.ext_iff ] using hi ) ⟩, by simpa [ Fin.ext_iff ] using hi', rfl ⟩, by rintro ⟨ a, ha, rfl ⟩ ; exact ha ⟩;
        by_cases hS'_nonempty : S'.Nonempty;
        · obtain ⟨ l, hl_pos, hl_le, hl ⟩ := h S' hS'_nonempty;
          refine' ⟨ s + l, by linarith, by linarith, _ ⟩;
          simp_all +decide [ Finset.sum_range_add, Finset.sum_image, Fin.snoc ];
          convert hl using 1;
          exact Finset.sum_congr rfl fun i hi => by rw [ show N + 1 + ( s + i ) = N + 1 + s + i by ring, hs i ( by linarith [ Finset.mem_range.mp hi ] ) ] ;
        · use s; aesop;
      · -- Since $Fin.last m \notin S$, we can consider $S$ as a subset of $Fin m$.
        obtain ⟨S', hS'⟩ : ∃ S' : Finset (Fin m), S = Finset.image (fun i => Fin.castSucc i) S' := by
          use Finset.univ.filter (fun i => Fin.castSucc i ∈ S);
          ext i; simp [Finset.mem_image];
          exact ⟨ fun hi => ⟨ ⟨ i.val, lt_of_le_of_ne ( Fin.le_last _ ) ( by rintro h; exact hm <| by convert hi; aesop ) ⟩, by simpa [ Fin.ext_iff ] using hi, rfl ⟩, by rintro ⟨ a, ha, rfl ⟩ ; exact ha ⟩;
        obtain ⟨ l, hl_pos, hl_le, hl ⟩ := h S' ( by simpa [ hS' ] using hS_nonempty ) ; use l; simp_all +decide [ Finset.sum_image ] ;
        linarith

/-
For any m, there exists a length L and vectors f_0, ..., f_{m-1} such that any non-empty subset sum of f_i's is realizable as a prefix sum of the valuation vector sequence starting at N+1, with positive length.
-/
lemma exists_rich_block (k : ℕ) (p : Fin k → ℕ) (hp : ∀ i, (p i).Prime) (N : ℕ) (m : ℕ) :
  ∃ (L : ℕ) (f : Fin m → Fin k → ZMod 2),
    ∀ (S : Finset (Fin m)), S.Nonempty → ∃ (l : ℕ), 0 < l ∧ l ≤ L ∧ ∑ i ∈ Finset.range l, val_vec k p (N + 1 + i) = ∑ i ∈ S, f i := by
      induction' m with m ih;
      · exact ⟨ 0, fun _ => 0, by simp +decide ⟩;
      · exact Exists.elim ih fun L hL => Exists.elim ( rich_block_inductive_step k p hp N m L hL.choose hL.choose_spec ) fun L' hL' => ⟨ L', hL'.choose, hL'.choose_spec ⟩

/-
There are infinitely many n such that n! is divisible by an even power of each of the p_i.
-/
theorem infinitely_many_even_factorial_exponents (k : ℕ) (p : Fin k → ℕ) (hp : ∀ i, (p i).Prime) (h_distinct : Function.Injective p) :
  Set.Infinite { n | ∀ i, partial_sum k p n i = 0 } := by
    -- By induction on $N$, we can construct an infinite sequence of such $n$.
    have h_seq : ∀ N : ℕ, ∃ n > N, ∀ i, (partial_sum k p n i) = 0 := by
      intro N
      induction' N with N ih;
      · use 1; simp [partial_sum];
      · obtain ⟨ n, hn₁, hn₂ ⟩ := ih;
        obtain ⟨ L, f, hf ⟩ := exists_rich_block k p hp n ( k + 1 );
        obtain ⟨ S, hS₁, hS₂ ⟩ := exists_subset_sum_zero f;
        obtain ⟨ l, hl₁, hl₂, hl₃ ⟩ := hf S hS₁;
        refine' ⟨ n + l, by linarith, fun i => _ ⟩;
        -- By definition of partial_sum, we have:
        have h_partial_sum : partial_sum k p (n + l) i = partial_sum k p n i + ∑ j ∈ Finset.range l, val_vec k p (n + 1 + j) i := by
          unfold partial_sum val_vec; simp +decide [ add_assoc ] ;
          have h_partial_sum : ∀ m, padicValNat (p i) (Nat.factorial (n + m)) = padicValNat (p i) (Nat.factorial n) + ∑ j ∈ Finset.range m, padicValNat (p i) (n + 1 + j) := by
            intro m; induction m <;> simp_all +decide [ Nat.factorial, Finset.sum_range_succ ] ;
            haveI := Fact.mk ( hp i ) ; rw [ padicValNat.mul ( by positivity ) ( by positivity ) ] ; simp_all +decide [ add_comm, add_left_comm, add_assoc ] ;
          simp_all +decide [ add_assoc ];
        simp_all +decide [ funext_iff ];
    exact Set.infinite_of_forall_exists_gt fun N => by obtain ⟨ n, hn₁, hn₂ ⟩ := h_seq N; exact ⟨ n, hn₂, hn₁ ⟩ ;

end

