        ┬À rw [ÔåÉ pow_succ]
          haveI := Fact.mk hp
          rw [padicValNat_dvd_iff_le]
          ┬À aesop
          ┬À positivity
        ┬À exact pow_padicValNat_dvd
    -- Then $n + k p^{M+1} = p^v u + k p^{M+1} =
