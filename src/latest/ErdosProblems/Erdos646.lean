      have h_val_ge : padicValNat p (m + k0) ÔëÑ M_next + 1 := by
        have h_val_ge : Ôêâ k < b, k Ôëá k0 Ôêº padicValNat p (m + k) = M_next := by
          have h_exists_k : Ôêâ k Ôêê Finset.erase (Finset.range b) k0, padicValNat p (m + k) = M_next := by
            have h_exists_k : Ôêâ k Ôêê Finset.erase (Finset.range b) k0, ÔêÇ j Ôêê Finset.erase (Finset.range b) k0, padicValNat p (m + j) Ôëñ padicValNat p (m + k) := by
              apply_rules [ Finset.exists_max_image ];
              exact Ôƒ¿ if k0 = 0 then 1 else 0, by aesop Ôƒ®;
            obtain Ôƒ¿ k, hkÔéü, hkÔéé Ôƒ® := h_exists_k; exact Ôƒ¿ k, hkÔéü, le_antisymm ( hM_next.symm Ôû© Finset.le_sup ( f := fun k => padicValNat p ( m + k ) ) hkÔéü ) ( hM_next.symm Ôû© Finset.sup_le fun j hj => hkÔéé j hj ) Ôƒ® ;
          aesop;
        grind;
      -- Thus $Q \mid (m+k_0)$. Let $m+k_0 = u Q$.
      obtain Ôƒ¿u, huÔƒ® : Ôêâ u, m + k0 = u * Q := by
        use (m + k0) / Q;
        rw [ Nat.div_mul_cancel ];
        rw [ ÔåÉ Nat.factorization_le_iff_dvd ] <;> norm_num [ hp.ne_zero, hp.ne_one ];
        ┬À intro q; by_cases hq : p = q <;> simp_all +decide [ Nat.factorization_pow ] ;
          simp_all +decide [ Nat.factorization ];
        ┬À exact hQ.1.symm Ôû© pow_ne_zero _ hp.ne_zero;
        ┬À aesop;
      -- We want to find $s = t Q$ such that $v_p(m+k_0+s) \equiv M \pmod 2$.
      obtain Ôƒ¿t, htÔƒ® : Ôêâ t Ôêê Finset.Icc 1 (2 * p), (padicValNat p (u + t)) % 2 = (M - (M_next + 1)) % 2 := by
        convert exists_shift_with_parity p hp u ( ( M - ( M_next + 1 ) ) % 2 ) using 1;
        norm_num [ ÔåÉ ZMod.natCast_eq_natCast_iff' ];
        ext; norm_num [ two_mul, add_assoc ] ;
        intro _ _; erw [ Nat.cast_sub ( by linarith ) ] ; norm_num;
        grind +ring;
      refine Ôƒ¿t * Q, ?_, ?_, ?_Ôƒ® <;> norm_num at *
      ┬À exact Ôƒ¿ ht.1.1, hQ.1.symm Ôû© pow_pos hp.pos _ Ôƒ®;
      ┬À nlinarith [ pow_succ' p M_next ];
      ┬À intro k hk
        by_cases hk_eq_k0 : k = k0;
        ┬À -- Using the properties of p-adic valuations, we can simplify the expression for the valuation of $m + k0 + t * Q$.
          have h_val_simplified : padicValNat p (m + k0 + t * Q) = padicValNat p (u + t) + (M_next + 1) := by
            haveI := Fact.mk hp; rw [ hu ] ; ring_nf;
            rw [ show u * Q + Q * t = Q * ( u + t ) by ring, padicValNat.mul ] <;> norm_num [ hQ.1, hp.ne_zero ]
            focus ring_nf
            grind +ring;
          grind +ring;
        ┬À -- Since $k \ne k0$, we have $v_p(m+k) \le M_{next}$.
          have h_val_le : padicValNat p (m + k) Ôëñ M_next := by
            exact hM_next.symm Ôû© Finset.le_sup ( f := fun k => padicValNat p ( m + k ) ) ( Finset.mem_erase_of_ne_of_mem hk_eq_k0 ( Finset.mem_range.mpr hk ) );
          -- Since $s$ is a multiple of $Q = p^{M_{next}+1}$, by `padicValNat_periodic_pos`, $v_p(m+k+s) = v_p(m+k)$.
          have h_val_eq : padicValNat p (m + k + t * Q) = padicValNat p (m + k) := by
            convert padicValNat_periodic_pos p hp ( m + k ) t M_next ( by linarith ) ( by linarith ) using 1;
            rw [ hQ.1 ];
          rw [ add_right_comm, h_val_eq ];
    ┬À interval_cases b ; simp_all +decide;
      -- By `exists_shift_with_parity`, there exists $t \in \{1, \dots, 2p\}$ such that $v_p(m+t)$ has the same parity as $v_p(m)$.
      obtain Ôƒ¿t, htÔƒ® : Ôêâ t Ôêê Finset.Icc 1 (2 * p), (padicValNat p (m + t)) % 2 = (padicValNat p m) % 2 := by
        convert exists_shift_with_parity p hp m _;
        focus erw [ ÔåÉ ZMod.natCast_eq_natCast_iff' ]
        focus norm_num
        focus erw [ show ( 2 : ZMod 2 ) = 0 by rfl ]
        focus norm_num
        convert Iff.rfl;
      exact Ôƒ¿ t, Finset.mem_Icc.mp ht.1 |>.1, by nlinarith [ Finset.mem_Icc.mp ht.1 |>.2, hp.two_le ], ht.2.symm Ôƒ®

/-
For any prime p and block of length b, there is a shift s <= 2*p^2*b that preserves parity of valuations.
-/
lemma lemma_2 (p : Ôäò) (hp : p.Prime) (b m : Ôäò) (hb : b > 0) (hm : m > 0) :
  Ôêâ s, 0 < s Ôêº s Ôëñ 2 * p^2 * b Ôêº
  ÔêÇ k < b, (padicValNat p (m + k)) % 2 = (padicValNat p (m + s + k)) % 2 := by
    by_cases h_unique : Ôêâ k1 k2, k1 < b Ôêº k2 < b Ôêº k1 Ôëá k2 Ôêº padicValNat p (m + k1) = Finset.sup (Finset.range b) (fun k => padicValNat p (m + k)) Ôêº padicValNat p (m + k2) = Finset.sup (Finset.range b) (fun k => padicValNat p (m + k));
    ┬À convert lemma_2_case_1 p hp b m hb hm _ rfl h_unique using 1;
    ┬À obtain Ôƒ¿k0, hk0Ôƒ® : Ôêâ k0, k0 < b Ôêº padicValNat p (m + k0) = Finset.sup (Finset.range b) (fun k => padicValNat p (m + k)) := by
        have h_sup : Ôêâ k0 Ôêê Finset.range b, ÔêÇ k Ôêê Finset.range b, padicValNat p (m + k) Ôëñ padicValNat p (m + k0) := by
          exact Finset.exists_max_image _ _ Ôƒ¿ _, Finset.mem_range.mpr hb Ôƒ®;
        exact Ôƒ¿ h_sup.choose, Finset.mem_range.mp h_sup.choose_spec.1, le_antisymm ( Finset.le_sup ( f := fun k => padicValNat p ( m + k ) ) h_sup.choose_spec.1 ) ( Finset.sup_le fun k hk => h_sup.choose_spec.2 k hk ) Ôƒ®;
      apply lemma_2_case_2 p hp b m hb hm (Finset.sup (Finset.range b) (fun k => padicValNat p (m + k))) (by
      rfl) k0 hk0.left hk0.right (by
      exact fun k hk hk' => lt_of_le_of_ne ( Finset.le_sup ( f := fun k => padicValNat p ( m + k ) ) ( Finset.mem_range.mpr hk ) ) fun h => h_unique Ôƒ¿ k, k0, hk, hk0.1, hk', h, hk0.2 Ôƒ®) (Finset.sup (Finset.erase (Finset.range b) k0) (fun k => padicValNat p (m + k))) (by
      rfl)

/-
If the maximum valuation M is attained at least twice in a block, then there exists an arithmetic progression of starts preserving parity.
-/
lemma lemma_block_recurrence_AP_case1 (p : Ôäò) (hp : p.Prime) (b m : Ôäò) (hb : b > 0) (hm : m > 0)
  (M : Ôäò) (hM : M = Finset.sup (Finset.range b) (fun k => padicValNat p (m + k)))
  (h_not_unique : Ôêâ k1 k2, k1 < b Ôêº k2 < b Ôêº k1 Ôëá k2 Ôêº padicValNat p (m + k1) = M Ôêº padicValNat p (m + k2) = M) :
  Ôêâ a d, a > 0 Ôêº d > 0 Ôêº d Ôëñ p^3 * b Ôêº ÔêÇ r : Ôäò, ÔêÇ k < b, (padicValNat p (a + r * d + k)) % 2 = (padicValNat p (m + k)) % 2 := by
    -- By `padicValNat_max_attained_twice_implies_pow_lt_b`, we have `p^M < b`.
    have h_pow_lt_b : p ^ M < b := by
      exact padicValNat_max_attained_twice_implies_pow_lt_b p hp b m hb M hM h_not_unique
    use m, p ^ ( M + 1 );
    refine Ôƒ¿hm, pow_pos hp.pos _, ?_, ?_Ôƒ®
    ┬À rw [ pow_succ' ] ; nlinarith [ Nat.mul_le_mul_left ( p ^ M ) ( show p ÔëÑ 2 by exact hp.two_le ), pow_pos hp.pos 2, pow_pos hp.pos 3 ] ;
    ┬À intro r k hk_lt_b
      have h_val_le_M : padicValNat p (m + k) Ôëñ M := by
        exact hM.symm Ôû© Finset.le_sup ( f := fun k => padicValNat p ( m + k ) ) ( Finset.mem_range.mpr hk_lt_b );
      rw [ show m + r * p ^ ( M + 1 ) + k = m + k + r * p ^ ( M + 1 ) by ring, padicValNat_periodic_pos ] <;> aesop

/-
Case b=1 of Lemma 2 Case 2.
-/
set_option linter.flexible false in
lemma lemma_block_recurrence_AP_case2_b_eq_1 (p : Ôäò) (hp : p.Prime) (b m : Ôäò) (hb : b = 1) (hm : m > 0)
  (M : Ôäò) (hM : M = Finset.sup (Finset.range b) (fun k => padicValNat p (m + k)))
  (k0 : Ôäò) (hk0 : k0 < b) (hk0_val : padicValNat p (m + k0) = M) :
  Ôêâ a d, a > 0 Ôêº d > 0 Ôêº d Ôëñ p^3 * b Ôêº ÔêÇ r : Ôäò, ÔêÇ k < b, (padicValNat p (a + r * d + k)) % 2 = (padicValNat p (m + k)) % 2 := by
    obtain Ôƒ¿M', hM'_pos, hM'_eq, hM'_leÔƒ® : Ôêâ M' Ôêê ({1, 2} : Finset Ôäò), M' % 2 = M % 2 Ôêº M' Ôëñ 2 := by
      cases Nat.mod_two_eq_zero_or_one M <;> simp +decide [ * ];
      ┬À aesop;
      ┬À grind +ring;
    refine
      Ôƒ¿p ^ M' + p ^ (M' + 1), p ^ (M' + 1), ?_, ?_, ?_, ?_Ôƒ® <;>
        simp_all +decide [Nat.pow_succ]
    ┬À exact Or.inl ( pow_pos hp.pos _ );
    ┬À exact Ôƒ¿ pow_pos hp.pos _, hp.pos Ôƒ®;
    ┬À interval_cases M' <;> nlinarith [ hp.two_le ];
    ┬À -- Let's simplify the expression for the valuation.
      have h_val : ÔêÇ r : Ôäò, padicValNat p (p ^ M' * (p + 1 + r * p)) = M' := by
        intro r; haveI := Fact.mk hp; rw [ padicValNat.mul ] <;> norm_num [ hp.ne_zero ] ;
        norm_num [ Nat.dvd_iff_mod_eq_zero, Nat.add_mod, Nat.mul_mod ];
        exact em _;
      intro r; rw [ show p ^ M' + p ^ M' * p + r * ( p ^ M' * p ) = p ^ M' * ( p + 1 + r * p ) by ring ] ; aesop;

/-
Existence of a start value a such that the valuation of a + r*d + k0 is constant M'.
-/
lemma lemma_exists_a_case2 (p : Ôäò) (hp : p.Prime) (b k0 M' : Ôäò) (hb : b > 0) (hk0 : k0 < b) (hM' : M' > 0) :
  Ôêâ a > 0, ÔêÇ r : Ôäò, padicValNat p (a + r * p^(M'+1) + k0) = M' := by
    -- Choose $a = p^{M'} + p^{M'+1} \cdot b - k0$.
    use p^M' + p^(M'+1) * b - k0
    constructor
    ┬À exact Nat.sub_pos_of_lt ( by nlinarith [ pow_pos hp.pos M', pow_pos hp.pos ( M' + 1 ) ] )
    ┬À intro r
      have h_factor : p ^ M' + p ^ (M' + 1) * b + r * p ^ (M' + 1) = p ^ M' * (1 + p * b + r * p) := by
        ring;
      have h_val : padicValNat p (p ^ M' * (1 + p * b + r * p)) = M' := by
        haveI := Fact.mk hp; rw [ padicValNat.mul ] <;> norm_num [ hp.ne_zero, hp.ne_one ] ;
        norm_num [ Nat.dvd_iff_mod_eq_zero, Nat.add_mod, Nat.mul_mod, Nat.pow_mod ] at * ; aesop;
      convert h_val using 2 ; linarith [ Nat.sub_add_cancel ( show k0 Ôëñ p ^ M' + p ^ ( M' + 1 ) * b from by nlinarith [ pow_pos hp.pos M', pow_pos hp.pos ( M' + 1 ) ] ) ]

/-
If M is the unique maximum valuation at k0, then the valuation of the distance to k0 is less than M.
-/
set_option linter.flexible false in
lemma lemma_valuation_diff_lt_max (p : Ôäò) (hp : p.Prime) (b m : Ôäò) (hm : m > 0) (k0 : Ôäò) (hk0 : k0 < b)
  (M : Ôäò) (hM : padicValNat p (m + k0) = M)
  (h_unique : ÔêÇ k < b, k Ôëá k0 ÔåÆ padicValNat p (m + k) < M) :
  ÔêÇ k < b, k Ôëá k0 ÔåÆ padicValNat p (if k > k0 then k - k0 else k0 - k) < M := by
    intro k hk hk_ne_k0
    by_contra h_contra
    have h_div : p^M Ôêú (if k > k0 then k - k0 else k0 - k) := by
      -- By definition of p-adic valuation, if $padicValNat p x \geq M$, then $p^M \mid x$.
      have h_div : ÔêÇ x : Ôäò, 0 < x ÔåÆ padicValNat p x ÔëÑ M ÔåÆ p^M Ôêú x := by
        intro x hx_pos hx_val
        have h_div : p ^ (padicValNat p x) Ôêú x := by
          exact pow_padicValNat_dvd
        exact dvd_trans ( pow_dvd_pow p hx_val ) h_div
      exact h_div _ ( Nat.pos_of_ne_zero ( by split_ifs <;> omega ) ) ( le_of_not_gt h_contra )
    have h_div_mk : p^M Ôêú m + k := by
      have h_div_mk : p^M Ôêú m + k0 := by
        rw [ ÔåÉ hM ];
        exact pow_padicValNat_dvd;
      split_ifs at h_div <;> simp_all +decide [ ÔåÉ ZMod.natCast_eq_zero_iff ] ; cases le_total k k0 <;> simp_all +decide [ Nat.cast_sub ] ;
      ┬À linear_combination' h_div_mk + h_div;
      ┬À grind
    have h_contra' : padicValNat p (m + k) ÔëÑ M := by
      haveI := Fact.mk hp; rw [ padicValNat_dvd_iff ] at *; aesop;
    linarith [h_unique k hk hk_ne_k0]

/-
If M is the unique maximum valuation at k0, then the valuation of the distance to k0 is less than M.
-/
lemma lemma_valuation_diff_lt_max' (p : Ôäò) (hp : p.Prime) (b m : Ôäò) (hm : m > 0) (k0 : Ôäò) (hk0 : k0 < b)
  (M : Ôäò) (hM : padicValNat p (m + k0) = M)
  (h_unique : ÔêÇ k < b, k Ôëá k0 ÔåÆ padicValNat p (m + k) < M) :
  ÔêÇ k < b, k Ôëá k0 ÔåÆ padicValNat p (if k > k0 then k - k0 else k0 - k) < M := by
    exact fun k hk hk_ne => lemma_valuation_diff_lt_max p hp b m hm k0 hk0 M hM h_unique k hk hk_ne

/-
If M is the unique maximum valuation at k0, then for other k, the valuation depends only on the distance to k0.
-/
set_option linter.flexible false in
lemma lemma_valuation_near_max (p : Ôäò) (hp : p.Prime) (b m : Ôäò) (hm : m > 0) (k0 : Ôäò) (hk0 : k0 < b)
  (M : Ôäò) (hM : padicValNat p (m + k0) = M)
  (h_unique : ÔêÇ k < b, k Ôëá k0 ÔåÆ padicValNat p (m + k) < M) :
  ÔêÇ k < b, k Ôëá k0 ÔåÆ padicValNat p (m + k) = padicValNat p (if k > k0 then k - k0 else k0 - k) := by
    intro k hk_lt hk_ne_k0
    by_cases hk_gt_k0 : k > k0;
    ┬À have h_val_eq : padicValNat p (m + k) = padicValNat p ((m + k0) + (k - k0)) := by
        rw [ add_assoc, Nat.add_sub_of_le hk_gt_k0.le ];
      have h_val_eq : padicValNat p ((m + k0) + (k - k0)) = padicValNat p (k - k0) := by
        have h_div : p ^ (padicValNat p (k - k0)) Ôêú (m + k0) + (k - k0) := by
          have h_div : p ^ (padicValNat p (k - k0)) Ôêú (k - k0) := by
            convert Nat.ordProj_dvd ( k - k0 ) p using 1;
            rw [ Nat.factorization_def ] ; aesop;
          have h_div : p ^ (padicValNat p (k - k0)) Ôêú (m + k0) := by
            have h_div : padicValNat p (k - k0) < M := by
              have := lemma_valuation_diff_lt_max p hp b m hm k0 hk0 M hM h_unique k hk_lt hk_ne_k0; aesop;
            have h_div : p ^ (padicValNat p (m + k0)) Ôêú (m + k0) := by
              haveI := Fact.mk hp; rw [ padicValNat_dvd_iff ] ; aesop;
            exact dvd_trans ( pow_dvd_pow _ ( by linarith ) ) h_div;
          exact dvd_add h_div ÔÇ╣_ÔÇ║
        have h_not_div : ┬¼(p ^ (padicValNat p (k - k0) + 1) Ôêú (m + k0) + (k - k0)) := by
          rw [ Nat.dvd_add_right ];
          ┬À rw [ Nat.Prime.pow_dvd_iff_le_factorization ] <;> norm_num [ hp ];
            ┬À rw [ Nat.factorization ] ; aesop;
            ┬À exact Nat.sub_ne_zero_of_lt hk_gt_k0;
          ┬À have h_not_div : padicValNat p (m + k0) > padicValNat p (k - k0) := by
              have := lemma_valuation_diff_lt_max p hp b m hm k0 hk0 M hM ( fun k hk_lt hk_ne_k0 => h_unique k hk_lt hk_ne_k0 ) k hk_lt hk_ne_k0; aesop;
            have h_not_div : padicValNat p (m + k0) = Nat.factorization (m + k0) p := by
              rw [ Nat.factorization_def ] ; aesop;
            exact Nat.dvd_trans ( pow_dvd_pow _ ( Nat.succ_le_of_lt ÔÇ╣_ÔÇ║ ) ) ( h_not_div.symm Ôû© Nat.ordProj_dvd _ _ )
        have h_val_eq : padicValNat p (m + k0 + (k - k0)) = Nat.factorization (m + k0 + (k - k0)) p := by
          rw [ Nat.factorization_def ] ; aesop;
        have h_val_eq : Nat.factorization (m + k0 + (k - k0)) p = padicValNat p (k - k0) := by
          exact le_antisymm ( Nat.le_of_not_lt fun h => h_not_div <| Nat.dvd_trans ( pow_dvd_pow _ h ) <| Nat.ordProj_dvd _ _ ) ( Nat.le_of_not_lt fun h => by exact absurd ( dvd_trans ( pow_dvd_pow _ h ) h_div ) <| Nat.pow_succ_factorization_not_dvd ( by linarith [ Nat.sub_pos_of_lt hk_gt_k0 ] ) hp );
        grind;
      aesop;
    ┬À have h_val : padicValNat p (m + k0 - (k0 - k)) = padicValNat p (k0 - k) := by
        have h_div : p ^ (padicValNat p (k0 - k)) Ôêú (m + k0 - (k0 - k)) := by
          have h_div : p ^ (padicValNat p (k0 - k)) Ôêú (m + k0) := by
            have h_div : padicValNat p (k0 - k) < M := by
              convert lemma_valuation_diff_lt_max p hp b m hm k0 hk0 M hM h_unique k hk_lt hk_ne_k0 using 1 ; split_ifs ; omega;
            have h_div : p ^ (padicValNat p (m + k0)) Ôêú (m + k0) := by
              convert Nat.ordProj_dvd ( m + k0 ) p using 1;
              rw [ Nat.factorization ] ; aesop;
            exact dvd_trans ( pow_dvd_pow _ ( by linarith ) ) h_div;
          refine Nat.dvd_sub h_div ?_;
          convert Nat.ordProj_dvd ( k0 - k ) p using 1;
          rw [ Nat.factorization_def ] ; aesop
        have h_not_div : ┬¼(p ^ (padicValNat p (k0 - k) + 1) Ôêú (m + k0 - (k0 - k))) := by
          intro h_div';
          have h_contra : p ^ (padicValNat p (k0 - k) + 1) Ôêú (k0 - k) := by
            have h_contra : padicValNat p (k0 - k) < M := by
              convert lemma_valuation_diff_lt_max p hp b m hm k0 hk0 M hM ( fun k hk_lt hk_ne_k0 => h_unique k hk_lt hk_ne_k0 ) k hk_lt hk_ne_k0 using 1;
              rw [ if_neg hk_gt_k0 ];
            have h_contra : p ^ (padicValNat p (k0 - k) + 1) Ôêú (m + k0) := by
              have h_contra : p ^ M Ôêú (m + k0) := by
                rw [ ÔåÉ hM ];
                convert Nat.ordProj_dvd ( m + k0 ) p using 1;
                rw [ Nat.factorization_def ] ; aesop;
              exact dvd_trans ( pow_dvd_pow _ ( by linarith ) ) h_contra;
            convert Nat.dvd_sub h_contra h_div' using 1 ; rw [ Nat.sub_sub_self ( show k0 - k Ôëñ m + k0 from Nat.sub_le_of_le_add <| by linarith ) ];
          have := Nat.factorization_le_iff_dvd ( by aesop ) ( Nat.sub_ne_zero_of_lt ( lt_of_le_of_ne ( le_of_not_gt hk_gt_k0 ) hk_ne_k0 ) ) |>.2 h_contra ; simp_all +decide [ Nat.factorization_pow ] ;
          replace := this p ; simp_all +decide [ Nat.factorization ]
        have h_val : padicValNat p (m + k0 - (k0 - k)) = Nat.factorization (m + k0 - (k0 - k)) p := by
          rw [ Nat.factorization_def ] ; aesop;
        have h_val : Nat.factorization (m + k0 - (k0 - k)) p = padicValNat p (k0 - k) := by
          exact le_antisymm ( Nat.le_of_not_lt fun h => h_not_div <| dvd_trans ( pow_dvd_pow _ h ) <| Nat.ordProj_dvd _ _ ) ( Nat.le_of_not_lt fun h => by exact absurd ( dvd_trans ( pow_dvd_pow _ h ) h_div ) <| Nat.pow_succ_factorization_not_dvd ( Nat.sub_ne_zero_of_lt <| by omega ) hp );
        linarith;
      grind +ring

/-
Definitions for the vector of valuations and the partial sum vector.
-/
def val_vec (k : Ôäò) (p : Fin k ÔåÆ Ôäò) (n : Ôäò) : Fin k ÔåÆ ZMod 2 :=
  fun i => padicValNat (p i) n

def partial_sum (k : Ôäò) (p : Fin k ÔåÆ Ôäò) (n : Ôäò) : Fin k ÔåÆ ZMod 2 :=
  fun i => padicValNat (p i) (Nat.factorial n)

/-
The sequence of valuation vectors is recurrent.
-/
set_option linter.flexible false in
lemma val_vec_recurrent (k : Ôäò) (p : Fin k ÔåÆ Ôäò) (hp : ÔêÇ i, (p i).Prime) (b m : Ôäò) (hb : b > 0) (hm : m > 0) :
  Ôêâ s > 0, ÔêÇ j < b, val_vec k p (m + j) = val_vec k p (m + s + j) := by
    revert k p hp b m hb hm;
    -- Let's choose the maximum valuation $M_i$ for each prime $p_i$.
    intros k p hp b m hb hm
    set M := fun i => Finset.sup (Finset.range (b + m)) (fun n => padicValNat (p i) (n + 1)) with hM_def;
    -- Let $S = \prod_{i=1}^k p_i^{M_i + 1}$.
    set S := Finset.prod Finset.univ (fun i => p i ^ (M i + 1)) with hS_def;
    refine
      Ôƒ¿S, Finset.prod_pos fun i _ => pow_pos (Nat.Prime.pos (hp i)) _, fun j hj => ?_Ôƒ®
    ext i
    simp +decide [add_right_comm, val_vec]
    -- By the properties of the p-adic valuation, we have that $v_{p_i}(m + j + S) = v_{p_i}(m + j)$ since $S$ is divisible by $p_i^{M_i + 1}$.
    have h_val_eq : padicValNat (p i) (m + j + S) = padicValNat (p i) (m + j) := by
      have h_val_eq : padicValNat (p i) (m + j) Ôëñ M i := by
        simpa [Nat.sub_add_cancel (by omega : 1 Ôëñ m + j)] using
          Finset.le_sup (f := fun n => padicValNat (p i) (n + 1))
            (Finset.mem_range.mpr (show m + j - 1 < b + m from by omega))
      convert padicValNat_periodic_pos ( p i ) ( hp i ) ( m + j ) ( S / p i ^ ( M i + 1 ) ) ( M i ) _ using 1;
      ┬À rw [ Nat.div_mul_cancel ( show p i ^ ( M i + 1 ) Ôêú S from Finset.dvd_prod_of_mem _ ( Finset.mem_univ _ ) ) ] ; aesop;
      ┬À linarith;
    rw [ h_val_eq ]

/-
Any sequence with values in a finite type has a repeating block of any length.
-/
lemma exists_repeating_block {A : Type} [Finite A] (f : Ôäò ÔåÆ A) (b : Ôäò) :
  Ôêâ n m, n < m Ôêº ÔêÇ k < b, f (n + k) = f (m + k) := by
    classical
    by_contra! h;
    -- Consider the sequence of blocks $B_n = (f(n), \dots, f(n+b-1))$. Each block $B_n$ belongs to the set $A^b$, which is finite since $A$ is finite.
    have h_blocks_finite : Set.Finite (Set.range (fun n => fun k : Fin b => f (n + k.val))) := by
      exact Set.toFinite _;
    exact h_blocks_finite.not_infinite <| Set.infinite_range_of_injective fun m n hmn => le_antisymm ( le_of_not_gt fun hmn' => by obtain Ôƒ¿ k, hkÔéü, hkÔéé Ôƒ® := h _ _ hmn'; have := congr_fun hmn Ôƒ¿ k, hkÔéü Ôƒ® ; aesop ) ( le_of_not_gt fun hmn' => by obtain Ôƒ¿ k, hkÔéü, hkÔéé Ôƒ® := h _ _ hmn'; have := congr_fun hmn.symm Ôƒ¿ k, hkÔéü Ôƒ® ; aesop )

/-
Definition of a recurrent sequence.
-/
def is_recurrent_seq {A : Type} (f : Ôäò ÔåÆ A) :=
  ÔêÇ b m, Ôêâ s > 0, ÔêÇ k < b, f (m + k) = f (m + s + k)

/-
The valuation vector sequence is recurrent for positive indices.
-/
def is_recurrent_seq_pos {A : Type} (f : Ôäò ÔåÆ A) :=
  ÔêÇ b, ÔêÇ m > 0, Ôêâ s > 0, ÔêÇ k < b, f (m + k) = f (m + s + k)

lemma val_vec_is_recurrent_pos (k : Ôäò) (p : Fin k ÔåÆ Ôäò) (hp : ÔêÇ i, (p i).Prime) :
  is_recurrent_seq_pos (val_vec k p) := by
    intro b m hm;
    convert val_vec_recurrent k p hp b m using 1;
    cases b <;> aesop

/-
For any m, there exists a length L and vectors f_0, ..., f_{m-1} such that any subset sum of f_i's is realizable as a prefix sum of the valuation vector sequence starting at N+1.
-/
lemma exists_prefix_sums (k : Ôäò) (p : Fin k ÔåÆ Ôäò) (hp : ÔêÇ i, (p i).Prime) (N : Ôäò) (m : Ôäò) :
  Ôêâ (L : Ôäò) (f : Fin m ÔåÆ Fin k ÔåÆ ZMod 2),
    ÔêÇ (S : Finset (Fin m)), Ôêâ (l : Ôäò), l Ôëñ L Ôêº Ôêæ i Ôêê Finset.range l, val_vec k p (N + 1 + i) = Ôêæ i Ôêê S, f i := by
      by_contra! h_contra;
      obtain Ôƒ¿ S, hS Ôƒ® := h_contra 0 ( fun _ => 0 ) ; specialize hS 0 ; aesop;

/-
Inductive step for constructing a rich block. Given a block of length L that generates all subset sums of f, we can extend it to a block of length L' that generates all subset sums of f extended with a new vector.
-/
set_option linter.flexible false in
lemma rich_block_inductive_step (k : Ôäò) (p : Fin k ÔåÆ Ôäò) (hp : ÔêÇ i, (p i).Prime) (N : Ôäò) (m : Ôäò) (L : Ôäò) (f : Fin m ÔåÆ Fin k ÔåÆ ZMod 2)
  (h : ÔêÇ (S : Finset (Fin m)), S.Nonempty ÔåÆ Ôêâ (l : Ôäò), 0 < l Ôêº l Ôëñ L Ôêº Ôêæ i Ôêê Finset.range l, val_vec k p (N + 1 + i) = Ôêæ i Ôêê S, f i) :
  Ôêâ (L' : Ôäò) (f' : Fin (m + 1) ÔåÆ Fin k ÔåÆ ZMod 2),
    ÔêÇ (S : Finset (Fin (m + 1))), S.Nonempty ÔåÆ Ôêâ (l : Ôäò), 0 < l Ôêº l Ôëñ L' Ôêº Ôêæ i Ôêê Finset.range l, val_vec k p (N + 1 + i) = Ôêæ i Ôêê S, f' i := by
      by_contra h_contra;
      obtain Ôƒ¿s, hs_pos, hsÔƒ® : Ôêâ s > 0, ÔêÇ j < L, val_vec k p (N + 1 + j) = val_vec k p (N + 1 + s + j) := by
        by_cases hL : L = 0;
        ┬À exact Ôƒ¿ 1, by norm_num, by norm_num [ hL ] Ôƒ®;
        ┬À convert val_vec_recurrent k p hp L ( N + 1 ) ( Nat.pos_of_ne_zero hL ) ( Nat.succ_pos _ ) using 1;
      refine
        h_contra
          Ôƒ¿s + L, Fin.snoc f (Ôêæ i Ôêê Finset.range s, val_vec k p (N + 1 + i)), ?_Ôƒ®
      intro S hS_nonempty
      by_cases hm : Fin.last m Ôêê S;
      ┬À -- Let $S' = S \setminus \{m\}$.
        obtain Ôƒ¿S', hS'Ôƒ® : Ôêâ S' : Finset (Fin m), S = Finset.image (Fin.castSucc) S' Ôê¬ {Fin.last m} := by
          use Finset.univ.filter (fun i => Fin.castSucc i Ôêê S);
          ext i; by_cases hi : i = Fin.last m <;> simp +decide [ hi, hm ] ;
          exact Ôƒ¿ fun hi' => Ôƒ¿ Ôƒ¿ i.val, lt_of_le_of_ne ( Fin.le_last _ ) ( by simpa [ Fin.ext_iff ] using hi ) Ôƒ®, by simpa [ Fin.ext_iff ] using hi', rfl Ôƒ®, by rintro Ôƒ¿ a, ha, rfl Ôƒ® ; exact ha Ôƒ®;
        by_cases hS'_nonempty : S'.Nonempty;
        ┬À obtain Ôƒ¿ l, hl_pos, hl_le, hl Ôƒ® := h S' hS'_nonempty;
          refine Ôƒ¿s + l, by linarith, by linarith, ?_Ôƒ®
          simp_all +decide [ Finset.sum_range_add, Finset.sum_image, Fin.snoc ];
          convert hl using 1;
          exact Finset.sum_congr rfl fun i hi => by rw [ show N + 1 + ( s + i ) = N + 1 + s + i by ring, hs i ( by linarith [ Finset.mem_range.mp hi ] ) ] ;
        ┬À use s; aesop;
      ┬À -- Since $Fin.last m \notin S$, we can consider $S$ as a subset of $Fin m$.
        obtain Ôƒ¿S', hS'Ôƒ® : Ôêâ S' : Finset (Fin m), S = Finset.image (fun i => Fin.castSucc i) S' := by
          use Finset.univ.filter (fun i => Fin.castSucc i Ôêê S);
          ext i; simp [Finset.mem_image];
          exact Ôƒ¿ fun hi => Ôƒ¿ Ôƒ¿ i.val, lt_of_le_of_ne ( Fin.le_last _ ) ( by rintro h; exact hm <| by convert hi; aesop ) Ôƒ®, by simpa [ Fin.ext_iff ] using hi, rfl Ôƒ®, by rintro Ôƒ¿ a, ha, rfl Ôƒ® ; exact ha Ôƒ®;
        obtain Ôƒ¿ l, hl_pos, hl_le, hl Ôƒ® := h S' ( by simpa [ hS' ] using hS_nonempty ) ; use l; simp_all +decide [ Finset.sum_image ] ;
        linarith

/-
For any m, there exists a length L and vectors f_0, ..., f_{m-1} such that any non-empty subset sum of f_i's is realizable as a prefix sum of the valuation vector sequence starting at N+1, with positive length.
-/
lemma exists_rich_block (k : Ôäò) (p : Fin k ÔåÆ Ôäò) (hp : ÔêÇ i, (p i).Prime) (N : Ôäò) (m : Ôäò) :
  Ôêâ (L : Ôäò) (f : Fin m ÔåÆ Fin k ÔåÆ ZMod 2),
    ÔêÇ (S : Finset (Fin m)), S.Nonempty ÔåÆ Ôêâ (l : Ôäò), 0 < l Ôêº l Ôëñ L Ôêº Ôêæ i Ôêê Finset.range l, val_vec k p (N + 1 + i) = Ôêæ i Ôêê S, f i := by
      induction m with
      | zero =>
        exact Ôƒ¿ 0, fun _ => 0, by simp +decide Ôƒ®
      | succ m ih =>
        exact Exists.elim ih fun L hL => Exists.elim ( rich_block_inductive_step k p hp N m L hL.choose hL.choose_spec ) fun L' hL' => Ôƒ¿ L', hL'.choose, hL'.choose_spec Ôƒ®

/-
There are infinitely many n such that n! is divisible by an even power of each of the p_i.
-/
set_option linter.flexible false in
theorem infinitely_many_even_factorial_exponents (k : Ôäò) (p : Fin k ÔåÆ Ôäò) (hp : ÔêÇ i, (p i).Prime) (h_distinct : Function.Injective p) :
  Set.Infinite { n | ÔêÇ i, partial_sum k p n i = 0 } := by
    -- By induction on $N$, we can construct an infinite sequence of such $n$.
    have h_seq : ÔêÇ N : Ôäò, Ôêâ n > N, ÔêÇ i, (partial_sum k p n i) = 0 := by
      intro N
      induction N with
      | zero =>
        use 1; simp [partial_sum]
      | succ N ih =>
        obtain Ôƒ¿ n, hnÔéü, hnÔéé Ôƒ® := ih;
        obtain Ôƒ¿ L, f, hf Ôƒ® := exists_rich_block k p hp n ( k + 1 );
        obtain Ôƒ¿ S, hSÔéü, hSÔéé Ôƒ® := exists_subset_sum_zero f;
        obtain Ôƒ¿ l, hlÔéü, hlÔéé, hlÔéâ Ôƒ® := hf S hSÔéü;
        refine Ôƒ¿n + l, by linarith, fun i => ?_Ôƒ®
        -- By definition of partial_sum, we have:
        have h_partial_sum : partial_sum k p (n + l) i = partial_sum k p n i + Ôêæ j Ôêê Finset.range l, val_vec k p (n + 1 + j) i := by
          unfold partial_sum val_vec; simp +decide [ add_assoc ] ;
          have h_partial_sum : ÔêÇ m, padicValNat (p i) (Nat.factorial (n + m)) = padicValNat (p i) (Nat.factorial n) + Ôêæ j Ôêê Finset.range m, padicValNat (p i) (n + 1 + j) := by
            intro m; induction m <;> simp_all +decide [ Nat.factorial, Finset.sum_range_succ ] ;
            haveI := Fact.mk ( hp i ) ; rw [ padicValNat.mul ( by positivity ) ( by positivity ) ] ; simp_all +decide [ add_comm, add_left_comm, add_assoc ] ;
          simp_all +decide [ add_assoc ];
        simp_all +decide [ funext_iff ];
    exact Set.infinite_of_forall_exists_gt fun N => by obtain Ôƒ¿ n, hnÔéü, hnÔéé Ôƒ® := h_seq N; exact Ôƒ¿ n, hnÔéé, hnÔéü Ôƒ® ;

#print axioms infinitely_many_even_factorial_exponents
