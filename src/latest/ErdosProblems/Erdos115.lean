lemma perturbed_small_on_nhd (p q : Polynomial ℂ) (r : ℝ)
    (h_small : ∀ z : ℂ, (∃ w ∈ p.roots, ‖z - w‖ < r) → ‖p.eval z‖ < 1 / 2) :
