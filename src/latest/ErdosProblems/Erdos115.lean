/-
The polynomial $f_n(z) = T_n(2^{(1-n)/n}z + 1)$ satisfies $|f_n'(0)| = 2^{(1/n)-1}n^2$.
-/
noncomputable def extremal_polynomial (n : ℕ) : Polynomial ℂ :=
  (Polynomial.Chebyshev.T ℂ n).comp (Polynomial.C ((2 : ℂ) ^ ((1 : ℂ) / n - 1)) * Polynomial.X + 1)

theorem extremal_polynomial_derivative_at_zero (n : ℕ) (hn : n ≠ 0) :
    ‖(extremal_polynomial n).derivative.eval 0‖ = eremenko_bound n := by
  unfold eremenko_bound extremal_polynomial;
  -- Let $q(x) = T_n(x)$.
  set q : Polynomial ℂ := Polynomial.Chebyshev.T ℂ n
  -- Then $T_n'(1) = n^2$.
  have h_q_deriv : Polynomial.eval 1 (Polynomial.derivative q) = n^2 := by
    simpa [q] using (Polynomial.Chebyshev.derivative_T_eval_one (R := ℂ) (n : ℤ))
  norm_num [ Polynomial.derivative_comp, h_q_deriv ];
  norm_num [ Complex.norm_cpow_of_ne_zero, hn ]

/-
Define $f^*$ as the polynomial $\prod (z + |z_k|)$ where $z_k$ are roots of $f$.
-/
noncomputable def polynomial_star (p : Polynomial ℂ) : Polynomial ℂ :=
  (p.roots.map (fun z => Polynomial.X + Polynomial.C (Complex.ofReal ‖z‖))).prod

/-
Prove that $f^*$ is monic.
-/
theorem polynomial_star_monic (p : Polynomial ℂ) : (polynomial_star p).Monic := by
  exact Polynomial.monic_multiset_prod_of_monic _ _ fun x hx => Polynomial.monic_X_add_C _

/-
Prove that $\deg(f^*) = \deg(f)$.
-/
theorem polynomial_star_degree (p : Polynomial ℂ) (hp : p.Monic) : (polynomial_star p).degree = p.degree := by
  rw [ polynomial_star ];
  rw [ Polynomial.degree_multiset_prod ];
  have h_splits : p.Splits := by
    exact IsAlgClosed.splits p;
  erw [ Polynomial.degree_eq_natDegree hp.ne_zero ] ; erw [ Polynomial.splits_iff_card_roots ] at h_splits ; aesop;

/-
Prove that $|f^*(0)| = |f(0)|$.
-/
theorem polynomial_star_eval_zero (p : Polynomial ℂ) (hp : p.Monic) : ‖(polynomial_star p).eval 0‖ = ‖p.eval 0‖ := by
  rw [ show p = Polynomial.C 1 * Multiset.prod ( Multiset.map ( fun z => Polynomial.X - Polynomial.C z ) p.roots ) from ?_ ];
  · unfold polynomial_star; norm_num;
    induction p.roots using Multiset.induction <;> simp_all +decide [ Polynomial.eval_multiset_prod ];
  · convert (IsAlgClosed.splits p).eq_prod_roots_of_monic hp;
    · norm_num;

/-
Prove that $|(f^*)'(0)| \ge |p'(0)|$.
-/
theorem polynomial_star_derivative_eval_zero (p : Polynomial ℂ) (hp : p.Monic) (h0 : p.eval 0 ≠ 0) :
    ‖(polynomial_star p).derivative.eval 0‖ ≥ ‖p.derivative.eval 0‖ := by
      -- By the properties of logarithms and roots, we can express the derivatives in terms of the roots of $p$ and $p^*$.
      have h_deriv : (Polynomial.derivative p).eval 0 = p.eval 0 * ∑ z ∈ p.roots.toFinset, (p.roots.count z) * (1 / (-z)) := by
        -- By definition of polynomial multiplication and the properties of roots, we can express p as a product of its roots.
        have h_factor : p = ∏ z ∈ p.roots.toFinset, (Polynomial.X - Polynomial.C z) ^ (p.roots.count z) := by
          convert (IsAlgClosed.splits p).eq_prod_roots_of_monic hp using 1;
          · simp +decide [ Finset.prod_multiset_map_count ];
        -- Apply the product rule to the factorization of p.
        have h_deriv : Polynomial.derivative p = ∑ z ∈ p.roots.toFinset, (Polynomial.derivative ((Polynomial.X - Polynomial.C z) ^ (p.roots.count z))) * (∏ w ∈ p.roots.toFinset \ {z}, (Polynomial.X - Polynomial.C w) ^ (p.roots.count w)) := by
          conv_lhs => rw [ h_factor ];
          erw [ Polynomial.derivative_prod ];
          simp +decide [ mul_comm, Finset.sdiff_singleton_eq_erase ];
          rfl;
        rw [ h_deriv, Polynomial.eval_finsetSum, Finset.mul_sum ];
        refine Finset.sum_congr rfl fun x hx => ?_;
        rw [ h_factor, Polynomial.eval_prod ];
        rw [ ← h_factor ];
        norm_num [ Polynomial.derivative_pow, Polynomial.eval_prod, Finset.prod_eq_prod_sdiff_singleton_mul hx ];
        rw [ show ( -x ) ^ Polynomial.rootMultiplicity x p = ( -x ) ^ ( Polynomial.rootMultiplicity x p - 1 ) * ( -x ) by rw [ ← pow_succ, Nat.sub_add_cancel ( Nat.succ_le_of_lt ( Nat.pos_of_ne_zero ( by intro h; simp_all +singlePass ) ) ) ] ] ; ring_nf;
        by_cases hx' : x = 0 <;> simp +decide [ hx', mul_assoc, mul_comm x ];
        exact Or.inl fun h => False.elim <| h0 h
      have h_deriv_star : (Polynomial.derivative (polynomial_star p)).eval 0 = (polynomial_star p).eval 0 * ∑ z ∈ p.roots.toFinset, (p.roots.count z) * (1 / (Complex.ofReal ‖z‖)) := by
        -- By definition of $f^*$, we can write its derivative as a sum over its roots.
        have h_deriv_star : (Polynomial.derivative (polynomial_star p)).eval 0 = ∑ z ∈ p.roots.toFinset, (p.roots.count z) * (∏ w ∈ p.roots.toFinset \ {z}, (0 + Complex.ofReal ‖w‖) ^ (p.roots.count w)) * (1 : ℂ) * (0 + Complex.ofReal ‖z‖) ^ (p.roots.count z - 1) := by
          -- Apply the product rule to the derivative of the product of linear factors.
          have h_prod_rule : Polynomial.derivative (Finset.prod p.roots.toFinset (fun z => (Polynomial.X + Polynomial.C (Complex.ofReal ‖z‖)) ^ (p.roots.count z))) = Finset.sum p.roots.toFinset (fun z => Polynomial.derivative ((Polynomial.X + Polynomial.C (Complex.ofReal ‖z‖)) ^ (p.roots.count z)) * Finset.prod (p.roots.toFinset \ {z}) (fun w => (Polynomial.X + Polynomial.C (Complex.ofReal ‖w‖)) ^ (p.roots.count w))) := by
            erw [ Polynomial.derivative_prod ];
            simp +decide [ mul_comm, Finset.sdiff_singleton_eq_erase ];
            rfl;
          convert congr_arg ( Polynomial.eval 0 ) h_prod_rule using 1
          focus
            norm_num [ Polynomial.eval_prod, Polynomial.eval_finsetSum ]
          focus
            ring_nf!
          · unfold polynomial_star ;
            rw [ Finset.prod_multiset_map_count ] ; aesop;
          · simp +decide [ Polynomial.eval_finsetSum, Polynomial.eval_mul, Polynomial.eval_prod, Polynomial.eval_add, Polynomial.eval_X, Polynomial.eval_C, Polynomial.derivative_pow ] ; ring_nf;
            ac_rfl;
        -- By definition of $f^*$, we can write its evaluation at 0 as a product over its roots.
        have h_eval_star : (polynomial_star p).eval 0 = ∏ z ∈ p.roots.toFinset, (Complex.ofReal ‖z‖) ^ (p.roots.count z) := by
          unfold polynomial_star; simp +decide
          simp +decide [ Finset.prod_multiset_map_count ];
          simp +decide [ Polynomial.eval_prod ];
        rw [ h_deriv_star, h_eval_star, Finset.mul_sum _ _ _ ];
        refine Finset.sum_congr rfl fun x hx => ?_ ; by_cases hx' : x = 0 <;> simp_all +decide [ Finset.prod_eq_prod_sdiff_singleton_mul hx ] ; ring_nf;
        cases n : Polynomial.rootMultiplicity x p <;> simp_all +decide [ pow_succ, mul_assoc ];
      -- Since $|(f^*)'(0)| = f^*(0) \sum \frac{1}{|z_k|}$ and $|p'(0)| = |p(0)| \left| \sum \frac{1}{z_k} \right|$, we need to show that $f^*(0) \sum \frac{1}{|z_k|} \ge |p(0)| \left| \sum \frac{1}{z_k} \right|$.
      have h_ineq : ‖(polynomial_star p).eval 0‖ * ∑ z ∈ p.roots.toFinset, (p.roots.count z) * (1 / (‖z‖ : ℝ)) ≥ ‖p.eval 0‖ * ‖∑ z ∈ p.roots.toFinset, (p.roots.count z) * (1 / (-z))‖ := by
        rw [ polynomial_star_eval_zero p hp ];
        gcongr;
        exact calc
          ‖∑ z ∈ p.roots.toFinset, (p.roots.count z : ℂ) * (1 / -z)‖
              ≤ ∑ z ∈ p.roots.toFinset, ‖(p.roots.count z : ℂ) * (1 / -z)‖ := by
                exact norm_sum_le _ _
          _ = ∑ z ∈ p.roots.toFinset, (p.roots.count z) * (1 / (‖z‖ : ℝ)) := by
                apply Finset.sum_congr rfl
                intro z hz
                simp [norm_inv, norm_neg, div_eq_mul_inv]
      simp_all +decide [ mul_comm ];
      convert h_ineq using 2 ; norm_cast ; norm_num [ Finset.sum_mul _ _ _ ];
      exact Finset.sum_nonneg fun _ _ => mul_nonneg ( inv_nonneg.2 ( norm_nonneg _ ) ) ( Nat.cast_nonneg _ )

/-
Prove that $|f^*(-|z|)| \le |p(z)|$ for monic $p$.
-/
theorem polynomial_star_neg_norm_le (p : Polynomial ℂ) (hp : p.Monic) (z : ℂ) :
    ‖(polynomial_star p).eval (-Complex.ofReal ‖z‖)‖ ≤ ‖p.eval z‖ := by
      -- We express both $p(z)$ and $f^*(-|z|)$ as products over the roots of $p$. Since $p$ is monic, $p(z) = \prod_{k} (z - z_k)$.
      have hp_prod : p = Polynomial.C (p.leadingCoeff) * Multiset.prod (Multiset.map (fun r => Polynomial.X - Polynomial.C r) (Polynomial.roots p)) := by
        convert (IsAlgClosed.splits p).eq_prod_roots_of_monic hp ; aesop;
      rw [ hp_prod ] ; norm_num [ hp ] ; ring_nf; (
      induction ( Polynomial.roots p ) using Multiset.induction with
      | empty =>
        norm_num [ polynomial_star ] at *
      | cons r s ih =>
        norm_num [ polynomial_star ] at *
        rw [ Polynomial.roots_mul ] <;> norm_num at *;
        · gcongr;
          rw [← Complex.ofReal_neg, ← Complex.ofReal_add, Complex.norm_real, Real.norm_eq_abs]
          rw [show -‖z‖ + ‖r‖ = -(‖z‖ - ‖r‖) by ring, abs_neg]
          simpa [sub_eq_add_neg] using abs_norm_sub_norm_le z r;
        · exact ⟨ Polynomial.X_sub_C_ne_zero _, fun x hx => Polynomial.X_sub_C_ne_zero _ ⟩);

/-
Prove that a non-constant polynomial has no non-zero local minima of its modulus.
-/
theorem polynomial_no_local_min_nonzero (p : Polynomial ℂ) (z₀ : ℂ) (hp : p.degree ≠ 0) (hz : p.eval z₀ ≠ 0) :
    ¬ IsLocalMin (fun z => ‖p.eval z‖) z₀ := by
      by_contra h;
      -- By the maximum modulus principle, $1/p$ must be constant in a neighborhood of $z_0$.
      have h_const : ∀ᶠ z in nhds z₀, (p.eval z)⁻¹ = (p.eval z₀)⁻¹ := by
        apply_rules [ Complex.eventually_eq_of_isLocalMax_norm ];
        · filter_upwards [ h, p.continuous.continuousAt.eventually_ne hz ] with z hz₁ hz₂ using DifferentiableAt.inv ( p.differentiableAt ) hz₂;
        · filter_upwards [ h ] with x hx using by simpa [ hz ] using inv_anti₀ ( norm_pos_iff.mpr hz ) hx;
      -- Since $p$ is a polynomial, it is equal to its Taylor series expansion.
      have h_poly_eq_taylor : p = Polynomial.C (p.eval z₀) := by
        have h_poly_eq_taylor : Set.Infinite {z : ℂ | p.eval z = p.eval z₀} := by
          have h_poly_eq_taylor : ∀ᶠ z in nhds z₀, p.eval z = p.eval z₀ := by
            filter_upwards [ h_const ] with z hz using inv_injective <| by aesop;
          rw [ Metric.eventually_nhds_iff ] at h_poly_eq_taylor;
          obtain ⟨ ε, ε_pos, hε ⟩ := h_poly_eq_taylor;
          have h_poly_eq_taylor : Set.Infinite (Set.image (fun t : ℝ => z₀ + t * Complex.I) (Set.Ioo 0 ε)) := by
            exact Set.Infinite.image ( fun t => by simp +decide [ Complex.ext_iff ] ) ( Set.Ioo_infinite ε_pos );
          exact h_poly_eq_taylor.mono fun x hx => by obtain ⟨ t, ht, rfl ⟩ := hx; exact hε <| by simpa [ abs_of_pos ht.1 ] using ht.2;
        exact Classical.not_not.1 fun h => h_poly_eq_taylor <| Set.Finite.subset ( p - Polynomial.C ( Polynomial.eval z₀ p ) |> Polynomial.roots |> Multiset.toFinset |> Finset.finite_toSet ) fun x hx => by simp_all +decide [ sub_eq_iff_eq_add ] ;
      rw [ h_poly_eq_taylor ] at hp ; rw [ Polynomial.degree_C ] at hp <;> simp_all +singlePass

/-
A polynomial is RealRootedNonpositive if all its roots are real and non-positive.
-/
def RealRootedNonpositive (p : Polynomial ℂ) : Prop :=
  ∀ z ∈ p.roots, z.im = 0 ∧ z.re ≤ 0

/-
The polynomial $f^*$ has roots $-|z_k|$, which are non-positive reals.
-/
theorem polynomial_star_roots_nonpositive (p : Polynomial ℂ) :
    RealRootedNonpositive (polynomial_star p) := by
      intro z hz; rw [ polynomial_star ] at hz; simp_all +decide
      simp_all +decide [ Polynomial.eval_multiset_prod, Multiset.prod_eq_zero_iff, add_eq_zero_iff_eq_neg ];
      aesop

/-
The minimum modulus of a polynomial $p$ on the circle of radius $r$.
-/
noncomputable def min_modulus (p : Polynomial ℂ) (r : ℝ) : ℝ :=
  sInf ((fun z => ‖p.eval z‖) '' {z | ‖z‖ = r})

/-
If the level set $\{z : |p(z)| \le 1\}$ is connected and contains 0, then for any $r$ between 0 and the maximum modulus of the roots, the minimum modulus of $p$ on the circle $|z|=r$ is at most 1.
-/
theorem min_modulus_le_one_of_connected (p : Polynomial ℂ)
    (h_zero : ‖p.eval 0‖ ≤ 1)
    (h_conn : IsConnected {z | ‖p.eval z‖ ≤ 1}) (r : ℝ) (hr : 0 ≤ r)
    (hr_le : r ≤ (p.roots.toFinset.image (fun z => ‖z‖)).max.getD 0) :
    min_modulus p r ≤ 1 := by
      by_contra! h_contra;
      -- If there's a circle of radius $r$ where $|p(z)| > 1$, then $E_f$ (the level set) is contained in the open disk $|z| < r$.
      have h_Ef_subset_disk : {z : ℂ | ‖p.eval z‖ ≤ 1} ⊆ {z : ℂ | ‖z‖ < r} := by
        intro z hz
        by_cases hz_r : ‖z‖ ≥ r;
        · -- Since $E_f$ is connected and contains $0$, it must intersect the circle $|z|=r$.
          have h_intersect : ∃ w : ℂ, ‖w‖ = r ∧ ‖p.eval w‖ ≤ 1 := by
            have h_intersect : IsConnected (Set.image (fun z => ‖z‖) {z : ℂ | ‖p.eval z‖ ≤ 1}) := by
              exact h_conn.image _ ( continuous_norm.continuousOn );
            have := h_intersect.Icc_subset ( Set.mem_image_of_mem _ <| show 0 ∈ { z : ℂ | ‖Polynomial.eval z p‖ ≤ 1 } from by simpa using h_zero ) ( Set.mem_image_of_mem _ hz );
            exact this ⟨ by simpa using hr, hz_r ⟩ |> fun ⟨ w, hw₁, hw₂ ⟩ => ⟨ w, hw₂, hw₁ ⟩;
          exact False.elim <| h_contra.not_ge <| le_trans ( csInf_le ⟨ 0, Set.forall_mem_image.2 fun x hx => norm_nonneg _ ⟩ ⟨ h_intersect.choose, h_intersect.choose_spec.1, rfl ⟩ ) h_intersect.choose_spec.2;
        · exact lt_of_not_ge hz_r;
      -- But $E_f$ contains roots (where $p(z)=0$), so $r$ must be greater than the maximum modulus of the roots.
      obtain ⟨z, hz⟩ : ∃ z ∈ p.roots, r ≤ ‖z‖ := by
        rcases h : Finset.max ( Finset.image ( fun z => ‖z‖ ) p.roots.toFinset ) with ( _ | ⟨ x, hx ⟩ ) <;> simp_all +decide [ Option.getD ];
        · exact absurd ( h_Ef_subset_disk 0 h_zero ) ( by norm_num; linarith );
        · have := Finset.mem_of_max h; aesop;
      exact not_lt_of_ge hz.2 <| h_Ef_subset_disk <| by aesop;

/-
For any $r \ge 0$, $|p^*(-r)| \le \min_{|z|=r} |p(z)|$.
-/
theorem polynomial_star_neg_r_le_min_modulus (p : Polynomial ℂ) (hp : p.Monic) (r : ℝ) (hr : 0 ≤ r) :
    ‖(polynomial_star p).eval (-r : ℂ)‖ ≤ min_modulus p r := by
      apply le_csInf
      focus
        exact ⟨ _, ⟨ r, by norm_num [ hr ], rfl ⟩ ⟩
      simp +zetaDelta at *;
      intro z hz; have := polynomial_star_neg_norm_le p hp z; aesop;

/-
The segment $[- \max |z_k|, 0]$ is contained in the level set $\{z : |p^*(z)| \le 1\}$.
-/
theorem polynomial_star_segment_subset_level_set (p : Polynomial ℂ) (hp : p.Monic)
    (h_zero : ‖p.eval 0‖ ≤ 1)
    (h_conn : IsConnected {z | ‖p.eval z‖ ≤ 1}) :
    let max_root := (p.roots.toFinset.image (fun z => ‖z‖)).max.getD 0
    ∀ x ∈ Set.Icc (-max_root) 0, (x : ℂ) ∈ {z | ‖(polynomial_star p).eval z‖ ≤ 1} := by
      intro max_root x hx
      have h_min_modulus_r : min_modulus p (-x) ≤ 1 := by
        apply min_modulus_le_one_of_connected p h_zero h_conn (-x) (by
        linarith [ hx.1, hx.2 ]) (by
        linarith [ hx.1, hx.2 ]);
      convert polynomial_star_neg_r_le_min_modulus p hp _ _ |> le_trans <| h_min_modulus_r using 1 <;> aesop;

/-
The boundary of a connected component of the level set $\{z : |p(z)| \le 1\}$ is contained in the set $\{z : |p(z)| = 1\}$.
-/
theorem boundary_component_subset_boundary_level_set (p : Polynomial ℂ) (z : ℂ) :
    frontier (connectedComponentIn {w | ‖p.eval w‖ ≤ 1} z) ⊆ {w | ‖p.eval w‖ = 1} := by
      intro w hw
      have h_boundary : w ∈ closure {w | ‖p.eval w‖ ≤ 1} ∧ w∉ interior {w | ‖p.eval w‖ ≤ 1} := by
        field_simp;
        refine ⟨ hw.1 |> fun h => closure_mono ( connectedComponentIn_subset _ _ ) h, fun h => hw.2 <| ?_ ⟩;
        rw [ mem_interior_iff_mem_nhds, Metric.mem_nhds_iff ] at *;
        obtain ⟨ ε, ε_pos, hε ⟩ := h; use ε, ε_pos; intro x hx; exact (by
        have h_connected : IsConnected (Metric.ball w ε ∪ connectedComponentIn {w | ‖p.eval w‖ ≤ 1} z) := by
          apply_rules [ IsConnected.union, isConnected_Ioo ];
          · have h_inter : w ∈ closure (connectedComponentIn {w | ‖p.eval w‖ ≤ 1} z) := by
              exact hw.1;
            rw [ mem_closure_iff_nhds ] at h_inter;
            exact h_inter _ ( Metric.ball_mem_nhds _ ε_pos );
          · exact ⟨ Metric.nonempty_ball.mpr ε_pos, convex_ball _ _ |> Convex.isPreconnected ⟩;
          · refine ⟨ ?_, ?_ ⟩;
            · contrapose! hw; aesop;
            · exact isPreconnected_connectedComponentIn;
        have h_subset : Metric.ball w ε ∪ connectedComponentIn {w | ‖p.eval w‖ ≤ 1} z ⊆ connectedComponentIn {w | ‖p.eval w‖ ≤ 1} z := by
          apply_rules [ IsPreconnected.subset_connectedComponentIn ];
          · exact h_connected.isPreconnected;
          · exact Or.inr <| mem_connectedComponentIn <| by
              contrapose! hw; simp_all +decide [ frontier_eq_closure_inter_closure ] ;
              rw [ connectedComponentIn_eq_empty ] <;> aesop;
          · exact Set.union_subset hε ( connectedComponentIn_subset _ _ );
        exact h_subset <| Set.mem_union_left _ hx);
      rw [ mem_closure_iff_seq_limit ] at h_boundary;
      -- If $|p(w)| < 1$, then there exists a neighborhood around $w$ where $|p(z)| < 1$.
      by_cases h : ‖p.eval w‖ < 1;
      · exact False.elim <| h_boundary.2 <| mem_interior_iff_mem_nhds.mpr <| Filter.mem_of_superset ( p.continuous.norm.continuousAt.eventually ( gt_mem_nhds h ) ) fun x hx => hx.out.le;
      · exact le_antisymm ( by rcases h_boundary.1 with ⟨ x, hx, hx' ⟩ ; exact le_of_tendsto' ( Filter.Tendsto.norm ( p.continuous.continuousAt.tendsto.comp hx' ) ) fun n => hx n ) ( not_lt.mp h )

/-
If $w$ is a minimum of $|p|$ on a component $K$ and $|p(w)| < 1$, then $w$ is a local minimum of $|p|$ in $\mathbb{C}$.
-/
theorem minimum_on_component_lt_one_implies_local_min (p : Polynomial ℂ) (z : ℂ)
    (K : Set ℂ) (hK : K = connectedComponentIn {z | ‖p.eval z‖ ≤ 1} z)
    (w : ℂ) (hw : w ∈ K) (h_min : ∀ u ∈ K, ‖p.eval w‖ ≤ ‖p.eval u‖)
    (h_lt : ‖p.eval w‖ < 1) :
    IsLocalMin (fun z => ‖p.eval z‖) w := by
      -- Since $|p(w)| < 1$, there exists a neighborhood $U$ of $w$ such that $|p(z)| < 1$ for all $z \in U$.
      obtain ⟨U, hU⟩ : ∃ U ∈ nhds w, ∀ z ∈ U, ‖p.eval z‖ < 1 := by
        exact ⟨ { z | ‖p.eval z‖ < 1 }, IsOpen.mem_nhds ( isOpen_lt ( p.continuous.norm ) continuous_const ) h_lt, fun z hz => hz ⟩;
      -- Since $U$ is a neighborhood of $w$ and $|p(z)| < 1$ for all $z \in U$, the connected component of $w$ in $|p(z)| < 1$ is contained in $K$.
      have h_connected_subset : connectedComponentIn {z | ‖p.eval z‖ < 1} w ⊆ K := by
        field_simp;
        have h_connected_subset : connectedComponentIn {z | ‖p.eval z‖ < 1} w ⊆ connectedComponentIn {z | ‖p.eval z‖ ≤ 1} w := by
          apply_rules [ connectedComponentIn_mono ] ; exact fun x hx => hx.out.le;
        convert h_connected_subset using 1;
        rw [ hK, connectedComponentIn_eq ];
        exact hK ▸ hw;
      -- Since $connectedComponentIn {z | ‖p.eval z‖ < 1} w$ is open, it is a neighborhood of $w$.
      have h_open : IsOpen (connectedComponentIn {z | ‖p.eval z‖ < 1} w) := by
        apply_rules [ IsOpen.connectedComponentIn ];
        exact isOpen_lt ( p.continuous.norm ) continuous_const;
      exact Filter.eventually_of_mem ( h_open.mem_nhds <| mem_connectedComponentIn <| by aesop ) fun x hx => h_min x <| h_connected_subset hx

/-
If $p$ is a non-constant polynomial and $p(z) \ne 0$, there exists a direction $v$ such that $|p(z+tv)| < |p(z)|$ for small $t > 0$.
-/
theorem exists_decreasing_path_near_point (p : Polynomial ℂ) (hp_deg : p.degree ≠ 0) (z : ℂ) (hz : p.eval z ≠ 0) :
    ∃ v : ℂ, ∃ δ : ℝ, δ > 0 ∧ ∀ t : ℝ, t ∈ Set.Ioo 0 δ → ‖p.eval (z + t • v)‖ < ‖p.eval z‖ := by
      by_contra! h_contra;
      -- Let $q(x) = p(z+x)$, then $q(0) = p(z) \neq 0$.
      set q : Polynomial ℂ := p.comp (Polynomial.X + Polynomial.C z) with hq
      have hq0 : q.eval 0 = p.eval z := by
        aesop
      have hq_nonconst : q.degree ≠ 0 := by
        rw [ hq, Polynomial.degree_eq_natDegree ] at * <;> norm_num [ Polynomial.natDegree_comp, Polynomial.natDegree_add_eq_left_of_natDegree_lt ] at *
        focus
          aesop
        · aesop_cat;
        · rw [ Polynomial.comp_eq_zero_iff ] ; aesop;
      -- Let $q(x) = a_0 + a_k x^k + x^{k+1} r(x)$ where $a_k \neq 0$ and $k \geq 1$.
      obtain ⟨k, hk⟩ : ∃ k : ℕ, k ≥ 1 ∧ ∃ a_k : ℂ, a_k ≠ 0 ∧ ∃ r : Polynomial ℂ, q = Polynomial.C (q.eval 0) + Polynomial.C a_k * Polynomial.X^k + Polynomial.X^(k+1) * r := by
        -- Let $k$ be the smallest index such that $a_k \neq 0$.
        obtain ⟨k, hk⟩ : ∃ k : ℕ, k ≥ 1 ∧ Polynomial.coeff (q - Polynomial.C (q.eval 0)) k ≠ 0 ∧ ∀ j < k, j ≥ 1 → Polynomial.coeff (q - Polynomial.C (q.eval 0)) j = 0 := by
          have h_coeff : ∃ k : ℕ, k ≥ 1 ∧ Polynomial.coeff (q - Polynomial.C (q.eval 0)) k ≠ 0 := by
            by_cases h_const : q - Polynomial.C (q.eval 0) = 0;
            · rw [ sub_eq_zero ] at h_const;
              rw [ h_const ] at hq_nonconst ; rw [ Polynomial.degree_C ] at hq_nonconst <;> norm_num at hq_nonconst ; aesop ( simp_config := { singlePass := true } ) ;
            · obtain ⟨k, hk⟩ : ∃ k : ℕ, Polynomial.coeff (q - Polynomial.C (q.eval 0)) k ≠ 0 := by
                exact not_forall.mp fun h => h_const <| Polynomial.ext h;
              by_cases hk_zero : k = 0;
              · simp_all +decide [ Polynomial.coeff_zero_eq_eval_zero ];
              · exact ⟨ k, Nat.pos_of_ne_zero hk_zero, hk ⟩;
          exact ⟨ Nat.find h_coeff, Nat.find_spec h_coeff |>.1, Nat.find_spec h_coeff |>.2, by aesop ⟩;
        -- Let $r(x)$ be the polynomial such that $q(x) - a_0 - a_k x^k = x^{k+1} r(x)$.
        obtain ⟨r, hr⟩ : ∃ r : Polynomial ℂ, q - Polynomial.C (q.eval 0) - Polynomial.C (Polynomial.coeff (q - Polynomial.C (q.eval 0)) k) * Polynomial.X^k = Polynomial.X^(k+1) * r := by
          have h_div : Polynomial.X^(k+1) ∣ (q - Polynomial.C (q.eval 0) - Polynomial.C (Polynomial.coeff (q - Polynomial.C (q.eval 0)) k) * Polynomial.X^k) := by
            have h_div : ∀ j < k + 1, Polynomial.coeff (q - Polynomial.C (q.eval 0) - Polynomial.C (Polynomial.coeff (q - Polynomial.C (q.eval 0)) k) * Polynomial.X^k) j = 0 := by
              intro j hj; rcases lt_trichotomy j k with hj' | rfl | hj' <;> simp_all +decide
              · by_cases hj'' : 1 ≤ j <;> simp_all +decide [ Polynomial.coeff_C, Polynomial.coeff_X_pow, sub_mul ];
                · grind +ring;
                · simp +decide [ Polynomial.coeff_zero_eq_eval_zero ];
                  grind +ring;
              · simp +decide [ sub_mul, Polynomial.coeff_C, Polynomial.coeff_X_pow ];
              · linarith
            rw [ Polynomial.X_pow_dvd_iff ] ; aesop ( simp_config := { singlePass := true } ) ;
          exact h_div;
        exact ⟨ k, hk.1, Polynomial.coeff ( q - Polynomial.C ( Polynomial.eval 0 q ) ) k, hk.2.1, r, by linear_combination' hr ⟩;
      -- Choose $v$ such that $a_k v^k = -a_0$. This is possible since $a_k \neq 0$ and $a_0 \neq 0$.
      obtain ⟨a_k, ha_k_ne_zero, r, hr⟩ := hk.right
      obtain ⟨v, hv⟩ : ∃ v : ℂ, a_k * v^k = -q.eval 0 := by
        exact ⟨ ( -q.eval 0 / a_k ) ^ ( 1 / k : ℂ ), by rw [ mul_comm ] ; rw [ ← Complex.cpow_nat_mul ] ; norm_num [ show k ≠ 0 by linarith, ha_k_ne_zero ] ⟩;
      -- Then $q(tv) = a_0 + a_k t^k v^k + t^{k+1} v^{k+1} r(tv) = a_0 - a_0 t^k + t^{k+1} v^{k+1} r(tv) = a_0 (1 - t^k + t^{k+1} O(1))$.
      have hq_tv : ∀ t : ℝ, q.eval (t * v) = q.eval 0 * (1 - t^k + t^(k+1) * (r.eval (t * v) * v^(k+1) / q.eval 0)) := by
        intro t; replace hr := congr_arg ( Polynomial.eval ( t * v ) ) hr; norm_num [ hv, hq0 ] at hr ⊢; ring_nf at *; simp +decide [ hz, mul_assoc, mul_comm, mul_left_comm ] at hr ⊢;
        grind +ring;
      -- For small $t$, $|1 - t^k + t^{k+1} O(1)| \le 1 - t^k + C t^{k+1}$.
      have h_bound : ∃ C > 0, ∀ t : ℝ, 0 < t ∧ t < 1 → ‖1 - t^k + t^(k+1) * (r.eval (t * v) * v^(k+1) / q.eval 0)‖ ≤ 1 - t^k + C * t^(k+1) := by
        -- Since $r$ is a polynomial, $r(t * v)$ is bounded for $t$ in $[0, 1]$.
        have h_r_bound : ∃ C > 0, ∀ t : ℝ, 0 ≤ t ∧ t ≤ 1 → ‖r.eval (t * v) * v^(k+1) / q.eval 0‖ ≤ C := by
          have h_r_bound : ContinuousOn (fun t : ℝ => r.eval (t * v) * v^(k+1) / q.eval 0) (Set.Icc 0 1) := by
            fun_prop (disch := norm_num);
          obtain ⟨ C, hC ⟩ := IsCompact.exists_bound_of_continuousOn ( CompactIccSpace.isCompact_Icc ) h_r_bound; use Max.max C 1; norm_num;
          exact fun t ht₁ ht₂ => Or.inl <| by simpa [ norm_div, norm_mul ] using hC t ⟨ ht₁, ht₂ ⟩ ;
        obtain ⟨ C, hC₀, hC ⟩ := h_r_bound; use C; refine ⟨ hC₀, fun t ht => ?_ ⟩ ; rw [ add_comm ] ; norm_cast; norm_num;
        refine le_trans ( norm_add_le _ _ ) ?_ ; norm_cast ; norm_num [ abs_of_nonneg, ht.1.le, ht.2.le ];
        rw [ abs_of_nonneg ( sub_nonneg_of_le ( pow_le_one₀ ht.1.le ht.2.le ) ) ] ; have := hC t ⟨ ht.1.le, ht.2.le ⟩ ; norm_num at * ; nlinarith [ pow_pos ht.1 ( k + 1 ) ] ;
      -- Choose $\delta > 0$ such that for all $t \in (0, \delta)$, $1 - t^k + C t^{k+1} < 1$.
      obtain ⟨C, hC_pos, hC_bound⟩ := h_bound
      obtain ⟨δ, hδ_pos, hδ⟩ : ∃ δ > 0, ∀ t : ℝ, 0 < t ∧ t < δ → 1 - t^k + C * t^(k+1) < 1 := by
        norm_num [ pow_succ' ] at *;
        exact ⟨ 1 / ( C + 1 ), by positivity, fun t ht₁ ht₂ => by nlinarith [ pow_pos ht₁ k, mul_div_cancel₀ 1 ( by positivity : ( C + 1 ) ≠ 0 ), mul_lt_mul_of_pos_right ht₂ ( pow_pos ht₁ k ) ] ⟩;
      -- Choose $t \in (0, \min(1, \delta))$.
      obtain ⟨t, ht_pos, ht_lt⟩ : ∃ t : ℝ, 0 < t ∧ t < min 1 δ ∧ ‖Polynomial.eval (z + t • v) p‖ ≥ ‖Polynomial.eval z p‖ := by
        exact Exists.elim ( h_contra v ( Min.min 1 δ ) ( lt_min zero_lt_one hδ_pos ) ) fun t ht => ⟨ t, ht.1.1, ht.1.2, ht.2 ⟩;
      -- Then $|q(tv)| = |a_0| |1 - t^k + t^{k+1} O(1)| \le |a_0| (1 - t^k + C t^{k+1}) < |a_0|$.
      have hq_tv_lt : ‖q.eval (t * v)‖ < ‖q.eval 0‖ := by
        rw [ hq_tv t ];
        norm_num +zetaDelta at *;
        exact mul_lt_of_lt_one_right ( norm_pos_iff.mpr hz ) ( lt_of_le_of_lt ( hC_bound t ht_pos ht_lt.1.1 ) ( hδ t ht_pos ht_lt.1.2 ) );
      norm_num +zetaDelta at *;
      exact hq_tv_lt.not_ge ( by simpa only [ add_comm ] using ht_lt.2 )

/-
If the modulus of a polynomial is 1 on a connected component of its level set (containing a point $z$), then the polynomial is constant.
-/
theorem modulus_eq_one_on_component_implies_const (p : Polynomial ℂ) (z : ℂ)
    (hz : ‖p.eval z‖ ≤ 1)
    (K : Set ℂ) (hK : K = connectedComponentIn {z | ‖p.eval z‖ ≤ 1} z)
    (h_mod : ∀ w ∈ K, ‖p.eval w‖ = 1) :
    ∃ c : ℂ, p = Polynomial.C c := by
      by_contra h_nonconst;
      -- By `exists_decreasing_path_near_point`, there exists $v$ and $\delta > 0$ such that for $t \in (0, \delta)$, $|p(z+tv)| < |p(z)| = 1$.
      obtain ⟨v, δ, hδ_pos, hδ⟩ : ∃ v : ℂ, ∃ δ : ℝ, δ > 0 ∧ ∀ t : ℝ, t ∈ Set.Ioo 0 δ → ‖p.eval (z + t • v)‖ < 1 := by
        have := exists_decreasing_path_near_point p ?_ z ?_ <;> simp_all +decide
        · exact ⟨ this.choose, this.choose_spec.choose, this.choose_spec.choose_spec.1, fun t ht₁ ht₂ => lt_of_lt_of_le ( this.choose_spec.choose_spec.2 t ht₁ ht₂ ) hz ⟩;
        · exact fun h => h_nonconst _ <| Polynomial.eq_C_of_degree_eq_zero h;
        · intro h; specialize h_mod z; simp_all +decide ;
          exact h_mod <| mem_connectedComponentIn ( by aesop );
      -- Let $\gamma(t) = z + t v$.
      set γ : ℝ → ℂ := fun t => z + t • v;
      have hγ_cont : Continuous γ := by
        change Continuous (fun t : ℝ => z + (t : ℂ) * v)
        fun_prop
      have hγ_image_subset : Set.image γ (Set.Icc 0 (δ / 2)) ⊆ {z | ‖p.eval z‖ ≤ 1} := by
        intro w hw
        obtain ⟨t, ht₁, ht₂⟩ := hw
        by_cases ht_zero : t = 0;
        · aesop;
        · exact ht₂ ▸ le_of_lt ( hδ t ⟨ lt_of_le_of_ne ht₁.1 ( Ne.symm ht_zero ), by linarith [ ht₁.2 ] ⟩ );
      have hγ_image_connected : IsConnected (Set.image γ (Set.Icc 0 (δ / 2))) := by
        exact ⟨ Set.Nonempty.image _ ⟨ 0, Set.left_mem_Icc.mpr <| by linarith ⟩, isPreconnected_Icc.image _ hγ_cont.continuousOn ⟩;
      have hγ_image_subset_K : Set.image γ (Set.Icc 0 (δ / 2)) ⊆ K := by
        rw [hK];
        apply_rules [ IsPreconnected.subset_connectedComponentIn ];
        · exact hγ_image_connected.isPreconnected;
        · exact ⟨ 0, ⟨ by norm_num, by linarith ⟩, by norm_num [ γ ] ⟩;
      exact absurd ( h_mod ( γ ( δ / 4 ) ) ( hγ_image_subset_K ( Set.mem_image_of_mem _ ( by constructor <;> linarith ) ) ) ) ( by linarith [ hδ ( δ / 4 ) ⟨ by linarith, by linarith ⟩ ] )

/-
The coefficients of the polynomial $f^*$ are real.
-/
theorem polynomial_star_coeff_real (p : Polynomial ℂ) (n : ℕ) :
    ((polynomial_star p).coeff n).im = 0 := by
      unfold polynomial_star;
      induction p.roots using Multiset.induction generalizing n with
      | empty =>
        simp_all +decide
        cases n <;> norm_num [ Polynomial.coeff_one ];
      | cons r s ih =>
        simp_all +decide
        rcases n <;> simp_all +decide [ add_mul ]

/-
The roots of the derivative of $f^*$ are real and non-positive.
-/
theorem polynomial_star_derivative_roots_nonpositive (p : Polynomial ℂ) :
    RealRootedNonpositive (polynomial_star p).derivative := by
      intro z hz;
      -- By the properties of the derivative and the fact that $f^*$ is monic, the roots of the derivative are contained in the convex hull of the roots of the polynomial.
      have h_convex_hull : ∀ z : ℂ, z ∈ (Polynomial.derivative (polynomial_star p)).roots → z ∈ (convexHull ℝ) (Multiset.toFinset (Polynomial.roots (polynomial_star p))) := by
        have h_convex_hull : ∀ p : Polynomial ℂ, p ≠ 0 → ∀ z : ℂ, z ∈ (Polynomial.derivative p).roots → z ∈ (convexHull ℝ) (Multiset.toFinset (Polynomial.roots p)) := by
          intros p hp z hz;
          by_cases h : z ∈ p.roots.toFinset <;> simp_all +decide
          · exact subset_convexHull ℝ _ ( by aesop );
          · -- Since $z$ is a root of the derivative of $p$, we have $p'(z) = 0$. By the properties of polynomials, this implies that $z$ is a root of $p$ or a root of $p$ with multiplicity greater than 1.
            have h_root : ∑ w ∈ p.roots.toFinset, (Polynomial.rootMultiplicity w p) * (z - w)⁻¹ = 0 := by
              have h_root : p.derivative.eval z = p.eval z * ∑ w ∈ p.roots.toFinset, (Polynomial.rootMultiplicity w p) * (z - w)⁻¹ := by
                have h_root : p = Polynomial.C (p.leadingCoeff) * ∏ w ∈ p.roots.toFinset, (Polynomial.X - Polynomial.C w) ^ (Polynomial.rootMultiplicity w p) := by
                  convert (IsAlgClosed.splits p).eq_prod_roots;
                  · simp +decide [ Finset.prod_multiset_map_count ];
                rw [ h_root ] ; norm_num [ Polynomial.eval_prod, Polynomial.eval_finsetSum ] ; ring_nf;
                have h_root : ∀ {S : Finset ℂ} {f : ℂ → ℕ}, (∀ w ∈ S, z ≠ w) → Polynomial.eval z (Polynomial.derivative (∏ w ∈ S, (Polynomial.X - Polynomial.C w) ^ (f w))) = (∏ w ∈ S, (z - w) ^ (f w)) * ∑ w ∈ S, (f w) * (z - w)⁻¹ := by
                  intros S f hf
                  induction S using Finset.induction with
                  | empty =>
                    simp +decide
                  | insert w S hwS ih =>
                    ring_nf
                    simp +decide [ Finset.prod_insert hwS, Polynomial.derivative_pow, Polynomial.derivative_mul, Polynomial.eval_prod, ih fun x hx => hf x <| Finset.mem_insert_of_mem hx ] ; ring_nf;
                    rcases k : f w with ( _ | k ) <;> simp +decide [ k, pow_succ, mul_assoc, mul_comm, Finset.sum_insert hwS ] ; ring_nf;
                    grind;
                rw [ h_root ];
                · rw [ ← ‹p = Polynomial.C p.leadingCoeff * ∏ w ∈ p.roots.toFinset, ( Polynomial.X - Polynomial.C w ) ^ Polynomial.rootMultiplicity w p› ] ; ring;
                · exact fun w hw => by rintro rfl; exact h <| Polynomial.isRoot_of_mem_roots <| Multiset.mem_toFinset.mp hw;
              aesop;
            -- Since $z$ is a root of the derivative of $p$, we have $p'(z) = 0$. By the properties of polynomials, this implies that $z$ is a root of $p$ or a root of $p$ with multiplicity greater than 1. Therefore, $z$ must be in the convex hull of the roots of $p$.
            have h_convex_hull : ∑ w ∈ p.roots.toFinset, (Polynomial.rootMultiplicity w p) * (1 / ‖z - w‖ ^ 2) * (z - w) = 0 := by
              convert congr_arg Star.star h_root using 1 <;> norm_num [ Complex.ext_iff, sq ];
              norm_num [ Complex.normSq, Complex.norm_def ] ; ring_nf ; norm_num;
              exact ⟨ by rw [ ← Finset.sum_sub_distrib, ← Finset.sum_sub_distrib ] ; exact Finset.sum_congr rfl fun _ _ => by rw [ Real.sq_sqrt ( by nlinarith [ sq_nonneg ( z.re - ‹ℂ›.re ), sq_nonneg ( z.im - ‹ℂ›.im ) ] ) ] ; ring, by rw [ ← Finset.sum_sub_distrib, ← Finset.sum_sub_distrib ] ; exact Finset.sum_congr rfl fun _ _ => by rw [ Real.sq_sqrt ( by nlinarith [ sq_nonneg ( z.re - ‹ℂ›.re ), sq_nonneg ( z.im - ‹ℂ›.im ) ] ) ] ; ring ⟩;
            -- Since $z$ is a root of the derivative of $p$, we have $p'(z) = 0$. By the properties of polynomials, this implies that $z$ is a root of $p$ or a root of $p$ with multiplicity greater than 1. Therefore, $z$ must be in the convex hull of the roots of $p$. Hence, we can write $z$ as a convex combination of the roots of $p$.
            have h_convex_combination : ∃ (c : ℂ → ℝ), (∀ w ∈ p.roots.toFinset, 0 ≤ c w) ∧ (∑ w ∈ p.roots.toFinset, c w = 1) ∧ z = ∑ w ∈ p.roots.toFinset, c w • w := by
              refine ⟨ fun w => ( Polynomial.rootMultiplicity w p * ( 1 / ‖z - w‖ ^ 2 ) ) / ( ∑ w ∈ p.roots.toFinset, Polynomial.rootMultiplicity w p * ( 1 / ‖z - w‖ ^ 2 ) ), ?_, ?_, ?_ ⟩ <;> norm_num [ Finset.sum_div _ _ _ ] at *;
              · exact fun _ _ _ => div_nonneg ( mul_nonneg ( Nat.cast_nonneg _ ) ( inv_nonneg.2 ( sq_nonneg _ ) ) ) ( Finset.sum_nonneg fun _ _ => mul_nonneg ( Nat.cast_nonneg _ ) ( inv_nonneg.2 ( sq_nonneg _ ) ) );
              · rw [ ← Finset.sum_div _ _ _, div_self ] ; norm_cast ; contrapose! h ; simp_all +decide [ Finset.sum_eq_zero_iff_of_nonneg, inv_nonneg ] ;
                obtain ⟨ w, hw ⟩ := Complex.exists_root ( show p.degree > 0 from not_le.mp fun h => by rw [ Polynomial.eq_C_of_degree_le_zero h ] at hp hz; aesop ) ; specialize h w hw; simp_all +decide [ sub_eq_iff_eq_add ] ;
              · simp_all +decide [ div_mul_eq_mul_div ];
                rw [ ← Finset.sum_div _ _ _, eq_div_iff ];
                · simp_all +decide [ mul_sub, Finset.mul_sum _ _ _ ];
                  simp_all +decide [ mul_comm, sub_eq_iff_eq_add ];
                · norm_cast ; simp_all +decide [ Finset.sum_eq_zero_iff_of_nonneg]
                  exact Exists.elim ( Complex.exists_root <| show p.degree > 0 from not_le.mp fun h => by rw [ Polynomial.eq_C_of_degree_le_zero h ] at hp hz; aesop ) fun x hx => ⟨ x, hx, sub_ne_zero_of_ne <| by aesop ⟩;
            rw [ convexHull_eq ];
            obtain ⟨ c, hc₁, hc₂, rfl ⟩ := h_convex_combination; exact ⟨ _, _, _, _, hc₁, hc₂, fun w hw => hw, by
              rw [Finset.centerMass, hc₂]
              simp only [inv_one, one_smul] ⟩ ;
        by_cases h : polynomial_star p = 0 <;> aesop;
      -- Since the roots of $f^*$ are real and non-positive, their convex hull is also contained in the interval $(-\infty, 0]$.
      have h_convex_hull_subset : (convexHull ℝ) (Multiset.toFinset (Polynomial.roots (polynomial_star p))) ⊆ {z : ℂ | z.im = 0 ∧ z.re ≤ 0} := by
        refine convexHull_min ?_ ?_;
        · intro z hz;
          have := polynomial_star_roots_nonpositive p z; aesop;
        · exact convex_iff_forall_pos.mpr fun x hx y hy a b ha hb hab =>
            ⟨ by
                have hax : (a • x).im = a * x.im := by
                  simp
                have hby : (b • y).im = b * y.im := by
                  simp
                calc
                  (a • x + b • y).im = (a • x).im + (b • y).im := Complex.add_im _ _
                  _ = a * x.im + b * y.im := by rw [hax, hby]
                  _ = 0 := by rw [hx.1, hy.1]; ring,
              by
                have hax : (a • x).re = a * x.re := by
                  simp
                have hby : (b • y).re = b * y.re := by
                  simp
                calc
                  (a • x + b • y).re = (a • x).re + (b • y).re := Complex.add_re _ _
                  _ = a * x.re + b * y.re := by rw [hax, hby]
                  _ ≤ 0 := by
                    nlinarith [mul_nonpos_of_nonneg_of_nonpos ha.le hx.2,
                      mul_nonpos_of_nonneg_of_nonpos hb.le hy.2] ⟩;
      exact h_convex_hull_subset <| h_convex_hull z hz

/-
The critical points of $f^*$ lie in the segment $[-A, 0]$.
-/
noncomputable def max_root (p : Polynomial ℂ) : ℝ :=
  (p.roots.toFinset.image (fun z => ‖z‖)).max.getD 0

theorem polynomial_star_critical_points_subset_segment (p : Polynomial ℂ) :
    ∀ x ∈ (polynomial_star p).derivative.roots, x.re ∈ Set.Icc (-max_root p) 0 ∧ x.im = 0 := by
      intro x hx
      have h_real : x.im = 0 := by
        have := polynomial_star_derivative_roots_nonpositive p x; aesop;
      have h_nonpos : x.re ≤ 0 := by
        have := polynomial_star_derivative_roots_nonpositive p x hx; aesop;
      have h_bound : -max_root p ≤ x.re := by
        by_contra h_contra;
        -- Since $x$ is a root of the derivative of $f^*$, we have that $(f^*)'(x) = 0$.
        have h_deriv_zero : deriv (fun x : ℝ => Complex.re ((polynomial_star p).eval (x : ℂ))) x.re = 0 := by
          have h_deriv_poly_ne_zero : (polynomial_star p).derivative ≠ 0 := by
            intro hzero
            rw [hzero, Polynomial.roots_zero] at hx
            simp at hx
          have hx_eval : ((polynomial_star p).derivative.eval x) = 0 :=
            (Polynomial.mem_roots h_deriv_poly_ne_zero).mp hx
          have hx_ofReal : (x.re : ℂ) = x := by
            apply Complex.ext <;> simp [h_real]
          have h_has :
              HasDerivAt
                (fun t : ℝ => ((polynomial_star p).eval (t : ℂ)).re)
                (((polynomial_star p).derivative.eval (x.re : ℂ)).re) x.re :=
            ((polynomial_star p).hasDerivAt (x.re : ℂ)).real_of_complex
          rw [h_has.deriv, hx_ofReal, hx_eval]
          norm_num;
        -- By definition of $f^*$, we know that its real part is given by $\prod_{k=1}^n (x + |z_k|)$.
        have h_real_part : ∀ x : ℝ, Complex.re ((polynomial_star p).eval (x : ℂ)) = ∏ z ∈ p.roots.toFinset, (x + ‖z‖) ^ (p.roots.count z) := by
          intro x; unfold polynomial_star; simp +decide
          simp +decide [  Finset.prod_multiset_map_count ];
          simp +decide [ Polynomial.eval_prod ];
          norm_cast;
        -- Since $x.re < -max_root p$, we have $x.re + ‖z‖ < 0$ for all $z \in p.roots.toFinset$.
        have h_neg : ∀ z ∈ p.roots.toFinset, x.re + ‖z‖ < 0 := by
          intros z hz
          have h_norm_le_max : ‖z‖ ≤ max_root p := by
            have h_max_root : ∀ z ∈ p.roots.toFinset, ‖z‖ ≤ (p.roots.toFinset.image (fun z => ‖z‖)).max.getD 0 := by
              intros z hz; exact (by
              have h_max_root : ∀ z ∈ p.roots.toFinset, ‖z‖ ≤ Finset.max (p.roots.toFinset.image (fun z => ‖z‖)) := by
                exact fun z hz => Finset.le_max <| Finset.mem_image_of_mem _ hz;
              specialize h_max_root z hz; cases h : Finset.max ( Finset.image ( fun z => ‖z‖ ) p.roots.toFinset ) <;> aesop;);
            exact h_max_root z hz
          linarith [h_contra];
        -- Since $x.re + ‖z‖ < 0$ for all $z \in p.roots.toFinset$, the product $\prod_{z \in p.roots.toFinset} (x.re + ‖z‖)^{p.roots.count z}$ is negative.
        have h_prod_neg : ∏ z ∈ p.roots.toFinset, (x.re + ‖z‖) ^ (p.roots.count z) ≠ 0 := by
          exact Finset.prod_ne_zero_iff.mpr fun z hz => pow_ne_zero _ <| ne_of_lt <| h_neg z hz;
        have h_prod_neg : deriv (fun x : ℝ => ∏ z ∈ p.roots.toFinset, (x + ‖z‖) ^ (p.roots.count z)) x.re = (∏ z ∈ p.roots.toFinset, (x.re + ‖z‖) ^ (p.roots.count z)) * (∑ z ∈ p.roots.toFinset, (p.roots.count z) / (x.re + ‖z‖)) := by
          have h_prod_neg : ∀ {S : Finset ℂ} {f : ℂ → ℝ → ℝ}, (∀ z ∈ S, DifferentiableAt ℝ (fun x => f z x) x.re) → (∀ z ∈ S, f z x.re ≠ 0) → deriv (fun x => ∏ z ∈ S, f z x) x.re = (∏ z ∈ S, f z x.re) * (∑ z ∈ S, deriv (fun x => f z x) x.re / f z x.re) := by
            intros S f hf_diff hf_ne_zero
            rw [deriv_fun_finsetProd hf_diff]
            rw [Finset.mul_sum]
            apply Finset.sum_congr rfl
            intro z hz
            have hz_ne : f z x.re ≠ 0 := hf_ne_zero z hz
            have hprod :
                (∏ j ∈ S.erase z, f j x.re) =
                  (∏ j ∈ S, f j x.re) / f z x.re := by
              have h := Finset.prod_eq_prod_sdiff_singleton_mul hz (fun j => f j x.re)
              rw [Finset.sdiff_singleton_eq_erase] at h
              rw [h]
              field_simp [hz_ne]
            simp [hprod, div_eq_mul_inv, mul_assoc, mul_comm]
          convert h_prod_neg _ _ using 3 <;> norm_num [ h_neg ];
          · rw [ div_eq_div_iff ] <;> norm_num [ show x.re + ‖‹ℂ›‖ ≠ 0 from by linarith [ h_neg _ ‹_› ] ] ; ring_nf;
            cases n : Polynomial.rootMultiplicity ‹_› p <;> simp_all +decide [ pow_succ, mul_assoc, mul_add, add_mul ] ; ring;
          · exact fun z _ _ h₁ _ => False.elim <| h₁.not_lt <| h_neg z <| by aesop;
        simp_all +decide [ div_eq_mul_inv ];
        exact absurd h_prod_neg <| ne_of_lt <| Finset.sum_neg ( fun z hz => mul_neg_of_pos_of_neg ( Nat.cast_pos.mpr <| Nat.pos_of_ne_zero <| by aesop ) <| inv_lt_zero.mpr <| h_neg z ( by aesop ) <| by aesop ) <| by
          by_cases h_empty : p.roots.toFinset = ∅;
          · simp_all +decide [ polynomial_star ];
          · exact Finset.nonempty_of_ne_empty h_empty;
      exact ⟨⟨h_bound, h_nonpos⟩, h_real⟩

