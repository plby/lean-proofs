    rw [Complex.mul_re]
    have h_im_p : (p.eval (0 : ℂ)).im = 0 := hp_real 0
    have h_im_q : (q.eval (0 : ℂ)).im = 0 := hq_real 0
    rw [h_im_p, h_im_q, mul_zero, sub_zero]
