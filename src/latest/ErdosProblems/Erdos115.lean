              rw [ h_sum_multiplicities, Polynomial.natDegree_eq_of_degree_eq_some hp_deg ];
            simp_all +decide [ Polynomial.degree_prod ];
            exact_mod_cast h_sum_multiplicities;
        exact h_poly_bound.elim fun x hx => hx.2.not_gt <| lt_of_le_of_lt ( h_bound x hx.1 ) <| by exact lt_of_lt_of_le ( by norm_num ) <| mul_le_mul_of_nonneg_left ( pow_le_pow_left₀ ( by linarith ) ( show ( b - a ) / 4 ≥ 1 by linarith ) _ ) zero_le_two;
      -- Therefore, the length of $I$ must be at most 4.
      have hI_length : ∀ a b : ℝ, a < b → (a ∈ Set.image Complex.re S ∧ b ∈ Set.image Complex.re S) → b - a ≤ 4 := by
        intros a b hab h_mem
        by_contra h_contra_length
        have h_interval : ∀ x ∈ Set.Icc a b, ‖(∏ k ∈ p.roots.toFinset, (x - k.re) ^ (p.roots.count k))‖ ≤ 1 := by
          intros x hx
          obtain ⟨z, hzS, hzx⟩ : ∃ z ∈ S, z.re = x := by
            exact hI_connected.Icc_subset h_mem.1 h_mem.2 hx
          have h_prod : ‖(∏ k ∈ p.roots.toFinset, (x - k.re) ^ (p.roots.count k))‖ ≤ ‖p.eval z‖ := by
            have h_prod : p.eval z = ∏ k ∈ p.roots.toFinset, (z - k) ^ (p.roots.count k) := by
              have h_prod : p = ∏ k ∈ p.roots.toFinset, (Polynomial.X - Polynomial.C k) ^ (p.roots.count k) := by
                convert (IsAlgClosed.splits p).eq_prod_roots_of_monic hp_monic;
                · simp +decide [ Finset.prod_multiset_map_count ];
              simpa [ Polynomial.eval_prod ] using congr_arg ( Polynomial.eval z ) h_prod;
            simp_all +decide [ Complex.norm_def, Complex.normSq ];
            exact Finset.prod_le_prod ( fun _ _ => by positivity ) fun _ _ => pow_le_pow_left₀ ( by positivity ) ( Real.abs_le_sqrt <| by nlinarith ) _
          exact le_trans h_prod (by
          exact hzS)
        exact h_contra hab (by linarith) h_interval;
      intro z hz;
      contrapose! hI_length;
      cases abs_cases z.re <;> [ exact ⟨ 0, z.re, by linarith, ⟨ ⟨ 0, by aesop ⟩, ⟨ z, by aesop ⟩ ⟩, by linarith ⟩ ; exact ⟨ z.re, 0, by linarith, ⟨ ⟨ z, by aesop ⟩, ⟨ 0, by aesop ⟩ ⟩, by linarith ⟩ ]

-- proven and Stated by Aristotle
lemma level_set_subset_ball_four {n : ℕ} (hn : n ≠ 0) {p : Polynomial ℂ} (hp_deg : p.degree = n) (hp_monic : p.Monic)
    (h_conn : IsConnected {z | ‖p.eval z‖ ≤ 1}) (h_zero : ‖p.eval 0‖ ≤ 1) :
    ∀ z, ‖p.eval z‖ ≤ 1 → ‖z‖ ≤ 4 := by
      -- Let $z$ be in the level set. If $z=0$, the bound holds. If $z \ne 0$, let $u = z/|z|$. Then $|u|=1$.
      intro z hz
      by_cases hz_zero : z = 0;
      · norm_num [ hz_zero ];
      · -- Let $u = z / ‖z‖$. Then $|u| = 1$.
        set u : ℂ := z / ‖z‖
        have hu : ‖u‖ = 1 := by
          aesop;
        -- Consider the polynomial $q(w) = u^{-n} p(u w)$. $q$ is monic of degree $n$.
        set q : Polynomial ℂ := Polynomial.C (u⁻¹ ^ n) * p.comp (Polynomial.C u * Polynomial.X) with hq_def
        have hq_monic : q.Monic := by
          simp +zetaDelta at *;
          rw [ Polynomial.Monic, Polynomial.leadingCoeff_mul, Polynomial.leadingCoeff_pow, Polynomial.leadingCoeff_C, Polynomial.leadingCoeff_comp ] <;> norm_num [ hn, hz_zero, hp_monic, hp_deg ];
          rw [ Polynomial.natDegree_eq_of_degree_eq_some hp_deg ] ; ring_nf ; aesop;
        have hq_deg : q.degree = n := by
          simp +zetaDelta at *;
          rw [ Polynomial.degree_C, Polynomial.degree_eq_natDegree ] <;> norm_num [ hn, hz_zero ];
          · rw [ Polynomial.natDegree_comp, Polynomial.natDegree_mul' ] <;> norm_num [ Polynomial.natDegree_eq_of_degree_eq_some hp_deg, hz_zero ];
          · rw [ Polynomial.comp_eq_zero_iff ] ; aesop
        have hq_zero : ‖q.eval 0‖ ≤ 1 := by
          aesop
        have hq_conn : IsConnected {w : ℂ | ‖q.eval w‖ ≤ 1} := by
          have hq_conn : IsConnected (Set.image (fun w => u⁻¹ * w) {z | ‖p.eval z‖ ≤ 1}) := by
            exact h_conn.image _ ( continuous_const.mul continuous_id' |> Continuous.continuousOn )
          generalize_proofs at *; (
          convert hq_conn using 1
          generalize_proofs at *; (
          ext w; simp [hq_def];
          constructor <;> intro h <;> simp_all +decide [ mul_comm u ];
          · exact ⟨ w * u, h, by rw [ inv_mul_eq_div, div_eq_iff ( by aesop ) ] ⟩;
          · rcases h with ⟨ x, hx, rfl ⟩ ; simp_all +decide [ mul_comm u⁻¹ ] ;
            rwa [ mul_assoc, inv_mul_cancel₀ ( by aesop ), mul_one ]))
        have hq_eval : ‖q.eval (‖z‖ : ℂ)‖ ≤ 1 := by
          aesop
        have hq_bound : |‖z‖| ≤ 4 := by
          have := real_projection_bound hn hq_deg hq_monic hq_conn hq_zero ( ‖z‖ : ℂ ) ; aesop;
        exact_mod_cast hq_bound.trans' ( le_abs_self _ ) |> le_trans <| by norm_num;

