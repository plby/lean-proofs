    norm_num at *;
    exact ⟨ fun k => Classical.choose ( h_contra ( ( k + 1 : ℝ ) ⁻¹ ) ( by positivity ) ), fun k => ⟨ Classical.choose_spec ( h_contra ( ( k + 1 : ℝ ) ⁻¹ ) ( by positivity ) ) |>.1, Classical.choose_spec ( h_contra ( ( k + 1 : ℝ ) ⁻¹ ) ( by positivity ) ) |>.2.1 ⟩, fun k => Classical.choose_spec ( h_contra ( ( k + 1 : ℝ ) ⁻¹ ) ( by positivity ) ) |>.2.2.choose, fun k => Classical.choose_spec ( h_contra ( ( k + 1 : ℝ ) ⁻¹ ) ( by positivity ) ) |>.2.2.choose_spec.1, fun k z hp hz => Classical.choose_spec ( h_contra ( ( k + 1 : ℝ ) ⁻¹ ) ( by positivity ) ) |>.2.2.choose_spec.2 z hp hz ⟩;
  -- Since $p$ is a monic polynomial of degree $n$, the sequence $w_k$ is bounded.
  have hw_k_bounded : ∃ M : ℝ, ∀ k, ‖w_k k‖ ≤ M := by
    -- Since $p$ is a monic polynomial of degree $n$, the sequence $w_k$ is bounded by the maximum modulus of the roots of $p$.
