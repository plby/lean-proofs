    generalize_proofs at *; (
    by_cases h : p.roots.toFinset.Nonempty <;> simp_all +decide;
    · have h_min_r : ∃ r_min > 0, ∀ w ∈ p.roots.toFinset, r_min ≤ r w := by
        have h_min : ∃ r_min ∈ Finset.image r p.roots.toFinset, ∀ r' ∈ Finset.image r p.roots.toFinset, r_min ≤ r' := by
          exact ⟨ Finset.min' _ ⟨ _, Finset.mem_image_of_mem _ ( Classical.choose_spec ( Multiset.exists_mem_of_ne_zero h ) |> fun x => Multiset.mem_toFinset.mpr x ) ⟩, Finset.min'_mem _ _, fun r' hr' => Finset.min'_le _ _ hr' ⟩
        generalize_proofs at *; (
        obtain ⟨ r_min, hr_min₁, hr_min₂ ⟩ := h_min; use r_min; aesop;)
      generalize_proofs at *; (
      obtain ⟨ r_min, hr_min_pos, hr_min ⟩ := h_min_r; exact ⟨ r_min, hr_min_pos, fun z x hp hq hq' => hr x hp hq |>.2 z <| lt_of_lt_of_le hq' <| hr_min x <| by aesop ⟩ ;);
    · exact ⟨ 1, zero_lt_one ⟩)
  generalize_proofs at *; (
  use r, hr_pos, hr)
