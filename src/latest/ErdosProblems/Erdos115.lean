lemma level_set_upper_semicontinuous_on_valid {n : ℕ} (p : Polynomial ℂ) (hp_deg : p.degree = ↑n) (hn : n ≠ 0) (W : Set ℂ) (hW : IsOpen W) (h_sub : {z | ‖p.eval z‖ ≤ 1} ⊆ W) :
    ∀ᶠ q in nhds p, q.Monic → q.degree = ↑n → {z | ‖q.eval z‖ ≤ 1} ⊆ W := by
      by_contra h_contra;
      -- Choose $R$ such that for $|z| \ge R$, $|p(z)| > 2$.
      obtain ⟨R, hR⟩ : ∃ R : ℝ, ∀ z : ℂ, ‖z‖ ≥ R → ‖p.eval z‖ > 2 := by
        have h_poly_growth : Filter.Tendsto (fun z : ℂ => ‖p.eval z‖) (Filter.comap (fun z : ℂ => ‖z‖) Filter.atTop) Filter.atTop := by
          apply_rules [ Polynomial.tendsto_norm_atTop ];
          · exact hp_deg.symm ▸ Nat.cast_pos.mpr ( Nat.pos_of_ne_zero hn );
          · exact Filter.tendsto_comap;
        have := h_poly_growth.eventually_gt_atTop 2;
        rw [ Filter.eventually_comap ] at this;
        rw [ Filter.eventually_atTop ] at this; rcases this with ⟨ R, hR ⟩ ; exact ⟨ R, fun z hz => hR _ hz _ rfl ⟩ ;
      -- Choose a larger $R$ such that for any monic polynomial $q$ of degree $n$ sufficiently close to $p$, $|q(z)| > 1$ for $|z| \ge R$.
      obtain ⟨R', hR'⟩ : ∃ R' : ℝ, ∀ q : Polynomial ℂ, q.Monic → q.degree = n → (∀ i ∈ Finset.range (n + 1), ‖q.coeff i - p.coeff i‖ < 1) → ∀ z : ℂ, ‖z‖ ≥ R' → ‖q.eval z‖ > 1 := by
        use Max.max R 2 + ∑ i ∈ Finset.range ( n + 1 ), ( ‖p.coeff i‖ + 1 ) + 1;
        intro q hq_monic hq_deg hq_coeff z hz
        have h_eval_bound : ‖q.eval z‖ ≥ ‖z‖^n - ∑ i ∈ Finset.range n, (‖p.coeff i‖ + 1) * ‖z‖^i := by
          have h_eval_bound : ‖q.eval z‖ ≥ ‖z‖^n - ∑ i ∈ Finset.range n, ‖q.coeff i‖ * ‖z‖^i := by
            have h_eval_bound : ‖q.eval z‖ ≥ ‖z^n‖ - ‖∑ i ∈ Finset.range n, q.coeff i * z^i‖ := by
              have h_eval_bound : ‖q.eval z‖ = ‖z^n + ∑ i ∈ Finset.range n, q.coeff i * z^i‖ := by
                rw [ Polynomial.eval_eq_sum_range ];
                rw [ Finset.sum_range_succ_comm, Polynomial.natDegree_eq_of_degree_eq_some hq_deg ];
                rw [ Polynomial.Monic.def, Polynomial.leadingCoeff, Polynomial.natDegree_eq_of_degree_eq_some hq_deg ] at hq_monic ; aesop;
              exact h_eval_bound.symm ▸ by simpa using norm_sub_le ( z ^ n + ∑ i ∈ Finset.range n, q.coeff i * z ^ i ) ( ∑ i ∈ Finset.range n, q.coeff i * z ^ i ) ;
            simpa using h_eval_bound.trans' ( sub_le_sub_left ( norm_sum_le _ _ |> le_trans <| Finset.sum_le_sum fun i hi => by simp +decide ) _ );
          refine le_trans ?_ h_eval_bound;
          gcongr;
          have := hq_coeff _ ( Finset.mem_range.mpr ( Nat.lt_succ_of_lt ( Finset.mem_range.mp ‹_› ) ) ) ; have := norm_sub_norm_le ( q.coeff ‹_› ) ( p.coeff ‹_› ) ; norm_num at * ; linarith;
        -- Since $‖z‖ \geq Max.max R 2 + ∑ i ∈ Finset.range (n + 1), (‖p.coeff i‖ + 1) + 1$, we have $‖z‖^n \geq (Max.max R 2 + ∑ i ∈ Finset.range (n + 1), (‖p.coeff i‖ + 1) + 1)^n$.
        have h_z_pow_n : ‖z‖^n ≥ (Max.max R 2 + ∑ i ∈ Finset.range (n + 1), (‖p.coeff i‖ + 1) + 1) * ‖z‖^(n-1) := by
          exact le_trans ( mul_le_mul_of_nonneg_right hz ( by positivity ) ) ( by rw [ ← pow_succ', Nat.sub_add_cancel ( Nat.one_le_iff_ne_zero.mpr hn ) ] );
        -- Since $‖z‖ \geq Max.max R 2 + ∑ i ∈ Finset.range (n + 1), (‖p.coeff i‖ + 1) + 1$, we have $∑ i ∈ Finset.range n, (‖p.coeff i‖ + 1) * ‖z‖^i ≤ (∑ i ∈ Finset.range (n + 1), (‖p.coeff i‖ + 1)) * ‖z‖^(n-1)$.
        have h_sum_bound : ∑ i ∈ Finset.range n, (‖p.coeff i‖ + 1) * ‖z‖^i ≤ (∑ i ∈ Finset.range (n + 1), (‖p.coeff i‖ + 1)) * ‖z‖^(n-1) := by
          rw [ Finset.sum_mul _ _ _ ];
          rw [ Finset.sum_range_succ ];
          exact le_add_of_le_of_nonneg ( Finset.sum_le_sum fun i hi => mul_le_mul_of_nonneg_left ( pow_le_pow_right₀ ( by linarith [ le_max_left R 2, le_max_right R 2, show 0 ≤ ∑ i ∈ Finset.range ( n + 1 ), ( ‖p.coeff i‖ + 1 ) from Finset.sum_nonneg fun _ _ => by positivity ] ) ( Nat.le_sub_one_of_lt ( Finset.mem_range.mp hi ) ) ) ( by positivity ) ) ( by positivity );
        nlinarith [ show ‖z‖ ^ ( n - 1 ) ≥ 1 from one_le_pow₀ ( by linarith [ le_max_left R 2, le_max_right R 2, show 0 ≤ ∑ i ∈ Finset.range ( n + 1 ), ( ‖p.coeff i‖ + 1 ) from Finset.sum_nonneg fun _ _ => add_nonneg ( norm_nonneg _ ) zero_le_one ] ), show 0 ≤ ∑ i ∈ Finset.range ( n + 1 ), ( ‖p.coeff i‖ + 1 ) from Finset.sum_nonneg fun _ _ => add_nonneg ( norm_nonneg _ ) zero_le_one, le_max_left R 2, le_max_right R 2 ];
      -- Let $K = \{z \in \mathbb{C} : |z| \le R'\} \setminus W$. Since $W$ is open, $K$ is compact.
      set K := {z : ℂ | ‖z‖ ≤ R' ∧ z ∉ W} with hK_def
      have hK_compact : IsCompact K := by
        exact ( Metric.isCompact_iff_isClosed_bounded.mpr ⟨ isClosed_Iic.preimage continuous_norm |> IsClosed.inter <| isClosed_compl_iff.mpr hW, isBounded_iff_forall_norm_le.mpr ⟨ R', fun z hz => hz.1 ⟩ ⟩ );
      -- On $K$, $|p(z)| > 1$ (since $\{|p| \le 1\} \subseteq W$ and $K$ is disjoint from $W$).
      have hK_gt_one : ∀ z ∈ K, ‖p.eval z‖ > 1 := by
        exact fun z hz => not_le.mp fun h => hz.2 <| h_sub h;
      -- Let $m = \min_{z \in K} |p(z)|$. Then $m > 1$.
      obtain ⟨m, hm⟩ : ∃ m : ℝ, 1 < m ∧ ∀ z ∈ K, ‖p.eval z‖ ≥ m := by
        by_cases hK_empty : K = ∅;
        · exact ⟨ 2, by norm_num, by aesop ⟩;
        · have hK_min : ∃ z ∈ K, ∀ w ∈ K, ‖p.eval z‖ ≤ ‖p.eval w‖ := by
            have hK_min : ContinuousOn (fun z => ‖p.eval z‖) K := by
              exact p.continuous.norm.continuousOn;
            exact hK_compact.exists_isMinOn ( Set.nonempty_iff_ne_empty.mpr hK_empty ) hK_min;
          exact ⟨ ‖p.eval hK_min.choose‖, hK_gt_one _ hK_min.choose_spec.1, fun z hz => hK_min.choose_spec.2 _ hz ⟩;
      -- By `uniform_approx_explicit`, for $\epsilon = m - 1$, there is a neighborhood of $p$ (in terms of coefficients) such that for all $q$ in it (with degree $\le n$), $|q(z) - p(z)| < m - 1$ for all $z \in K$.
      obtain ⟨δ, hδ_pos, hδ⟩ : ∃ δ > 0, ∀ q : Polynomial ℂ, q.degree ≤ n → (∀ i ∈ Finset.range (n + 1), ‖q.coeff i - p.coeff i‖ < δ) → ∀ z ∈ K, ‖q.eval z - p.eval z‖ < m - 1 := by
        have := @uniform_approx_explicit n K hK_compact ( m - 1 ) ( sub_pos.mpr hm.1 );
        exact ⟨ this.choose, this.choose_spec.1, fun q hq hq' z hz => by simpa only [ norm_sub_rev ] using this.choose_spec.2 q p hq ( by rw [ hp_deg ] ) ( fun i hi => by simpa only [ norm_sub_rev ] using hq' i hi ) z hz ⟩;
      refine h_contra ?_;
      rw [ nhds_induced ];
      rw [ Filter.eventually_comap ];
      rw [ nhds_pi ];
      refine Filter.mem_pi.mpr ?_;
      refine ⟨ Finset.range ( n + 1 ), Finset.finite_toSet _, fun i => Metric.ball ( p.coeff i ) ( Min.min δ 1 ), ?_, ?_ ⟩ <;> norm_num;
      · exact fun i => Metric.ball_mem_nhds _ ( lt_min hδ_pos zero_lt_one );
      · intro x hx q hq hq_monic hq_deg z hz; specialize hδ q ( by rw [ hq_deg ] ) ( fun i hi => by simpa [ hq, dist_eq_norm ] using lt_of_lt_of_le ( Metric.mem_ball.mp (hx i ( Finset.mem_range.mp hi )) ) ( min_le_left _ _ ) ) z; simp_all +decide [ Set.subset_def ] ;
        by_cases hzW : z ∈ W <;> simp_all +decide [ dist_eq_norm ];
        by_cases hzR' : ‖z‖ ≤ R' <;> simp_all +decide
        · have := hm.2 z hzR' hzW; have := norm_sub_le ( Polynomial.eval z q - Polynomial.eval z p ) ( Polynomial.eval z q ) ; norm_num at * ; linarith;
        · exact not_le_of_gt ( hR' q hq_monic hq_deg ( fun i hi => by simpa [ hq ] using hx i hi |>.2 ) z hzR'.le ) hz

/-
The set of monic polynomials of degree $n$ is closed.
proven and stated by Aristotle
-/
lemma isClosed_monic_degree_n (n : ℕ) : IsClosed {p : Polynomial ℂ | p.Monic ∧ p.degree = n} := by
  -- The set of monic polynomials of degree $n$ is defined by the condition that the leading coefficient is $1$ and all other coefficients are zero.
  have h_def : {p : Polynomial ℂ | p.Monic ∧ p.degree = n} = {p : Polynomial ℂ | p.coeff n = 1 ∧ ∀ k > n, p.coeff k = 0} := by
    ext p;
    constructor;
    · exact fun h => ⟨ by rw [ ← Polynomial.natDegree_eq_of_degree_eq_some h.2, Polynomial.coeff_natDegree ] ; aesop, fun k hk => Polynomial.coeff_eq_zero_of_degree_lt <| by rw [ h.2 ] ; exact WithBot.coe_lt_coe.mpr hk ⟩;
    · intro hp
      obtain ⟨h_coeff_n, h_coeff_gt⟩ := hp
      have h_deg : p.degree = n := by
        rw [ Polynomial.degree_eq_of_le_of_coeff_ne_zero ] <;> norm_num [ h_coeff_n ];
        rw [ Polynomial.degree_le_iff_coeff_zero ] ; aesop
      have h_monic : p.Monic := by
        rwa [ Polynomial.Monic, Polynomial.leadingCoeff, Polynomial.natDegree_eq_of_degree_eq_some h_deg ]
      exact ⟨h_monic, h_deg⟩;
  -- Each coefficient condition defines a closed set, so their intersection is also closed.
  have h_closed : ∀ k, IsClosed {p : Polynomial ℂ | p.coeff k = if k = n then 1 else 0} := by
    intro k
    have h_coeff_cont : Continuous (fun p : Polynomial ℂ => p.coeff k) := by
      rw [ continuous_iff_continuousAt ];
      intro p;
      rw [ ContinuousAt ];
      rw [ nhds_induced ];
      exact tendsto_pi_nhds.mp ( Filter.tendsto_comap ) k
    exact isClosed_eq h_coeff_cont continuous_const;
  rw [ h_def ];
  convert isClosed_iInter fun k => isClosed_iInter fun hk => h_closed k using 1;
  focus
    ext
  focus
    simp
  swap;
  focus
    exact fun k => if k = n then True else n < k
  grind +ring

/-
Evaluation of polynomials is continuous on the set of polynomials with degree at most $n$.
proven and stated by Aristotle
-/
lemma continuous_eval_on_degree_le (n : ℕ) (z : ℂ) : ContinuousOn (fun p : Polynomial ℂ => p.eval z) {p | p.degree ≤ n} := by
  -- Let $S = \{p \in \text{Polynomial } \mathbb{C} \mid \deg(p) \le n\}$.
  set S : Set (Polynomial ℂ) := {p : Polynomial ℂ | Polynomial.degree p ≤ n} with hS_def;
  -- The function $F(p) = \sum_{k=0}^n p_k z^k$ is continuous on the whole space `Polynomial ℂ`.
  have hF_cont : Continuous (fun p : Polynomial ℂ => ∑ k ∈ Finset.range (n + 1), p.coeff k * z ^ k) := by
    refine continuous_finsetSum (Finset.range (n + 1)) fun i hi => ?_;
    refine Continuous.mul ?_ continuous_const;
    rw [ continuous_iff_continuousAt ];
    intro p; exact (by
    rw [ ContinuousAt ];
    rw [ nhds_induced ];
    exact tendsto_pi_nhds.mp ( Filter.tendsto_comap ) i);
  refine hF_cont.continuousOn.congr fun p hp => ?_;
  rw [ Polynomial.eval_eq_sum_range' ];
  exact Nat.lt_succ_of_le ( Polynomial.natDegree_le_of_degree_le hp )

/-- A helper lemma for extracting an approximating polynomial `q` from a cluster point `p`
    such that `q` strictly satisfies the neighborhood conditions evaluated at `zA, zB`
    and uniformly over its level set.
proven by Aristotle -/
lemma extraction_q_of_cluster_pt {n : ℕ} (p : Polynomial ℂ)
    (h_cluster : ClusterPt p (Filter.principal (ValidPolys n)))
    (zA zB : ℂ) (U V : Set ℂ)
    (hUo : IsOpen U) (hVo : IsOpen V)
    (h_zA : ‖p.eval zA‖ < 1) (h_zB : ‖p.eval zB‖ < 1)
    (h_sub : {z : ℂ | ‖p.eval z‖ ≤ 1} ⊆ U ∪ V) :
    ∃ q ∈ ValidPolys n, ‖q.eval zA‖ < 1 ∧ ‖q.eval zB‖ < 1 ∧ {z : ℂ | ‖q.eval z‖ ≤ 1} ⊆ U ∪ V := by
  have h_valid : p.Monic ∧ p.degree = n := by
    have h_closed : IsClosed {q : Polynomial ℂ | q.Monic ∧ q.degree = n} := by
      exact isClosed_monic_degree_n n
    generalize_proofs at *; (
    exact h_closed.closure_subset_iff.mpr ( fun q hq => ⟨ hq.2.1, hq.1 ⟩ ) ( mem_closure_iff_clusterPt.mpr h_cluster ) |> fun h => ⟨ h.1, h.2 ⟩ ;);
  -- By the upper semicontinuity of the level set, there exists a neighborhood $N_W$ of $p$ such that for any monic $q$ of degree $n$ in $N_W$, $\{z \mid |q(z)| \le 1\} \subseteq U \cup V$.
  obtain ⟨N_W, hN_W⟩ : ∃ N_W ∈ nhds p, ∀ q : Polynomial ℂ, q.Monic → q.degree = n → q ∈ N_W → {z | ‖q.eval z‖ ≤ 1} ⊆ U ∪ V := by
    by_cases hn : n = 0;
    · rw [ Polynomial.degree_eq_natDegree ] at h_valid <;> aesop;
    · have := level_set_upper_semicontinuous_on_valid p h_valid.2 hn ( U ∪ V ) ( hUo.union hVo ) h_sub; aesop;
  have h_cont : ContinuousOn (fun q : Polynomial ℂ => q.eval zA) {q : Polynomial ℂ | q.degree ≤ n} ∧ ContinuousOn (fun q : Polynomial ℂ => q.eval zB) {q : Polynomial ℂ | q.degree ≤ n} := by
    exact ⟨ continuous_eval_on_degree_le n zA, continuous_eval_on_degree_le n zB ⟩;
  have h_cont : ∃ U_A ∈ nhds p, ∀ q ∈ U_A ∩ {q : Polynomial ℂ | q.degree ≤ n}, ‖q.eval zA‖ < 1 := by
    have := h_cont.1.continuousWithinAt ( show p ∈ { q : Polynomial ℂ | q.degree ≤ ( n : WithBot ℕ ) } from h_valid.2.le );
    have := this.norm.eventually ( gt_mem_nhds h_zA );
    rw [ eventually_nhdsWithin_iff ] at this; aesop;
  have h_cont' : ∃ U_B ∈ nhds p, ∀ q ∈ U_B ∩ {q : Polynomial ℂ | q.degree ≤ n}, ‖q.eval zB‖ < 1 := by
    have := ‹ContinuousOn ( fun q : Polynomial ℂ => Polynomial.eval zA q ) { q : Polynomial ℂ | q.degree ≤ ( n : WithBot ℕ ) } ∧ ContinuousOn ( fun q : Polynomial ℂ => Polynomial.eval zB q ) { q : Polynomial ℂ | q.degree ≤ ( n : WithBot ℕ ) } ›.2;
    have := this.continuousWithinAt ( show p ∈ { q : Polynomial ℂ | q.degree ≤ ( n : WithBot ℕ ) } from by aesop );
    have := this.norm.eventually ( gt_mem_nhds h_zB );
    rw [ eventually_nhdsWithin_iff ] at this;
    exact ⟨ _, this, fun q hq => hq.2 |> fun hq' => this.self_of_nhds |> fun h => by aesop ⟩;
  obtain ⟨ U_A, hU_A₁, hU_A₂ ⟩ := h_cont; obtain ⟨ U_B, hU_B₁, hU_B₂ ⟩ := h_cont'; simp_all +decide [ ClusterPt ] ;
  contrapose! h_cluster; simp_all +decide [ Filter.inf_principal_eq_bot ] ;
  filter_upwards [ hN_W.1, hU_A₁, hU_B₁ ] with q hq₁ hq₂ hq₃ using fun hq₄ => h_cluster q hq₄ ( hU_A₂ q hq₂ <| le_trans hq₄.1.le <| by norm_num ) ( hU_B₂ q hq₃ <| le_trans hq₄.1.le <| by norm_num ) <| hN_W.2 q hq₄.2.1 hq₄.1 hq₁;
/-
The set of valid polynomials is compact.
-/
theorem valid_polynomials_compact (n : ℕ) : IsCompact (ValidPolys n) := by
  let f : Polynomial ℂ → (ℕ → ℂ) := fun p => p.coeff
  have h_embed : Topology.IsEmbedding f := {
    eq_induced := rfl
    injective := fun p1 p2 h => Polynomial.ext fun n => congr_fun h n
  }
  rw [Topology.IsEmbedding.isCompact_iff h_embed]
  have h_bounds : ∃ (C : ℕ → ℝ), ∀ p ∈ ValidPolys n, ∀ i, ‖p.coeff i‖ ≤ C i := by
    let B := 2 * (n : ℝ)
    let bound := (max B 1)^n * (n.choose (n/2) : ℝ)
    use fun _ => bound
    intro p hp i
    let ⟨hp_deg, hp_monic, hp_val, hp_conn⟩ := hp
    have hp_natDeg : p.natDegree ≤ n := by
      rw [Polynomial.natDegree_le_iff_degree_le, hp_deg]
    have hp_roots : ∀ z ∈ (p.map (RingHom.id ℂ)).roots, ‖z‖ ≤ B := by
      intro z hz
      rw [Polynomial.map_id] at hz
      have h_max_p_bound := max_root_bound hp_deg hp_monic hp_conn (le_of_eq hp_val)
      apply le_trans _ h_max_p_bound
      let S := p.roots.toFinset.image (fun z => ‖z‖)
      have h_mem : ‖z‖ ∈ S := by
        simp only [Finset.mem_image, Multiset.mem_toFinset, S]
        exact ⟨z, hz, rfl⟩
      have h_ne : S.Nonempty := ⟨‖z‖, h_mem⟩
      obtain ⟨m, hm⟩ := Finset.max_of_nonempty h_ne
      have h_max_p : max_root p = m := by
        unfold max_root
        rw [hm]
        rfl
      rw [h_max_p]
      exact Finset.le_max_of_eq h_mem hm
    have h_coeff := Polynomial.coeff_bdd_of_roots_le (RingHom.id ℂ) hp_monic (by simpa using (IsAlgClosed.splits p)) hp_natDeg hp_roots i
    rw [Polynomial.map_id] at h_coeff
    dsimp
    exact h_coeff
  obtain ⟨C, hC⟩ := h_bounds
  have h_closed : IsClosed (f '' ValidPolys n) := by
    rw [isClosed_iff_clusterPt]
    intro c hc
    -- 1. Show that c corresponds to a polynomial p of degree n
    have h_eventually_zero : ∀ i > n, c i = 0 := by
      intro i hi
      let coord := fun (g : ℕ → ℂ) => g i
      have h_coord : Continuous coord := continuous_apply i
      have h_subset_zero : (f '' ValidPolys n) ⊆ coord ⁻¹' {0} := by
        rintro _ ⟨q, hq, rfl⟩
        simp only [coord, Set.mem_preimage, Set.mem_singleton_iff]
        apply Polynomial.coeff_eq_zero_of_degree_lt
        rw [hq.1]
        exact WithBot.coe_lt_coe.mpr hi
      have h_zero_closed : IsClosed (coord ⁻¹' {0}) := isClosed_singleton.preimage h_coord
      have h_in_closure : c ∈ closure (f '' ValidPolys n) := mem_closure_iff_clusterPt.mpr hc
      exact h_zero_closed.closure_subset (closure_mono h_subset_zero h_in_closure)
    let p_finsupp : ℕ →₀ ℂ := Finsupp.onFinset (Finset.range (n + 1)) c (fun i hi => by
      by_contra h_not_mem
      rw [Finset.mem_range, not_lt] at h_not_mem
      exact hi (h_eventually_zero i (Nat.lt_of_succ_le h_not_mem)))
    let p : Polynomial ℂ := Polynomial.ofFinsupp p_finsupp
    have h_p_coeff : ∀ i, p.coeff i = c i := by
      intro i
      rw [Polynomial.coeff_ofFinsupp]
      dsimp [p_finsupp]
    use p; constructor
    · -- show p ∈ ValidPolys n
      have h_cn : c n = 1 := by
        let coord := fun (g : ℕ → ℂ) => g n
        have h_coord : Continuous coord := continuous_apply n
        have h_subset_one : (f '' ValidPolys n) ⊆ coord ⁻¹' {1} := by
          rintro _ ⟨q, ⟨hq_deg, hq_monic, hq_val, hq_conn⟩, rfl⟩
          show q.coeff n = 1
          rw [← hq_monic.coeff_natDegree, Polynomial.natDegree_eq_of_degree_eq_some hq_deg]
        have h_one_closed : IsClosed (coord ⁻¹' {1}) := isClosed_singleton.preimage h_coord
        exact h_one_closed.closure_subset (closure_mono h_subset_one (mem_closure_iff_clusterPt.mpr hc))
      have h_c0 : ‖c 0‖ = 1 := by
        let coord := fun (g : ℕ → ℂ) => ‖g 0‖
        have h_coord : Continuous coord := continuous_norm.comp (continuous_apply 0)
        have h_subset_one : (f '' ValidPolys n) ⊆ coord ⁻¹' {1} := by
          rintro _ ⟨q, ⟨hq_deg, hq_monic, hq_val, hq_conn⟩, rfl⟩
          show ‖q.coeff 0‖ = 1
          rw [Polynomial.coeff_zero_eq_eval_zero]
          exact hq_val
        have h_one_closed : IsClosed (coord ⁻¹' {1}) := isClosed_singleton.preimage h_coord
        exact h_one_closed.closure_subset (closure_mono h_subset_one (mem_closure_iff_clusterPt.mpr hc))
      refine ⟨?_, ?_, ?_, ?_⟩
      · -- degree p = n
        apply Polynomial.degree_eq_of_le_of_coeff_ne_zero
        · rw [Polynomial.degree_le_iff_coeff_zero]
          intro i hi; rw [h_p_coeff]; exact h_eventually_zero i (WithBot.coe_lt_coe.mp hi)
        · rw [h_p_coeff, h_cn]; exact one_ne_zero
      · -- Monic
        have h_deg : p.degree = n := by
          apply Polynomial.degree_eq_of_le_of_coeff_ne_zero
          · rw [Polynomial.degree_le_iff_coeff_zero]
            intro i hi; rw [h_p_coeff]; exact h_eventually_zero i (WithBot.coe_lt_coe.mp hi)
          · rw [h_p_coeff, h_cn]; exact one_ne_zero
        have h_ndeg : p.natDegree = n := Polynomial.natDegree_eq_of_degree_eq_some h_deg
        rw [Polynomial.Monic, Polynomial.leadingCoeff, h_ndeg, h_p_coeff, h_cn]
      · -- ‖p.eval 0‖ = 1
        rw [← Polynomial.coeff_zero_eq_eval_zero, h_p_coeff, h_c0]
      · -- IsConnected
        -- Non-emptiness: 0 is in the level set because |p(0)| = 1
        have hp0 : ‖p.eval 0‖ = 1 := by
          rw [← Polynomial.coeff_zero_eq_eval_zero, h_p_coeff, h_c0]
        have h_nonempty : {z | ‖p.eval z‖ ≤ 1}.Nonempty := ⟨0, by simp [hp0]⟩
        refine ⟨h_nonempty, ?_⟩
        -- Preconnectedness: use the fact that it's a limit of connected sets
        rw [isPreconnected_closed_iff]
        intro A B h_closed_A h_closed_B h_union h_A_nonempty h_B_nonempty
        have h_p_coeff_ext : f p = c := by funext i; exact h_p_coeff i
        have h_p_cluster : ClusterPt p (Filter.principal (ValidPolys n)) := by
          apply h_embed.isInducing.mapClusterPt_iff.mp
          show MapClusterPt (f p) (Filter.principal (ValidPolys n)) f
          rw [h_p_coeff_ext, MapClusterPt, Filter.map_principal]
          exact hc
        have h_deg_p : p.degree = n := by
          apply Polynomial.degree_eq_of_le_of_coeff_ne_zero
          · rw [Polynomial.degree_le_iff_coeff_zero]
            intro i hi; rw [h_p_coeff]; exact h_eventually_zero i (WithBot.coe_lt_coe.mp hi)
          · rw [h_p_coeff, h_cn]; exact one_ne_zero
        by_cases hn : n = 0
        · -- n = 0 case: p is a constant of norm 1, so level set is C
          have hp_const : p.natDegree = 0 := by
            rw [Polynomial.natDegree_eq_of_degree_eq_some h_deg_p, hn]
          have h_level_univ : {z | ‖p.eval z‖ ≤ 1} = Set.univ := by
            obtain ⟨k, hk⟩ := Polynomial.natDegree_eq_zero.mp hp_const
            have hk1 : ‖k‖ = 1 := by rw [← hk] at hp0; simpa using hp0
            ext z; simp [← hk, hk1]
          rw [h_level_univ] at h_union h_A_nonempty h_B_nonempty
          have h_univ_conn : (Set.univ ∩ (A ∩ B)).Nonempty :=
            isPreconnected_closed_iff.mp isPreconnected_univ A B h_closed_A h_closed_B h_union h_A_nonempty h_B_nonempty
          rw [h_level_univ]
          exact h_univ_conn
        · -- n > 0 case: Use separation argument
          have hn_pos : 0 < n := Nat.pos_of_ne_zero hn
          let K := {z | ‖p.eval z‖ ≤ 1}
          have h_K_cpct : IsCompact K := polynomial_level_set_compact p (by rw [h_deg_p]; exact WithBot.coe_pos.mpr hn_pos) 1
          -- Assume intersection A ∩ B ∩ K is empty and derive contradiction
          by_contra h_nonempty_inter
          have h_empty_inter : K ∩ (A ∩ B) = ∅ := Set.not_nonempty_iff_eq_empty.mp h_nonempty_inter
          -- Then K ∩ A and K ∩ B form a partition of K into disjoint compact sets.
          have h_disjoint : Disjoint (K ∩ A) (K ∩ B) := by
            rw [Set.disjoint_iff_inter_eq_empty]
            rw [← Set.inter_assoc, Set.inter_comm K A, Set.inter_assoc, Set.inter_assoc]
            rw [← Set.inter_assoc K K B, Set.inter_self K, Set.inter_left_comm, h_empty_inter]
          have hKA_cpct : IsCompact (K ∩ A) := h_K_cpct.inter_right h_closed_A
          have hKB_cpct : IsCompact (K ∩ B) := h_K_cpct.inter_right h_closed_B
          obtain ⟨U, V, hUo, hVo, hKAo, hKBo, hUV⟩ :=
            SeparatedNhds.of_isCompact_isCompact_isClosed hKA_cpct hKB_cpct (h_K_cpct.isClosed.inter h_closed_B) h_disjoint
          -- Now we have disjoint open U, V separating K ∩ A and K ∩ B.
          -- Let W = U ∪ V. Then K ⊆ W because K = (K ∩ A) ∪ (K ∩ B).
          have hK_sub_W : {z | ‖p.eval z‖ ≤ 1} ⊆ U ∪ V := by
            intro x hx; rcases h_union hx with hxA | hxB
            · left; exact hKAo ⟨hx, hxA⟩
            · right; exact hKBo ⟨hx, hxB⟩
          -- Since p is non-constant (n > 0) and ‖p 0‖ = 1, there are points near K ∩ A and K ∩ B with ‖p z‖ < 1.
          -- Because if ‖p z‖ ≥ 1 locally, and ‖p z₀‖ = 1, then it's a minimum, so p is constant (Minimum Principle).
          -- But n > 0 makes p non-constant.
          have h_not_const : ¬∃ w : ℂ, ∀ z ∈ Set.univ, p.eval z = w := by
            intro ⟨w, hw⟩
            have hp_eq : p = Polynomial.C w := by
              apply Polynomial.funext
              intro z
              rw [hw z (Set.mem_univ z), Polynomial.eval_C]
            have h_deg0 : p.degree ≤ 0 := by
              rw [hp_eq]; exact Polynomial.degree_C_le
            rw [h_deg_p] at h_deg0
            exact (WithBot.coe_le_coe.mp h_deg0).not_gt hn_pos
          have h_analytic : AnalyticOnNhd ℂ (fun z => p.eval z) Set.univ := fun z _ =>
            p.differentiable.analyticAt z
          have h_open_map : IsOpenMap (fun z => p.eval z) := fun s hs =>
            (AnalyticOnNhd.is_constant_or_isOpen h_analytic isPreconnected_univ).resolve_left
              h_not_const s (Set.subset_univ s) hs
          -- For now, let's assume we can pick zA and zB in U and V with norm < 1
          obtain ⟨zA, hzA_mem, hzA_val⟩ : ∃ z ∈ U, ‖p.eval z‖ < 1 := by
            obtain ⟨z0, hz0_mem⟩ := h_A_nonempty
            have hz0U : z0 ∈ U := hKAo ⟨hz0_mem.1, hz0_mem.2⟩
            obtain ⟨ε, hε, hball⟩ := Metric.isOpen_iff.mp hUo z0 hz0U
            have himage := h_open_map (Metric.ball z0 ε) Metric.isOpen_ball
            have hmem : p.eval z0 ∈ p.eval '' Metric.ball z0 ε := Set.mem_image_of_mem _ (Metric.mem_ball_self hε)
            obtain ⟨δ, hδ, hballδ⟩ := Metric.isOpen_iff.mp himage (p.eval z0) hmem
            let δ' := min δ 1
            have hδ' : 0 < δ' := lt_min hδ zero_lt_one
            have hδ'δ : δ' ≤ δ := min_le_left _ _
            by_cases h_lt : ‖p.eval z0‖ < 1
            · exact ⟨z0, hz0U, h_lt⟩
            · have h_eq : ‖p.eval z0‖ = 1 := le_antisymm hz0_mem.1 (not_lt.mp h_lt)
              have h_r_pos : 0 < 1 - δ' / 2 := by linarith [(min_le_right δ 1 : δ' ≤ 1)]
              let v := ((1 - δ' / 2 : ℝ) : ℂ) • p.eval z0
              have hv_ball : v ∈ Metric.ball (p.eval z0) δ := by
                apply Metric.ball_subset_ball hδ'δ
                rw [Metric.mem_ball, dist_eq_norm]
                have : v - p.eval z0 = ((- δ' / 2 : ℝ) : ℂ) • p.eval z0 := by
                  calc v - p.eval z0 = ((1 - δ' / 2 : ℝ) : ℂ) • p.eval z0 - (1 : ℂ) • p.eval z0 := by rw [one_smul]
                    _ = (((1 - δ' / 2 : ℝ) : ℂ) - 1) • p.eval z0 := by rw [← sub_smul]
                    _ = ((- δ' / 2 : ℝ) : ℂ) • p.eval z0 := by congr 1; push_cast; ring
                rw [this, norm_smul, Complex.norm_real, h_eq, mul_one, Real.norm_eq_abs, abs_of_nonpos (by linarith)]
                linarith
              obtain ⟨zA, hzA_ball, hzA_eval⟩ := hballδ hv_ball
              refine ⟨zA, hball hzA_ball, ?_⟩
              change p.eval zA = v at hzA_eval
              rw [hzA_eval, norm_smul, Complex.norm_real, h_eq, mul_one, Real.norm_eq_abs, abs_of_pos h_r_pos]
              linarith
          obtain ⟨zB, hzB_mem, hzB_val⟩ : ∃ z ∈ V, ‖p.eval z‖ < 1 := by
            obtain ⟨z0, hz0_mem⟩ := h_B_nonempty
            have hz0V : z0 ∈ V := hKBo ⟨hz0_mem.1, hz0_mem.2⟩
            obtain ⟨ε, hε, hball⟩ := Metric.isOpen_iff.mp hVo z0 hz0V
            have himage := h_open_map (Metric.ball z0 ε) Metric.isOpen_ball
            have hmem : p.eval z0 ∈ p.eval '' Metric.ball z0 ε := Set.mem_image_of_mem _ (Metric.mem_ball_self hε)
            obtain ⟨δ, hδ, hballδ⟩ := Metric.isOpen_iff.mp himage (p.eval z0) hmem
            let δ' := min δ 1
            have hδ' : 0 < δ' := lt_min hδ zero_lt_one
            have hδ'δ : δ' ≤ δ := min_le_left _ _
            by_cases h_lt : ‖p.eval z0‖ < 1
            · exact ⟨z0, hz0V, h_lt⟩
            · have h_eq : ‖p.eval z0‖ = 1 := le_antisymm hz0_mem.1 (not_lt.mp h_lt)
              have h_r_pos : 0 < 1 - δ' / 2 := by linarith [(min_le_right δ 1 : δ' ≤ 1)]
              let v := ((1 - δ' / 2 : ℝ) : ℂ) • p.eval z0
              have hv_ball : v ∈ Metric.ball (p.eval z0) δ := by
                apply Metric.ball_subset_ball hδ'δ
                rw [Metric.mem_ball, dist_eq_norm]
                have : v - p.eval z0 = ((- δ' / 2 : ℝ) : ℂ) • p.eval z0 := by
                  calc v - p.eval z0 = ((1 - δ' / 2 : ℝ) : ℂ) • p.eval z0 - (1 : ℂ) • p.eval z0 := by rw [one_smul]
                    _ = (((1 - δ' / 2 : ℝ) : ℂ) - 1) • p.eval z0 := by rw [← sub_smul]
                    _ = ((- δ' / 2 : ℝ) : ℂ) • p.eval z0 := by congr 1; push_cast; ring
                rw [this, norm_smul, Complex.norm_real, h_eq, mul_one, Real.norm_eq_abs, abs_of_nonpos (by linarith)]
                linarith
              obtain ⟨zB, hzB_ball, hzB_eval⟩ := hballδ hv_ball
              refine ⟨zB, hball hzB_ball, ?_⟩
              change p.eval zB = v at hzB_eval
              rw [hzB_eval, norm_smul, Complex.norm_real, h_eq, mul_one, Real.norm_eq_abs, abs_of_pos h_r_pos]
              linarith
          -- Now we use ClusterPt p (principal (ValidPolys n))
          -- There exists q ∈ ValidPolys n arbitrarily close to p.
          -- Close enough that ‖q zA‖ < 1, ‖q zB‖ < 1, and E_q ⊆ U ∪ V.
          let δ_z := min (1 - ‖p.eval zA‖) (1 - ‖p.eval zB‖) / 2
          have hδ_z_pos : 0 < δ_z := by
            apply half_pos
            apply lt_min
            · exact sub_pos.mpr hzA_val
            · exact sub_pos.mpr hzB_val
          -- The sequence of valid polynomials q whose coefficients converge to p's coefficients
          -- will uniformly converge to p on the compact set K ∪ {zA, zB}.
          -- Thus, for q close enough to p, E_q ⊆ U ∪ V, and q zA, q zB have norm < 1.
          -- Since E_q is connected, it cannot be partitioned by disjoint open sets U and V.
          -- Therefore, the original assumption that E_p is disconnected must be false.
          -- We need an open neighborhood W of p in Polynomial ℂ such that for all q ∈ W:
          -- 1) ‖q.eval zA‖ < 1
          -- 2) ‖q.eval zB‖ < 1
          -- 3) E_q ⊆ U ∪ V
          --
          -- ‖p.eval zA‖ < 1 and ‖p.eval zB‖ < 1 are open conditions on q (eval zA, eval zB are continuous).
          -- E_q ⊆ U ∪ V is also an open condition on q (because the level sets are uniformly bounded and U ∪ V is open).
          --
          -- For E_q ⊆ U ∪ V, we define:
          -- W_UV = {q | ∀ z, ‖q.eval z‖ ≤ 1 → z ∈ U ∪ V}
          -- By a standard compactness argument, since p ∈ W_UV, W_UV is open in the topology of polynomials.
          -- Actually, a simpler way is to use the fact that f is an embedding.
          have H_exist_q : ∃ q ∈ ValidPolys n, ‖q.eval zA‖ < 1 ∧ ‖q.eval zB‖ < 1 ∧ {z | ‖q.eval z‖ ≤ 1} ⊆ U ∪ V :=
            extraction_q_of_cluster_pt p h_p_cluster zA zB U V hUo hVo hzA_val hzB_val hK_sub_W
          obtain ⟨q, hq_valid, hqA, hqB, hq_sub⟩ := H_exist_q
          have hq_conn : IsPreconnected {z | ‖q.eval z‖ ≤ 1} := hq_valid.2.2.2.2
          -- We now use the definition of IsPreconnected.
          -- We have open sets U and V separating E_q.
          have H_union_q : {z | ‖q.eval z‖ ≤ 1} ⊆ U ∪ V := hq_sub
          have H_nonemptyA_q : ({z | ‖q.eval z‖ ≤ 1} ∩ U).Nonempty := ⟨zA, hqA.le, hzA_mem⟩
          have H_nonemptyB_q : ({z | ‖q.eval z‖ ≤ 1} ∩ V).Nonempty := ⟨zB, hqB.le, hzB_mem⟩
          have H_inter_nonempty := hq_conn U V hUo hVo H_union_q H_nonemptyA_q H_nonemptyB_q
          -- But U and V are disjoint.
          have H_disj_empty : U ∩ V = ∅ := Set.disjoint_iff_inter_eq_empty.mp hUV
          rw [H_disj_empty, Set.inter_empty] at H_inter_nonempty
          exact Set.not_nonempty_empty H_inter_nonempty
    · ext i; exact h_p_coeff i
  have h_pi_compact : IsCompact (Set.pi Set.univ (fun i => Metric.closedBall (0 : ℂ) (C i))) := by
    apply isCompact_univ_pi
    intro i
    exact isCompact_closedBall (0 : ℂ) (C i)
  have h_subset : (f '' ValidPolys n) ⊆ Set.pi Set.univ (fun i => Metric.closedBall (0 : ℂ) (C i)) := by
    rintro _ ⟨p, hp, rfl⟩ i _
    simp only [Metric.mem_closedBall, dist_zero_right]
    exact hC p hp i
  exact IsCompact.of_isClosed_subset h_pi_compact h_closed h_subset
/-
An extremal polynomial exists. Proven by Gemini 3.1 Pro and Gemini 3.0 Flash in ulam.ai harness
-/
theorem exists_extremal_polynomial (n : ℕ) (hn : n ≠ 0) :
    ∃ p ∈ ValidPolys n, ∀ q ∈ ValidPolys n, ‖q.derivative.eval 0‖ ≤ ‖p.derivative.eval 0‖ := by
  let f : Polynomial ℂ → ℝ := fun p => ‖p.derivative.eval 0‖
  have hf : Continuous f := by
    apply continuous_norm.comp
    have h_coeff : (fun p : Polynomial ℂ => p.derivative.eval 0) = (fun p => p.coeff 1) := by
      ext p
      rw [← Polynomial.coeff_zero_eq_eval_zero, Polynomial.coeff_derivative, zero_add]
      simp
    rw [h_coeff]
    exact (continuous_apply 1).comp continuous_induced_dom
  have hne : (ValidPolys n).Nonempty := by
    let p0 : Polynomial ℂ := (Polynomial.X + Polynomial.C 1) ^ n
    use p0
    refine ⟨?_, ?_, ?_, ?_⟩
    · rw [Polynomial.degree_pow, Polynomial.degree_X_add_C]
      simp
    · exact Polynomial.Monic.pow (Polynomial.monic_X_add_C 1) n
    · simp only [p0, Polynomial.eval_pow, Polynomial.eval_add, Polynomial.eval_X, Polynomial.eval_C,
        zero_add, one_pow, norm_one]
    · have h_ball : {z : ℂ | ‖p0.eval z‖ ≤ 1} = Metric.closedBall (-1 : ℂ) 1 := by
        ext z
        simp only [p0, Set.mem_setOf_eq, Metric.mem_closedBall, dist_eq_norm,
          sub_neg_eq_add, Polynomial.eval_pow, Polynomial.eval_add, Polynomial.eval_X, Polynomial.eval_C, norm_pow]
        constructor
        · intro h
          by_contra! hC
          have hn_pos : 0 < n := Nat.pos_of_ne_zero hn
          have h_gt : (1 : ℝ) ^ n < ‖z + 1‖ ^ n := by gcongr
          rw [one_pow] at h_gt
          linarith
        · intro h
          have hn_pos : 0 ≤ ‖z + 1‖ := norm_nonneg (z + 1)
          have h1 : ‖z + 1‖ ^ n ≤ 1 ^ n := by gcongr
          rwa [one_pow] at h1
      rw [h_ball]
      exact (convex_closedBall (-1 : ℂ) 1).isConnected (Metric.nonempty_closedBall.mpr zero_le_one)
  obtain ⟨p, hp, hmax⟩ := (valid_polynomials_compact n).exists_isMaxOn hne hf.continuousOn
  exact ⟨p, hp, hmax⟩
/-
Every connected component of the level set $\{z \mid |p(z)| \le 1\}$ contains a root of $p$.
Proven and stated by Aristotle
-/
theorem polynomial_level_set_component_contains_root (p : Polynomial ℂ) (hp : 0 < p.degree) (z : ℂ) (hz : ‖p.eval z‖ ≤ 1) :
    ∃ w ∈ connectedComponentIn {z | ‖p.eval z‖ ≤ 1} z, p.eval w = 0 := by
      -- Let $K = \{z \mid |p(z)| \le 1\}$. By `polynomial_level_set_compact` (using `hp`), $K$ is compact.
      set K := {z : ℂ | ‖p.eval z‖ ≤ 1} with hK_def
      have hK_compact : IsCompact K := by
        exact polynomial_level_set_compact p hp 1
      -- Let $C$ be the connected component of $z$ in $K$. $C$ is a closed subset of the compact set $K$, hence $C$ is compact.
      set C := connectedComponentIn K z with hC_def
      have hC_compact : IsCompact C := by
        refine hK_compact.of_isClosed_subset ?_ ?_;
        · refine isClosed_of_closure_subset fun x hx => ?_;
          -- Since $x$ is in the closure of $C$, and $C$ is a connected component of $K$, $x$ must be in $K$.
          have hx_in_K : x ∈ K := by
            exact hK_compact.isClosed.closure_subset_iff.mpr ( connectedComponentIn_subset _ _ ) hx;
          -- Since $C$ is the connected component of $z$ in $K$, and $x$ is in the closure of $C$, $x$ must be in $C$.
          have hC_closure : IsPreconnected (closure C) := by
            exact IsPreconnected.closure ( isPreconnected_connectedComponentIn );
          have hC_closure_subset : closure C ⊆ connectedComponentIn K z := by
            intro y hy;
            have hC_closure_subset : IsPreconnected (closure C) ∧ closure C ⊆ K := by
              exact ⟨ hC_closure, closure_minimal ( connectedComponentIn_subset _ _ ) hK_compact.isClosed ⟩;
            have hC_closure_subset : IsPreconnected (closure C) ∧ closure C ⊆ K ∧ z ∈ closure C := by
              exact ⟨ hC_closure, hC_closure_subset.2, subset_closure <| mem_connectedComponentIn <| by aesop ⟩;
            exact hC_closure_subset.1.subset_connectedComponentIn ( by aesop ) ( by aesop ) hy;
          exact hC_closure_subset hx;
        · exact connectedComponentIn_subset _ _;
      -- The function $u \mapsto |p(u)|$ is continuous on $C$. Since $C$ is compact and nonempty (contains $z$), $|p|$ attains a minimum on $C$ at some $w \in C$.
      obtain ⟨w, hw⟩ : ∃ w ∈ C, ∀ u ∈ C, ‖p.eval u‖ ≥ ‖p.eval w‖ := by
        have h_continuous : ContinuousOn (fun u => ‖p.eval u‖) C := by
          exact p.continuous.norm.continuousOn
        generalize_proofs at *;
        exact hC_compact.exists_isMinOn ⟨ z, mem_connectedComponentIn <| by aesop ⟩ h_continuous |> fun ⟨ w, hw₁, hw₂ ⟩ => ⟨ w, hw₁, fun u hu => hw₂ hu ⟩ ;
      generalize_proofs at *;
      -- Case 1: $m < 1$.
      by_cases h_case1 : ‖p.eval w‖ < 1;
      · -- By `minimum_on_component_lt_one_implies_local_min`, $w$ is a local minimum of $|p|$ in $\mathbb{C}$.
        have h_local_min : IsLocalMin (fun z => ‖p.eval z‖) w := by
          apply minimum_on_component_lt_one_implies_local_min p z C rfl w hw.1 hw.2 h_case1
        generalize_proofs at *; (
        exact ⟨ w, hw.1, Classical.not_not.1 fun h => polynomial_no_local_min_nonzero p w ( ne_of_gt hp ) h h_local_min ⟩);
      · -- Since $|p(w)| = 1$ for all $u \in C$, by `modulus_eq_one_on_component_implies_const`, $p$ is constant.
        have h_const : ∃ c : ℂ, p = Polynomial.C c := by
          apply modulus_eq_one_on_component_implies_const p z hz C rfl
          generalize_proofs at *; (
          exact fun u hu => le_antisymm ( by exact ( connectedComponentIn_subset _ _ hu ) |> fun h => by aesop ) ( by linarith [ hw.2 u hu ] ) ;)
        generalize_proofs at *; (
        rw [ Polynomial.degree_eq_natDegree ] at hp <;> aesop_cat;)
/-
The level set of the polynomial `f^*` is connected.
Proven by Aristotle
-/
theorem polynomial_star_level_set_connected (p : Polynomial ℂ) (hp : p.Monic) (hp_deg : p.degree ≠ 0) (h_zero : ‖p.eval 0‖ ≤ 1)
    (h_conn : IsConnected {z | ‖p.eval z‖ ≤ 1}) :
    IsConnected {z | ‖(polynomial_star p).eval z‖ ≤ 1} := by
  -- By `polynomial_star_segment_subset_level_set`, the segment $S = [-\max|z_k|, 0]$ is contained in $K^*$.
  have h_segment : ∀ x : ℝ, -((p.roots.toFinset.image (fun z => ‖z‖)).max.getD 0) ≤ x ∧ x ≤ 0 → (x : ℂ) ∈ {z | ‖(polynomial_star p).eval z‖ ≤ 1} := by
    intro x hx
    convert polynomial_star_segment_subset_level_set p hp h_zero h_conn x hx using 1;
  -- Since $C$ and $C_0$ are connected components, $C = C_0$.
  have h_eq_components : ∀ z : ℂ, ‖(polynomial_star p).eval z‖ ≤ 1 → ∃ z₀ : ℝ, -((p.roots.toFinset.image (fun z => ‖z‖)).max.getD 0) ≤ z₀ ∧ z₀ ≤ 0 ∧ z ∈ connectedComponentIn {w | ‖(polynomial_star p).eval w‖ ≤ 1} (z₀ : ℂ) := by
    intro z hz
    obtain ⟨w, hw⟩ : ∃ w : ℂ, w ∈ connectedComponentIn {w | ‖(polynomial_star p).eval w‖ ≤ 1} z ∧ (polynomial_star p).eval w = 0 := by
      apply polynomial_level_set_component_contains_root (polynomial_star p) (by
      rw [ polynomial_star_degree ]
      focus
        contrapose! hp_deg
      focus
        aesop
      assumption) z hz;
    -- Since $w$ is a root of $f^*$, we have $w = -|z_k|$ for some root $z_k$ of $p$.
    obtain ⟨z_k, hz_k⟩ : ∃ z_k ∈ p.roots, w = -Complex.ofReal ‖z_k‖ := by
      unfold polynomial_star at hw; simp_all +decide
      simp_all +decide [ Polynomial.eval_multiset_prod, Multiset.prod_eq_zero_iff, add_eq_zero_iff_eq_neg ];
    refine ⟨ -‖z_k‖, ?_, ?_, ?_ ⟩ <;> simp_all +decide [ Option.getD ];
    · cases h : Finset.max ( Multiset.toFinset ( Multiset.map ( fun z => ‖z‖ ) p.roots ) ) <;> simp_all +decide [ Finset.max ];
      exact_mod_cast h ▸ Finset.le_sup ( f := WithBot.some ) ( Multiset.mem_toFinset.mpr ( Multiset.mem_map.mpr ⟨ z_k, Polynomial.mem_roots ( show p ≠ 0 from hp.ne_zero ) |>.2 hz_k.1.2, rfl ⟩ ) );
    · rw [ connectedComponentIn ] at *;
      split_ifs at * <;> simp_all +decide [ connectedComponent ];
      exact ⟨ hw.1.choose_spec.choose, ⟨ hw.1.choose_spec.choose_spec.1.1, hw.1.choose_spec.choose_spec.2 ⟩, hw.1.choose_spec.choose_spec.1.2 ⟩;
