    let p_real_eval0 : ℝ := (f.roots.map (fun z => ‖z‖)).prod
    have h_f_star_eval0 : f_star.eval 0 = algebraMap ℝ ℂ p_real_eval0 := by
      rw [hf_def, polynomial_star, h_eval_prod]
