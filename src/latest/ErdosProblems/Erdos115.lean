Proven by Aristotle
-/
lemma roots_nhd_small_modulus (p : Polynomial ℂ) :
    ∃ r : ℝ, r > 0 ∧ ∀ z : ℂ, (∃ w ∈ p.roots, ‖z - w‖ < r) → ‖p.eval z‖ < 1 / 2 := by
  obtain ⟨r, hr_pos, hr⟩ : ∃ r > 0, ∀ z : ℂ, (∃ w ∈ p.roots, ‖z - w‖ < r) → ‖p.eval z‖ < 1 / 2 := by
    have h_dist : ∀ w ∈ p.roots, ∃ r > 0, ∀ z : ℂ, ‖z - w‖ < r → ‖p.eval z‖ < 1 / 2 := by
      intro w hw
      obtain ⟨r, hr_pos, hr⟩ := Metric.continuous_iff.mp p.continuous w (1 / 2) (by norm_num)
      refine ⟨r, hr_pos, ?_⟩
      intro z hz
      have hw_eval : p.eval w = 0 := by aesop
      have hz' : dist z w < r := by simpa [dist_eq_norm] using hz
      simpa [hw_eval, dist_eq_norm] using hr z hz'
