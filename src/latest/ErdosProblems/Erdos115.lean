      unfold P_val
      simp only [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_C, Polynomial.eval_X]
      rw [hA, mul_assoc, hB]; rfl
    have h_norm : ‖P_val‖ ^ 2 = P_val.re ^ 2 + P_val.im ^ 2 := by
      rw [← Complex.normSq_eq_norm_sq, Complex.normSq_apply, sq, sq]
    have h_re : P_val.re = (p.eval (x : ℂ)).re + δ * ((x : ℂ) * q.eval (x : ℂ)).re := by
      rw [h_val]; simp
    have h_im : P_val.im = 0 := by
      rw [h_val]; simp
    have h_pq_re : (p.eval (x : ℂ) * q.eval (x : ℂ)).re = (p.eval (x : ℂ)).re * (q.eval (x : ℂ)).re := by
      rw [Complex.mul_re, hx_real_p, hx_real_q]; simp
    have h_xq_norm : ‖(x : ℂ) * q.eval (x : ℂ)‖ ^ 2 = x ^ 2 * (q.eval (x : ℂ)).re ^ 2 := by
      rw [norm_mul, Complex.norm_real, Real.norm_eq_abs, mul_pow, sq_abs]
      have hq_norm_sq : ‖q.eval (x : ℂ)‖ ^ 2 = (q.eval (x : ℂ)).re ^ 2 := by
