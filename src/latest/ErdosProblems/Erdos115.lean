          apply Complex.ext <;> simp_all
        -- Conclude a ∈ critical_points_with_val_one p
        apply Finset.mem_filter.mpr
        refine ⟨Multiset.mem_toFinset.mpr (Polynomial.mem_roots ?_ |>.mpr h_deriv_zero_full), ha_norm_one⟩
        intro H
        -- H : p.derivative = 0 means p = C c (constant polynomial)
        -- After rewriting, hp_deg would say degree of constant = n. But n = 0 for constants.
        -- Then max_root p = 0, but a < 0 means a not in [-0, 0] = {0}, contradiction.
        have h_p_const : p = Polynomial.C (p.coeff 0) := Polynomial.eq_C_of_derivative_eq_zero H
        have h_nd : p.natDegree = n := Polynomial.natDegree_eq_of_degree_eq_some hp_deg
