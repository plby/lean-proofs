          · rcases n with ( _ | _ | n ) <;> norm_num at *;
            rw [ Polynomial.degree_eq_natDegree ] at hp_deg <;> aesop;
          · rw [ Polynomial.natDegree_mul', Polynomial.natDegree_mul' ] <;> norm_num [ hq ];
            · rw [ Polynomial.degree_eq_natDegree hq ] at hq_deg ; norm_cast at hq_deg;
