lemma h_crit_nhd_zero {n : ℕ} {p q : Polynomial ℂ}
    (hp_monic : p.Monic) (_hp_deg : p.degree = ↑n)
    (hp_real : ∀ x : ℝ, (p.eval (x : ℂ)).im = 0)
    (hq_real : ∀ x : ℝ, (q.eval (x : ℂ)).im = 0)
    (hp_roots : RealRootedNonpositive p)
    (h_zero : ‖p.eval 0‖ ≤ 1)
    (h0_sign : (q.eval 0 * p.eval 0).re > 0)
    (h_sq_le_one : ∀ y : ℝ, -(max_root p : ℝ) < y → y ≤ 0 → ‖p.eval (y : ℂ)‖ ≤ 1)
    (h_pq_cont_re : Continuous (fun x : ℝ => (p.eval (x : ℂ) * q.eval (x : ℂ)).re))
    (h_q_norm_cont : Continuous (fun x : ℝ => ‖q.eval (x : ℂ)‖)) :
    ∃ ε_0 > 0, ∃ U_0 ∈ nhds (0 : ℝ), ∀ (δ : ℝ), 0 < δ → δ ≤ ε_0 →
      ∀ x ∈ U_0 ∩ Set.Icc (-(max_root p : ℝ)) 0,
        ‖(p + Polynomial.C (δ : ℂ) * Polynomial.X * q).eval (x : ℂ)‖ ≤ 1 := by
  -- p(0)q(0) is real and positive.
