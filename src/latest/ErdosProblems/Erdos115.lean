-- proven and Stated by Aristotle
lemma monic_norm_bound_on_interval {n : ℕ} (hn : n ≠ 0) (p : Polynomial ℂ) (hp_monic : p.Monic) (hp_deg : p.degree = n) (a b : ℝ) (h_lt : a < b) :
    ∃ x ∈ Set.Icc a b, ‖p.eval (x : ℂ)‖ ≥ 2 * ((b - a) / 4) ^ n := by
      -- Let $q(t) = p(\phi(t))$. This is a polynomial in $t$.
      let phi := fun (t : ℝ) => (b - a) / 2 * t + (a + b) / 2
      let q := p.comp (Polynomial.C (Complex.ofReal ((b - a) / 2)) * Polynomial.X + Polynomial.C (Complex.ofReal ((a + b) / 2)));
      -- Let $r(t) = (\frac{2}{b-a})^n q(t)$. $r$ is monic.
      let r := Polynomial.C (Complex.ofReal ((2 : ℝ) / (b - a)) ^ n) * q;
      -- By `monic_norm_bound_on_unit_interval`, there exists $t \in [-1, 1]$ such that $|r(t)| \ge 1/2^{n-1}$.
      obtain ⟨t, ht⟩ : ∃ t ∈ Set.Icc (-1 : ℝ) 1, ‖r.eval (t : ℂ)‖ ≥ 1 / 2 ^ (n - 1) := by
        have hr_monic : r.Monic := by
          rw [ Polynomial.Monic, Polynomial.leadingCoeff_mul, Polynomial.leadingCoeff_C ];
          rw [ Polynomial.leadingCoeff_comp ] <;> norm_num [ hp_monic, hp_deg ];
          · rw [ Polynomial.leadingCoeff, Polynomial.natDegree_add_C, Polynomial.natDegree_C_mul_X ] <;> norm_num [ hn, hp_deg, Polynomial.natDegree_eq_of_degree_eq_some hp_deg ];
            · rw [ ← mul_pow, div_mul_div_cancel₀ ] <;> norm_cast
              focus
                aesop
              linarith;
            · exact sub_ne_zero_of_ne <| mod_cast h_lt.ne';
          · rw [ Polynomial.natDegree_C_mul_X ] <;> norm_num [ sub_ne_zero.2 ( by norm_cast; linarith : ( b : ℂ ) ≠ a ) ]
        have hr_deg : r.degree = n := by
          rw [ Polynomial.degree_mul, Polynomial.degree_C ] <;> norm_num [ hn, hp_deg ];
          · erw [ Polynomial.degree_eq_iff_natDegree_eq_of_pos ( Nat.pos_of_ne_zero hn ) ] at * ; erw [ Polynomial.natDegree_comp, Polynomial.natDegree_add_C, Polynomial.natDegree_C_mul_X ] <;> aesop;
          · exact sub_ne_zero_of_ne <| by norm_cast; linarith;
        apply monic_norm_bound_on_unit_interval hn r hr_monic hr_deg;
      refine ⟨ phi t, ?_, ?_ ⟩ <;> norm_num at *;
      · constructor <;> nlinarith [ show phi t = ( b - a ) / 2 * t + ( a + b ) / 2 from rfl ];
