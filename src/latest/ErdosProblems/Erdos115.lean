          have B_im : ((x : ℂ) * q.eval (x : ℂ)).im = 0 := by simp [hx_real_q]
          rw [← Complex.normSq_eq_norm_sq, Complex.normSq_apply, B_im, mul_zero, add_zero, ← sq]
        calc (P δ x).re ^ 2
          _ = ( (p.eval (x : ℂ)).re + δ * ((x : ℂ) * q.eval (x : ℂ)).re ) ^ 2 := by
               have h_re : (P δ x).re = (p.eval (x : ℂ)).re + δ * ((x : ℂ) * q.eval (x : ℂ)).re := by
                 rw [hP_val]
                 simp only [Complex.add_re, Complex.mul_re, Complex.ofReal_re, Complex.ofReal_im, zero_mul, sub_zero]
               rw [h_re]
          _ = (p.eval (x : ℂ)).re ^ 2 + 2 * δ * (((x : ℂ) * q.eval (x : ℂ)).re * (p.eval (x : ℂ)).re) + δ ^ 2 * ((x : ℂ) * q.eval (x : ℂ)).re ^ 2 := by ring
          _ = (p.eval (x : ℂ)).re ^ 2 + 2 * δ * (x * (p.eval (x : ℂ) * q.eval (x : ℂ)).re) + δ ^ 2 * ‖(x : ℂ) * q.eval (x : ℂ)‖ ^ 2 := by rw [h2, h3]
          _ = (p.eval (x : ℂ)).re ^ 2 + δ * (2 * x * (p.eval (x : ℂ) * q.eval (x : ℂ)).re + δ * ‖(x : ℂ) * q.eval (x : ℂ)‖ ^ 2) := by ring
      have h_term_le_zero : 2 * x * (p.eval (x : ℂ) * q.eval (x : ℂ)).re + δ * ‖(x : ℂ) * q.eval (x : ℂ)‖ ^ 2 ≤ 0 := by
        have hx_le_a_half : x ≤ a / 2 := by
          have hd : dist x a ≤ r' := hx_ball
          have hd_abs : |x - a| ≤ r' := hd
          have hl : x - a ≤ |x - a| := le_abs_self (x - a)
          have hr'_min : r' ≤ -a / 2 := min_le_right _ _
