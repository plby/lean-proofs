              have h_max_eq : max_root p = (p.roots.toFinset.image (fun z => ‖z‖)).max.getD 0 := rfl
              -- Since max_root p > 0, the Finset is non-empty and max_root p is in it.
              have h_mem : max_root p ∈ p.roots.toFinset.image (fun z => ‖z‖) := by
                cases h_max : (p.roots.toFinset.image (fun z => ‖z‖)).max with
                | bot =>
                  have h_bot : (p.roots.toFinset.image (fun z => ‖z‖)).max.getD 0 = 0 := by
                    rw [h_max]; rfl
                  rw [h_bot] at h_max_eq
                  linarith [h_max_eq]
                | coe v =>
                  have h_coe : (p.roots.toFinset.image (fun z => ‖z‖)).max.getD 0 = v := by
                    rw [h_max]; rfl
                  rw [h_coe] at h_max_eq
                  have := Finset.mem_of_max h_max
                  rwa [← h_max_eq] at this
              -- So max_root p = ‖z‖ for some z ∈ p.roots
              simp only [Finset.mem_image, Multiset.mem_toFinset] at h_mem
              rcases h_mem with ⟨z, hz_root, hz_norm⟩
              -- Since z is a root, it is real and non-positive.
              have hz_real := hp_roots z hz_root
              have hz_im : z.im = 0 := hz_real.1
              have hz_re : z.re ≤ 0 := hz_real.2
              have hz_eq : z = -((max_root p : ℝ) : ℂ) := by
                apply Complex.ext
                · rw [← hz_norm]
                  have h_norm_re : ‖z‖ = -z.re := by
                    have h1 : ‖z‖ ^ 2 = z.re ^ 2 := by
                      calc ‖z‖ ^ 2 = Complex.normSq z := Complex.normSq_eq_norm_sq z |>.symm
                      _ = z.re * z.re + z.im * z.im := rfl
                      _ = z.re * z.re + 0 * 0 := by rw [hz_im]
                      _ = z.re ^ 2 := by ring
                    have h2 : 0 ≤ -z.re := by linarith
                    nlinarith [norm_nonneg z]
                  simp [h_norm_re]
                · simp [hz_im]
              -- Thus p.eval (-max_root p) = 0
              have h_p_z_zero : p.eval z = 0 := (Polynomial.mem_roots (hp_monic.ne_zero)).mp hz_root
              rw [hz_eq] at h_p_z_zero
              -- But a = -max_root p
              have h_a_eq : (a : ℂ) = -((max_root p : ℝ) : ℂ) := by
                have : a = -(max_root p : ℝ) := h.symm
                rw [this]
                push_cast
                rfl
              rw [← h_a_eq] at h_p_z_zero
              rw [h_p_z_zero] at h_one
              simp at h_one
            exact absurd ha_norm_one h_absurd
        -- Now a is in the open interval: (-max_root p, 0)
        -- h_sq_le_one: ‖p(y)‖ ≤ 1 for y ∈ Ioc (-max_root p, 0)
        -- h_local_max: a is local max of p.re²
        have h_local_max : IsLocalMax (fun x : ℝ => (p.eval (x : ℂ)).re ^ 2) a := by
          apply IsLocalMaxOn.isLocalMax (s := Set.Ioo (-max_root p) 0)
          · exact eventually_nhdsWithin_of_forall (fun x hx =>
              show (p.eval (x : ℂ)).re ^ 2 ≤ (p.eval (a : ℂ)).re ^ 2 from by
              simp only [Set.mem_Ioo] at hx
              have hx_norm := h_sq_le_one x hx.1 hx.2.le
              have hx_real : (p.eval (x : ℂ)).im = 0 := hp_real x
              have hx_re_sq : (p.eval (x : ℂ)).re ^ 2 ≤ 1 := by
                have h1 : ‖p.eval (x : ℂ)‖ ^ 2 ≤ 1 := by nlinarith [norm_nonneg (p.eval (x : ℂ))]
                rw [← Complex.normSq_eq_norm_sq, Complex.normSq_apply, hx_real, mul_zero, add_zero, ← sq] at h1
                exact h1
              nlinarith [ha_sq, hx_re_sq])
          · exact Ioo_mem_nhds h_a_gt_lower ha_lt_zero
        -- The real derivative of x ↦ p(x).re² at a is 0
