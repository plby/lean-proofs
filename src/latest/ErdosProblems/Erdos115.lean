lemma perturbed_roots_in_nhd (n : ℕ) (p q : Polynomial ℂ)
    (hp_monic : p.Monic) (hp_deg : p.degree = ↑n)
    (hq_deg : (Polynomial.X * q).degree < ↑n) (r : ℝ) (hr : r > 0)
    (h_small : ∀ z : ℂ, (∃ w ∈ p.roots, ‖z - w‖ < r) → ‖p.eval z‖ < 1 / 2) :
    ∃ ε₁ : ℝ, ε₁ > 0 ∧ ∀ δ : ℝ, 0 < δ ∧ δ ≤ ε₁ →
      ∀ w : ℂ, (p + Polynomial.C (δ : ℂ) * Polynomial.X * q).eval w = 0 →
        ∃ z ∈ p.roots, ‖w - z‖ < r := by
  by_contra h_contra;
