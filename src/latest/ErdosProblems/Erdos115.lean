          have hx_root : p.eval (x : ℂ) = 0 := by
            rw [← heq]
            have h_roots_ne : p.roots ≠ 0 := by
              intro h_empty
              have h_max : max_root p = 0 := by
                unfold max_root
                rw [h_empty]
                rfl
              linarith [h_max, ha.1, ha_lt_zero]
            let s := p.roots.toFinset.image (fun z => ‖z‖)
            have hs_ne : s.Nonempty := by
              apply Finset.Nonempty.image
              rwa [Multiset.toFinset_nonempty]
            obtain ⟨m, hm⟩ := Finset.max_of_nonempty hs_ne
            have hm_mem := Finset.mem_of_max hm
            rcases Finset.mem_image.mp hm_mem with ⟨z, hz_root, hz_norm⟩
