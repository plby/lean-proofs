      have hP_sq_le : ‖P δ x‖ ^ 2 ≤ 1 := by
        calc ‖P δ x‖ ^ 2 = (p.eval (x : ℂ)).re ^ 2 + δ * (2 * x * (p.eval (x : ℂ) * q.eval (x : ℂ)).re + δ * ‖(x : ℂ) * q.eval (x : ℂ)‖ ^ 2) := hP_expand
