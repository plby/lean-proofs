    have h_cont : ∃ M > 0, ∀ z : ℂ, (∃ w ∈ p.roots, ‖z - w‖ < r) → ‖z * q.eval z‖ ≤ M := by
      have h_compact : IsCompact {z : ℂ | ∃ w ∈ p.roots, ‖z - w‖ ≤ r} := by
