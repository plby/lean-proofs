          have := monic_norm_bound_on_interval hn ( ∏ k ∈ p.roots.toFinset, ( Polynomial.X - Polynomial.C ( k.re : ℂ ) ) ^ ( p.roots.count k ) ) ?_ ?_ a b hab <;> norm_num at *;
          · convert this using 4 ; norm_num [ Polynomial.eval_prod ];
            norm_cast;
          · exact Polynomial.monic_prod_of_monic _ _ fun x hx => Polynomial.monic_X_sub_C _ |> Polynomial.Monic.pow <| Polynomial.rootMultiplicity x p;
          · -- Since the polynomial is monic, the sum of the multiplicities of its roots is equal to its degree.
            have h_sum_multiplicities : ∑ k ∈ p.roots.toFinset, Polynomial.rootMultiplicity k p = n := by
              have h_sum_multiplicities : ∑ k ∈ p.roots.toFinset, Polynomial.rootMultiplicity k p = p.natDegree := by
                have h_sum_multiplicities : p = ∏ k ∈ p.roots.toFinset, (Polynomial.X - Polynomial.C k) ^ (Polynomial.rootMultiplicity k p) := by
                  convert (IsAlgClosed.splits p).eq_prod_roots_of_monic hp_monic;
                  · norm_num [ Finset.prod_multiset_map_count ];
                conv_rhs => rw [ h_sum_multiplicities ];
