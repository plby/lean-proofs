        convert mul_le_mul_of_nonneg_left ht.2 ( show ( 0 : ℝ ) ≤ ( ( b - a ) / 2 ) ^ n by exact pow_nonneg ( by linarith ) _ ) using 1 <;> norm_cast <;> norm_num
        focus
          ring_nf
        · cases n <;> norm_num [ pow_succ' ] at * ; ring_nf at *;
          simpa only [ mul_assoc, ← mul_pow ] using by ring;
        · norm_num [ ← mul_assoc, ← mul_pow, abs_of_pos ( sub_pos.mpr h_lt ) ];
          rw [ show ( b - a ) / 2 * ( 2 / ( b - a ) ) = 1 by rw [ mul_div, div_eq_iff ] <;> linarith ] ; norm_num

-- proven and Stated by Aristotle
lemma real_projection_bound {n : ℕ} (hn : n ≠ 0) {p : Polynomial ℂ} (hp_deg : p.degree = n) (hp_monic : p.Monic)
    (h_conn : IsConnected {z | ‖p.eval z‖ ≤ 1}) (h_zero : ‖p.eval 0‖ ≤ 1) :
    ∀ z, ‖p.eval z‖ ≤ 1 → |z.re| ≤ 4 := by
      -- Let $S = \{z \mid |p(z)| \le 1\}$. Since $S$ is connected and $p$ is continuous, $I = \text{Re}(S)$ is a connected subset of $\mathbb{R}$, i.e., an interval.
      let S := {z : ℂ | ‖p.eval z‖ ≤ 1}
      have hI_connected : IsConnected (Set.image Complex.re S) := by
        exact h_conn.image _ Complex.continuous_re.continuousOn;
      -- Since $q$ is a monic polynomial of degree $n$, if the length of $I$ is greater than 4, then $q$ would have to be bounded by 1 on an interval longer than 4, which contradicts the properties of monic polynomials.
      have h_contra : ∀ {a b : ℝ}, a < b → (b - a) > 4 → ¬(∀ x ∈ Set.Icc a b, ‖(∏ k ∈ p.roots.toFinset, (x - k.re) ^ (p.roots.count k))‖ ≤ 1) := by
        intros a b hab hlt h_bound
