            omega)
        · exact Complex.ofReal_ne_zero.mpr h_eps_pos.ne'
    have hP_valid : P ∈ ValidPolys n := by
      have hP_deg : P.degree = ↑n := by
        rw [Polynomial.degree_add_eq_left_of_degree_lt h_perturb_deg]
        exact hf_star_deg_n
      have hP_monic : P.Monic := by
        apply Polynomial.Monic.add_of_left hf_star_monic
        exact h_perturb_deg
      have hP_eval0 : ‖P.eval 0‖ = 1 := by
        simp [P, Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_C, Polynomial.eval_X]
        exact hf_star_eval0_norm
      have hP_conn : IsConnected {z | ‖P.eval z‖ ≤ 1} := by
        apply h_eps_conn_val
        exact ⟨h_eps_pos, min_le_left _ _⟩
      exact ⟨hP_deg, hP_monic, hP_eval0, hP_conn⟩
    exact (hf_star_extr_at_0 P hP_valid).not_gt (h_eps_deriv_val eps ⟨h_eps_pos, min_le_right _ _⟩)
  -- 5. f_star is Chebyshev
  have hf_star_is_cheb : f_star = extremal_polynomial n := extremal_is_chebyshev n hn f_star hf_star_valid (polynomial_star_roots_nonpositive f) hm_max
  -- 6. Final bound
  calc ‖p.derivative.eval 0‖
    _ ≤ ‖f.derivative.eval 0‖ := hf_extr p ⟨hp_deg, hp_monic, hp_zero, h_conn⟩
    _ ≤ ‖f_star.derivative.eval 0‖ := by
      apply polynomial_star_derivative_eval_zero f hf_valid.2.1
      have : ‖f.eval 0‖ = 1 := hf_valid.2.2.1
      intro h_eval0
      rw [h_eval0, norm_zero] at this
      norm_num at this
    _ = eremenko_bound n := by rw [hf_star_is_cheb]; exact extremal_polynomial_derivative_at_zero n hn
/--
If $p(z)$ is a polynomial of degree $n$ such that $\{z : \lvert p(z)\rvert\leq 1\}$ is connected then is it true that
\[\max_{\substack{z\in\mathbb{C}\\ \lvert p(z)\rvert\leq 1}} \lvert p'(z)\rvert \leq (\tfrac{1}{2}+o(1))n^2?\]
and that the Chebyshev polynomials are the extreme examples
-/
theorem eremenko_lempert_1999 (n : ℕ) :
    (n ≠ 0 → ∀ p : Polynomial ℂ, p.Monic → p.degree = n →
      IsConnected {z | ‖p.eval z‖ ≤ 1} →
      ∀ z, ‖p.eval z‖ ≤ 1 → ‖p.derivative.eval z‖ ≤ (2 : ℝ) ^ ((1 : ℝ) / n - 1) * (n : ℝ) ^ 2) ∧
    (n ≠ 0 → ‖(extremal_polynomial n).derivative.eval 0‖ = (2 : ℝ) ^ ((1 : ℝ) / n - 1) * (n : ℝ) ^ 2) := by
  have h_bound : (2 : ℝ) ^ ((1 : ℝ) / n - 1) * (n : ℝ) ^ 2 = eremenko_bound n := rfl
  rw [h_bound]
  exact ⟨eremenko_lempert_reduction n (eremenko_lempert_at_zero_proof n),
         extremal_polynomial_derivative_at_zero n⟩
#print axioms eremenko_lempert_1999
