          apply Complex.ext
          · rfl
          · simp [hx_real_p]
        have hB : (x : ℂ) * q.eval (x : ℂ) = ((x : ℂ) * q.eval (x : ℂ)).re := by
          apply Complex.ext
          · rfl
          · simp [hx_real_q]
