lemma complex_centerMass_re (s : Finset ℂ) (w : ℂ → ℝ) (z : ℂ → ℂ) :
    (s.centerMass w z).re = s.centerMass w (fun x => (z x).re) := by
  unfold Finset.centerMass
  refine (Complex.smul_re ((∑ i ∈ s, w i)⁻¹) (∑ i ∈ s, w i • z i)).trans ?_
  congr 1
  rw [Complex.re_sum]
  exact Finset.sum_congr rfl fun x hx => Complex.smul_re (w x) (z x)

lemma complex_centerMass_im (s : Finset ℂ) (w : ℂ → ℝ) (z : ℂ → ℂ) :
    (s.centerMass w z).im = s.centerMass w (fun x => (z x).im) := by
  unfold Finset.centerMass
  refine (Complex.smul_im ((∑ i ∈ s, w i)⁻¹) (∑ i ∈ s, w i • z i)).trans ?_
  congr 1
  rw [Complex.im_sum]
  exact Finset.sum_congr rfl fun x hx => Complex.smul_im (w x) (z x)

/-
The bound $(\tfrac{1}{2}+o(1))n^2$, specifically $2^{(1/n)-1}n^2$.
-/
noncomputable def eremenko_bound (n : ℕ) : ℝ := (2 : ℝ) ^ ((1 : ℝ) / n - 1) * (n : ℝ) ^ 2

/-
Theorem 1 implies the Main Theorem.
The Main Theorem states that for any monic polynomial $p$ of degree $n$ with connected level set $\{z : |p(z)| \le 1\}$, $|p'(z)| \le 2^{(1/n)-1}n^2$ for all $z$ in the level set.
Theorem 1 states the same bound but restricted to the case where $|p(0)|=1$ and evaluating the derivative at 0.
The reduction uses the translation invariance and the Maximum Modulus Principle.
-/
def EremenkoLempertAtZeroStatement (n : ℕ) : Prop :=
  n ≠ 0 → ∀ p : Polynomial ℂ, p.Monic → p.degree = n → ‖p.eval 0‖ = 1 →
  IsConnected {z | ‖p.eval z‖ ≤ 1} → ‖p.derivative.eval 0‖ ≤ eremenko_bound n

def EremenkoLempertStatement (n : ℕ) : Prop :=
  n ≠ 0 → ∀ p : Polynomial ℂ, p.Monic → p.degree = n →
  IsConnected {z | ‖p.eval z‖ ≤ 1} →
  ∀ z, ‖p.eval z‖ ≤ 1 → ‖p.derivative.eval z‖ ≤ eremenko_bound n

