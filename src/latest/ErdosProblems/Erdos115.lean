      have h_map_p : f_star = p_real.map (algebraMap ℝ ℂ) := by
        rw [hf_def, polynomial_star, Polynomial.map_multiset_prod, Multiset.map_map]
        apply congr_arg
        apply Multiset.map_congr rfl
        intro z hz
        rw [Function.comp_apply, Polynomial.map_add, Polynomial.map_X, Polynomial.map_C]
