  · intro k; rw [ Polynomial.eval_finsetSum, Finset.sum_eq_single k ] <;> simp_all +decide [ Polynomial.eval_prod, Finset.prod_eq_zero_iff, sub_eq_zero, ha_inj.eq_iff ] ;
    exact fun b hb => Or.inr ( Ne.symm hb )
/-
