            simp only [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_C, Polynomial.eval_X]
          calc Polynomial.eval (↑x) (p + (Polynomial.C (↑δ : ℂ)) * Polynomial.X * q)
