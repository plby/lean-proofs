  apply mul_nonpos_of_nonpos_of_nonneg
  · linarith [hx_neg]
  · have h_re_pq_ge : (p.eval (x : ℂ) * q.eval (x : ℂ)).re ≥ v_min_val := hv_min_bound hx_ball
    have h_delta_x_q_sq_ge : δ * x * ‖q.eval (x : ℂ)‖ ^ 2 ≥ - v_min_val := by
      have h_q_le_Mq : ‖q.eval (x : ℂ)‖ ≤ Mq := hMq x hx_ball
      rw [Set.mem_Icc] at hx_ball
      have h_x_bound : -x ≤ r' := by
        have h_mem := Set.mem_Icc.mp hx_ball
        linarith
      have h_q_sq_le : ‖q.eval (x : ℂ)‖ ^ 2 ≤ Mq ^ 2 := sq_le_sq.mpr (by
