/-
The set of valid polynomials for the extremal problem.
-/
noncomputable instance : TopologicalSpace (Polynomial ℂ) :=
  TopologicalSpace.induced (fun p => (p.coeff : ℕ → ℂ)) (Pi.topologicalSpace)

def ValidPolys (n : ℕ) : Set (Polynomial ℂ) :=
  { p | p.degree = n ∧ p.Monic ∧ ‖p.eval 0‖ = 1 ∧ IsConnected {z | ‖p.eval z‖ ≤ 1} }

-- proven and Stated by Aristotle
lemma monic_norm_bound_on_unit_interval {n : ℕ} (hn : n ≠ 0) (p : Polynomial ℂ) (hp_monic : p.Monic) (hp_deg : p.degree = n) :
    ∃ x ∈ Set.Icc (-1 : ℝ) 1, ‖p.eval (x : ℂ)‖ ≥ 1 / (2 : ℝ) ^ (n - 1) := by
      by_contra! h_contra;
      -- Let $u(x) = \Re(p(x))$. $u$ is a real polynomial of degree $n$.
      set u : Polynomial ℝ := ∑ k ∈ Finset.range (n + 1), Polynomial.monomial k (Complex.re (p.coeff k));
      -- Since $u$ is a real polynomial of degree $n$, we have $|u(x)| < 1/2^{n-1}$ for all $x \in [-1, 1]$.
      have hu_bound : ∀ x ∈ Set.Icc (-1 : ℝ) 1, |u.eval x| < 1 / 2 ^ (n - 1) := by
        intro x hx
        have hu_eval : u.eval x = Complex.re (p.eval (x : ℂ)) := by
          simp +zetaDelta at *;
          simp +decide [ Polynomial.eval_finsetSum, Polynomial.eval_monomial ];
          rw [ Polynomial.eval_eq_sum_range ] ; simp +decide [ Polynomial.natDegree_eq_of_degree_eq_some hp_deg]
          norm_cast ; norm_num;
        exact hu_eval.symm ▸ lt_of_le_of_lt ( Complex.abs_re_le_norm _ ) ( h_contra x hx );
      -- Consider the polynomial $q(x) = \frac{1}{2^{n-1}} T_n(x)$, where $T_n$ is the Chebyshev polynomial of the first kind.
      set q : Polynomial ℝ := Polynomial.C (1 / 2 ^ (n - 1)) * Polynomial.Chebyshev.T ℝ n;
      -- Since $q$ is a polynomial of degree $n$ with leading coefficient $1$, and $u$ is a polynomial of degree $n$ with leading coefficient $1$, their difference $u - q$ is a polynomial of degree less than $n$.
        have h_diff_deg : Polynomial.degree (u - q) < n := by
          have hp_natDegree : p.natDegree = n := Polynomial.natDegree_eq_of_degree_eq_some hp_deg
          have hp_coeff_n : p.coeff n = 1 := by
            rw [← hp_natDegree]
            exact hp_monic.coeff_natDegree
          have hu_coeff_n : u.coeff n = 1 := by
            simp [u, Polynomial.coeff_monomial, hp_coeff_n]
          have hu_degree_le : u.degree ≤ n := by
            change (∑ k ∈ Finset.range (n + 1), Polynomial.monomial k (p.coeff k).re).degree ≤ (n : WithBot ℕ)
            exact le_trans (Polynomial.degree_sum_le _ _) <|
              Finset.sup_le fun i hi =>
                (Polynomial.degree_monomial_le _ _).trans <|
                  WithBot.coe_le_coe.mpr (Nat.le_of_lt_succ (Finset.mem_range.mp hi))
          have hu_degree : u.degree = n :=
            Polynomial.degree_eq_of_le_of_coeff_ne_zero hu_degree_le (by simp [hu_coeff_n])
          have hu_ne_zero : u ≠ 0 := by
            intro hu_zero
            have := congr_arg (fun r : Polynomial ℝ => r.coeff n) hu_zero
            simp [hu_coeff_n] at this
          have hu_lc : u.leadingCoeff = 1 := by
            rw [Polynomial.leadingCoeff, Polynomial.natDegree_eq_of_degree_eq_some hu_degree]
            exact hu_coeff_n
          have hq_degree : q.degree = n := by
            have hc : (1 / 2 ^ (n - 1) : ℝ) ≠ 0 := by positivity
            change (Polynomial.C (1 / 2 ^ (n - 1)) * Polynomial.Chebyshev.T ℝ n).degree = (n : WithBot ℕ)
            rw [Polynomial.degree_C_mul hc]
            simp
          have h_chebyshev_leading_coeff :
              Polynomial.leadingCoeff (Polynomial.Chebyshev.T ℝ n) = 2 ^ (n - 1) := by
            simp
          have hq_lc : q.leadingCoeff = 1 := by
            change (Polynomial.C (1 / 2 ^ (n - 1)) * Polynomial.Chebyshev.T ℝ n).leadingCoeff = 1
            rw [Polynomial.leadingCoeff_mul, Polynomial.leadingCoeff_C, h_chebyshev_leading_coeff]
            field_simp [pow_ne_zero]
          have hdeg_eq : u.degree = q.degree := by rw [hu_degree, hq_degree]
          have hlc_eq : u.leadingCoeff = q.leadingCoeff := by rw [hu_lc, hq_lc]
          exact (Polynomial.degree_sub_lt hdeg_eq hu_ne_zero hlc_eq).trans_eq hu_degree
      -- By the properties of the Chebyshev polynomial, we know that $q(x_k) = \frac{(-1)^k}{2^{n-1}}$ for $x_k = \cos(k \pi / n)$, $k = 0, 1, \ldots, n$.
      have hq_values : ∀ k ∈ Finset.range (n + 1), q.eval (Real.cos (k * Real.pi / n)) = (-1 : ℝ) ^ k / 2 ^ (n - 1) := by
        simp +zetaDelta at *;
        intro k hk; rw [ mul_div_cancel₀ _ ( by positivity ) ] ; ring_nf; norm_num [ mul_assoc, mul_comm Real.pi _, hn ] ;
        exact Nat.recOn k ( by norm_num ) fun n ih => by simp +decide [ add_mul, pow_succ', ih ] ;
      -- Since $|u(x_k)| < 1/2^{n-1}$ and $|q(x_k)| = 1/2^{n-1}$, we have $u(x_k) - q(x_k)$ has the same sign as $-q(x_k)$.
      have h_diff_sign : ∀ k ∈ Finset.range (n + 1), (u.eval (Real.cos (k * Real.pi / n)) - q.eval (Real.cos (k * Real.pi / n))) * (-1) ^ (k + 1) > 0 := by
        intro k hk; specialize hu_bound ( Real.cos ( k * Real.pi / n ) ) ⟨ Real.neg_one_le_cos _, Real.cos_le_one _ ⟩ ; specialize hq_values k hk; simp_all +decide [ abs_lt ] ;
        by_cases h : Even k <;> simp_all +decide [ pow_succ' ] ; ring_nf at * ; nlinarith [ inv_pos.mpr ( pow_pos ( zero_lt_two' ℝ ) ( n - 1 ) ) ];
      -- Since $u - q$ is a polynomial of degree less than $n$ and changes sign $n+1$ times, it must have at least $n$ roots.
      have h_diff_roots : ∃ r : Finset ℝ, r.card ≥ n ∧ ∀ x ∈ r, (u - q).eval x = 0 := by
        -- By the properties of the intermediate value theorem, since $u - q$ changes sign $n+1$ times, it must have at least $n$ roots.
        have h_ivt : ∀ k ∈ Finset.range n, ∃ x ∈ Set.Ioo (Real.cos ((k + 1) * Real.pi / n)) (Real.cos (k * Real.pi / n)), (u - q).eval x = 0 := by
          intro k hk;
          have h_ivt : (u - q).eval (Real.cos ((k + 1) * Real.pi / n)) * (u - q).eval (Real.cos (k * Real.pi / n)) < 0 := by
