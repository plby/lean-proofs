    nlinarith [norm_nonneg ((p + Polynomial.C (δ : ℂ) * Polynomial.X * q).eval (x : ℂ))]
  rw [hP_expand]
  suffices 2 * x * (p.eval (x : ℂ) * q.eval (x : ℂ)).re + δ * ‖(x : ℂ) * q.eval (x : ℂ)‖ ^ 2 ≤ 0 by
    nlinarith [hx_re_sq_le]
  have h_factor : 2 * x * (p.eval (x : ℂ) * q.eval (x : ℂ)).re + δ * ‖(x : ℂ) * q.eval (x : ℂ)‖ ^ 2 = x * (2 * (p.eval (x : ℂ) * q.eval (x : ℂ)).re + δ * x * ‖q.eval (x : ℂ)‖ ^ 2) := by
    have h_norm_sq : ‖(x : ℂ) * q.eval (x : ℂ)‖ ^ 2 = x ^ 2 * ‖q.eval (x : ℂ)‖ ^ 2 := by
      rw [norm_mul, Complex.norm_real, Real.norm_eq_abs, mul_pow, sq_abs]
