            simp [Polynomial.Monic, Polynomial.leadingCoeff_C] at hp_monic
            simp [← hc_eq, hp_monic, map_one]
          rw [hp_one]
          simp only [Polynomial.roots_one]
          rfl
        linarith [ha.1, h_mr_zero.symm ▸ ha_lt_zero]
      -- Step 2: By h_sign, (q(a)*p(a)).re > 0
      have ha_sign : (q.eval (a : ℂ) * p.eval (a : ℂ)).re > 0 := h_sign _ h_a_in_crit
      -- Step 3: by continuity, there's a neighborhood of a where (q(x)*p(x)).re > 0
      have h_pq_cont : Continuous (fun x : ℝ => (p.eval (x : ℂ) * q.eval (x : ℂ)).re) := by
        apply Complex.continuous_re.comp
        exact (p.continuous.comp Complex.continuous_ofReal).mul
              (q.continuous.comp Complex.continuous_ofReal)
      -- (q(a)*p(a)).re > 0 in the form needed by continuity (reversed order of q and p)
      have ha_sign' : (p.eval (a : ℂ) * q.eval (a : ℂ)).re > 0 := by
        rw [mul_comm]; exact ha_sign
      obtain ⟨r, hr_pos, hr_ball⟩ : ∃ r > 0, ∀ x : ℝ, dist x a < r →
                (p.eval (x : ℂ) * q.eval (x : ℂ)).re > 0 := by
        have h_cont_at : ContinuousAt (fun x : ℝ => (p.eval (x : ℂ) * q.eval (x : ℂ)).re) a :=
          h_pq_cont.continuousAt
        rw [Metric.continuousAt_iff] at h_cont_at
        have hv := ha_sign'
        set v := (p.eval (a : ℂ) * q.eval (a : ℂ)).re with hv_def
        have hv_pos : v > 0 := hv
        obtain ⟨r, hr_pos, hr⟩ := h_cont_at (v / 2) (by linarith)
        exact ⟨r, hr_pos, fun x hx => by
          have hd := hr hx
          rw [Real.dist_eq, hv_def] at hd
          have := (abs_lt.mp hd).1
          linarith⟩
      -- Step 4: For x ∈ ball(a, r) ∩ segment with x ≤ 0,
      --   ‖P(δ,x)‖² = ‖p(x) + δ x q(x)‖²
      --   = ‖p(x)‖² + 2δ x Re(p(x)q(x)) + δ² x² ‖q(x)‖²
      --   ≤ 1 + 2δ x Re(p(x)q(x)) + δ² x² ‖q(x)‖²  (since ‖p(x)‖ ≤ 1)
      -- Since x ≤ 0 and Re(p(x)q(x)) > 0, the term 2δ x Re(p(x)q(x)) ≤ 0.
      -- The δ² term needs to be bounded: we can pick ε = -a * Re(p(a)q(a)) / (r² M_q²) or similar.
      -- Full implementation requires polynomial degree bounds on q. Leave as ryry.
      -- We have x * q(x) is continuous, so it is bounded on a compact neighborhood of a.
