      nlinarith [hP_sq_le, hP_norm_nonneg]
  -- Step 2: Away from critical points, |p(a)| < 1, so by continuity there's a neighborhood
  -- and an epsilon where |P(x)| <= 1
  have h_noncrit_nhd : ∀ a ∈ Set.Icc (-(max_root p : ℝ)) 0, ‖p.eval (a : ℂ)‖ < 1 →
    ∃ ε_a > 0, ∃ U_a ∈ nhds a, ∀ δ > 0, δ ≤ ε_a → ∀ x ∈ U_a ∩ Set.Icc (-(max_root p : ℝ)) 0, ‖P δ x‖ ≤ 1 := by
    intro a ha ha_lt_one
    have h_margin_pos : (1 - ‖p.eval (a : ℂ)‖) / 2 > 0 := by linarith [ha_lt_one]
    let margin := (1 - ‖p.eval (a : ℂ)‖) / 2
    -- p is continuous, so there's a neighborhood where |p(x)| < 1 - margin
    have h_p_cont : Continuous (fun x : ℝ => ‖p.eval (x : ℂ)‖) := by
      exact continuous_norm.comp (p.continuous.comp Complex.continuous_ofReal)
    have h_p_nhd_pred : {x : ℝ | ‖p.eval (x : ℂ)‖ < 1 - margin} ∈ nhds a := by
      have h1 : IsOpen {x : ℝ | ‖p.eval (x : ℂ)‖ < 1 - margin} :=
        isOpen_lt h_p_cont continuous_const
      have h2 : a ∈ {x : ℝ | ‖p.eval (x : ℂ)‖ < 1 - margin} := by
        simp only [Set.mem_setOf_eq]
        have h_eval_a : ‖p.eval (a : ℂ)‖ < 1 - (1 - ‖p.eval (a : ℂ)‖) / 2 := by linarith [ha_lt_one]
        exact h_eval_a
      exact IsOpen.mem_nhds h1 h2
    -- x * q(x) is continuous, so it's bounded on the compact neighborhood [a - 1, a + 1]
    have h_q_cont : Continuous (fun x : ℝ => ‖(x : ℂ) * q.eval (x : ℂ)‖) := by
      have hc1 : Continuous (fun x : ℝ => (x : ℂ)) := Complex.continuous_ofReal
      have hc2 : Continuous (fun x : ℝ => q.eval (x : ℂ)) := q.continuous.comp Complex.continuous_ofReal
      exact continuous_norm.comp (hc1.mul hc2)
    have h_compact_a : IsCompact (Metric.closedBall a 1) := isCompact_closedBall a 1
    obtain ⟨M, hM_bound⟩ := h_compact_a.exists_bound_of_continuousOn h_q_cont.continuousOn
    have hM_pos : M + 1 > 0 := by
      have hb := hM_bound a (Metric.mem_closedBall_self (by norm_num))
      rw [norm_norm] at hb
      have hn : 0 ≤ ‖(a : ℂ) * q.eval (a : ℂ)‖ := norm_nonneg _
      have hm_ge_zero : 0 ≤ M := le_trans hn hb
      linarith
    -- Choose U_a to be intersection of the two condition neighborhoods
    let U_a : Set ℝ := {x | ‖p.eval (x : ℂ)‖ < 1 - margin} ∩ Metric.closedBall a 1
    have hU_a_nhd : U_a ∈ nhds a := Filter.inter_mem h_p_nhd_pred (Metric.closedBall_mem_nhds a (by norm_num))
    use margin / (M + 1)
    constructor
    · exact div_pos h_margin_pos hM_pos
    · use U_a
      constructor
      · exact hU_a_nhd
      · intro δ hδ_pos hδ_le x ⟨⟨hx_p, hx_ball⟩, _⟩
        have h_perturb : ‖(x : ℂ) * q.eval (x : ℂ)‖ ≤ M + 1 := by
          have h1 := hM_bound x hx_ball
          rw [norm_norm] at h1
          linarith
        have h_P_def : P δ x = p.eval (x : ℂ) + (δ : ℂ) * ((x : ℂ) * q.eval (x : ℂ)) := by
          simp only [P, Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_C, Polynomial.eval_X]
          ring
        rw [h_P_def]
        have h_triangle := norm_add_le (p.eval (x : ℂ)) ((δ : ℂ) * ((x : ℂ) * q.eval (x : ℂ)))
        have h_norm_mul : ‖(δ : ℂ) * ((x : ℂ) * q.eval (x : ℂ))‖ = ‖(δ : ℂ)‖ * ‖(x : ℂ) * q.eval (x : ℂ)‖ := norm_mul _ _
        have h_norm_delta : ‖(δ : ℂ)‖ = δ :=
          Eq.trans (Complex.norm_real δ) (abs_of_pos hδ_pos)
        rw [h_norm_mul, h_norm_delta] at h_triangle
        have h_delta_bound : δ * ‖(x : ℂ) * q.eval (x : ℂ)‖ ≤ margin := by
          have h1 : δ * ‖(x : ℂ) * q.eval (x : ℂ)‖ ≤ (margin / (M + 1)) * (M + 1) := by
            apply mul_le_mul hδ_le h_perturb (norm_nonneg _) (le_of_lt (div_pos h_margin_pos hM_pos))
          rwa [div_mul_cancel₀ _ (ne_of_gt hM_pos)] at h1
        have h_p_bound : ‖p.eval (x : ℂ)‖ < 1 - margin := hx_p
        linarith
  -- Step 3: Combine the two cases to get a neighborhood and epsilon for *every* point in the segment
  -- Note that |p(a)| <= 1 for all a in the segment, because the segment is in the connected level set.
  have h_local_bound : ∀ a ∈ Set.Icc (-(max_root p : ℝ)) 0,
    ∃ ε_a > 0, ∃ U_a ∈ nhds a, ∀ δ > 0, δ ≤ ε_a → ∀ x ∈ U_a ∩ Set.Icc (-(max_root p : ℝ)) 0, ‖P δ x‖ ≤ 1 := by
    intro a ha
    have h_a_mem_Seg : (a : ℂ) ∈ (Complex.ofReal '' Set.Icc (-(max_root p : ℝ)) 0) :=
      Set.mem_image_of_mem Complex.ofReal ha
    have h_a_level : ‖p.eval (a : ℂ)‖ ≤ 1 := by
      -- p has real non-positive roots, so p = p^*
      have h_p_eq_star : p = polynomial_star p := by
        have h_p_prod : p = (p.roots.map (fun z => Polynomial.X - Polynomial.C z)).prod := by
          have h1 : p = Polynomial.C p.leadingCoeff * (p.roots.map (fun z => Polynomial.X - Polynomial.C z)).prod := by
            exact (IsAlgClosed.splits p).eq_prod_roots
          rwa [hp_monic.leadingCoeff, Polynomial.C_1, one_mul] at h1
        have h_map_eq : Multiset.map (fun z => Polynomial.X + Polynomial.C (Complex.ofReal ‖z‖)) p.roots =
                        Multiset.map (fun z => Polynomial.X - Polynomial.C z) p.roots := by
          apply Multiset.map_congr rfl
          intro z hz
          have hz_real : z.im = 0 := (hp_roots z hz).1
          have hz_nonpos : z.re ≤ 0 := (hp_roots z hz).2
          have h_norm : (Complex.ofReal ‖z‖) = -z := by
            apply Complex.ext
            · simp [Complex.norm_def, Complex.normSq_apply, hz_real]
              rw [← sq z.re]
              rw [Real.sqrt_sq_eq_abs, abs_of_nonpos hz_nonpos]
            · simp [hz_real]
          rw [h_norm, Polynomial.C_neg, sub_eq_add_neg]
        have h_star_def : polynomial_star p = (Multiset.map (fun z => Polynomial.X + Polynomial.C (Complex.ofReal ‖z‖)) p.roots).prod := rfl
        rw [h_star_def, h_map_eq, ← h_p_prod]
      rw [h_p_eq_star]
      -- Let r = -a. Since a ∈ [-max_root p, 0], r ∈ [0, max_root p]
      let r : ℝ := -a
      have hr_pos : 0 ≤ r := by
        dsimp [r]
        linarith [ha.2]
      have hr_le : r ≤ max_root p := by
        dsimp [r]
        linarith [ha.1]
      -- Since a = -r, we want bounds on ‖(polynomial_star p).eval (-r)‖
      -- By polynomial_star_neg_r_le_min_modulus, it is bounded by min_modulus p r
      have h_star_le_min := polynomial_star_neg_r_le_min_modulus p hp_monic r hr_pos
      -- By min_modulus_le_one_of_connected, min_modulus p r ≤ 1
      have h_min_le_one := min_modulus_le_one_of_connected p h_zero hp_conn r hr_pos hr_le
      -- Combining these, ‖(polynomial_star p).eval a‖ ≤ 1
      have h_a_eq_neg_r : (a : ℂ) = -(r : ℂ) := by
        dsimp [r]
        norm_cast
        ring
      rw [h_a_eq_neg_r]
      exact le_trans h_star_le_min h_min_le_one
    rcases le_iff_eq_or_lt.mp h_a_level with h_eq | h_lt
    · exact h_crit_nhd a ha h_eq
    · exact h_noncrit_nhd a ha h_lt
  -- Let us extract the choice functions explicitly so we don't fight Classical.choose
  -- We use the Subtype for the segment to make the choice functions clean
  have h_local_bound' : ∀ a : Set.Icc (-(max_root p : ℝ)) 0,
    ∃ (ε_a : ℝ) (U_a : Set ℝ), ε_a > 0 ∧ U_a ∈ nhds (a : ℝ) ∧
      ∀ δ > 0, δ ≤ ε_a → ∀ x ∈ U_a ∩ Set.Icc (-(max_root p : ℝ)) 0, ‖P δ x‖ ≤ 1 := by
    intro ⟨a, ha⟩
    obtain ⟨ε_a, hε_a_pos, U_a, hU_a_nhd, h_bound⟩ := h_local_bound a ha
    exact ⟨ε_a, U_a, hε_a_pos, hU_a_nhd, h_bound⟩
  choose ε U hε_pos hU_nhds h_bounds using h_local_bound'
  -- Step 4: By compactness, extract a finite subcover from the neighborhoods U_a
  have h_finite_subcover : ∃ t : Finset (Set.Icc (-(max_root p : ℝ)) 0),
    (Set.Icc (-(max_root p : ℝ)) 0 ⊆ ⋃ a ∈ t, U a) := by
    have h_open : ∀ a : Set.Icc (-(max_root p : ℝ)) 0, IsOpen (interior (U a)) := fun _ => isOpen_interior
    have h_cover : Set.Icc (-(max_root p : ℝ)) 0 ⊆ ⋃ a : Set.Icc (-(max_root p : ℝ)) 0, interior (U a) := by
      intro x hx
      simp only [Set.mem_iUnion]
      use ⟨x, hx⟩
      exact mem_interior_iff_mem_nhds.mpr (hU_nhds ⟨x, hx⟩)
    obtain ⟨t, ht⟩ := isCompact_Icc.elim_finite_subcover _ h_open h_cover
    use t
    exact ht.trans (Set.iUnion₂_mono (fun a _ => interior_subset))
  -- Step 5: Take the minimum of the finitely many epsilons
  -- We can redefine h_min_eps using the obtained t
  have h_min_eps_t : ∀ t : Finset (Set.Icc (-(max_root p : ℝ)) 0), ∃ ε₃ > 0, ∀ a ∈ t, ε₃ ≤ ε a := by
    intro t
    by_cases h_empty : t = ∅
    · use 1, by norm_num
      intro a ha; exfalso; exact Finset.notMem_empty a (h_empty ▸ ha)
    · have h_pos : ∀ a ∈ t, 0 < ε a := fun a _ => hε_pos a
      have h_nonempty : (t.image ε).Nonempty := by
        obtain ⟨a, ha⟩ := Finset.nonempty_iff_ne_empty.mpr h_empty
        exact ⟨ε a, Finset.mem_image_of_mem _ ha⟩
      use (t.image ε).min' h_nonempty
      constructor
      · have h_min_mem := Finset.min'_mem (t.image ε) h_nonempty
        obtain ⟨a, ha_t, ha_eq⟩ := Finset.mem_image.mp h_min_mem
        rw [← ha_eq]
        exact h_pos a ha_t
      · intro a ha_t
        exact Finset.min'_le _ _ (Finset.mem_image_of_mem ε ha_t)
  -- Step 6: Assemble the final proof
  obtain ⟨t, ht_cover⟩ := h_finite_subcover
  obtain ⟨ε₃, hε₃_pos, hε₃_le⟩ := h_min_eps_t t
  exact ⟨ε₃, hε₃_pos, fun δ ⟨hδ_pos, hδ_le⟩ x hx => by
    have hx_cov := ht_cover hx
    simp only [Set.mem_iUnion] at hx_cov
    obtain ⟨a, ha_t, hx_Ua⟩ := hx_cov
    have h_x_in_Ua : x ∈ U a ∩ Set.Icc (-(max_root p : ℝ)) 0 := ⟨hx_Ua, hx⟩
    have hδ_le_εa : δ ≤ ε a := le_trans hδ_le (hε₃_le a ha_t)
    exact h_bounds a δ hδ_pos hδ_le_εa x h_x_in_Ua⟩
/-
For small `δ`, there exists a connected set `S` that is contained in the level set of `P`,
and contains all roots of `P`.
-/
lemma combined_set_connected_in_level_set (n : ℕ) (p q : Polynomial ℂ)
    (hp_monic : p.Monic) (hp_deg : p.degree = ↑n)
    (hq_deg : (Polynomial.X * q).degree < ↑n)
    (hp_real : ∀ x : ℝ, (p.eval (x : ℂ)).im = 0)
    (hq_real : ∀ x : ℝ, (q.eval (x : ℂ)).im = 0)
    (hp_roots : RealRootedNonpositive p)
    (hp_conn : IsConnected {z | ‖p.eval z‖ ≤ 1})
    (h_zero : ‖p.eval 0‖ ≤ 1)
    (h_sign : ∀ z ∈ (critical_points_with_val_one p), (q.eval z * p.eval z).re > 0)
    (h0_sign : (q.eval 0 * p.eval 0).re > 0) :
    ∃ ε₄ : ℝ, ε₄ > 0 ∧ ∀ δ : ℝ, 0 < δ ∧ δ ≤ ε₄ →
      ∃ S : Set ℂ, IsConnected S ∧
        S ⊆ {z | ‖(p + Polynomial.C (δ : ℂ) * Polynomial.X * q).eval z‖ ≤ 1} ∧
        ∀ w : ℂ, (p + Polynomial.C (δ : ℂ) * Polynomial.X * q).eval w = 0 → w ∈ S := by
  -- Step 2: Get radius r around roots of p where ‖p‖ < 1/2
  obtain ⟨r, hr_pos, hr_small⟩ := roots_nhd_small_modulus p
  -- Step 3: Get ε₁ s.t. for δ ≤ ε₁, all roots of P are within r of some root of p
  obtain ⟨ε₁, hε₁_pos, hε₁⟩ := perturbed_roots_in_nhd n p q hp_monic hp_deg hq_deg r hr_pos hr_small
  -- Step 4: Get ε₂ s.t. for δ ≤ ε₂, ‖P(z)‖ < 1 on N
  obtain ⟨ε₂, hε₂_pos, hε₂⟩ := perturbed_small_on_nhd p q r hr_small
  -- Step 5: Get ε₃ s.t. for δ ≤ ε₃, ‖P(x)‖ ≤ 1 on the segment [-max_root p, 0]
  obtain ⟨ε₃, hε₃_pos, hε₃⟩ :=
    perturbed_le_one_on_segment n p q hp_monic hp_deg hp_real hq_real hp_roots hp_conn h_zero h_sign h0_sign
  -- Step 6: Take ε₄ = min of all three epsilons
  use min (min ε₁ ε₂) ε₃
  constructor
  · positivity
  intro δ ⟨hδ_pos, hδ_le⟩
  -- Unpack the three ε-bounds
  have hδ_le₁ : δ ≤ ε₁ := le_trans hδ_le ((min_le_left _ _).trans (min_le_left _ _))
  have hδ_le₂ : δ ≤ ε₂ := le_trans hδ_le ((min_le_left _ _).trans (min_le_right _ _))
  have hδ_le₃ : δ ≤ ε₃ := le_trans hδ_le (min_le_right _ _)
  -- Define S = N ∪ Seg where N is the union of balls around roots and Seg is the real segment
  let N : Set ℂ := ⋃ w ∈ p.roots.toFinset, Metric.ball w r
  let Seg : Set ℂ := Complex.ofReal '' Set.Icc (-(max_root p : ℝ)) 0
  use N ∪ Seg
  -- Property 1: S is connected
  have hSeg_conn : IsConnected Seg := by
    apply IsConnected.image
    · have h_max_root_nonneg : 0 ≤ max_root p := by
        unfold max_root
        generalize h_max : (p.roots.toFinset.image (fun z => ‖z‖)).max = opt
        cases opt
        · exact le_refl (0 : ℝ)
        · case coe m =>
          have hm : m ∈ p.roots.toFinset.image (fun z => ‖z‖) := Finset.mem_of_max h_max
          rcases Finset.mem_image.mp hm with ⟨w, _, rfl⟩
          exact norm_nonneg w
      exact isConnected_Icc (neg_nonpos_of_nonneg h_max_root_nonneg)
    · exact Complex.continuous_ofReal.continuousOn
  have hS_conn : IsConnected (N ∪ Seg) := by
    -- We show N ∪ Seg is connected by induction on the finite set of roots
    -- We start with Seg (which is connected) and add (ball w r) for each root w
    -- Since w ∈ Seg and w ∈ ball w r, the intersection is non-empty, so the union remains connected
    have h_union : N ∪ Seg = (⋃ w ∈ p.roots.toFinset, Metric.ball w r) ∪ Seg := rfl
    rw [h_union]
    have h_induction : ∀ s : Finset ℂ, s ⊆ p.roots.toFinset → IsConnected ((⋃ w ∈ s, Metric.ball w r) ∪ Seg) := by
      intro s hs
      induction s using Finset.induction_on with
      | empty =>
        simp [hSeg_conn]
      | insert w s hw ih =>
        rw [Finset.set_biUnion_insert, Set.union_assoc]
        have h_ball_conn : IsConnected (Metric.ball w r) := Metric.isConnected_ball hr_pos
        have hw_ball : w ∈ Metric.ball w r := Metric.mem_ball_self hr_pos
        have hw_seg : w ∈ Seg := by
          have hp_ne_zero : p ≠ 0 := by
            intro hp_zero
            have h_deg : p.degree = ⊥ := by simp [hp_zero]
            have h_bot : (n : WithBot ℕ) = ⊥ := hp_deg.symm.trans h_deg
            exact WithBot.coe_ne_bot h_bot
          have hw_mem : w ∈ p.roots := Multiset.mem_toFinset.mp (hs (Finset.mem_insert_self w s))
          have hw_root : (p.eval w) = 0 := (Polynomial.mem_roots hp_ne_zero).mp hw_mem
          have hw_re : w.im = 0 := (hp_roots w hw_mem).1
          have hw_nonpos : w.re ≤ 0 := (hp_roots w hw_mem).2
          have hw_bound : -max_root p ≤ w.re := by
            have h_mem_image : ‖w‖ ∈ p.roots.toFinset.image (fun z => ‖z‖) :=
              Finset.mem_image_of_mem _ (hs (Finset.mem_insert_self w s))
            have h_norm_le : ‖w‖ ≤ max_root p := by
              unfold max_root
              have h_le := Finset.le_max h_mem_image
              generalize hm : (p.roots.toFinset.image (fun z => ‖z‖)).max = opt
              rw [hm] at h_le
              cases opt
              · exact False.elim (Finset.notMem_empty _ (Finset.max_eq_bot.mp hm ▸ h_mem_image))
              · case coe m =>
                exact WithBot.coe_le_coe.mp h_le
            have h_re_norm : ‖w‖ = -w.re := by
              have h1 : ‖w‖ = Real.sqrt (w.re * w.re + w.im * w.im) := by
                rw [Complex.norm_def, Complex.normSq_apply]
              rw [hw_re] at h1
              simp only [mul_zero, add_zero] at h1
              rw [← sq, Real.sqrt_sq_eq_abs, abs_of_nonpos hw_nonpos] at h1
              exact h1
            linarith
          exact ⟨w.re, ⟨hw_bound, hw_nonpos⟩, Complex.ext rfl (hw_re.symm)⟩
        have hw_accum : w ∈ (⋃ w ∈ s, Metric.ball w r) ∪ Seg := Set.mem_union_right _ hw_seg
        exact h_ball_conn.union ⟨w, hw_ball, hw_accum⟩ (ih (fun x hx => hs (Finset.mem_insert_of_mem hx)))
    exact h_induction p.roots.toFinset (fun _ h => h)
  -- Property 2: S ⊆ {‖P‖ ≤ 1}
  have hS_sub : N ∪ Seg ⊆ {z | ‖(p + Polynomial.C (δ : ℂ) * Polynomial.X * q).eval z‖ ≤ 1} := by
    intro z hz
    rcases hz with hz_N | hz_Seg
    · -- z ∈ N: apply hε₂
      simp only [N, Set.mem_iUnion, Metric.mem_ball] at hz_N
      obtain ⟨w, hw_mem, hw_dist⟩ := hz_N
      exact le_of_lt (hε₂ δ ⟨hδ_pos, hδ_le₂⟩ z
        ⟨w, Multiset.mem_toFinset.mp hw_mem, by simpa [dist_eq_norm] using hw_dist⟩)
    · -- z ∈ Seg: apply hε₃
      simp only [Seg, Set.mem_image] at hz_Seg
      obtain ⟨x, hx_mem, hx_eq⟩ := hz_Seg
      have h_bound := hε₃ δ ⟨hδ_pos, hδ_le₃⟩ x hx_mem
      rwa [hx_eq] at h_bound
  -- Property 3: every root of P lies in S (in fact in N)
  have hS_roots : ∀ w : ℂ, (p + Polynomial.C (δ : ℂ) * Polynomial.X * q).eval w = 0 → w ∈ N ∪ Seg := by
    intro w hw_root
    have hw_in_N : w ∈ N := by
      simp only [N, Set.mem_iUnion, Metric.mem_ball]
      obtain ⟨z, hz_roots, hz_dist⟩ := hε₁ δ ⟨hδ_pos, hδ_le₁⟩ w hw_root
      exact ⟨z, Multiset.mem_toFinset.mpr hz_roots, by simpa [dist_eq_norm] using hz_dist⟩
    exact Set.mem_union_left _ hw_in_N
  exact ⟨hS_conn, hS_sub, hS_roots⟩
/-
If a connected set `S` is contained in the level set `{‖p‖ ≤ 1}` and contains all roots of `p`,
then the full level set is connected. Uses the minimum principle.
Proven by Aristotle
-/
lemma level_set_connected_of_roots_in_connected_subset (p : Polynomial ℂ)
    (hp : p.Monic) (hp_deg : p.degree ≠ 0)
    (S : Set ℂ) (hS_conn : IsConnected S)
    (hS_sub : S ⊆ {z | ‖p.eval z‖ ≤ 1})
    (hS_roots : ∀ w : ℂ, p.eval w = 0 → w ∈ S) :
    IsConnected {z | ‖p.eval z‖ ≤ 1} := by
  -- Assume there exists a point $z_0$ in $\{ \|p(z)\| \leq 1 \}$ that is not in the connected component of $\{ \|p(z)\| \leq 1 \}$ containing $S$.
  by_contra h_contra
  obtain ⟨z₀, hz₀⟩ : ∃ z₀, z₀ ∈ {z | ‖p.eval z‖ ≤ 1} ∧ ¬(z₀ ∈ connectedComponentIn {z | ‖p.eval z‖ ≤ 1} (Classical.choose (hS_conn.nonempty))) := by
    contrapose! h_contra with h_contra
    generalize_proofs at *; (
    exact ⟨ ⟨ _, hS_sub hS_conn.nonempty.some_mem ⟩, isPreconnected_of_forall_pair fun x hx y hy => by
      use connectedComponentIn {z | ‖p.eval z‖ ≤ 1} (Classical.choose (hS_conn.nonempty));
      exact ⟨ connectedComponentIn_subset _ _, h_contra x hx, h_contra y hy, isPreconnected_connectedComponentIn ⟩ ⟩);
  -- By the maximum modulus principle, $|p|$ attains its minimum on the boundary of $K$.
  have h_min_boundary : ∃ w ∈ frontier (connectedComponentIn {z | ‖p.eval z‖ ≤ 1} z₀), ∀ z ∈ connectedComponentIn {z | ‖p.eval z‖ ≤ 1} z₀, ‖p.eval w‖ ≤ ‖p.eval z‖ := by
    have h_min_boundary : IsCompact (closure (connectedComponentIn {z | ‖p.eval z‖ ≤ 1} z₀)) := by
      have h_bounded : Bornology.IsBounded {z | ‖p.eval z‖ ≤ 1} := by
        have h_bounded : Filter.Tendsto (fun z => ‖p.eval z‖) (Filter.cocompact ℂ) Filter.atTop := by
          apply_rules [ Polynomial.tendsto_norm_atTop ];
          · exact lt_of_le_of_ne ( le_of_not_gt fun h => by aesop ) ( Ne.symm hp_deg );
          · exact tendsto_norm_cocompact_atTop;
        have := h_bounded.eventually_gt_atTop 1;
        rw [ Filter.eventually_iff ] at this;
        rw [ Filter.mem_cocompact ] at this;
        obtain ⟨ t, ht₁, ht₂ ⟩ := this; exact ht₁.isBounded.subset fun x hx => by_contra fun hx' => not_le_of_gt ( ht₂ hx' ) hx.out;
      refine ( Metric.isCompact_iff_isClosed_bounded.mpr ?_ );
      exact ⟨ isClosed_closure, h_bounded.closure.subset <| closure_mono <| connectedComponentIn_subset _ _ ⟩;
    have h_min_boundary : ∃ w ∈ closure (connectedComponentIn {z | ‖p.eval z‖ ≤ 1} z₀), ∀ z ∈ closure (connectedComponentIn {z | ‖p.eval z‖ ≤ 1} z₀), ‖p.eval w‖ ≤ ‖p.eval z‖ := by
      have h_min_boundary : ContinuousOn (fun z => ‖p.eval z‖) (closure (connectedComponentIn {z | ‖p.eval z‖ ≤ 1} z₀)) := by
        exact p.continuous.norm.continuousOn;
      have := ‹IsCompact ( closure ( connectedComponentIn { z | ‖Polynomial.eval z p‖ ≤ 1 } z₀ ) ) ›.exists_isMinOn ⟨ z₀, subset_closure <| mem_connectedComponentIn <| by aesop ⟩ h_min_boundary;
      exact ⟨ this.choose, this.choose_spec.1, fun z hz => this.choose_spec.2 hz ⟩;
    obtain ⟨ w, hw₁, hw₂ ⟩ := h_min_boundary;
    by_cases hw₃ : w ∈ interior (connectedComponentIn {z | ‖p.eval z‖ ≤ 1} z₀);
    · have h_min_boundary : ‖p.eval w‖ = 0 := by
        have h_min_boundary : ∀ᶠ z in nhds w, ‖p.eval z‖ ≥ ‖p.eval w‖ := by
          exact Filter.mem_of_superset ( IsOpen.mem_nhds ( isOpen_interior ) hw₃ ) fun z hz => hw₂ z <| subset_closure <| interior_subset hz;
        have h_min_boundary : p.eval w = 0 := by
          apply Classical.byContradiction
          intro h_nonzero;
          exact absurd ( polynomial_no_local_min_nonzero p w hp_deg h_nonzero ) ( by tauto );
        aesop;
      have h_min_boundary : w ∈ S := by
        aesop;
      have h_min_boundary : connectedComponentIn {z | ‖p.eval z‖ ≤ 1} z₀ = connectedComponentIn {z | ‖p.eval z‖ ≤ 1} (Classical.choose (hS_conn.nonempty)) := by
        have h_min_boundary : w ∈ connectedComponentIn {z | ‖p.eval z‖ ≤ 1} z₀ ∧ w ∈ connectedComponentIn {z | ‖p.eval z‖ ≤ 1} (Classical.choose (hS_conn.nonempty)) := by
          exact ⟨ interior_subset hw₃, by exact mem_connectedComponentIn ( by aesop ) |> fun h => by exact (by
          have := Classical.choose_spec ( hS_conn.nonempty );
          have h_min_boundary : IsPreconnected (S : Set ℂ) := by
            exact hS_conn.isPreconnected;
          exact h_min_boundary.subset_connectedComponentIn ( by aesop ) ( by aesop ) ‹w ∈ S›) ⟩;
        rw [ connectedComponentIn_eq h_min_boundary.1, connectedComponentIn_eq h_min_boundary.2 ];
      exact False.elim <| hz₀.2 <| h_min_boundary ▸ mem_connectedComponentIn ( by aesop );
    · exact ⟨ w, ⟨ hw₁, hw₃ ⟩, fun z hz => hw₂ z <| subset_closure hz ⟩;
  obtain ⟨ w, hw₁, hw₂ ⟩ := h_min_boundary;
  -- Since $w$ is on the boundary of the connected component of $\{ \|p(z)\| \leq 1 \}$ containing $z₀$, we have $|p(w)| = 1$.
  have hw_boundary : ‖p.eval w‖ = 1 := by
    apply_rules [ boundary_component_subset_boundary_level_set ];
  -- Since $|p(w)| = 1$, by the maximum modulus principle, $|p(z)| \geq 1$ for all $z$ in the connected component of $\{ \|p(z)\| \leq 1 \}$ containing $z₀$.
  have hw_ge_one : ∀ z ∈ connectedComponentIn {z | ‖p.eval z‖ ≤ 1} z₀, ‖p.eval z‖ ≥ 1 := by
    exact fun z hz => hw_boundary ▸ hw₂ z hz;
  -- Since $|p(z)| \geq 1$ for all $z$ in the connected component of $\{ \|p(z)\| \leq 1 \}$ containing $z₀$, and $|p(z₀)| \leq 1$, it follows that $|p(z)| = 1$ for all $z$ in the connected component of $\{ \|p(z)\| \leq 1 \}$ containing $z₀$.
  have hw_eq_one : ∀ z ∈ connectedComponentIn {z | ‖p.eval z‖ ≤ 1} z₀, ‖p.eval z‖ = 1 := by
    exact fun z hz => le_antisymm ( by exact connectedComponentIn_subset _ _ hz |> fun h => h.out ) ( hw_ge_one z hz );
  -- Since $|p(z)| = 1$ for all $z$ in the connected component of $\{ \|p(z)\| \leq 1 \}$ containing $z₀$, and $p$ is non-constant, this contradicts the fact that $p$ is non-constant.
  have h_contradiction : ∃ c : ℂ, p = Polynomial.C c := by
    apply modulus_eq_one_on_component_implies_const p z₀ (by
    exact hz₀.1) (connectedComponentIn {z | ‖p.eval z‖ ≤ 1} z₀) (by
    rfl) (by
    exact hw_eq_one);
  cases h_contradiction ; simp_all +decide;
  exact h_contra <| isConnected_univ
/-
The level set of the perturbed polynomial is connected.
Proven by Aristotle
-/
theorem perturbed_level_set_connected (n : ℕ) (hn : n ≠ 0) (p q : Polynomial ℂ)
    (hp_monic : p.Monic)
    (hp_real : ∀ x : ℝ, (p.eval (x : ℂ)).im = 0)
    (hq_real : ∀ x : ℝ, (q.eval (x : ℂ)).im = 0)
    (hp_deg : p.degree = ↑n)
    (hq_deg : (Polynomial.X * q).degree < ↑n)
    (hp_conn : IsConnected {z | ‖p.eval z‖ ≤ 1})
    (h_zero : ‖p.eval 0‖ ≤ 1)
    (hp_roots : RealRootedNonpositive p)
    (h_sign : ∀ z ∈ (critical_points_with_val_one p), (q.eval z * p.eval z).re > 0)
    (h0_sign : (q.eval 0 * p.eval 0).re > 0) :
    ∃ ε : ℝ, ε > 0 ∧ ∀ δ, 0 < δ ∧ δ ≤ ε → IsConnected {z | ‖(p + Polynomial.C (δ:ℂ) * Polynomial.X * q).eval z‖ ≤ 1} := by
  obtain ⟨ ε₁, hε₁, h₁ ⟩ := combined_set_connected_in_level_set n p q hp_monic hp_deg hq_deg hp_real hq_real hp_roots hp_conn h_zero h_sign h0_sign;
  refine ⟨ ε₁, hε₁, fun δ hδ => ?_ ⟩;
  obtain ⟨ S, hS₁, hS₂, hS₃ ⟩ := h₁ δ hδ;
  convert level_set_connected_of_roots_in_connected_subset ( p + Polynomial.C ( δ : ℂ ) * Polynomial.X * q ) _ _ S hS₁ hS₂ hS₃ using 1;
  · rw [ Polynomial.Monic, Polynomial.leadingCoeff, Polynomial.natDegree_add_eq_left_of_natDegree_lt ] <;> norm_num [ hp_monic, hp_deg ];
    · rw [ Polynomial.coeff_eq_zero_of_degree_lt ];
      by_cases hq : q = 0 <;> simp_all +decide [ Polynomial.natDegree ];
      rw [ Polynomial.degree_C ] <;> norm_num [ hδ.1.ne' ] ; exact hq_deg.trans_le' ( by norm_num );
    · by_cases hq : q = 0 <;> simp_all +decide;
      rw [ Polynomial.natDegree_mul', Polynomial.natDegree_mul' ] <;> norm_num [ Polynomial.natDegree_eq_of_degree_eq_some hp_deg, hq ];
      · rw [ Polynomial.degree_eq_natDegree hq ] at hq_deg ; norm_cast at hq_deg;
      · linarith;
      · linarith;
  · rw [ Polynomial.degree_add_eq_left_of_degree_lt ] <;> simp_all +decide [ Polynomial.degree_mul ];
    · have hδ_ne : (δ : ℂ) ≠ 0 := Complex.ofReal_ne_zero.mpr hδ.1.ne'
      rw [ Polynomial.degree_C hδ_ne, zero_add]
      exact hq_deg
/-
The derivative of the perturbed polynomial at 0 is strictly greater.
Proven by Aristotle
-/
theorem perturbed_deriv_greater (p q : Polynomial ℂ)
    (hq_real : ∀ x : ℝ, (q.eval (x : ℂ)).im = 0)
    (hp_deriv : (p.derivative.eval 0).re > 0)
    (hq0 : (q.eval 0).re > 0) :
    ∃ ε : ℝ, ε > 0 ∧ ∀ δ, 0 < δ ∧ δ ≤ ε → ‖p.derivative.eval 0‖ < ‖(p + Polynomial.C (δ:ℂ) * Polynomial.X * q).derivative.eval 0‖ := by
  norm_num [ Complex.normSq, Complex.norm_def ] at *;
  refine ⟨ 1, zero_lt_one, fun δ δ_pos δ_le => Real.sqrt_lt_sqrt ?_ ?_ ⟩;
  · nlinarith;
  · have := hq_real 0; simp_all +decide ; nlinarith [ mul_pos δ_pos hq0 ] ;
-- proven by Aristotle
lemma chebyshev_T_ode (n : ℕ) :
    (Polynomial.derivative (Polynomial.Chebyshev.T ℂ (n : ℤ))) ^ 2 * (1 - Polynomial.X ^ 2) +
      Polynomial.C (↑(n : ℤ) ^ 2 : ℂ) * ((Polynomial.Chebyshev.T ℂ (n : ℤ)) ^ 2 - 1) = 0 := by
  refine Polynomial.funext fun x => ?_;
  -- By definition of Chebyshev polynomials, we know that $T_n(\cos \theta) = \cos(n \theta)$ and $U_n(\cos \theta) = \frac{\sin((n+1)\theta)}{\sin \theta}$.
  have h_chebyshev : ∀ θ : ℝ, (Polynomial.Chebyshev.T ℂ n).eval (Complex.cos θ) = Complex.cos (n * θ) ∧ (Polynomial.derivative (Polynomial.Chebyshev.T ℂ n)).eval (Complex.cos θ) * (-Complex.sin θ) = -n * Complex.sin (n * θ) := by
    intro θ
    have h_chebyshev : ∀ θ : ℝ, (Polynomial.Chebyshev.T ℂ n).eval (Complex.cos θ) = Complex.cos (n * θ) := by
      bound
    have h_chebyshev_deriv : ∀ θ : ℝ, (Polynomial.derivative (Polynomial.Chebyshev.T ℂ n)).eval (Complex.cos θ) * (-Complex.sin θ) = -n * Complex.sin (n * θ) := by
      intro θ
      have h_chebyshev_deriv : deriv (fun θ : ℝ => (Polynomial.Chebyshev.T ℂ n).eval (Complex.cos θ)) θ = (Polynomial.derivative (Polynomial.Chebyshev.T ℂ n)).eval (Complex.cos θ) * (-Complex.sin θ) := by
        simpa [Function.comp_def] using
          HasDerivAt.deriv
            (HasDerivAt.comp θ
              (Polynomial.hasDerivAt (Polynomial.Chebyshev.T ℂ n) (Complex.cos (θ : ℂ)))
              (HasDerivAt.comp θ (Complex.hasDerivAt_cos (θ : ℂ))
                (hasDerivAt_id θ |>.ofReal_comp)))
      rw [ ← h_chebyshev_deriv, show ( fun θ : ℝ => Polynomial.eval ( Complex.cos ( θ : ℂ ) ) ( Polynomial.Chebyshev.T ℂ n ) ) = fun θ : ℝ => Complex.cos ( n * θ ) from funext fun _ => h_chebyshev _ ] ; norm_num [ mul_comm ];
      have h_cos_deriv : deriv (fun θ : ℝ => Complex.cos ((n : ℂ) * (θ : ℂ))) θ =
          -(n : ℂ) * Complex.sin ((n : ℂ) * (θ : ℂ)) := by
        simpa [Function.comp_def, mul_comm, mul_left_comm, mul_assoc] using
          HasDerivAt.deriv
            (HasDerivAt.comp θ (Complex.hasDerivAt_cos ((n : ℂ) * (θ : ℂ)))
              ((hasDerivAt_id θ |>.ofReal_comp).const_mul (n : ℂ)))
      simpa [mul_comm, mul_left_comm, mul_assoc] using h_cos_deriv
    exact ⟨h_chebyshev θ, h_chebyshev_deriv θ⟩;
  -- By definition of Chebyshev polynomials, we know that $T_n(\cos \theta) = \cos(n \theta)$ and $U_n(\cos \theta) = \frac{\sin((n+1)\theta)}{\sin \theta}$ for all $\theta$.
  have h_chebyshev_all : ∀ θ : ℝ, ((Polynomial.derivative (Polynomial.Chebyshev.T ℂ n)).eval (Complex.cos θ))^2 * (1 - Complex.cos θ^2) + (n : ℂ)^2 * ((Polynomial.Chebyshev.T ℂ n).eval (Complex.cos θ)^2 - 1) = 0 := by
    intro θ; specialize h_chebyshev θ; simp_all +decide ; ring_nf;
    have := congr_arg ( · ^ 2 ) h_chebyshev; ring_nf at *; norm_num [ Complex.sin_sq, Complex.cos_sq ] at *; linear_combination' this;
  -- Since these equalities hold for all $\theta$, the polynomials must be equal.
  have h_poly_eq : Set.Infinite {x : ℂ | ((Polynomial.derivative (Polynomial.Chebyshev.T ℂ n)).eval x)^2 * (1 - x^2) + (n : ℂ)^2 * ((Polynomial.Chebyshev.T ℂ n).eval x^2 - 1) = 0} := by
    refine Set.infinite_of_injective_forall_mem ( fun x y hxy => ?_ ) fun x : ℕ => h_chebyshev_all ( Real.arccos ( 1 - 1 / ( x + 1 ) ) );
    norm_cast at hxy;
    rw [ Real.cos_arccos, Real.cos_arccos ] at hxy <;> norm_num at * <;> nlinarith [ inv_mul_cancel₀ ( by linarith : ( x : ℝ ) + 1 ≠ 0 ), inv_mul_cancel₀ ( by linarith : ( y : ℝ ) + 1 ≠ 0 ) ];
  have h_poly_eq : ((Polynomial.derivative (Polynomial.Chebyshev.T ℂ n))^2 * (1 - Polynomial.X^2) + (Polynomial.C (n^2 : ℂ)) * ((Polynomial.Chebyshev.T ℂ n)^2 - 1)) = 0 := by
    exact Classical.not_not.1 fun h => h_poly_eq <| Set.Finite.subset ( Polynomial.roots ( ( Polynomial.derivative ( Polynomial.Chebyshev.T ℂ n ) ) ^ 2 * ( 1 - Polynomial.X ^ 2 ) + Polynomial.C ( n ^ 2 : ℂ ) * ( Polynomial.Chebyshev.T ℂ n ^ 2 - 1 ) ) |> Multiset.toFinset |> Finset.finite_toSet ) fun x hx => by aesop;
  exact congr_arg ( Polynomial.eval x ) h_poly_eq
lemma eval_zero_eq_one_of_valid_real_rooted (n : ℕ) (p : Polynomial ℂ)
    (hp_valid : p ∈ ValidPolys n) (h_roots : RealRootedNonpositive p) :
    p.eval 0 = 1 := by
  have hp_monic : p.Monic := hp_valid.2.1
  have hp_eval0_norm : ‖p.eval 0‖ = 1 := hp_valid.2.2.1
  have h_splits : p.Splits := IsAlgClosed.splits p
  have h_prod := h_splits.eq_prod_roots_of_monic hp_monic
  have h_eval0 : p.eval 0 = (p.roots.map fun a => -a).prod := by
    nth_rw 1 [h_prod]
    simp only [Polynomial.eval_multiset_prod, Multiset.map_map, Function.comp_apply, Polynomial.eval_sub, Polynomial.eval_X, Polynomial.eval_C, zero_sub]
  set r_p := (p.roots.map fun a => -a.re).prod
  have h_eval0_real : p.eval 0 = ↑r_p := by
    rw [h_eval0]
    let f : ℂ → ℂ := fun a => -a
    let g : ℂ → ℝ := fun a => -a.re
    let coe : ℝ →+* ℂ := Complex.ofRealHom
    have h_map : p.roots.map f = p.roots.map (coe ∘ g) := by
      apply Multiset.map_congr rfl
      intro a ha
      obtain ⟨ha_im, _⟩ := h_roots a ha
      apply Complex.ext <;> simp [ha_im, coe, f, g]
    rw [h_map, ← Multiset.map_map]
    rw [Multiset.prod_hom (p.roots.map g) coe]
    rfl
  have hr_nonneg : 0 ≤ r_p := by
    apply Multiset.prod_nonneg
    intro r hr
    obtain ⟨a, ha, rfl⟩ := Multiset.mem_map.mp hr
    obtain ⟨_, ha_re⟩ := h_roots a ha
    linarith
  rw [h_eval0_real] at hp_eval0_norm
  rw [Complex.norm_of_nonneg hr_nonneg] at hp_eval0_norm
  rw [h_eval0_real, hp_eval0_norm]
  norm_cast
lemma deriv_roots_strictly_negative_of_valid (n : ℕ) (hn : n ≥ 2) (p : Polynomial ℂ)
    (hp_valid : p ∈ ValidPolys n) (h_roots : RealRootedNonpositive p) :
    ∀ z ∈ p.derivative.roots, z.re < 0 ∧ z.im = 0 := by
  have hd : p.natDegree = n := Polynomial.natDegree_eq_of_degree_eq_some hp_valid.1
  have hp_monic : p.Monic := hp_valid.2.1
  have hp_eval0 : ‖p.eval 0‖ = 1 := hp_valid.2.2.1
  have hp_deg_pos : 0 < p.degree := by
    rw [Polynomial.degree_eq_natDegree hp_monic.ne_zero, hd]
    norm_cast; omega
  have hp_deriv_ne_zero : p.derivative ≠ 0 := by
    intro h
    have := Polynomial.derivative_eq_zero.mp h
    rw [hd] at this
    omega
  have h_p_roots_neg : ∀ r ∈ p.roots, r.re < 0 ∧ r.im = 0 := by
    intro r hr
    have h_r_real : r.im = 0 ∧ r.re ≤ 0 := h_roots r hr
    constructor
    · by_contra h_ge
      have h_re_zero : r.re = 0 := by linarith [h_r_real.2]
      have h_r_zero : r = 0 := by
        apply Complex.ext
        · exact h_re_zero
        · exact h_r_real.1
      have h0_root : p.eval 0 = 0 := by
        have hr_is_root : p.eval r = 0 := (Polynomial.mem_roots hp_monic.ne_zero).mp hr
        rwa [h_r_zero] at hr_is_root
      rw [h0_root] at hp_eval0
      simp at hp_eval0
    · exact h_r_real.1
  intro z hz
  have hz_eval : p.derivative.eval z = 0 := (Polynomial.mem_roots hp_deriv_ne_zero).mp hz
  let weight := p.derivRootWeight z
  have h_z_cm : z = p.roots.toFinset.centerMass weight id :=
    Polynomial.eq_centerMass_of_eval_derivative_eq_zero hp_deg_pos hz_eval
  have h_weights_nonneg : ∀ r ∈ p.roots.toFinset, 0 ≤ weight r := fun r _ => Polynomial.derivRootWeight_nonneg p z r
  have h_weights_pos : 0 < ∑ r ∈ p.roots.toFinset, weight r := Polynomial.sum_derivRootWeight_pos hp_deg_pos z
  constructor
  · -- z.re < 0
    rw [show z.re = p.roots.toFinset.centerMass weight (fun w => w.re) by
      rw [h_z_cm]
      simpa using complex_centerMass_re p.roots.toFinset weight id]
    apply lt_of_le_of_lt
    · apply Finset.centerMass_le_sup h_weights_nonneg h_weights_pos
    · rw [Finset.sup'_lt_iff]
      · intro r hr
        specialize h_p_roots_neg r (Multiset.mem_toFinset.mp hr)
        exact h_p_roots_neg.1
  · -- z.im = 0
    rw [show z.im = p.roots.toFinset.centerMass weight (fun w => w.im) by
      rw [h_z_cm]
      simpa using complex_centerMass_im p.roots.toFinset weight id]
    unfold Finset.centerMass
    simp only [smul_eq_mul]
    have h_sum_im_zero : ∑ i ∈ p.roots.toFinset, weight i * i.im = 0 := by
      apply Finset.sum_eq_zero
      intro r hr
      rw [(h_p_roots_neg r (Multiset.mem_toFinset.mp hr)).2, mul_zero]
    rw [h_sum_im_zero, mul_zero]
lemma exists_x_lt_roots_eval_eq_neg_one_pow (n : ℕ) (hn : n ≥ 2) (p : Polynomial ℂ)
    (hp_valid : p ∈ ValidPolys n) (h_roots : RealRootedNonpositive p)
    (hm : (critical_points_with_val_one p).card = n - 1) :
    ∃ x : ℝ, (∀ z ∈ p.derivative.roots, x < z.re) ∧ p.eval (x : ℂ) = (-1 : ℂ) ^ n := by
  have hd : p.natDegree = n := Polynomial.natDegree_eq_of_degree_eq_some hp_valid.1
  have hp_deriv_ne_zero : p.derivative ≠ 0 := by
    intro hp0
    have hz_roots : p.derivative.roots = 0 := by rw [hp0, Polynomial.roots_zero]
    have h_card_zero : p.derivative.roots.toFinset.card = 0 := by rw [hz_roots, Multiset.toFinset_zero, Finset.card_empty]
    have h_crit_sub : (critical_points_with_val_one p) ⊆ p.derivative.roots.toFinset := Finset.filter_subset _ _
    have h_crit_card : (critical_points_with_val_one p).card ≤ p.derivative.roots.toFinset.card := Finset.card_le_card h_crit_sub
    rw [h_card_zero, hm] at h_crit_card
    omega
  have h_nonempty : p.derivative.roots.toFinset.Nonempty := by
    have h_card_pos : 0 < (critical_points_with_val_one p).card := by omega
    exact Finset.Nonempty.mono (Finset.filter_subset _ _) (Finset.card_pos.mp h_card_pos)
  let roots_re := p.derivative.roots.toFinset.image Complex.re
  have h_roots_re_nonempty : roots_re.Nonempty := h_nonempty.image _
  let min_root := roots_re.min' h_roots_re_nonempty
  have h_min_root_mem : min_root ∈ roots_re := Finset.min'_mem _ _
  have h_min_root_le : ∀ y ∈ roots_re, min_root ≤ y := fun y hy => Finset.min'_le _ _ hy
  obtain ⟨c, hc_mem, hc_eq⟩ := Finset.mem_image.mp h_min_root_mem
  have hc_crit : c ∈ critical_points_with_val_one p := by
    by_contra h_not_crit
    have h_card : (critical_points_with_val_one p).card = n - 1 := hm
    have h_subset : (critical_points_with_val_one p) ⊆ p.derivative.roots.toFinset := Finset.filter_subset _ _
    have hp_deriv_deg : p.derivative.natDegree ≤ n - 1 := by
      calc p.derivative.natDegree ≤ p.natDegree - 1 := Polynomial.natDegree_derivative_le p
        _ = n - 1 := by rw [hd]
    have h_max_roots : p.derivative.roots.toFinset.card ≤ n - 1 := by
      calc p.derivative.roots.toFinset.card ≤ p.derivative.roots.card := Multiset.toFinset_card_le _
        _ ≤ p.derivative.natDegree := Polynomial.card_roots' _
        _ ≤ n - 1 := hp_deriv_deg
    have h_all_crit_are_val_one : (critical_points_with_val_one p) = p.derivative.roots.toFinset := Finset.eq_of_subset_of_card_le h_subset (show (critical_points_with_val_one p).card ≥ p.derivative.roots.toFinset.card by linarith)
    rw [h_all_crit_are_val_one] at h_not_crit
    exact h_not_crit hc_mem
  have hc_val_one : ‖p.eval c‖ = 1 := (Finset.mem_filter.mp hc_crit).2
  have hc_real : c.im = 0 := (deriv_roots_strictly_negative_of_valid n hn p hp_valid h_roots c (Multiset.mem_toFinset.mp hc_mem)).2
  have h_p_eval_real : (p.eval c).im = 0 := by
    have h_im := eval_im_eq_zero_of_real_rooted_nonpositive p hp_valid.2.1 h_roots c.re
    have h_eq : c = ↑(c.re) := by
      apply Complex.ext
      · rfl
      · exact hc_real
    rw [h_eq]
    exact h_im
  have hp_eval_re : (p.eval c).re ^ 2 = 1 := by
    have h_norm_sq : ‖p.eval c‖ ^ 2 = 1 := by rw [hc_val_one, one_pow]
    rw [← Complex.normSq_eq_norm_sq, Complex.normSq_apply] at h_norm_sq
    have h_im_sq : (p.eval c).im * (p.eval c).im = 0 := by rw [h_p_eval_real, mul_zero]
    linarith
  have hp_c_eq : p.eval c = 1 ∨ p.eval c = -1 := by
    cases sq_eq_one_iff.mp hp_eval_re with
    | inl h_pos =>
      left; apply Complex.ext
      · exact h_pos
      · exact show (p.eval c).im = (1 : ℂ).im from by rw [h_p_eval_real, Complex.one_im]
    | inr h_neg =>
      right; apply Complex.ext
      · exact h_neg
      · exact show (p.eval c).im = (-1 : ℂ).im from by rw [h_p_eval_real, Complex.neg_im, Complex.one_im, neg_zero]
  have h_lim_neg_inf : Filter.Tendsto (fun x : ℝ => (∑ i ∈ Finset.range (p.natDegree + 1), p.coeff i * (x : ℂ) ^ i).re) Filter.atBot (if Even n then Filter.atTop else Filter.atBot) := by
    have hp_monic : p.Monic := hp_valid.2.1
    have h_leading_term : Filter.Tendsto (fun x : ℝ => x ^ p.natDegree + ∑ i ∈ Finset.range p.natDegree, (p.coeff i).re * x ^ i) Filter.atBot (if Even n then Filter.atTop else Filter.atBot) := by
      have h_leading_term : Filter.Tendsto (fun x : ℝ => x ^ p.natDegree * (1 + ∑ i ∈ Finset.range p.natDegree, (p.coeff i).re / x ^ (p.natDegree - i))) Filter.atBot (if Even n then Filter.atTop else Filter.atBot) := by
        have h_sum_zero : Filter.Tendsto (fun x : ℝ => ∑ i ∈ Finset.range p.natDegree, (p.coeff i).re / x ^ (p.natDegree - i)) Filter.atBot (nhds 0) := by
          have h_sum_zero : ∀ i ∈ Finset.range p.natDegree, Filter.Tendsto (fun x : ℝ => (p.coeff i).re / x ^ (p.natDegree - i)) Filter.atBot (nhds 0) := by
            intro i hi
            have h_abs : Filter.Tendsto (fun x : ℝ => |(p.coeff i).re| / |x| ^ (p.natDegree - i)) Filter.atBot (nhds 0) := by
              exact tendsto_const_nhds.div_atTop ( Filter.tendsto_pow_atTop ( Nat.sub_ne_zero_of_lt ( Finset.mem_range.mp hi ) ) |> Filter.Tendsto.comp <| Filter.tendsto_abs_atBot_atTop );
            refine squeeze_zero_norm ?_ h_abs ; aesop;
          simpa only [ Finset.sum_const_zero ] using tendsto_finsetSum _ h_sum_zero;
        have h_leading_pow : Filter.Tendsto (fun x : ℝ => x ^ p.natDegree) Filter.atBot (if Even n then Filter.atTop else Filter.atBot) := by
          by_cases h_even : Even n
          · simp [h_even]
            have h_leading_term : Filter.Tendsto (fun x : ℝ => (-x) ^ p.natDegree) Filter.atBot Filter.atTop := by
              have h_pow_atTop : Filter.Tendsto (fun x : ℝ => x ^ p.natDegree) Filter.atTop Filter.atTop := Filter.tendsto_pow_atTop (by omega)
              exact h_pow_atTop.comp Filter.tendsto_neg_atBot_atTop
            refine h_leading_term.congr' ?_
            filter_upwards with x
            have hn_even_deg : Even p.natDegree := by rw [hd]; exact h_even
            exact (Even.neg_pow hn_even_deg x)
          · simp [h_even]
            have h_leading_term : Filter.Tendsto (fun x : ℝ => -(-x) ^ p.natDegree) Filter.atBot Filter.atBot := by
              have h_pow_atTop : Filter.Tendsto (fun x : ℝ => x ^ p.natDegree) Filter.atTop Filter.atTop := Filter.tendsto_pow_atTop (by omega)
              exact Filter.tendsto_neg_atTop_atBot.comp (h_pow_atTop.comp Filter.tendsto_neg_atBot_atTop)
            refine h_leading_term.congr' ?_
            filter_upwards with x
            have hn_odd_deg : Odd p.natDegree := by rw [hd]; exact (Nat.even_or_odd n).resolve_left h_even
            exact neg_eq_iff_eq_neg.mpr (Odd.neg_pow hn_odd_deg x)
        by_cases h_even : Even n
        · simp [h_even] at *; apply Filter.Tendsto.atTop_mul_pos zero_lt_one h_leading_pow; simpa using h_sum_zero.const_add 1
        · simp [h_even] at *; apply Filter.Tendsto.atBot_mul_pos zero_lt_one h_leading_pow; simpa using h_sum_zero.const_add 1
      refine h_leading_term.congr' ?_;
      filter_upwards [ Filter.eventually_ne_atBot 0 ] with x hx;
      simp +decide [ mul_add, Finset.mul_sum _ _ _ ];
      refine Finset.sum_congr rfl fun i hi => ?_;
      rw [ mul_div, div_eq_iff ( pow_ne_zero _ hx ) ] ; rw [ show x ^ p.natDegree = x ^ ( p.natDegree - i ) * x ^ i by rw [ ← pow_add, Nat.sub_add_cancel ( Finset.mem_range_le hi ) ] ] ; ring;
    simp_all +decide [ Finset.sum_range_succ_comm ];
    norm_cast ; aesop;
  let f : ℝ → ℝ := fun x => (p.eval (x : ℂ)).re
  have hf_cont : Continuous f := by
    fun_prop (disch := norm_num)
  have h_lim_f : Filter.Tendsto f Filter.atBot (if Even n then Filter.atTop else Filter.atBot) := by
    refine h_lim_neg_inf.congr' ?_
    filter_upwards with x
    simp only [f, Polynomial.eval_eq_sum_range, Complex.re_sum, ← Complex.ofReal_pow]
  have hp_monic : p.Monic := hp_valid.2.1
  have hp_deg_pos : p.natDegree ≠ 0 := by rw [hd]; omega
  have h_p_nonempty : p.roots.toFinset.Nonempty := by
    have h_deg : p.degree = n := by rw [Polynomial.degree_eq_natDegree hp_monic.ne_zero, hd]
    obtain ⟨z, hz⟩ := IsAlgClosed.exists_root p (by rw [h_deg]; norm_cast; linarith)
    exact ⟨z, Multiset.mem_toFinset.mpr ((Polynomial.mem_roots hp_monic.ne_zero).mpr hz)⟩
  let p_roots_re := p.roots.toFinset.image Complex.re
  have h_re_nonempty : p_roots_re.Nonempty := h_p_nonempty.image _
  let r_min := p_roots_re.min' h_re_nonempty
  have hr_min_mem : r_min ∈ p_roots_re := Finset.min'_mem _ _
  obtain ⟨z_min, hz_min_mem, hz_min_re⟩ := Finset.mem_image.mp hr_min_mem
  have hz_min_val : p.eval z_min = 0 := (Polynomial.mem_roots hp_monic.ne_zero).mp (Multiset.mem_toFinset.mp hz_min_mem)
  have hz_min_im : z_min.im = 0 := (h_roots z_min (Multiset.mem_toFinset.mp hz_min_mem)).1
  have hz_min_eq : z_min = ↑r_min := by
    apply Complex.ext
    · exact hz_min_re
    · rw [hz_min_im]; simp
  have hf_r_min : f r_min = 0 := by
    simp [f, hz_min_eq.symm, hz_min_val]
  have h_x_exists : ∃ x < r_min, f x = (-1 : ℝ) ^ n := by
    by_cases h_even : Even n
    · have h_pow : (-1 : ℝ) ^ n = 1 := by
        obtain ⟨k, hk⟩ := h_even
        have hk2 : n = 2 * k := by omega
        rw [hk2, pow_mul]
        norm_num
      simp [h_even] at h_lim_f
      have h_ev := (Filter.eventually_lt_atBot r_min).and (h_lim_f.eventually (Filter.eventually_gt_atTop 1))
      obtain ⟨x_bot, hx_bot_lt, hx_bot_val⟩ := h_ev.exists
      have h_val_mem : (1 : ℝ) ∈ Set.uIcc (f x_bot) (f r_min) := by
        rw [hf_r_min, Set.uIcc_of_ge (le_of_lt (by linarith))]
        exact ⟨by linarith, le_of_lt hx_bot_val⟩
      obtain ⟨x_res, hx_res_mem, hx_res_val⟩ := intermediate_value_uIcc hf_cont.continuousOn h_val_mem
      have hx_res_lt : x_res < r_min := by
        rcases Set.mem_uIcc.mp hx_res_mem with ⟨_, h2⟩ | ⟨_, _⟩
        · apply lt_of_le_of_ne h2
          intro h; rw [h, hf_r_min] at hx_res_val; norm_num at hx_res_val
        · linarith
      exact ⟨x_res, hx_res_lt, by rw [hx_res_val, h_pow]⟩
    · have h_odd : Odd n := (Nat.even_or_odd n).resolve_left h_even
      have h_pow : (-1 : ℝ) ^ n = -1 := by
        obtain ⟨k, hk⟩ := h_odd
        have hk2 : n = 2 * k + 1 := by omega
        rw [hk2, pow_add, pow_mul, pow_one]
        norm_num
      simp [h_even] at h_lim_f
      have h_ev := (Filter.eventually_lt_atBot r_min).and (h_lim_f.eventually (Filter.eventually_lt_atBot (-1)))
      obtain ⟨x_bot, hx_bot_lt, hx_bot_val⟩ := h_ev.exists
      have h_val_mem : (-1 : ℝ) ∈ Set.uIcc (f x_bot) (f r_min) := by
        rw [hf_r_min, Set.uIcc_of_le (le_of_lt (by linarith))]
        exact ⟨le_of_lt hx_bot_val, by linarith⟩
      obtain ⟨x_res, hx_res_mem, hx_res_val⟩ := intermediate_value_uIcc hf_cont.continuousOn h_val_mem
      have hx_res_lt : x_res < r_min := by
        rcases Set.mem_uIcc.mp hx_res_mem with ⟨_, h2⟩ | ⟨_, _⟩
        · apply lt_of_le_of_ne h2
          intro h; rw [h, hf_r_min] at hx_res_val; norm_num at hx_res_val
        · linarith
      exact ⟨x_res, hx_res_lt, by rw [hx_res_val, h_pow]⟩
  obtain ⟨x, hx_lt, hx_val⟩ := h_x_exists
  use x
  constructor
  · intro z hz
    apply lt_of_lt_of_le hx_lt
    have hp_deg_pos_real : 0 < p.degree := by
      rw [Polynomial.degree_eq_natDegree hp_monic.ne_zero, hd]
      norm_cast; omega
    have hz_eval : p.derivative.eval z = 0 := (Polynomial.mem_roots hp_deriv_ne_zero).mp hz
    let weight := p.derivRootWeight z
    have h_z_cm : z = p.roots.toFinset.centerMass weight id :=
      Polynomial.eq_centerMass_of_eval_derivative_eq_zero hp_deg_pos_real hz_eval
    rw [show z.re = p.roots.toFinset.centerMass weight (fun w => w.re) by
      rw [h_z_cm]
      simpa using complex_centerMass_re p.roots.toFinset weight id]
    have hr_min_inf : r_min = p.roots.toFinset.inf' h_p_nonempty (fun w => w.re) := by
      show p_roots_re.min' h_re_nonempty = _
      unfold p_roots_re
      exact Finset.inf'_image h_re_nonempty id
    rw [hr_min_inf]
    apply Finset.inf_le_centerMass (fun w hw => Polynomial.derivRootWeight_nonneg p z w)
    · apply Polynomial.sum_derivRootWeight_pos hp_deg_pos_real
  · apply Complex.ext
    · dsimp [f] at hx_val
      rw [hx_val]
      norm_cast
    · have h_im_val := eval_im_eq_zero_of_real_rooted_nonpositive p hp_monic h_roots x
      rw [h_im_val]
      norm_cast
lemma exists_rescaling (n : ℕ) (hn : n ≥ 2) (p : Polynomial ℂ) (hp_valid : p ∈ ValidPolys n)
    (h_roots : RealRootedNonpositive p)
    (hm : (critical_points_with_val_one p).card = n - 1) :
    ∃ (a : ℝ), a > 0 ∧
      let g := p.comp (Polynomial.C (↑a : ℂ) * Polynomial.X + Polynomial.C (↑(-a) : ℂ))
      g.degree = ↑n ∧
      g.eval 1 = 1 ∧
      g.eval (-1) = (-1 : ℂ) ^ n ∧
      (∀ z ∈ g.derivative.roots.toFinset, g.eval z = 1 ∨ g.eval z = -1) ∧
      (∀ z ∈ g.derivative.roots.toFinset, z.re ∈ Set.Ioo (-1 : ℝ) 1 ∧ z.im = 0) := by
  obtain ⟨x, hx_lt, hx_eval⟩ := exists_x_lt_roots_eval_eq_neg_one_pow n hn p hp_valid h_roots hm
  let a := -x / 2
  have ha_pos : a > 0 := by
    have hm_pos : (critical_points_with_val_one p).card > 0 := by omega
    have h_crit_nonempty : (critical_points_with_val_one p).Nonempty := Finset.card_pos.mp hm_pos
    obtain ⟨c, hc_mem⟩ := h_crit_nonempty
    have hc_root : c ∈ p.derivative.roots.toFinset := Finset.filter_subset _ _ hc_mem
    have h_c_neg : c.re < 0 := (deriv_roots_strictly_negative_of_valid n hn p hp_valid h_roots c (Multiset.mem_toFinset.mp hc_root)).1
    have h_x_lt_c : x < c.re := hx_lt c (Multiset.mem_toFinset.mp hc_root)
    have h_x_neg : x < 0 := lt_trans h_x_lt_c h_c_neg
    change -x / 2 > 0
    linarith
  use a
  refine ⟨ha_pos, ?_⟩
  have h_g_deg : (p.comp (Polynomial.C (↑a : ℂ) * Polynomial.X + Polynomial.C (↑(-a) : ℂ))).degree = ↑n := by
    have h_natDegree : (p.comp (Polynomial.C (↑a : ℂ) * Polynomial.X + Polynomial.C (↑(-a) : ℂ))).natDegree = n := by
      rw [Polynomial.natDegree_comp]
      have hp_natDeg : p.natDegree = n := Polynomial.natDegree_eq_of_degree_eq_some hp_valid.1
      have h_inner_natDeg : (Polynomial.C (↑a : ℂ) * Polynomial.X + Polynomial.C (↑(-a) : ℂ)).natDegree = 1 := by
        have h1 : (Polynomial.C (↑a : ℂ) * Polynomial.X).natDegree = 1 := by
          have h_C_ne_zero : (Polynomial.C (↑a : ℂ)) ≠ 0 := Polynomial.C_ne_zero.mpr (Complex.ofReal_ne_zero.mpr (ne_of_gt ha_pos))
          rw [Polynomial.natDegree_mul_X h_C_ne_zero, Polynomial.natDegree_C, zero_add]
        have h2 : (Polynomial.C (↑(-a) : ℂ)).natDegree = 0 := Polynomial.natDegree_C _
        rw [Polynomial.natDegree_add_eq_left_of_natDegree_lt]
        · exact h1
        · rw [h1, h2]; exact zero_lt_one
      rw [hp_natDeg, h_inner_natDeg, mul_one]
    have h_zero : (p.comp (Polynomial.C (↑a : ℂ) * Polynomial.X + Polynomial.C (↑(-a) : ℂ))) ≠ 0 := by
      intro h
      rw [h, Polynomial.natDegree_zero] at h_natDegree
      omega
    rw [Polynomial.degree_eq_natDegree h_zero, h_natDegree]
  have h_g_eval1 : (p.comp (Polynomial.C (↑a : ℂ) * Polynomial.X + Polynomial.C (↑(-a) : ℂ))).eval 1 = 1 := by
    rw [Polynomial.eval_comp, Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_C, Polynomial.eval_X, Polynomial.eval_C]
    have h_inner : (a : ℂ) * 1 + ↑(-a) = 0 := by push_cast; ring
    rw [h_inner]
    exact eval_zero_eq_one_of_valid_real_rooted n p hp_valid h_roots
  have h_g_eval_neg1 : (p.comp (Polynomial.C (↑a : ℂ) * Polynomial.X + Polynomial.C (↑(-a) : ℂ))).eval (-1) = (-1 : ℂ) ^ n := by
    rw [Polynomial.eval_comp, Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_C, Polynomial.eval_X, Polynomial.eval_C]
    have h_inner : (a : ℂ) * (-1) + ↑(-a) = ↑x := by
      have hx_val : (-a : ℝ) + (-a) = x := by
        dsimp [a]
        ring
      have h_push : (a : ℂ) * (-1) + ↑(-a) = ↑(-a : ℝ) + ↑(-a : ℝ) := by push_cast; ring
      rw [h_push, ← Complex.ofReal_add, hx_val]
    rw [h_inner]
    exact hx_eval
  have hp_deriv_ne_zero : p.derivative ≠ 0 := by
    intro hp0
    have hz_roots : p.derivative.roots = 0 := by rw [hp0, Polynomial.roots_zero]
    have h_card_zero : p.derivative.roots.toFinset.card = 0 := by rw [hz_roots, Multiset.toFinset_zero, Finset.card_empty]
    have h_crit_sub : (critical_points_with_val_one p) ⊆ p.derivative.roots.toFinset := Finset.filter_subset _ _
    have h_crit_card : (critical_points_with_val_one p).card ≤ p.derivative.roots.toFinset.card := Finset.card_le_card h_crit_sub
    rw [h_card_zero, hm] at h_crit_card
    omega
  have h_g_crit_val : ∀ z ∈ (p.comp (Polynomial.C (↑a : ℂ) * Polynomial.X + Polynomial.C (↑(-a) : ℂ))).derivative.roots.toFinset, (p.comp (Polynomial.C (↑a : ℂ) * Polynomial.X + Polynomial.C (↑(-a) : ℂ))).eval z = 1 ∨ (p.comp (Polynomial.C (↑a : ℂ) * Polynomial.X + Polynomial.C (↑(-a) : ℂ))).eval z = -1 := by
    intro z hz
    have h_deriv_simp : (p.comp (Polynomial.C (↑a : ℂ) * Polynomial.X + Polynomial.C (↑(-a) : ℂ))).derivative = (p.derivative.comp (Polynomial.C (↑a : ℂ) * Polynomial.X + Polynomial.C (↑(-a) : ℂ)) * Polynomial.C (↑a : ℂ)) := by
      rw [Polynomial.derivative_comp, Polynomial.derivative_add, Polynomial.derivative_C_mul_X, Polynomial.derivative_C, add_zero, mul_comm]
    rw [h_deriv_simp] at hz
    have hz_deriv : (p.derivative.comp (Polynomial.C (↑a : ℂ) * Polynomial.X + Polynomial.C (↑(-a) : ℂ)) * Polynomial.C (↑a : ℂ)).eval z = 0 := Polynomial.isRoot_of_mem_roots (Multiset.mem_toFinset.mp hz)
    rw [Polynomial.eval_mul, Polynomial.eval_C] at hz_deriv
    have ha_ne_zero : (a : ℂ) ≠ 0 := Complex.ofReal_ne_zero.mpr (ne_of_gt ha_pos)
    cases mul_eq_zero.mp hz_deriv with
    | inl h1 =>
      rw [Polynomial.eval_comp, Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_C, Polynomial.eval_X, Polynomial.eval_C] at h1
      have hc_mem_roots : (a : ℂ) * z + ↑(-a) ∈ p.derivative.roots := Polynomial.mem_roots hp_deriv_ne_zero |>.mpr h1
      have hc : (a : ℂ) * z + ↑(-a) ∈ p.derivative.roots.toFinset := Multiset.mem_toFinset.mpr hc_mem_roots
      have hc_val_one : ‖p.eval ((a : ℂ) * z + ↑(-a))‖ = 1 := by
        have hc_mem_crit : (a : ℂ) * z + ↑(-a) ∈ critical_points_with_val_one p := by
          by_contra h_not_in
          have h_card : (critical_points_with_val_one p).card = n - 1 := hm
          have h_subset : (critical_points_with_val_one p) ⊆ p.derivative.roots.toFinset := Finset.filter_subset _ _
          have hp_deriv_deg : p.derivative.natDegree ≤ n - 1 := by
            have hd : p.natDegree = n := Polynomial.natDegree_eq_of_degree_eq_some hp_valid.1
            calc p.derivative.natDegree ≤ p.natDegree - 1 := Polynomial.natDegree_derivative_le p
              _ = n - 1 := by rw [hd]
          have h_max_roots : p.derivative.roots.toFinset.card ≤ n - 1 := by
            calc p.derivative.roots.toFinset.card ≤ p.derivative.roots.card := Multiset.toFinset_card_le _
              _ ≤ p.derivative.natDegree := Polynomial.card_roots' _
              _ ≤ n - 1 := hp_deriv_deg
          have h_all_crit_are_val_one : (critical_points_with_val_one p) = p.derivative.roots.toFinset := Finset.eq_of_subset_of_card_le h_subset (show (critical_points_with_val_one p).card ≥ p.derivative.roots.toFinset.card by linarith)
          rw [h_all_crit_are_val_one] at h_not_in
          exact h_not_in hc
        exact (Finset.mem_filter.mp hc_mem_crit).2
      have hc_real : ((a : ℂ) * z + ↑(-a)).im = 0 := (deriv_roots_strictly_negative_of_valid n hn p hp_valid h_roots _ hc_mem_roots).2
      have h_p_eval_real : (p.eval ((a : ℂ) * z + ↑(-a))).im = 0 := by
        have h_im := eval_im_eq_zero_of_real_rooted_nonpositive p hp_valid.2.1 h_roots ((a : ℂ) * z + ↑(-a)).re
        have h_eq : (a : ℂ) * z + ↑(-a) = ↑(((a : ℂ) * z + ↑(-a)).re) := by
          apply Complex.ext
          · rfl
          · exact hc_real
        rw [h_eq]
        exact h_im
      have hp_eval_re : (p.eval ((a : ℂ) * z + ↑(-a))).re ^ 2 = 1 := by
        have h_norm_sq : ‖p.eval ((a : ℂ) * z + ↑(-a))‖ ^ 2 = 1 := by rw [hc_val_one, one_pow]
        rw [← Complex.normSq_eq_norm_sq, Complex.normSq_apply] at h_norm_sq
        have h_im_sq : (p.eval ((a : ℂ) * z + ↑(-a))).im * (p.eval ((a : ℂ) * z + ↑(-a))).im = 0 := by rw [h_p_eval_real, mul_zero]
        linarith
      rw [sq_eq_one_iff] at hp_eval_re
      have h_eval_eq : p.eval ((a : ℂ) * z + ↑(-a)) = ↑((p.eval ((a : ℂ) * z + ↑(-a))).re) := by
        apply Complex.ext
        · rfl
        · exact h_p_eval_real
      rw [Polynomial.eval_comp, Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_C, Polynomial.eval_X, Polynomial.eval_C]
      cases hp_eval_re with
      | inl h_pos => left; rw [h_eval_eq, h_pos]; rfl
      | inr h_neg => right; rw [h_eval_eq, h_neg]; push_cast; rfl
    | inr h2 => contradiction
  have h_g_crit_loc : ∀ z ∈ (p.comp (Polynomial.C (↑a : ℂ) * Polynomial.X + Polynomial.C (↑(-a) : ℂ))).derivative.roots.toFinset, z.re ∈ Set.Ioo (-1 : ℝ) 1 ∧ z.im = 0 := by
    intro z hz
    have h_deriv_simp : (p.comp (Polynomial.C (↑a : ℂ) * Polynomial.X + Polynomial.C (↑(-a) : ℂ))).derivative = (p.derivative.comp (Polynomial.C (↑a : ℂ) * Polynomial.X + Polynomial.C (↑(-a) : ℂ)) * Polynomial.C (↑a : ℂ)) := by
      rw [Polynomial.derivative_comp, Polynomial.derivative_add, Polynomial.derivative_C_mul_X, Polynomial.derivative_C, add_zero, mul_comm]
    rw [h_deriv_simp] at hz
    have hz_deriv : (p.derivative.comp (Polynomial.C (↑a : ℂ) * Polynomial.X + Polynomial.C (↑(-a) : ℂ)) * Polynomial.C (↑a : ℂ)).eval z = 0 := Polynomial.isRoot_of_mem_roots (Multiset.mem_toFinset.mp hz)
    rw [Polynomial.eval_mul, Polynomial.eval_C] at hz_deriv
    have ha_ne_zero : (a : ℂ) ≠ 0 := Complex.ofReal_ne_zero.mpr (ne_of_gt ha_pos)
    cases mul_eq_zero.mp hz_deriv with
    | inl h1 =>
      rw [Polynomial.eval_comp, Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_C, Polynomial.eval_X, Polynomial.eval_C] at h1
      have hc_mem_roots : (a : ℂ) * z + ↑(-a) ∈ p.derivative.roots := Polynomial.mem_roots hp_deriv_ne_zero |>.mpr h1
      have hc : (a : ℂ) * z + ↑(-a) ∈ p.derivative.roots.toFinset := Multiset.mem_toFinset.mpr hc_mem_roots
      have hc_real : ((a : ℂ) * z + ↑(-a)).im = 0 := (deriv_roots_strictly_negative_of_valid n hn p hp_valid h_roots _ hc_mem_roots).2
      have h_z_im : z.im = 0 := by
        have h_im_eq : (((a : ℂ) * z + ↑(-a)).im : ℝ) = a * z.im := by push_cast; simp [Complex.add_im, Complex.mul_im]
        rw [hc_real] at h_im_eq
