      intro hg_zero
      rw [hg_zero, Polynomial.degree_zero] at hg_deg
      norm_num at hg_deg
    have hg_lc_ne : g.leadingCoeff ≠ 0 := Polynomial.leadingCoeff_ne_zero.mpr hg_ne_zero
    have hc_ne : c ≠ 0 := by
      dsimp [c]
      exact div_ne_zero hg_lc_ne hT_lc_ne
    have hscaled_degree : (Polynomial.C c * T).degree = (n : WithBot ℕ) := by
      rw [Polynomial.degree_C_mul hc_ne, hTn_degree]
    have hdeg_eq : g.degree = (Polynomial.C c * T).degree := by
      rw [hg_deg, hscaled_degree]
    have hlc_eq : g.leadingCoeff = (Polynomial.C c * T).leadingCoeff := by
      rw [Polynomial.leadingCoeff_mul, Polynomial.leadingCoeff_C]
      dsimp [c]
      field_simp [hT_lc_ne]
    have hlt := Polynomial.degree_sub_lt hdeg_eq hg_ne_zero hlc_eq
    simpa [hg_deg] using hlt
  have hdiff_zero : g - Polynomial.C c * T = 0 := by
    by_contra hdiff_ne_zero
    have hdeg_eq :=
      chebyshev_ode_degree_eq_n n (g - Polynomial.C c * T) hdiff_ne_zero hdiff_second_order_ode
    exact (ne_of_lt hdiff_deg_lt) hdeg_eq
  have hg_eq_scaled : g = Polynomial.C c * T := sub_eq_zero.mp hdiff_zero
  have hc_eq_one : c = 1 := by
    have h_eval_scaled : Polynomial.eval 1 (Polynomial.C c * T) = 1 := by
      rw [← hg_eq_scaled]
      exact hg_1
    rw [Polynomial.eval_mul, Polynomial.eval_C, hT_eval_one, mul_one] at h_eval_scaled
    exact h_eval_scaled
  rw [hg_eq_scaled, hc_eq_one]
  simp
/-
The leading coefficient of the Chebyshev polynomial $T_n(x)$ is $2^{n-1}$ for $n \ge 1$.
-/
/-
The degree and leading coefficient of the Chebyshev polynomial $T_n(x)$ for $n \ge 1$.
-/
lemma T_natDegree_and_leadingCoeff (n : ℕ) (hn : n ≠ 0) :
    (Polynomial.Chebyshev.T ℂ n).natDegree = n ∧
    (Polynomial.Chebyshev.T ℂ n).leadingCoeff = 2 ^ (n - 1) := by
  induction n using Nat.strong_induction_on with
  | h n ih =>
    rcases n with _ | _ | n
    · contradiction
    · change (Polynomial.Chebyshev.T ℂ 1).natDegree = 1 ∧ (Polynomial.Chebyshev.T ℂ 1).leadingCoeff = 2 ^ 0
      rw [Polynomial.Chebyshev.T_one]
      exact ⟨Polynomial.natDegree_X, Polynomial.leadingCoeff_X⟩
    · -- Case for n + 2
      have ih1_pre := ih (n + 1) (by omega) (by omega)
      have ih1 : (Polynomial.Chebyshev.T ℂ (n + 1)).natDegree = n + 1 ∧
                 (Polynomial.Chebyshev.T ℂ (n + 1)).leadingCoeff = 2 ^ n := by
        rcases ih1_pre with ⟨hdeg, hl⟩
        exact ⟨hdeg, by simpa using hl⟩
      have ih2 : n = 0 ∨ ((Polynomial.Chebyshev.T ℂ n).natDegree = n ∧ (Polynomial.Chebyshev.T ℂ n).leadingCoeff = 2 ^ (n - 1)) := by
        by_cases hn0 : n = 0
        · exact Or.inl hn0
        · exact Or.inr (ih n (by omega) hn0)
      have h_T_add_two := Polynomial.Chebyshev.T_add_two ℂ n
      have h_2X : (2 * Polynomial.X : Polynomial ℂ) = Polynomial.C (2:ℂ) * Polynomial.X := by
        exact rfl
      have hc : (Polynomial.C (2:ℂ) * Polynomial.X : Polynomial ℂ).natDegree = 1 := by
        rw [Polynomial.natDegree_mul, Polynomial.natDegree_C, Polynomial.natDegree_X, zero_add]
        · exact Polynomial.C_ne_zero.mpr two_ne_zero
        · exact Polynomial.X_ne_zero
      have hd1 : ((Polynomial.C (2:ℂ) * Polynomial.X) * Polynomial.Chebyshev.T ℂ (n + 1)).natDegree = n + 2 := by
        rw [Polynomial.natDegree_mul, hc, ih1.1, add_comm]
        · exact mul_ne_zero (Polynomial.C_ne_zero.mpr two_ne_zero) Polynomial.X_ne_zero
        · rw [← Polynomial.leadingCoeff_ne_zero, ih1.2]
          exact pow_ne_zero n two_ne_zero
      have hd2 : (Polynomial.Chebyshev.T ℂ n).natDegree ≤ n := by
        rcases ih2 with hn0 | ⟨hnd, _⟩
        · subst hn0
          have h0 : Polynomial.Chebyshev.T ℂ 0 = 1 := Polynomial.Chebyshev.T_zero ℂ
          rw [Nat.cast_zero, h0, Polynomial.natDegree_one]
        · rw [hnd]
      have h_lt : (Polynomial.Chebyshev.T ℂ n).natDegree < (Polynomial.C (2:ℂ) * Polynomial.X * Polynomial.Chebyshev.T ℂ (n + 1)).natDegree := by
        rw [hd1]
        exact lt_of_le_of_lt hd2 (by omega)
      have h_deg : (Polynomial.Chebyshev.T ℂ (n + 2)).natDegree = n + 2 := by
        rw [h_T_add_two, h_2X, Polynomial.natDegree_sub_eq_left_of_natDegree_lt h_lt, hd1]
      have h_coeff : (Polynomial.Chebyshev.T ℂ (n + 2)).leadingCoeff = 2 ^ (n + 1) := by
        have h_deg_lt : Polynomial.degree (Polynomial.Chebyshev.T ℂ n) < Polynomial.degree (Polynomial.C (2:ℂ) * Polynomial.X * Polynomial.Chebyshev.T ℂ (n + 1)) := by
          exact Polynomial.degree_lt_degree h_lt
        rw [h_T_add_two, h_2X, Polynomial.leadingCoeff_sub_of_degree_lt h_deg_lt]
        rw [Polynomial.leadingCoeff_mul, Polynomial.leadingCoeff_mul, Polynomial.leadingCoeff_C, Polynomial.leadingCoeff_X, mul_one, ih1.2]
        ring
      exact ⟨h_deg, h_coeff⟩
lemma T_leadingCoeff (n : ℕ) (hn : n ≠ 0) :
    (Polynomial.Chebyshev.T ℂ n).leadingCoeff = 2 ^ (n - 1) :=
  (T_natDegree_and_leadingCoeff n hn).2
/-
Characterization of the Chebyshev polynomial as the unique extremal polynomial with n-1 such critical points.
-/
theorem extremal_is_chebyshev (n : ℕ) (hn : n ≠ 0) (p : Polynomial ℂ) (hp_valid : p ∈ ValidPolys n)
    (h_roots : RealRootedNonpositive p)
    (hm : (critical_points_with_val_one p).card = n - 1) :
    p = extremal_polynomial n := by
  by_cases hn0 : n = 0
  · contradiction
  by_cases hn1 : n = 1
  · -- For n=1, p is monic degree 1, ||p(0)||=1, and has a real non-positive root.
    -- This implies p = X + 1.
    have h_p1 : p = Polynomial.X + 1 := by
      have h_deg : p.natDegree = 1 := by
        rw [Polynomial.natDegree_eq_of_degree_eq_some hp_valid.1, hn1]
      have h_monic : p.Monic := hp_valid.2.1
      set c := p.coeff 0 with hc_def
      have hc : p = Polynomial.X + Polynomial.C c := by
        apply Polynomial.ext; intro i
        rcases i with (_ | _ | i)
        · simp [hc_def]
        · have h_coeff := h_monic.coeff_natDegree
          rw [h_deg] at h_coeff
          simp [h_coeff]
        · simp [Polynomial.coeff_eq_zero_of_natDegree_lt, h_deg]
      have h_norm : ‖c‖ = 1 := by
        rw [hc] at hp_valid; simpa using hp_valid.2.2.1
      have h_root_real : c.im = 0 ∧ c.re ≥ 0 := by
        have h_root_mem : -c ∈ p.roots := by
          rw [hc, Polynomial.roots_X_add_C]; simp
        specialize h_roots (-c) h_root_mem
        simp [Complex.neg_re, Complex.neg_im] at h_roots
        exact ⟨h_roots.1, by linarith [h_roots.2]⟩
      have h_c_one : c = 1 := by
        apply Complex.ext
        · have h_abs_sq : c.re ^ 2 = 1 := by
            have h_norm_sq : ‖c‖ ^ 2 = 1 := by rw [h_norm, one_pow]
            rw [← Complex.normSq_eq_norm_sq, Complex.normSq_apply] at h_norm_sq
            simp [h_root_real.1] at h_norm_sq
            rwa [sq]
          rw [sq_eq_one_iff] at h_abs_sq
          rcases h_abs_sq with h1 | h2
          · exact h1
          · linarith [h_root_real.2]
        · exact h_root_real.1
      rw [hc, h_c_one]; simp
    rw [h_p1, hn1]
    unfold extremal_polynomial
    simp
  -- We may now assume n ≥ 2.
  have hn_ge2 : n ≥ 2 := by omega
  -- Phase 4: Construct the rescaling g(z) = p(a*z - a).
  -- (Phases 1-3 are built into the helper lemmas or handled within exists_rescaling)
  have h_rescaling : ∃ (a : ℝ), a > 0 ∧
    let g := p.comp (Polynomial.C (↑a : ℂ) * Polynomial.X + Polynomial.C (↑(-a) : ℂ))
    g.degree = ↑n ∧
    g.eval 1 = 1 ∧
    g.eval (-1) = (-1 : ℂ) ^ n ∧
    (∀ z ∈ g.derivative.roots.toFinset, g.eval z = 1 ∨ g.eval z = -1) ∧
    (∀ z ∈ g.derivative.roots.toFinset, z.re ∈ Set.Ioo (-1 : ℝ) 1 ∧ z.im = 0) := by
    apply exists_rescaling n hn_ge2 p hp_valid h_roots hm
  obtain ⟨a, ha_pos, hg_deg, hg_1, hg_neg1, h_crit_val, h_crit_bounds⟩ := h_rescaling
  set g := p.comp (Polynomial.C (↑a : ℂ) * Polynomial.X + Polynomial.C (↑(-a) : ℂ)) with hg_def
  -- The number of critical points of g is also n - 1.
  have h_g_crit_count : g.derivative.roots.toFinset.card = n - 1 := by
    have ha_ne_zero : (a : ℂ) ≠ 0 := by exact mod_cast ne_of_gt ha_pos
    have hg_deriv : g.derivative = (p.derivative.comp (Polynomial.C (↑a : ℂ) * Polynomial.X + Polynomial.C (↑(-a) : ℂ))) * Polynomial.C (↑a : ℂ) := by
      rw [hg_def, Polynomial.derivative_comp]
      simp only [Polynomial.derivative_add, Polynomial.derivative_mul, Polynomial.derivative_C, Polynomial.derivative_X, mul_one, zero_mul, add_zero, zero_add]
      rw [mul_comm (Polynomial.C (↑a : ℂ))]
    have h_p_deriv_ne_zero : p.derivative ≠ 0 := by
      intro h_zero
      have h_eq_C := Polynomial.eq_C_of_derivative_eq_zero h_zero
      have hd : p.natDegree = n := Polynomial.natDegree_eq_of_degree_eq_some hp_valid.1
      have hc : p.natDegree = 0 := by rw [h_eq_C, Polynomial.natDegree_C]
      omega
    have h_g_deriv_ne_zero : g.derivative ≠ 0 := by
      intro h_zero
      have h_eq_C := Polynomial.eq_C_of_derivative_eq_zero h_zero
      have hd : g.natDegree = n := Polynomial.natDegree_eq_of_degree_eq_some hg_deg
      have hc : g.natDegree = 0 := by rw [h_eq_C, Polynomial.natDegree_C]
      omega
    have h_roots_eq : g.derivative.roots.toFinset = p.derivative.roots.toFinset.image (fun (z : ℂ) => (z + (a:ℂ)) / (a:ℂ)) := by
      ext z
      simp only [Finset.mem_image, Multiset.mem_toFinset, Polynomial.mem_roots h_g_deriv_ne_zero, Polynomial.mem_roots h_p_deriv_ne_zero]
      constructor
      · intro hz_eval
        dsimp [Polynomial.IsRoot] at hz_eval ⊢
        use (a:ℂ) * z - (a:ℂ)
        rw [hg_deriv, Polynomial.eval_mul, mul_eq_zero] at hz_eval
        cases hz_eval with
        | inl h_eval =>
          simp only [Polynomial.eval_comp, Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_C, Polynomial.eval_X] at h_eval
          constructor
          · have h_sub : (a : ℂ) * z - (a : ℂ) = (a : ℂ) * z + ↑(-a) := by push_cast; ring
            rw [h_sub]
            exact h_eval
          · have hz_calc : ((a : ℂ) * z - (a : ℂ) + (a : ℂ)) / (a : ℂ) = z := by
              rw [sub_add_cancel]
              exact mul_div_cancel_left₀ z ha_ne_zero
            exact hz_calc
        | inr h_a =>
          rw [Polynomial.eval_C] at h_a
          contradiction
      · rintro ⟨w, hw_eval, rfl⟩
        dsimp [Polynomial.IsRoot] at hw_eval ⊢
        simp only [hg_deriv, Polynomial.eval_mul, Polynomial.eval_comp, Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_C, Polynomial.eval_X]
        have h_calc : (a : ℂ) * ((w + ↑a) / ↑a) + ↑(-a) = w := by
          calc (a : ℂ) * ((w + ↑a) / ↑a) + ↑(-a) = ((w + ↑a) / ↑a) * (a : ℂ) + ↑(-a) := by rw [mul_comm]
            _ = w + ↑a + ↑(-a) := by rw [div_mul_cancel₀ _ ha_ne_zero]
            _ = w := by push_cast; ring
        rw [h_calc, hw_eval, zero_mul]
    have h_inj : Function.Injective (fun (z:ℂ) => (z + (a:ℂ)) / (a:ℂ)) := by
      intro x y hxy
      have h1 : (x + (a : ℂ)) / (a : ℂ) * (a : ℂ) = (y + (a : ℂ)) / (a : ℂ) * (a : ℂ) := congrArg (· * (a:ℂ)) hxy
      rw [div_mul_cancel₀ _ ha_ne_zero, div_mul_cancel₀ _ ha_ne_zero] at h1
      exact add_right_cancel h1
    rw [h_roots_eq, Finset.card_image_of_injective _ h_inj]
    -- Now we need to show p.derivative.roots.toFinset.card = n - 1
    have h_p_crit : (critical_points_with_val_one p).card = n - 1 := hm
    have h_subset : (critical_points_with_val_one p) ⊆ p.derivative.roots.toFinset := by
      unfold critical_points_with_val_one
      exact Finset.filter_subset _ _
    have h_p_deriv_deg : p.derivative.natDegree ≤ n - 1 := by
      have hd : p.natDegree = n := Polynomial.natDegree_eq_of_degree_eq_some hp_valid.1
      calc p.derivative.natDegree ≤ p.natDegree - 1 := Polynomial.natDegree_derivative_le p
        _ = n - 1 := by rw [hd]
    have h_max_roots : p.derivative.roots.toFinset.card ≤ n - 1 := by
      calc p.derivative.roots.toFinset.card ≤ p.derivative.roots.card := Multiset.toFinset_card_le _
        _ ≤ p.derivative.natDegree := Polynomial.card_roots' _
        _ ≤ n - 1 := h_p_deriv_deg
    have h_eq : p.derivative.roots.toFinset.card = n - 1 := by
      have h1 := Finset.card_le_card h_subset
      omega
    exact h_eq
  -- Phase 4b: The zero-counting argument shows g satisfies the ODE.
  have h_g_ode : g.derivative ^ 2 * (1 - Polynomial.X ^ 2) +
    Polynomial.C ((↑n : ℂ) ^ 2) * (g ^ 2 - 1) = 0 := by
    apply rescaled_satisfies_ode n hn_ge2 g hg_deg hg_1 hg_neg1 h_crit_val h_g_crit_count h_crit_bounds
  -- Phase 5: Uniqueness from the ODE. g must be exactly the Chebyshev polynomial.
  have h_g_eq_Tn : g = Polynomial.Chebyshev.T ℂ (n : ℤ) := by
    apply unique_from_chebyshev_ode n hn0 g hg_deg hg_1 h_g_ode
  -- Phase 6: Back-substitute to find p from g.
  -- Since g(z) = p(a*z - a) = T_n(z), we have p(w) = T_n((w/a) + 1).
  have h_p_expr : p = (Polynomial.Chebyshev.T ℂ n).comp (Polynomial.C ((a : ℂ)⁻¹) * Polynomial.X + 1) := by
    have ha_ne_zero : (a : ℂ) ≠ 0 := by exact mod_cast ne_of_gt ha_pos
    have h1 : g.comp (Polynomial.C ((a : ℂ)⁻¹) * Polynomial.X + 1) = (Polynomial.Chebyshev.T ℂ n).comp (Polynomial.C ((a : ℂ)⁻¹) * Polynomial.X + 1) := by
      rw [h_g_eq_Tn]
    have h2 : g.comp (Polynomial.C ((a : ℂ)⁻¹) * Polynomial.X + 1) = p := by
      rw [hg_def, Polynomial.comp_assoc]
      have h_inner : (Polynomial.C (↑a : ℂ) * Polynomial.X + Polynomial.C (↑(-a) : ℂ)).comp (Polynomial.C ((a : ℂ)⁻¹) * Polynomial.X + 1) = Polynomial.X := by
        simp only [Polynomial.add_comp, Polynomial.mul_comp, Polynomial.C_comp, Polynomial.X_comp]
        rw [mul_add, ← mul_assoc, ← Polynomial.C_mul]
        have h_inv : (a : ℂ) * (a : ℂ)⁻¹ = 1 := mul_inv_cancel₀ ha_ne_zero
        rw [h_inv, Polynomial.C_1, one_mul, mul_one]
        have h_neg : (a:ℂ) + ↑(-a) = 0 := by push_cast; ring
        rw [add_assoc, ← Polynomial.C_add, h_neg, Polynomial.C_0, add_zero]
      rw [h_inner, Polynomial.comp_X]
    rw [← h1, h2]
  -- Use the fact that p is monic to determine the scaling factor a = 2^((n-1)/n).
  have ha_val : (a : ℂ) = (2 : ℂ) ^ (((n - 1) : ℂ) / (n : ℂ)) := by
    have ha_ne_zero : (a : ℂ) ≠ 0 := by exact mod_cast ne_of_gt ha_pos
    let q : Polynomial ℂ := Polynomial.C (a : ℂ) * Polynomial.X + Polynomial.C (↑(-a) : ℂ)
    have h_p_deg : (Polynomial.C (a : ℂ) * Polynomial.X).natDegree = 1 := by
      rw [Polynomial.natDegree_mul_X (Polynomial.C_ne_zero.mpr ha_ne_zero), Polynomial.natDegree_C, zero_add]
    have h_lt_deg : (Polynomial.C (↑(-a) : ℂ)).natDegree < (Polynomial.C (a : ℂ) * Polynomial.X).natDegree := by
      rw [h_p_deg, Polynomial.natDegree_C]
      exact zero_lt_one
    have hq_deg : q.natDegree = 1 := by
      rw [Polynomial.natDegree_add_eq_left_of_natDegree_lt h_lt_deg, h_p_deg]
    have hq_lc : q.leadingCoeff = (a : ℂ) := by
      have h_lt_deg_val : Polynomial.degree (Polynomial.C (↑(-a) : ℂ)) < Polynomial.degree (Polynomial.C (a : ℂ) * Polynomial.X) :=
        Polynomial.degree_lt_degree h_lt_deg
      rw [Polynomial.leadingCoeff_add_of_degree_lt' h_lt_deg_val, Polynomial.leadingCoeff_mul_X, Polynomial.leadingCoeff_C]
    have h_lc_g : g.leadingCoeff = (a : ℂ) ^ n := by
      rw [hg_def, Polynomial.leadingCoeff_comp (by rw [hq_deg]; exact one_ne_zero), hp_valid.2.1, hq_lc, Polynomial.natDegree_eq_of_degree_eq_some hp_valid.1, one_mul]
    have h_lc_Tn : (Polynomial.Chebyshev.T ℂ n).leadingCoeff = (2 : ℂ) ^ (n - 1) := T_leadingCoeff n hn
    have h_lc_eq : (a : ℂ) ^ n = (2 : ℂ) ^ (n - 1) := by rw [← h_lc_g, h_g_eq_Tn, h_lc_Tn]
    have h_a_real : (a : ℂ) = Complex.ofReal a := rfl
    have h_2_real : (2 : ℂ) = Complex.ofReal 2 := rfl
    rw [h_a_real, h_2_real, ← Complex.ofReal_pow, ← Complex.ofReal_pow] at h_lc_eq
    have h_lc_eq_real : a ^ n = 2 ^ (n - 1) := Complex.ofReal_inj.mp h_lc_eq
    have h_a_val_real : a = Real.rpow 2 (((n : ℝ) - 1) / (n : ℝ)) := by
      have hn_real : (n : ℝ) ≠ 0 := by
        intro h
        have : n = 0 := by exact_mod_cast h
        omega
      have h1 : a ^ (n : ℝ) = 2 ^ (↑(n - 1) : ℝ) := by
        rw [Real.rpow_natCast, Real.rpow_natCast]
        exact h_lc_eq_real
      have h2 : (a ^ (n : ℝ)) ^ (n : ℝ)⁻¹ = (2 ^ (↑(n - 1) : ℝ)) ^ (n : ℝ)⁻¹ := by rw [h1]
      rw [Real.rpow_rpow_inv ha_pos.le hn_real] at h2
      rw [h2, ← Real.rpow_mul zero_le_two]
      congr 1
      have h_ge1 : 1 ≤ n := by omega
      rw [Nat.cast_sub h_ge1]
      field_simp; ring
    rw [h_a_real, h_a_val_real]
    have hd : Real.rpow 2 (((n : ℝ) - 1) / (n : ℝ)) = (2 : ℝ) ^ (((n : ℝ) - 1) / (n : ℝ)) := rfl
    rw [hd, Complex.ofReal_cpow zero_le_two]
    push_cast
    congr 1
  -- Substitute the value of a into the expression for p to conclude.
  have ha_inv : (a : ℂ)⁻¹ = (2 : ℂ) ^ ((1 : ℂ) / (n : ℂ) - 1) := by
    rw [ha_val, ← Complex.cpow_neg]
    congr 1
    have hn_nz : (n : ℂ) ≠ 0 := by norm_cast
    field_simp [hn_nz]
    ring
  rw [h_p_expr, ha_inv]
  exact rfl
/-
Proof of the main theorem statement at zero.
-/
theorem eremenko_lempert_at_zero_proof (n : ℕ) : EremenkoLempertAtZeroStatement n := by
  intro hn p hp_monic hp_deg hp_zero h_conn
  -- 1. Existence of extremal polynomial
  obtain ⟨f, hf_valid, hf_extr⟩ := exists_extremal_polynomial n hn
  -- 2. Consider f^* (polynomial_star f)
  let f_star := polynomial_star f
  have hf_star_monic := polynomial_star_monic f
  have h_f_deg := hf_valid.1
  have hf_star_deg := polynomial_star_degree f hf_valid.2.1
  have hf_star_eval0 := polynomial_star_eval_zero f hf_valid.2.1
  have hf_star_deg_n : f_star.degree = n := by rw [hf_star_deg]; exact hf_valid.1
  have hf_star_eval0_norm : ‖f_star.eval 0‖ = 1 := by rw [hf_star_eval0]; exact hf_valid.2.2.1
  have hf_star_conn := polynomial_star_level_set_connected f hf_valid.2.1
    (by rw [hf_valid.1]; exact Nat.cast_ne_zero.mpr hn)
    (by
      have : ‖f.eval 0‖ = 1 := hf_valid.2.2.1
      rw [this])
    hf_valid.2.2.2
  have hf_star_valid : f_star ∈ ValidPolys n := ⟨hf_star_deg_n, hf_star_monic, hf_star_eval0_norm, hf_star_conn⟩
  -- 3. f_star is also extremal
  have hf_star_extr_at_0 : ∀ q ∈ ValidPolys n, ‖q.derivative.eval 0‖ ≤ ‖f_star.derivative.eval 0‖ := by
    intro q hq
    refine le_trans (hf_extr q hq) ?_
    apply polynomial_star_derivative_eval_zero f hf_valid.2.1
    have : ‖f.eval 0‖ = 1 := hf_valid.2.2.1
    intro h_eval0
    rw [h_eval0, norm_zero] at this
