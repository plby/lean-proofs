      G.componentComplMk (K := C.vSet (G := G)) huK =
        G.componentComplMk (K := C.vSet (G := G)) hvK := by
    simpa [SimpleGraph.componentComplMk] using
      (SimpleGraph.ConnectedComponent.eq
        (G := G.induce (C.vSet (G := G))ᶜ)
        (v := ⟨u, huK⟩) (w := ⟨v, hvK⟩)).2 hreach
