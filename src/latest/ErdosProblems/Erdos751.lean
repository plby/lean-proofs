          r.length =
              (C.walk.dropUntil x hx_supp).length +
                (C.walk.takeUntil x hx_supp).length := by
            simp [r, SimpleGraph.Walk.rotate]
          _ =
              (C.walk.takeUntil x hx_supp).length +
                (C.walk.dropUntil x hx_supp).length := by
            simp [add_comm]
