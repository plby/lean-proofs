            (C.walk.takeUntil x hx_supp).length +
                (C.walk.dropUntil x hx_supp).length =
                ((C.walk.takeUntil x hx_supp).append
                    (C.walk.dropUntil x hx_supp)).length := hlen''
            _ = C.walk.length := by
              simp
