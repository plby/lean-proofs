/-- Existence of a (paper-)cycle from connected + δ≥2 + card≥2. -/
theorem exists_cycle_of_connected_minDegreeGE2
    (hconn : G.Connected) (hδ2 : MinDegreeGE2 (G := G)) (hcard2 : Fintype.card V ≥ 2) :
    ∃ _ : Cycle (G := G), True := by
  classical
  by_contra hno
