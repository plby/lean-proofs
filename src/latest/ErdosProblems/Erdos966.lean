/-
A set A has an arithmetic progression of length k if there exist a and d (with d non-zero) such that a + i*d is in A for all i < k.
-/
def HasAP (A : Set ℕ) (k : ℕ) : Prop :=
  ∃ a d : ℕ, d ≠ 0 ∧ ∀ i : Fin k, a + i * d ∈ A

/-
A set A has a monochromatic arithmetic progression of length k with respect to a coloring c if there exist a and d (non-zero) such that the AP is in A and all terms have the same color.
-/
def HasMonochromaticAP (A : Set ℕ) (k : ℕ) {r : ℕ} (c : ℕ → Fin r) : Prop :=
  ∃ a d : ℕ, d ≠ 0 ∧ (∀ i : Fin k, a + i * d ∈ A) ∧ (∃ y : Fin r, ∀ i : Fin k, c (a + i * d) = y)

/-
The map `hj_map` converts a vector `v` in `Fin n -> Fin k` to a natural number by interpreting it as a base `2k` expansion.
-/
noncomputable def hj_map (n k : ℕ) (v : Fin n → Fin k) : ℕ :=
  ∑ i : Fin n, (v i).val * (2 * k) ^ (i : ℕ)

/-
`hj_set` is the set of values produced by `hj_map`. `hj_map` is injective when k >= 2, which follows from the uniqueness of base expansion.
-/
def hj_set (n k : ℕ) : Set ℕ :=
  Set.range (hj_map n k)

lemma hj_map_injective {n k : ℕ} (hk : k ≥ 2) : Function.Injective (hj_map n k) := by
  intros v w hvw
  have h_eq : ∀ i, v i = w i := by
    induction' n with n ih;
    · simp +decide;
    · -- By definition of hj_map, we have that v 0 = w 0.
      have h0 : v 0 = w 0 := by
        have h0 : (v 0).val % (2 * k) = (w 0).val % (2 * k) := by
          unfold hj_map at hvw; simp_all +decide [ Fin.sum_univ_succ ] ;
          replace hvw := congr_arg ( · % ( 2 * k ) ) hvw ; simp_all +decide [ Nat.add_mod, Nat.mul_mod, Nat.pow_mod, Finset.sum_nat_mod ] ;
        generalize_proofs at *; (
        exact Fin.ext ( Nat.mod_eq_of_lt ( show ( v 0 : ℕ ) < 2 * k from by linarith [ Fin.is_lt ( v 0 ) ] ) ▸ Nat.mod_eq_of_lt ( show ( w 0 : ℕ ) < 2 * k from by linarith [ Fin.is_lt ( w 0 ) ] ) ▸ h0 ))
      generalize_proofs at *; (
      -- By definition of hj_map, we have that hj_map n k (fun i => v (Fin.succ i)) = hj_map n k (fun i => w (Fin.succ i)).
      have h_eq : hj_map n k (fun i => v (Fin.succ i)) = hj_map n k (fun i => w (Fin.succ i)) := by
        unfold hj_map at *; simp_all +decide [ Fin.sum_univ_succ ] ;
        simp_all +decide [ pow_succ, ← mul_assoc, ← Finset.sum_mul _ _ _ ];
        exact hvw.resolve_right ( by positivity ) ▸ rfl;
      generalize_proofs at *; (
      exact fun i => Fin.cases h0 ( ih h_eq ) i;))
  aesop

/-
The map `hj_map` transforms any combinatorial line `L` in the hypercube `Fin n -> Fin k` into an arithmetic progression in the natural numbers. Specifically, there exist `a` and `d` (with `d` non-zero) such that for every `x` in `Fin k`, the image of the point `L x` under `hj_map` is `a + x * d`.
-/
lemma hj_map_maps_line_to_AP (n k : ℕ) (L : Combinatorics.Line (Fin k) (Fin n)) :
  ∃ a d : ℕ, d ≠ 0 ∧ ∀ x : Fin k, hj_map n k (L x) = a + x.val * d := by
    unfold hj_map;
    by_cases hk : k = 0 <;> simp_all +decide;
    · aesop;
    · obtain ⟨a, d, hd⟩ : ∃ a d : ℕ, ∀ x : Fin k, ∑ i : Fin n, ((L.idxFun i).getD x).val * (2 * k) ^ (i : ℕ) = a + x.val * d := by
        have h_decomp : ∀ i : Fin n, ∃ a_i d_i : ℕ, ∀ x : Fin k, ((L.idxFun i).getD x).val = a_i + x.val * d_i := by
          intro i
          by_cases h_const : ∀ x y : Fin k, ((L.idxFun i).getD x).val = ((L.idxFun i).getD y).val;
          · exact ⟨ ( L.idxFun i |> Option.getD <| ⟨ 0, Nat.pos_of_ne_zero hk ⟩ ) |> Fin.val, 0, fun x => by simpa using h_const x ⟨ 0, Nat.pos_of_ne_zero hk ⟩ ⟩;
          · -- Since L.idxFun i is not constant, it must be the identity function.
            have h_id : ∀ x : Fin k, ((L.idxFun i).getD x).val = x.val := by
              cases h : L.idxFun i ; aesop;
              aesop;
            exact ⟨ 0, 1, fun x => by simpa using h_id x ⟩;
        choose a d h using h_decomp ; exact ⟨ ∑ i, a i * ( 2 * k ) ^ ( i : ℕ ), ∑ i, d i * ( 2 * k ) ^ ( i : ℕ ), fun x => by rw [ Finset.sum_congr rfl fun i hi => by rw [ h i x ] ] ; simp +decide [Finset.sum_add_distrib,
          add_mul, mul_assoc, mul_comm, Finset.mul_sum _ _ _] ⟩ ;
      by_cases hd_zero : d = 0;
      · rcases k with ( _ | _ | k ) <;> simp_all +decide [ Fin.forall_fin_succ ];
        · exact ⟨ 0, 0, by norm_num [ ← hd ] ⟩;
        · have h_unique : Function.Injective (fun v : Fin n → Fin (k + 2) => ∑ i, (v i).val * (2 * (k + 2)) ^ (i : ℕ)) := by
            apply hj_map_injective; norm_num;
          have := @h_unique ( fun i => L.idxFun i |> Option.getD <| 0 ) ( fun i => L.idxFun i |> Option.getD <| 1 ) ; simp_all +decide ;
          have := L.proper; simp_all +decide [ funext_iff ] ;
          obtain ⟨ i, hi ⟩ := this; specialize ‹∀ x : Fin n, ( L.idxFun x ).getD 0 = ( L.idxFun x ).getD 1› i; aesop;
      · exact ⟨ a, d - 1, fun x => by rw [ hd x, Nat.sub_add_cancel ( Nat.pos_of_ne_zero hd_zero ) ] ⟩

/-
If `u`, `v`, `w` are vectors in `Fin n -> Fin k` such that their mapped values satisfy `hj_map u + hj_map w = 2 * hj_map v`, then for each coordinate `i`, `u[i] + w[i] = 2 * v[i]`. This holds because the base `2k` is large enough to prevent carries during addition.
-/
lemma hj_midpoint_property {n k : ℕ} (hk : k ≥ 2) (u v w : Fin n → Fin k)
  (h_eq : hj_map n k u + hj_map n k w = 2 * hj_map n k v) :
  ∀ i, (u i).val + (w i).val = 2 * (v i).val := by
    unfold hj_map at *;
    induction' n with n ih;
    · simp +decide;
    · simp +arith +decide [ Fin.sum_univ_succ ] at *;
      -- By simplifying, we can see that the equation holds for the first coordinate as well.
      have h_first_coord : (u 0).val + (w 0).val = 2 * (v 0).val := by
        have h_first_coord : (u 0).val + (w 0).val ≡ 2 * (v 0).val [MOD 2 * k] := by
          have := congr_arg ( · % ( 2 * k ) ) h_eq; norm_num [ Nat.ModEq, Nat.add_mod, Nat.mul_mod, Nat.pow_mod, Finset.sum_nat_mod ] at this ⊢; aesop;
        rw [ Nat.ModEq ] at h_first_coord;
        rw [ Nat.mod_eq_of_lt, Nat.mod_eq_of_lt ] at h_first_coord <;> linarith [ Fin.is_lt ( u 0 ), Fin.is_lt ( w 0 ), Fin.is_lt ( v 0 ) ];
      simp_all +decide [ pow_succ, ← mul_assoc, ← Finset.sum_mul _ _ _ ];
      exact fun i => Fin.cases h_first_coord ( ih ( fun i => u i.succ ) ( fun i => v i.succ ) ( fun i => w i.succ ) ( by nlinarith ) ) i

/-
If a sequence `f` of length `k+1` takes values strictly less than `k` and forms an arithmetic progression (i.e., `f(i+1) = f(i) + d`), then the sequence must be constant. This is because a non-zero step `d` would cause the values to eventually exceed the bound `k-1`.
-/
lemma nat_AP_in_bounded_range_is_const (k : ℕ) (f : Fin (k + 1) → ℕ)
  (h_range : ∀ i, f i < k)
  (h_ap : ∃ d, ∀ i : Fin k, f (i.castSucc) + d = f (i.succ)) :
  ∃ c, ∀ i, f i = c := by
    -- Let's obtain the common difference d from the hypothesis h_ap.
    obtain ⟨d, hd⟩ := h_ap;
    by_cases hd_zero : d = 0;
    · use f 0; intro i; induction i using Fin.inductionOn <;> aesop;
    · -- Since $d \neq 0$, we have $f(i) = f(0) + i * d$ for all $i$.
      have h_formula : ∀ i : Fin (k + 1), f i = f 0 + i.val * d := by
        exact fun i => Fin.inductionOn i ( by norm_num ) fun i hi => by have := hd i; norm_num at * ; linarith;
      nlinarith [ h_range 0, h_range ( Fin.last k ), h_formula ( Fin.last k ), Nat.pos_of_ne_zero hd_zero ]

/-
The set `hj_set n k` does not contain any non-trivial arithmetic progression of length `k+1`.
-/
theorem hj_set_no_AP (n k : ℕ) (hk : k ≥ 2) : ¬ HasAP (hj_set n k) (k + 1) := by
  unfold HasAP;
  simp_all +decide [ hj_set ];
  intro a d;
  by_contra! h;
  choose f hf using h
  have h_midpoint : ∀ i : Fin (k - 1), ∀ j : Fin n, (f ⟨i.val, by
    exact lt_of_lt_of_le i.2 ( Nat.sub_le_of_le_add <| by linarith )⟩ j).val + (f ⟨i.val + 2, by
    linarith [ Fin.is_lt i, Nat.sub_add_cancel ( by linarith : 1 ≤ k ) ]⟩ j).val = 2 * (f ⟨i.val + 1, by
    grind⟩ j).val := by
    intros i j
    have h_eq : hj_map n k (f ⟨i.val, by
      exact lt_of_lt_of_le i.2 ( Nat.sub_le_of_le_add <| by linarith )⟩) + hj_map n k (f ⟨i.val + 2, by
      linarith [ Fin.is_lt i, Nat.sub_add_cancel ( by linarith : 1 ≤ k ) ]⟩) = 2 * hj_map n k (f ⟨i.val + 1, by
      grind⟩) := by
      simp +arith +decide [ hf ] ; ring
    generalize_proofs at *;
    exact hj_midpoint_property hk _ _ _ h_eq j
  generalize_proofs at *;
  -- By `nat_AP_in_bounded_range_is_const`, since the values are in `0..k-1` and the length is `k+1`, this sequence must be constant.
  have h_const : ∀ j : Fin n, ∃ c : Fin k, ∀ i : Fin (k + 1), f i j = c := by
    intro j
    have h_seq_const : ∀ i : Fin (k - 1), (f ⟨i.val, by
      (expose_names; exact pf i)⟩ j).val + (f ⟨i.val + 2, by
      (expose_names; exact pf_1 i)⟩ j).val = 2 * (f ⟨i.val + 1, by
      (expose_names; exact pf_2 i)⟩ j).val := by
      exact fun i => h_midpoint i j
    generalize_proofs at *;
    have h_seq_const : ∃ d : ℤ, ∀ i : Fin k, (f ⟨i.val + 1, by
      linarith [ Fin.is_lt i ]⟩ j).val = (f ⟨i.val, by
      linarith [ Fin.is_lt i ]⟩ j).val + d := by
      use (f ⟨1, by
        linarith⟩ j).val - (f ⟨0, by
        linarith⟩ j).val
      generalize_proofs at *;
      intro i
      induction' i with i ih;
      induction' i with i ih;
      · norm_num;
      · have := h_seq_const ⟨ i, Nat.lt_pred_iff.mpr ih ⟩ ; norm_num at * ; linarith [ ‹∀ ( ih : i < k ), ( f ⟨ i + 1, by linarith ⟩ j : ℤ ) = ( f ⟨ i, by linarith ⟩ j : ℤ ) + ( f ⟨ 1, by linarith ⟩ j - f ⟨ 0, by linarith ⟩ j ) › ( Nat.lt_of_succ_lt ih ) ] ;
    generalize_proofs at *;
    obtain ⟨ d, hd ⟩ := h_seq_const;
    -- By induction on $i$, we can show that $(f i j).val = (f 0 j).val + i * d$ for all $i$.
    have h_ind : ∀ i : Fin (k + 1), (f i j).val = (f ⟨0, by
      linarith⟩ j).val + i.val * d := by
      intro i
      induction' i using Fin.induction with i ih;
      · norm_num;
      · have := hd i; norm_num at *; linarith!;
    generalize_proofs at *;
    -- Since $d$ must be zero for the sequence to be bounded, we have $(f i j).val = (f 0 j).val$ for all $i$.
    have h_d_zero : d = 0 := by
      have := h_ind ⟨ k, by linarith ⟩;
      norm_num at *;
      nlinarith [ Fin.is_lt ( f ⟨ k, by linarith ⟩ j ), Fin.is_lt ( f 0 j ) ];
    exact ⟨ f ⟨ 0, by linarith ⟩ j, fun i => Fin.ext <| by simpa [ h_d_zero ] using h_ind i ⟩;
  choose c hc using h_const; have := hf 0; have := hf 1; simp_all +decide [ hj_map ] ;

/-
For any alphabet size `k` and number of colors `r`, there exists a dimension `n` such that any `r`-coloring of the hypercube `Fin n -> Fin k` contains a monochromatic combinatorial line. This is a specialization of the general Hales-Jewett theorem.
-/
lemma exists_n_HalesJewett (k r : ℕ) : ∃ n : ℕ, ∀ c : (Fin n → Fin k) → Fin r, ∃ L : Combinatorics.Line (Fin k) (Fin n), Combinatorics.Line.IsMono c L := by
  by_contra h;
  -- Apply the lemma to obtain the dimension n.
  obtain ⟨n, hn⟩ : ∃ n, ∀ c : (Fin n → Fin k) → Fin r, ∃ L : Combinatorics.Line (Fin k) (Fin n), Combinatorics.Line.IsMono c L := by
    convert Combinatorics.Line.exists_mono_in_high_dimension _ _;
    rotate_left;
    exact Fin k;
    exact inferInstance;
    exact Fin r;
    · infer_instance;
    · constructor <;> intro h;
      · tauto;
      · obtain ⟨ ι, hι, h ⟩ := h;
        use Fintype.card ι;
        intro c;
        obtain ⟨ e ⟩ := Fintype.truncEquivFin ι;
        obtain ⟨ L, hL ⟩ := h ( fun f => c ( fun i => f ( e.symm i ) ) );
        refine' ⟨ _, _ ⟩;
        constructor;
        rotate_left;
        exact fun i => L.idxFun ( e.symm i );
        exact hL
        obtain ⟨ i, hi ⟩ := L.proper;
        exact ⟨ e i, by simpa using hi ⟩;
  exact h ⟨ n, hn ⟩

/-
For any k, r >= 2, there exists a set A of natural numbers such that A does not contain any arithmetic progression of length k+1, but for any r-coloring of the natural numbers, A contains a monochromatic arithmetic progression of length k. The set A is constructed as the image of a high-dimensional grid under a map that preserves arithmetic progressions, using the Hales-Jewett theorem to guarantee the monochromatic AP.
-/
theorem existence_of_AP_free_Ramsey_set :
  ∀ k r : ℕ, k ≥ 2 → r ≥ 2 → ∃ A : Set ℕ, ¬ HasAP A (k + 1) ∧ ∀ c : ℕ → Fin r, HasMonochromaticAP A k c := by
    intros k r hk hr
    obtain ⟨n, hn⟩ : ∃ n : ℕ, ∀ c : (Fin n → Fin k) → Fin r, ∃ L : Combinatorics.Line (Fin k) (Fin n), Combinatorics.Line.IsMono c L := by
      exact exists_n_HalesJewett k r
    use Set.image (fun v : Fin n → Fin k => hj_map n k v) (Set.univ : Set (Fin n → Fin k));
    constructor;
    · convert hj_set_no_AP n k hk using 1;
      unfold hj_set; aesop;
    · intro c
      obtain ⟨L, hL⟩ := hn (fun v => c (hj_map n k v));
      obtain ⟨ a, d, hd, h ⟩ := hj_map_maps_line_to_AP n k L;
      use a, d;
      simp +zetaDelta at *;
      exact ⟨ hd, fun i => ⟨ _, h i ⟩, by obtain ⟨ y, hy ⟩ := hL; exact ⟨ y, fun i => by simpa [ h ] using hy i ⟩ ⟩

#print axioms existence_of_AP_free_Ramsey_set
