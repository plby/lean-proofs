/-
We have formalized and proven the theorem `erdos_1126`, which gives a positive
answer to the question posed by Erdős and solved by de Bruijn.
The theorem states that if a function $f: \mathbb{R} \to \mathbb{R}$ satisfies
$f(x+y) = f(x) + f(y)$ for almost all pairs $(x, y)$ (with respect to the
Lebesgue measure on $\mathbb{R}^2$), then there exists an additive function
$h: \mathbb{R} \to \mathbb{R}$ (i.e., $h(x+y) = h(x) + h(y)$ for all $x, y$)
such that $f(x) = h(x)$ for almost all $x$ (with respect to the Lebesgue measure
on $\mathbb{R}$).

The proof follows the steps outlined in the provided text:
1.  We identify a set $M$ of measure zero such that for $x \notin M$, the additivity
    relation holds for almost all $y$.
2.  We construct the function $h$ using values of $f$ shifted by elements not in $M$.
3.  We prove that $h$ is additive and coincides with $f$ almost everywhere.
-/

import Mathlib

namespace Erdos1126

open scoped BigOperators
open scoped Real
open scoped Nat
open scoped Pointwise

open MeasureTheory Measure Filter Set

/-
If $f(x+y)=f(x)+f(y)$ for almost all $x,y\in \mathbb{R}$ then there exists an
additive function $h$ such that $f(x)=h(x)$ for almost all $x$.
-/
theorem erdos_1126
    (f : ℝ → ℝ)
    (h :
      ∀ᵐ (p : ℝ × ℝ) ∂(volume.prod volume),
        f (p.1 + p.2) = f p.1 + f p.2) :
    ∃ h : ℝ → ℝ,
      (∀ x y, h (x + y) = h x + h y) ∧ (∀ᵐ x ∂volume, f x = h x) := by
  classical
  -- There is a linear set $M$ of linear measure zero such that for every
  -- $x\notin M$ it is true that $f(x+y)=f(x)+f(y)$ holds for almost all $y$.
  obtain ⟨M, hM⟩ :
      ∃ M : Set ℝ,
        MeasurableSet M ∧
          MeasureTheory.volume M = 0 ∧
            ∀ x ∉ M, ∀ᵐ y ∂MeasureTheory.volume, f (x + y) = f x + f y := by
    have h_fubini :
        ∀ᵐ x ∂MeasureTheory.volume,
          MeasureTheory.volume {y | f (x + y) ≠ f x + f y} = 0 := by
      exact ae_ae_eq_of_ae_eq_uncurry h
    exact
      ⟨ MeasureTheory.toMeasurable MeasureTheory.MeasureSpace.volume
          {x : ℝ |
            ¬MeasureTheory.MeasureSpace.volume
              {y : ℝ | f (x + y) ≠ f x + f y} = 0},
        MeasureTheory.measurableSet_toMeasurable _ _,
        by
          rw [MeasureTheory.measure_toMeasurable]
          simp_all only [ne_eq]
          exact h_fubini,
        fun x hx => by
          have hzero :
              MeasureTheory.volume {y : ℝ | f (x + y) ≠ f x + f y} = 0 := by
            simpa [hx] using
              Classical.not_not.1 fun hx' =>
                hx <| MeasureTheory.subset_toMeasurable _ _ hx'
          filter_upwards [MeasureTheory.measure_eq_zero_iff_ae_notMem.mp hzero] with y hy
          simpa using hy⟩
  -- Let $x$ be any real number. Since $\mu(M)=\mu(x-M)=0$, we have
  -- $M\cup(x-M)\ne \mathbb{R}$. It follows that $x_{1}\in \mathbb{R}$ exists
  -- such that $x_{1}\notin M$, $x-x_{1}\notin M$.
  have h_exists_x1 : ∀ x : ℝ, ∃ x1 : ℝ, x1 ∉ M ∧ x - x1 ∉ M := by
    intro x
    by_contra h_contra
    -- If for every $x_1 \notin M$, we have $x - x_1 \in M$, then
    -- $M \cup (x - M) = \mathbb{R}$.
    have h_union : M ∪ (Set.image (fun y => x - y) M) = Set.univ := by
      ext y
      simp only [mem_union, mem_image, mem_univ, iff_true]
      by_cases hy : y ∈ M
      · exact Or.inl hy
      · right
        refine ⟨x - y, ?_, by ring⟩
        by_contra hxy
        exact h_contra ⟨y, hy, hxy⟩
    -- Since $M$ has measure zero, the image of $M$ under the function
    -- $y \mapsto x - y$ also has measure zero.
    have h_image_zero : MeasureTheory.volume (Set.image (fun y => x - y) M) = 0 := by
      rw [
        show (fun y => x - y) '' M = (fun y => -y) '' M + {x} by
          ext z
          simp +decide only [mem_image, image_neg_eq_neg, add_singleton, image_add_right,
            mem_preimage, Set.mem_neg, neg_add_rev, neg_neg]
          constructor
          · rintro ⟨m, hm, hmz⟩
            subst z
            simpa [sub_eq_add_neg, add_comm, add_left_comm, add_assoc] using hm
          · intro hz
            refine ⟨x + -z, hz, ?_⟩
            ring
      ]
      simp +decide [*, Set.add_singleton]
    exact absurd
      (h_union ▸ MeasureTheory.measure_union_null hM.2.1 h_image_zero)
      (by norm_num)
  -- Therefore, $f(x_{1}+y)-f(y)=f(x_{1})$ for almost all $y$, and
  -- $f(x-x_{1}+z)-f(z)=f(x-x_{1})$ for almost all $z$.
  have h_eq :
      ∀ x : ℝ,
        ∃ x1 : ℝ,
          x1 ∉ M ∧
            x - x1 ∉ M ∧
              (∀ᵐ y ∂MeasureTheory.volume, f (x1 + y) - f y = f x1) ∧
                (∀ᵐ z ∂MeasureTheory.volume, f (x - x1 + z) - f z = f (x - x1)) := by
    exact fun x => by
      obtain ⟨x1, hx1, hx2⟩ := h_exists_x1 x
      exact
        ⟨x1, hx1, hx2,
          by
            filter_upwards [hM.2.2 x1 hx1] with y hy
            linarith,
          by
            filter_upwards [hM.2.2 (x - x1) hx2] with z hz
            linarith⟩
  -- Putting $z=x_{1}+y$, we infer that
  -- $f(x+y)-f(y)=f(x_{1})+f(x-x_{1})$ for almost all $y$.
  have h_add :
      ∀ x : ℝ, ∃ c : ℝ, ∀ᵐ y ∂MeasureTheory.volume, f (x + y) - f y = c := by
    intro x
    obtain ⟨x1, hx1_not_in_M, hx1_minus_x_not_in_M, hx1_eq, hx1_minus_x_eq⟩ :=
      h_eq x
    use f x1 + f (x - x1)
    have h_subst :
        ∀ᵐ y ∂MeasureTheory.volume,
          f (x - x1 + (x1 + y)) - f (x1 + y) = f (x - x1) := by
      rw [MeasureTheory.ae_iff] at *
      rw [
        show
            {a : ℝ |
              ¬f (x - x1 + (x1 + a)) - f (x1 + a) = f (x - x1)} =
              (fun y => x1 + y) ⁻¹'
                {a : ℝ | ¬f (x - x1 + a) - f a = f (x - x1)} by
          ext
          simp +decide [add_comm, add_assoc]
      ]
      rw [MeasureTheory.measure_preimage_add]
      simp_all only
    filter_upwards [hx1_eq, h_subst] with y hy₁ hy₂ using by
      ring_nf at *
      linarith
  choose c hc using h_add
  -- Thus there is a uniquely determined function $h$ with the property that for
  -- every $x$ it is true that $f(x+y)-f(y)=h(x)$ for almost all $y$.
  have h_unique : ∀ x y : ℝ, c (x + y) = c x + c y := by
    -- For every $x$, let $K_{x}$ denote the set of $y$'s for which this does
    -- not hold, whence $\mu(K_{x})=0$. If $x\notin M$ we also have
    -- $f(x+y)=f(x)+f(y)$ for almost all $y$, and it follows that $h(x)=f(x)$
    -- ($x\notin M$).
    intros x y
    have h_eq :
        ∀ᵐ z ∂MeasureTheory.volume,
          f (x + y + z) - f z = c (x + y) ∧
            f (x + z) - f z = c x ∧
              f (y + (x + z)) - f (x + z) = c y := by
      have h_eq :
          ∀ᵐ z ∂MeasureTheory.volume,
            f (x + y + z) - f z = c (x + y) := by
        exact hc _
      have h_eq' : ∀ᵐ z ∂MeasureTheory.volume, f (x + z) - f z = c x := by
        exact hc x
      have h_eq'' :
          ∀ᵐ z ∂MeasureTheory.volume,
            f (y + (x + z)) - f (x + z) = c y := by
        rw [MeasureTheory.ae_iff] at *
        rw [
          show
              {a : ℝ | ¬f (y + (x + a)) - f (x + a) = c y} =
                (fun a => x + a) ⁻¹' {a : ℝ | ¬f (y + a) - f a = c y} by
            ext
            simp +decide
        ]
        rw [MeasureTheory.measure_preimage_add]
        obtain ⟨left, right⟩ := hM
        obtain ⟨left_1, right⟩ := right
        apply hc
      exact Filter.Eventually.and h_eq (Filter.Eventually.and h_eq' h_eq'')
    obtain ⟨z, hz⟩ := h_eq.exists
    ring_nf at *
    linarith
  -- For every $x$, let $K_{x}$ denote the set of $y$'s for which this does not
  -- hold, whence $\mu(K_{x})=0$. If $x\notin M$ we also have
  -- $f(x+y)=f(x)+f(y)$ for almost all $y$, and it follows that $h(x)=f(x)$
  -- ($x\notin M$).
  have h_eq_f : ∀ x : ℝ, x ∉ M → c x = f x := by
    intro x hx
    specialize hc x
    specialize hM
    have := hM.2.2 x hx
    simp_all +decide [sub_eq_iff_eq_add']
    have := hc.and (hM.2.2 x hx)
    obtain ⟨y, hy₁, hy₂⟩ := this.exists
    linarith
  exact
    ⟨c, h_unique,
      by
        filter_upwards [MeasureTheory.measure_eq_zero_iff_ae_notMem.mp hM.2.1] with x hx
        exact Eq.symm (h_eq_f x hx)⟩

end Erdos1126

