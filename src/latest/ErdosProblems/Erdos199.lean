noncomputable section

/-
A 3-term arithmetic progression is a set of three distinct numbers a, b, c such that a + c = 2b. An infinite arithmetic progression is a set of the form {a + nb | n ∈ ℕ} with b ≠ 0.
-/
def IsThreeTermAP (a b c : ℝ) : Prop :=
  a + c = 2 * b ∧ a ≠ c

def IsInfiniteAP (S : Set ℝ) : Prop :=
  ∃ a b : ℝ, b ≠ 0 ∧ S = {x | ∃ n : ℕ, x = a + n * b}

/-
A 3-term arithmetic progression in a vector space V over ℚ is a set of three distinct vectors a, b, c such that a + c = 2b. An infinite arithmetic progression is a set of the form {a + nb | n ∈ ℕ} with b ≠ 0.
-/
def IsThreeTermAP_V {V : Type*} [AddCommGroup V] [Module ℚ V] (a b c : V) : Prop :=
  a + c = 2 • b ∧ a ≠ c

def IsInfiniteAP_V {V : Type*} [AddCommGroup V] [Module ℚ V] (S : Set V) : Prop :=
  ∃ a b : V, b ≠ 0 ∧ S = {x | ∃ n : ℕ, x = a + n • b}

/-
The coefficient sequence of a vector x with respect to an ordered basis b is the list of coefficients of x in the basis expansion, ordered by the basis indices.
-/
noncomputable def coeffSeq {ι : Type*} [LinearOrder ι] {V : Type*} [AddCommGroup V] [Module ℚ V]
  (b : Module.Basis ι ℚ V) (x : V) : List ℚ :=
  let support := (b.repr x).support.sort (· ≤ ·)
  support.map (b.repr x)

/-
Given a basis, a starting vector u, a non-zero direction vector v, and a threshold T, there exists a natural number m such that the coefficients of u + m*v corresponding to the support of v are all greater than T in absolute value.
-/
lemma exists_large_coeff_in_AP {ι : Type*} [LinearOrder ι] {V : Type*} [AddCommGroup V] [Module ℚ V]
  (b : Module.Basis ι ℚ V) (u v : V) (_hv : v ≠ 0) (T : ℚ) :
  ∃ m : ℕ, ∀ i ∈ (b.repr v).support, |(b.repr (u + m • v)) i| > T := by
  -- For each $i \in S$, $|u_i + m v_i| \ge m |v_i| - |u_i|$. Since $v_i \neq 0$ (because $i \in S$), $|v_i| > 0$, and $m |v_i| - |u_i| \to \infty$ as $m \to \infty$.
  have h_abs : ∀ i ∈ (b.repr v).support, ∃ m : ℕ, ∀ k ≥ m, |(b.repr u i) + k * (b.repr v i)| > T := by
    -- By the Archimedean property, for each $i \in S$, there exists an $m$ such that $m |v_i| > T + |u_i|$.
    intro i hi
    obtain ⟨m, hm⟩ : ∃ m : ℕ, m * |(b.repr v i)| > T + |(b.repr u i)| := by
      exact exists_nat_gt ( ( T + |b.repr u i| ) / |b.repr v i| ) |> fun ⟨ m, hm ⟩ => ⟨ m, by rwa [ div_lt_iff₀ ( abs_pos.mpr ( Finsupp.mem_support_iff.mp hi ) ) ] at hm ⟩;
    exact ⟨ m, fun k hk => by cases abs_cases ( ( b.repr u i ) + ( k : ℚ ) * ( b.repr v i ) ) <;> cases abs_cases ( ( b.repr v i ) ) <;> cases abs_cases ( ( b.repr u i ) ) <;> nlinarith [ show ( k : ℚ ) ≥ m by norm_cast ] ⟩;
  choose! m hm using h_abs;
  exact ⟨ Finset.sup ( b.repr v |> Finsupp.support ) m + 1, fun i hi => by simpa using hm i hi _ ( Nat.le_succ_of_le ( Finset.le_sup ( f := m ) hi ) ) ⟩

/-
A sequence of patterns (lists of rationals) and thresholds is spaced if for every n, all coefficients in previous patterns are bounded by t_n, all coefficients in the n-th pattern are either bounded by t_n or greater than 3*t_n, and there is at least one coefficient in the n-th pattern greater than 3*t_n.
-/
def IsSpacedPatternSeq (σ : ℕ → List ℚ) (t : ℕ → ℚ) : Prop :=
  ∀ n,
    (∀ k < n, ∀ r ∈ σ k, |r| ≤ t n) ∧
    (∀ r ∈ σ n, |r| ≤ t n ∨ |r| > 3 * t n) ∧
    (∃ r ∈ σ n, |r| > 3 * t n)

/-
The first value in a list l that is greater than 3*t in absolute value.
-/
def firstLargeValue (l : List ℚ) (t : ℚ) : Option ℚ :=
  l.find? (fun x => |x| > 3 * t)

/-
Searching for a value satisfying P in a mapped sorted list returns the image of the smallest index satisfying the condition.
-/
lemma find_map_sorted {α β : Type*} [LinearOrder α]
  (l : List α) (f : α → β) (P : β → Bool) (i : α)
  (h_sorted : l.Pairwise (· < ·))
  (h_mem : i ∈ l)
  (h_sat : P (f i))
  (h_first : ∀ j ∈ l, j < i → ¬ P (f j)) :
  (l.map f).find? P = some (f i) := by
  rw [List.find?_map]
  have hfind : List.find? (P ∘ f) l = some i := by
    induction l with
    | nil => simp at h_mem
    | cons a l ih =>
        by_cases hai : a = i
        · subst i
          exact List.find?_cons_of_pos h_sat
        · have hmem_tail : i ∈ l := by
            have hai' : i ≠ a := fun h => hai h.symm
            simpa [hai'] using h_mem
          have ha_false : ¬(P (f a) = true) := by
            exact h_first a (by simp) (h_sorted.rel_head_tail hmem_tail)
          rw [List.find?_cons_of_neg (p := P ∘ f) (a := a) ha_false]
          exact ih (List.Pairwise.tail h_sorted) hmem_tail fun j hj hj_lt =>
            h_first j (by simp [hj]) hj_lt
  simp [hfind]

/-
The index of the first coefficient of v (in the sorted basis order) that is greater than 3T in absolute value.
-/
def firstLargeIndex {ι : Type*} [LinearOrder ι] {V : Type*} [AddCommGroup V] [Module ℚ V]
  (b : Module.Basis ι ℚ V) (v : V) (T : ℚ) : Option ι :=
  ((b.repr v).support.sort (· ≤ ·)).find? (fun i => |b.repr v i| > 3 * T)

/-
Key step for Case 2: If a + c = 2b, a is small, b has a first large index i, and b and c have the same spaced coefficient sequence, then b_i = c_i.
-/
lemma case2_key_step {ι : Type*} [LinearOrder ι] {V : Type*} [AddCommGroup V] [Module ℚ V]
  (b : Module.Basis ι ℚ V) (a b_vec c : V) (T : ℚ) (i : ι)
  (h_ap : a + c = 2 • b_vec)
  (h_a_small : ∀ j, |b.repr a j| ≤ T)
  (h_b_large_i : |b.repr b_vec i| > 3 * T)
  (h_b_small_prev : ∀ j < i, |b.repr b_vec j| ≤ T)
  (h_seq_eq : coeffSeq b b_vec = coeffSeq b c)
  (_h_c_spaced : ∀ r ∈ coeffSeq b c, |r| ≤ T ∨ |r| > 3 * T) :
  b.repr b_vec i = b.repr c i := by
    by_contra h_contra;
    -- Applying the large_coeff_implies_large_val lemma, we know that the first large value in the coefficient sequence of b_vec is (b.repr b_vec) i.
    have h_b_large_val : firstLargeValue (coeffSeq b b_vec) T = some ((b.repr b_vec) i) := by
      unfold firstLargeValue coeffSeq
      refine find_map_sorted ((b.repr b_vec).support.sort (· ≤ ·)) (fun j => b.repr b_vec j)
        (fun x : ℚ => decide (|x| > 3 * T)) i (Finset.sortedLT_sort ((b.repr b_vec).support)).pairwise ?_ ?_ ?_
      · simp +zetaDelta at *;
        exact fun h => by rw [ h ] at h_b_large_i; norm_num at h_b_large_i; linarith [ show T ≥ 0 by exact le_trans ( abs_nonneg _ ) ( h_a_small i ) ] ;
      · grind;
      · norm_num +zetaDelta at *;
        exact fun j hj₁ hj₂ => le_trans ( h_b_small_prev j hj₂ ) ( by linarith [ abs_le.mp ( h_a_small j ) ] );
    -- Applying the large_coeff_implies_large_val lemma, we know that the first large value in the coefficient sequence of c is (b.repr c) i.
    have h_c_large_val : firstLargeValue (coeffSeq b c) T = some ((b.repr c) i) := by
      unfold firstLargeValue coeffSeq
      refine find_map_sorted ((b.repr c).support.sort (· ≤ ·)) (fun j => b.repr c j)
        (fun x : ℚ => decide (|x| > 3 * T)) i (Finset.sortedLT_sort ((b.repr c).support)).pairwise ?_ ?_ ?_
      · simp_all +decide [ firstLargeValue, coeffSeq ];
        replace h_ap := congr_arg ( fun x => b.repr x i ) h_ap ; simp_all +decide [ two_smul ];
        cases abs_cases ( ( b.repr b_vec ) i ) <;> cases abs_cases ( ( b.repr a ) i ) <;> cases abs_cases ( ( b.repr c ) i ) <;> linarith [ h_a_small i ];
      · replace h_ap := congr_arg ( fun x => b.repr x i ) h_ap ; simp_all +decide [ two_smul ] ; cases abs_cases ( b.repr b_vec i ) <;> cases abs_cases ( b.repr c i ) <;> cases lt_or_gt_of_ne h_contra <;> linarith [ abs_le.mp ( h_a_small i ) ] ;
      · intro j hj_mem hj_lt_i; specialize h_b_small_prev j hj_lt_i; simp_all +decide [ two_smul ] ;
        replace h_ap := congr_arg ( fun x => b.repr x j ) h_ap ; simp_all +decide  ; cases abs_cases ( b.repr a j ) <;> cases abs_cases ( b.repr c j ) <;> cases abs_cases ( b.repr b_vec j ) <;> linarith [ h_a_small j ] ;
    grind

/-
If a, b, c form a 3-term AP and their coefficient patterns correspond to indices m, n, p with m < n = p, and the patterns are spaced, then we reach a contradiction.
-/
lemma spaced_implies_no_3AP_case2 {ι : Type*} [LinearOrder ι] {V : Type*} [AddCommGroup V] [Module ℚ V]
  (b : Module.Basis ι ℚ V) (σ : ℕ → List ℚ) (t : ℕ → ℚ)
  (h_spaced : IsSpacedPatternSeq σ t)
  (a b_vec c : V) (m n p : ℕ)
  (ha : coeffSeq b a = σ m) (hb : coeffSeq b b_vec = σ n) (hc : coeffSeq b c = σ p)
  (h_order : m < n ∧ n = p)
  (h_ap : a + c = 2 • b_vec) : False := by
    -- Let i be the first index where |b_i| > 3t_n. Such an i exists because sigma(b) = sigma_n has a large element.
    obtain ⟨i, hi⟩ : ∃ i, i ∈ (b.repr b_vec).support ∧ |b.repr b_vec i| > 3 * t n ∧ ∀ j ∈ (b.repr b_vec).support, j < i → |b.repr b_vec j| ≤ t n := by
      have := h_spaced n;
      -- Let i be the first index where |b_i| > 3t_n. Such an i exists because sigma(b) = sigma_n has a large element and the coefficients are spaced.
      obtain ⟨i, hi⟩ : ∃ i ∈ (b.repr b_vec).support, |b.repr b_vec i| > 3 * t n := by
        have := this.2.2; obtain ⟨ r, hr₁, hr₂ ⟩ := this; simp_all +decide [ coeffSeq ] ;
        rw [ ← hb ] at hr₁; rw [ List.mem_map ] at hr₁; obtain ⟨ i, hi, rfl ⟩ := hr₁; use i; aesop;
      obtain ⟨i, hi⟩ : ∃ i ∈ (b.repr b_vec).support, |b.repr b_vec i| > 3 * t n ∧ ∀ j ∈ (b.repr b_vec).support, j < i → |b.repr b_vec j| ≤ 3 * t n := by
        exact ⟨ Finset.min' ( ( b.repr b_vec ).support.filter fun j => |( b.repr b_vec ) j| > 3 * t n ) ⟨ i, by aesop ⟩, Finset.mem_filter.mp ( Finset.min'_mem ( ( b.repr b_vec ).support.filter fun j => |( b.repr b_vec ) j| > 3 * t n ) ⟨ i, by aesop ⟩ ) |>.1, Finset.mem_filter.mp ( Finset.min'_mem ( ( b.repr b_vec ).support.filter fun j => |( b.repr b_vec ) j| > 3 * t n ) ⟨ i, by aesop ⟩ ) |>.2, fun j hj hj' => not_lt.1 fun contra => hj'.not_ge ( Finset.min'_le _ _ <| by aesop ) ⟩;
      refine' ⟨ i, hi.1, hi.2.1, fun j hj hj' => _ ⟩;
      cases this.2.1 ( b.repr b_vec j ) ( by rw [ ← hb ] ; exact List.mem_map.mpr ⟨ j, Finset.mem_sort ( α := ι ) ( · ≤ · ) |>.2 ( by aesop ), rfl ⟩ ) <;> linarith [ hi.2.2 j hj hj' ];
    -- By case2_key_step, b_i = c_i.
    have h_bi_ci : b.repr b_vec i = b.repr c i := by
      apply case2_key_step b a b_vec c (t n) i h_ap;
      · intro j
        have h_a_small : ∀ r ∈ coeffSeq b a, |r| ≤ t n := by
          exact fun r hr => h_spaced n |>.1 m h_order.1 r ( ha ▸ hr );
        by_cases hj : j ∈ (b.repr a).support;
        · unfold coeffSeq at h_a_small; aesop;
        · simp_all +decide
          contrapose! h_a_small;
          have := h_spaced m;
          exact ⟨ this.2.2.choose, this.2.2.choose_spec.1, by linarith [ this.2.2.choose_spec.2, abs_nonneg this.2.2.choose ] ⟩;
      · exact hi.2.1;
      · intro j hj; by_cases hj' : j ∈ ( b.repr b_vec ).support <;> simp_all +decide ;
        have := h_spaced p; simp_all +decide [ IsSpacedPatternSeq ] ;
        contrapose! this;
        exact ⟨ m, by linarith, _, h_spaced m |>.2.2.choose_spec.1, lt_of_lt_of_le this ( abs_nonneg _ ) ⟩;
      · grind;
      · have := h_spaced n; aesop;
    -- By the properties of the coefficient sequence, if i is not in the support of a, then |a_i| ≤ t_n.
    have h_ai_le_t : |b.repr a i| ≤ t n := by
      have := h_spaced n;
      convert this.1 m h_order.1 _ _;
      rw [ ← ha ];
      unfold coeffSeq;
      by_cases hi : i ∈ ( b.repr a ).support <;> simp_all +decide;
      · use i;
      · replace h_ap := congr_arg ( fun x => b.repr x i ) h_ap ; simp_all +decide [ two_smul ];
    replace h_ap := congr_arg ( fun x => b.repr x i ) h_ap ; simp_all +decide [ two_smul ] ; linarith [ abs_le.mp h_ai_le_t ] ;

/-
If a, b, c form a 3-term AP and are distinct, there is a first index where their coefficients differ.
-/
lemma case3_first_diff {ι : Type*} [LinearOrder ι] {V : Type*} [AddCommGroup V] [Module ℚ V]
  (b : Module.Basis ι ℚ V) (a b_vec c : V)
  (h_ap : a + c = 2 • b_vec)
  (h_distinct : a ≠ c) :
  ∃ i : ι, (b.repr a i ≠ b.repr b_vec i ∨ b.repr b_vec i ≠ b.repr c i) ∧
    ∀ j < i, b.repr a j = b.repr b_vec j ∧ b.repr b_vec j = b.repr c j := by
      -- Since $a$ and $c$ are distinct, there exists at least one index $i$ such that $b.repr a i \neq b.repr c i$.
      have h_diff : ∃ i : ι, ((b.repr a) i ≠ (b.repr c) i) := by
        exact not_forall.mp fun h => h_distinct <| b.repr.injective <| by ext i; exact h i;
      -- Since the supports of $a$, $b$, and $c$ are finite, there exists a minimum index $i$ where $b.repr a i \neq b.repr c i$.
      obtain ⟨i, hi⟩ : ∃ i : ι, ((b.repr a) i ≠ (b.repr c) i) ∧ ∀ j : ι, j < i → (b.repr a) j = (b.repr c) j := by
        obtain ⟨i, hi⟩ : ∃ i : ι, (b.repr a) i ≠ (b.repr c) i := h_diff
        have h_support_finite : Set.Finite {j : ι | (b.repr a) j ≠ (b.repr c) j} := by
          exact Set.Finite.subset ( b.repr a |> Finsupp.support |> Finset.finite_toSet |> Set.Finite.union <| b.repr c |> Finsupp.support |> Finset.finite_toSet ) fun x hx => by by_cases ha : b.repr a x = 0 <;> by_cases hc : b.repr c x = 0 <;> aesop;
        exact ⟨ Finset.min' ( h_support_finite.toFinset ) ⟨ i, h_support_finite.mem_toFinset.mpr hi ⟩, h_support_finite.mem_toFinset.mp ( Finset.min'_mem _ _ ), fun j hj => Classical.not_not.1 fun hji => hj.not_ge ( Finset.min'_le _ _ ( h_support_finite.mem_toFinset.mpr hji ) ) ⟩;
      refine' ⟨ i, _, _ ⟩;
      · contrapose! hi; simp_all +decide [ two_smul ] ;
      · intro j hj; have := congr_arg ( b.repr ) h_ap; norm_num at this; simp_all +decide [ two_smul ] ;
        replace this := congr_arg ( fun f => f j ) this; simp_all +decide [ ← two_smul ℚ ] ;

/-
Definitions of suffix and prefix coefficient sequences based on a split index i.
-/
def suffixCoeffSeq {ι : Type*} [LinearOrder ι] {V : Type*} [AddCommGroup V] [Module ℚ V]
  (b : Module.Basis ι ℚ V) (x : V) (i : ι) : List ℚ :=
  (((b.repr x).support.sort (· ≤ ·)).filter (fun j => i ≤ j)).map (b.repr x)

def prefixCoeffSeq {ι : Type*} [LinearOrder ι] {V : Type*} [AddCommGroup V] [Module ℚ V]
  (b : Module.Basis ι ℚ V) (x : V) (i : ι) : List ℚ :=
  (((b.repr x).support.sort (· ≤ ·)).filter (fun j => j < i)).map (b.repr x)

/-
If two vectors have the same coefficient sequence and agree on all indices less than i, then their suffix coefficient sequences starting at i are identical.
-/
lemma suffix_eq_of_coeffSeq_eq {ι : Type*} [LinearOrder ι] {V : Type*} [AddCommGroup V] [Module ℚ V]
  (b : Module.Basis ι ℚ V) (u v : V) (i : ι)
  (h_seq : coeffSeq b u = coeffSeq b v)
  (h_prev : ∀ j < i, b.repr u j = b.repr v j) :
  suffixCoeffSeq b u i = suffixCoeffSeq b v i := by
    have h_split : coeffSeq b u = (prefixCoeffSeq b u i) ++ (suffixCoeffSeq b u i) ∧ coeffSeq b v = (prefixCoeffSeq b v i) ++ (suffixCoeffSeq b v i) := by
      have h_split : ∀ (x : V) (i : ι), coeffSeq b x = (prefixCoeffSeq b x i) ++ (suffixCoeffSeq b x i) := by
        intro x i;
        have h_split : ∀ (l : List ι), l.Pairwise (· ≤ ·) → ∀ (i : ι), (l.map (b.repr x)) = ((l.filter (fun j => j < i)).map (b.repr x)) ++ ((l.filter (fun j => i ≤ j)).map (b.repr x)) := by
          intro l hl i
          induction' l with j l ih generalizing i;
          · rfl;
          · by_cases h : j < i <;> simp_all +decide
            · exact ih i;
            · rw [ ih i ];
              rw [ List.filter_eq_nil_iff.mpr ] <;> simp +decide
              exact fun a ha => le_trans h (hl.1 a ha);
        convert h_split ((b.repr x |> Finsupp.support).sort (· ≤ ·)) (Finset.pairwise_sort _ (· ≤ ·)) i using 1;
      exact ⟨ h_split u i, h_split v i ⟩;
    have h_prefix_eq : prefixCoeffSeq b u i = prefixCoeffSeq b v i := by
      unfold prefixCoeffSeq;
      have h_support_eq : (b.repr u).support.filter (fun j => j < i) = (b.repr v).support.filter (fun j => j < i) := by
        ext j; aesop;
      have h_sorted_eq : List.filter (fun j => j < i) ((b.repr u).support.sort (· ≤ ·)) = List.filter (fun j => j < i) ((b.repr v).support.sort (· ≤ ·)) := by
        have h_sorted_eq : List.Perm (List.filter (fun j => j < i) ((b.repr u).support.sort (· ≤ ·))) (List.filter (fun j => j < i) ((b.repr v).support.sort (· ≤ ·))) := by
          rw [ List.perm_iff_count ];
          intro j; by_cases hj : j < i <;> simp_all +decide [ Finset.ext_iff ] ;
          · by_cases hj' : j ∈ ( b.repr u ).support <;> by_cases hj'' : j ∈ ( b.repr v ).support <;> simp_all +decide [ List.count_eq_zero_of_not_mem ];
          · rw [ List.count_eq_zero_of_not_mem, List.count_eq_zero_of_not_mem ] <;> aesop;
        have h_sorted_eq : (List.filter (fun j => j < i) ((b.repr u).support.sort (· ≤ ·))).Pairwise (· ≤ ·) ∧ (List.filter (fun j => j < i) ((b.repr v).support.sort (· ≤ ·))).Pairwise (· ≤ ·) := by
          exact ⟨ List.Pairwise.filter _ (Finset.pairwise_sort _ (· ≤ ·)), List.Pairwise.filter _ (Finset.pairwise_sort _ (· ≤ ·)) ⟩;
        exact List.Perm.eq_of_pairwise (fun a b _ _ hab hba => le_antisymm hab hba) h_sorted_eq.1 h_sorted_eq.2 ‹_›;
      rw [ h_sorted_eq ];
      rw [ List.map_congr_left ] ; aesop;
    rw [h_split.left, h_split.right, h_prefix_eq] at h_seq
    aesop

/-
If u has a non-zero coefficient at i, then the first element of its suffix coefficient sequence starting at i is that coefficient.
-/
lemma head_suffix_eq_apply_of_ne_zero {ι : Type*} [LinearOrder ι] {V : Type*} [AddCommGroup V] [Module ℚ V]
  (b : Module.Basis ι ℚ V) (u : V) (i : ι)
  (hu_nz : b.repr u i ≠ 0) :
  (suffixCoeffSeq b u i).head? = some (b.repr u i) := by
    unfold suffixCoeffSeq;
    -- Since $i$ is in the support and we are filtering for $j \geq i$, $i$ is the smallest element in the filtered support. Thus, $i$ is the first element of the sorted filtered support.
    have h_sorted_filter : List.filter (fun j => i ≤ j) ((b.repr u).support.sort (· ≤ ·)) = i :: List.filter (fun j => i < j) ((b.repr u).support.sort (· ≤ ·)) := by
      have h_sorted_filter : List.Perm (List.filter (fun j => i ≤ j) ((b.repr u).support.sort (· ≤ ·))) (i :: List.filter (fun j => i < j) ((b.repr u).support.sort (· ≤ ·))) := by
        rw [ List.perm_iff_count ];
        intro j; by_cases hj : j = i <;> by_cases hj' : i ≤ j <;> by_cases hj'' : i < j <;> simp_all +decide [ List.count_cons ] ;
        · rw [ List.count_eq_zero ] ; aesop;
        · exact ne_of_lt hj'';
        · exact False.elim ( hj ( le_antisymm hj'' hj' ) );
        · exact False.elim ( lt_asymm hj' hj'' );
        · rw [ List.count_eq_zero_of_not_mem, List.count_eq_zero_of_not_mem ] <;> aesop;
      have h_sorted_filter : (List.filter (fun j => i ≤ j) ((b.repr u).support.sort (· ≤ ·))).Pairwise (· ≤ ·) := by
        exact List.Pairwise.filter _ (Finset.pairwise_sort _ (· ≤ ·));
      have h_sorted_filter : (i :: List.filter (fun j => i < j) ((b.repr u).support.sort (· ≤ ·))).Pairwise (· ≤ ·) := by
        simp +zetaDelta at *;
        exact ⟨ fun _ _ hlt => le_of_lt hlt,
          List.Pairwise.filter (fun j : ι => i < j) (Finset.pairwise_sort ((b.repr u).support) (· ≤ ·)) ⟩;
      exact List.Perm.eq_of_pairwise (fun a b _ _ hab hba => le_antisymm hab hba) ‹_› ‹_› ‹_›;
    aesop

/-
If two vectors have the same coefficient sequence, agree on indices less than i, and both have non-zero coefficients at i, then their coefficients at i are equal.
-/
lemma next_nonzero_coeff_eq {ι : Type*} [LinearOrder ι] {V : Type*} [AddCommGroup V] [Module ℚ V]
  (b : Module.Basis ι ℚ V) (u v : V) (i : ι)
  (h_seq : coeffSeq b u = coeffSeq b v)
  (h_prev : ∀ j < i, b.repr u j = b.repr v j)
  (hu_nz : b.repr u i ≠ 0)
  (hv_nz : b.repr v i ≠ 0) :
  b.repr u i = b.repr v i := by
    -- By suffix_eq_of_coeffSeq_eq, suffixCoeffSeq b u i = suffixCoeffSeq b v i.
    have h_suffix_eq : suffixCoeffSeq b u i = suffixCoeffSeq b v i := by
      exact suffix_eq_of_coeffSeq_eq b u v i h_seq h_prev;
    -- By head_suffix_eq_apply_of_ne_zero applied to u, the head of suffixCoeffSeq b u i is some (b.repr u i).
    have h_head_u : (suffixCoeffSeq b u i).head? = some (b.repr u i) := by
      exact head_suffix_eq_apply_of_ne_zero b u i hu_nz;
    -- By head_suffix_eq_apply_of_ne_zero applied to v, the head of suffixCoeffSeq b v i is some (b.repr v i).
    have h_head_v : (suffixCoeffSeq b v i).head? = some (b.repr v i) := by
      exact head_suffix_eq_apply_of_ne_zero b v i hv_nz;
    grind

/-
If a, b, c form a 3-term AP and their coefficient patterns correspond to indices m, n, p with m = n = p, and the patterns are spaced, then we reach a contradiction.
-/
lemma spaced_implies_no_3AP_case3 {ι : Type*} [LinearOrder ι] {V : Type*} [AddCommGroup V] [Module ℚ V]
  (b : Module.Basis ι ℚ V) (σ : ℕ → List ℚ) (t : ℕ → ℚ)
  (_h_spaced : IsSpacedPatternSeq σ t)
  (a b_vec c : V) (m n p : ℕ)
  (ha : coeffSeq b a = σ m) (hb : coeffSeq b b_vec = σ n) (hc : coeffSeq b c = σ p)
  (h_order : m = n ∧ n = p)
  (h_ap : a + c = 2 • b_vec)
  (h_distinct : a ≠ c) : False := by
    obtain ⟨ i, hi ⟩ := case3_first_diff b a b_vec c h_ap h_distinct;
    -- Since a, b, c have the same coefficient sequence, and agree on the prefix, the next non-zero coefficient must be the same for all of them.
    have h_next_nonzero_coeff_eq : b.repr a i = b.repr b_vec i ∧ b.repr b_vec i = b.repr c i := by
      by_cases hi_a : b.repr a i = 0;
      · by_cases hi_b : b.repr b_vec i = 0 <;> simp_all +decide
        · replace h_ap := congr_arg ( fun x => b.repr x i ) h_ap ; simp_all +decide
        · have h_coeff_eq_i : (b.repr b_vec) i = (b.repr c) i := by
            apply next_nonzero_coeff_eq b b_vec c i;
            · rw [hb, hc];
            · exact fun j hj => hi.2 j hj |>.2;
            · exact hi_b;
            · replace h_ap := congr_arg ( fun x => b.repr x i ) h_ap; simp_all +decide
          replace h_ap := congr_arg ( fun x => b.repr x i ) h_ap ; simp_all +decide
      · by_cases hi_b : b.repr b_vec i = 0;
        · replace h_ap := congr_arg ( fun x => b.repr x i ) h_ap ; simp_all +decide [ two_smul ];
          have h_coeff_eq : (b.repr a) i = (b.repr c) i := by
            apply next_nonzero_coeff_eq b a c i (by
            grind +ring) (by
            exact fun j hj => by rw [ hi j hj |>.1, hi j hj |>.2 ] ;) (by
            exact hi_a) (by
            aesop_cat);
          exact hi_a ( by linarith );
        · have h_next_nonzero_coeff_eq : b.repr a i = b.repr b_vec i := by
            apply next_nonzero_coeff_eq b a b_vec i;
            · grind;
            · exact fun j hj => hi.2 j hj |>.1;
            · exact hi_a;
            · exact hi_b;
          replace h_ap := congr_arg ( fun x => b.repr x i ) h_ap ; simp_all +decide [ two_smul ];
    aesop

/-
If three vectors u, v, w have coefficient sequences with indices m, n, p where m, n < p, then they cannot form a 3-term arithmetic progression in any order.
-/
lemma spaced_implies_no_3AP_max_unique {ι : Type*} [LinearOrder ι] {V : Type*} [AddCommGroup V] [Module ℚ V]
  (b : Module.Basis ι ℚ V) (σ : ℕ → List ℚ) (t : ℕ → ℚ)
  (h_spaced : IsSpacedPatternSeq σ t)
  (u v w : V) (m n p : ℕ)
  (hu : coeffSeq b u = σ m) (hv : coeffSeq b v = σ n) (hw : coeffSeq b w = σ p)
  (h_order : m < p ∧ n < p)
  (h_ap : u + v = 2 • w ∨ u + w = 2 • v ∨ v + w = 2 • u) : False := by
    -- Since $m < p$ and $n < p$, by the definition of spaced patterns, $w$ has a coefficient greater than $3*t_p$.
    obtain ⟨i, hi⟩ : ∃ i : ι, |b.repr w i| > 3 * t p := by
      obtain ⟨ r, hr ⟩ := h_spaced p |>.2.2;
      unfold coeffSeq at hw;
      grind;
    -- Since $m < p$ and $n < p$, by the definition of spaced patterns, $u$ and $v$ have all coefficients $\leq t_p$.
    have h_u_v_le_tp : ∀ j : ι, |b.repr u j| ≤ t p ∧ |b.repr v j| ≤ t p := by
      intro j
      have h_u_le_tp : ∀ r ∈ coeffSeq b u, |r| ≤ t p := by
        have := h_spaced p; aesop;
      have h_v_le_tp : ∀ r ∈ coeffSeq b v, |r| ≤ t p := by
        intro r hr; specialize h_spaced p; aesop;
      refine' ⟨ _, _ ⟩;
      · by_cases hj : j ∈ (b.repr u).support;
        · unfold coeffSeq at h_u_le_tp; aesop;
        · simp_all +decide [ Finsupp.mem_support_iff ];
          contrapose! h_u_le_tp;
          exact ⟨ _, hu ▸ List.head!_mem_self ( show coeffSeq b u ≠ [] from by
                                                  intro h; specialize h_spaced m; aesop; ), lt_of_lt_of_le h_u_le_tp ( abs_nonneg _ ) ⟩;
      · by_cases hj : j ∈ ( b.repr v |> Finsupp.support ) <;> simp_all +decide
        · convert h_v_le_tp _ _;
          rw [ ← hv ];
          unfold coeffSeq; aesop;
        · contrapose! h_v_le_tp;
          have := h_spaced n;
          exact ⟨ this.2.2.choose, this.2.2.choose_spec.1, by linarith [ this.2.2.choose_spec.2, abs_nonneg ( this.2.2.choose ) ] ⟩;
    obtain h | h | h := h_ap <;> have := congr_arg ( fun x => b.repr x i ) h <;> norm_num [ two_smul ] at this;
    · cases abs_cases ( b.repr u i ) <;> cases abs_cases ( b.repr v i ) <;> cases abs_cases ( b.repr w i ) <;> linarith [ h_u_v_le_tp i ];
    · cases abs_cases ( b.repr u i ) <;> cases abs_cases ( b.repr v i ) <;> cases abs_cases ( b.repr w i ) <;> linarith [ h_u_v_le_tp i ];
    · cases abs_cases ( b.repr w i ) <;> cases abs_cases ( b.repr u i ) <;> cases abs_cases ( b.repr v i ) <;> linarith [ h_u_v_le_tp i ]

/-
If the first large index of v is i, then the first large value in the coefficient sequence of v is the coefficient of v at i.
-/
lemma firstLargeValue_eq_repr_firstLargeIndex {ι : Type*} [LinearOrder ι] {V : Type*} [AddCommGroup V] [Module ℚ V]
  (b : Module.Basis ι ℚ V) (v : V) (T : ℚ) (i : ι)
  (h_idx : firstLargeIndex b v T = some i) :
  firstLargeValue (coeffSeq b v) T = some (b.repr v i) := by
    unfold firstLargeValue coeffSeq firstLargeIndex at *
    aesop

/-
If a list is sorted and i is an element satisfying P such that no earlier element satisfies P, then find? returns some i.
-/
lemma List.find?_eq_some_of_sorted {α : Type*} [LinearOrder α]
  (l : List α) (P : α → Bool) (i : α)
  (h_sorted : l.Pairwise (· < ·))
  (h_mem : i ∈ l)
  (h_sat : P i)
  (h_first : ∀ j ∈ l, j < i → ¬ P j) :
  l.find? P = some i := by
    simpa using find_map_sorted l (fun x : α => x) P i h_sorted h_mem h_sat h_first

/-
If i is the first index where the coefficient of v is greater than 3T, then firstLargeIndex returns some i.
-/
lemma is_first_large_index {ι : Type*} [LinearOrder ι] {V : Type*} [AddCommGroup V] [Module ℚ V]
  (b : Module.Basis ι ℚ V) (v : V) (T : ℚ) (i : ι)
  (h_large : |b.repr v i| > 3 * T)
  (h_prev : ∀ j < i, |b.repr v j| ≤ 3 * T)
  (h_T_nonneg : 0 ≤ T) :
  firstLargeIndex b v T = some i := by
    unfold firstLargeIndex
    apply List.find?_eq_some_of_sorted;
    · exact (Finset.sortedLT_sort ((b.repr v).support)).pairwise;
    · exact Finset.mem_sort ( α := ι ) ( · ≤ · ) |>.2 ( by contrapose! h_large; aesop );
    · grind;
    · aesop

/-
If two vectors v and w have the same spaced coefficient sequence and the same first large index i, then their coefficients at i are equal.
-/
lemma first_large_index_eq_implies_coeff_eq {ι : Type*} [LinearOrder ι] {V : Type*} [AddCommGroup V] [Module ℚ V]
  (b : Module.Basis ι ℚ V) (v w : V) (σ : List ℚ) (t : ℚ)
  (hv : coeffSeq b v = σ) (hw : coeffSeq b w = σ)
  (_h_spaced : ∀ r ∈ σ, |r| ≤ t ∨ |r| > 3 * t)
  (i : ι)
  (hv_large : |b.repr v i| > 3 * t)
  (hv_small_prev : ∀ j < i, |b.repr v j| ≤ t)
  (hw_large : |b.repr w i| > 3 * t)
  (hw_small_prev : ∀ j < i, |b.repr w j| ≤ t)
  (ht_nonneg : 0 ≤ t) :
  b.repr v i = b.repr w i := by
    -- By `is_first_large_index`, `firstLargeIndex b v t = some i`.
    have hv_first_large : firstLargeIndex b v t = some i := by
      apply is_first_large_index;
      · exact hv_large;
      · exact fun j hj => le_trans ( hv_small_prev j hj ) ( by linarith );
      · exact ht_nonneg
    have hw_first_large : firstLargeIndex b w t = some i := by
      apply is_first_large_index;
      · exact hw_large;
      · exact fun j hj => le_trans ( hw_small_prev j hj ) ( by linarith );
      · exact ht_nonneg;
    have hv_first_large_val : firstLargeValue (coeffSeq b v) t = some (b.repr v i) := by
      exact firstLargeValue_eq_repr_firstLargeIndex b v t i hv_first_large
    have hw_first_large_val : firstLargeValue (coeffSeq b w) t = some (b.repr w i) := by
      exact firstLargeValue_eq_repr_firstLargeIndex b w t i hw_first_large;
    grind +ring

/-
If v and w have coefficient sequences with index p, u has index m < p, and v + w = 2u, then we reach a contradiction.
-/
lemma large_large_small_contradiction {ι : Type*} [LinearOrder ι] {V : Type*} [AddCommGroup V] [Module ℚ V]
  (b : Module.Basis ι ℚ V) (σ : ℕ → List ℚ) (t : ℕ → ℚ)
  (h_spaced : IsSpacedPatternSeq σ t)
  (u v w : V) (m p : ℕ)
  (hu : coeffSeq b u = σ m) (hv : coeffSeq b v = σ p) (hw : coeffSeq b w = σ p)
  (h_order : m < p)
  (h_ap : v + w = 2 • u) : False := by
    have coeff_mem_of_support (x : V) (j : ι) (hj : j ∈ (b.repr x).support) :
        b.repr x j ∈ coeffSeq b x := by
      unfold coeffSeq
      exact List.mem_map.mpr ⟨j, (Finset.mem_sort (α := ι) (· ≤ ·)).2 hj, rfl⟩
    have ht_nonneg : 0 ≤ t p := by
      obtain ⟨r, hr_mem, _hr_large⟩ := (h_spaced m).2.2
      exact le_trans (abs_nonneg r) ((h_spaced p).1 m h_order r hr_mem)
    have h_u_small : ∀ j : ι, |b.repr u j| ≤ t p := by
      intro j
      by_cases hj : j ∈ (b.repr u).support
      · exact (h_spaced p).1 m h_order (b.repr u j) (by
          simpa [hu] using coeff_mem_of_support u j hj)
      · have hz : b.repr u j = 0 := by
          simpa [Finsupp.mem_support_iff] using hj
        rw [hz]
        simpa using ht_nonneg
    have hcoord (j : ι) : b.repr w j = 2 * b.repr u j - b.repr v j := by
      have h := congr_arg (fun x => b.repr x j) h_ap
      simp [two_smul] at h
      linarith
    obtain ⟨i₀, hi₀_supp, hi₀_large⟩ :
        ∃ i : ι, i ∈ (b.repr v).support ∧ |b.repr v i| > 3 * t p := by
      obtain ⟨r, hr_mem, hr_large⟩ := (h_spaced p).2.2
      have hr_mem' : r ∈ coeffSeq b v := by simpa [hv] using hr_mem
      unfold coeffSeq at hr_mem'
      rcases List.mem_map.mp hr_mem' with ⟨i, hi_mem, rfl⟩
      exact ⟨i, (Finset.mem_sort (α := ι) (· ≤ ·)).1 hi_mem, hr_large⟩
    let largeSupport : Finset ι :=
      (b.repr v).support.filter fun j => |b.repr v j| > 3 * t p
    have h_largeSupport_nonempty : largeSupport.Nonempty := by
      exact ⟨i₀, by simp [largeSupport, hi₀_supp, hi₀_large]⟩
    let i : ι := largeSupport.min' h_largeSupport_nonempty
    have hi_mem_largeSupport : i ∈ largeSupport := Finset.min'_mem _ _
    have hi_supp : i ∈ (b.repr v).support := (Finset.mem_filter.mp hi_mem_largeSupport).1
    have hi_large : |b.repr v i| > 3 * t p := (Finset.mem_filter.mp hi_mem_largeSupport).2
    have hi_min : ∀ j ∈ largeSupport, i ≤ j := by
      intro j hj
      exact Finset.min'_le _ _ hj
    have h_v_small_prev : ∀ j < i, |b.repr v j| ≤ t p := by
      intro j hj_lt
      by_cases hj_supp : j ∈ (b.repr v).support
      · have hj_mem : b.repr v j ∈ σ p := by
          simpa [hv] using coeff_mem_of_support v j hj_supp
        rcases (h_spaced p).2.1 (b.repr v j) hj_mem with hsmall | hlarge
        · exact hsmall
        · exfalso
          have hj_largeSupport : j ∈ largeSupport := by
            simp [largeSupport, hj_supp, hlarge]
          exact (not_lt_of_ge (hi_min j hj_largeSupport)) hj_lt
      · have hz : b.repr v j = 0 := by
          simpa [Finsupp.mem_support_iff] using hj_supp
        rw [hz]
        simpa using ht_nonneg
    have h_w_large_i : |b.repr w i| > 3 * t p := by
      have hw_gt_t : |b.repr w i| > t p := by
        have hw_ge : |b.repr w i| ≥ |b.repr v i| - 2 * |b.repr u i| := by
          rw [hcoord i]
          cases abs_cases (b.repr v i) <;> cases abs_cases (b.repr u i) <;>
            cases abs_cases (2 * b.repr u i - b.repr v i) <;> linarith
        nlinarith [hw_ge, hi_large, h_u_small i, abs_nonneg (b.repr u i)]
      have hw_ne : b.repr w i ≠ 0 := by
        intro hz
        rw [hz] at hw_gt_t
        norm_num at hw_gt_t
        linarith
      have hw_supp : i ∈ (b.repr w).support := by
        simpa [Finsupp.mem_support_iff] using hw_ne
      have hw_mem : b.repr w i ∈ σ p := by
        simpa [hw] using coeff_mem_of_support w i hw_supp
      rcases (h_spaced p).2.1 (b.repr w i) hw_mem with hsmall | hlarge
      · linarith
      · exact hlarge
    have h_w_small_prev : ∀ j < i, |b.repr w j| ≤ t p := by
      intro j hj_lt
      by_cases hj_supp : j ∈ (b.repr w).support
      · have hw_le_3t : |b.repr w j| ≤ 3 * t p := by
          have hw_le : |b.repr w j| ≤ 2 * |b.repr u j| + |b.repr v j| := by
            calc
              |b.repr w j| = |2 * b.repr u j - b.repr v j| := by rw [hcoord j]
              _ = |2 * b.repr u j + -b.repr v j| := by ring_nf
              _ ≤ |2 * b.repr u j| + |-b.repr v j| := abs_add_le _ _
              _ = 2 * |b.repr u j| + |b.repr v j| := by
                rw [abs_mul, abs_of_nonneg (by norm_num : (0 : ℚ) ≤ 2), abs_neg]
          nlinarith [hw_le, h_u_small j, h_v_small_prev j hj_lt,
            abs_nonneg (b.repr u j), abs_nonneg (b.repr v j)]
        have hw_mem : b.repr w j ∈ σ p := by
          simpa [hw] using coeff_mem_of_support w j hj_supp
        rcases (h_spaced p).2.1 (b.repr w j) hw_mem with hsmall | hlarge
        · exact hsmall
        · linarith
      · have hz : b.repr w j = 0 := by
          simpa [Finsupp.mem_support_iff] using hj_supp
        rw [hz]
        simpa using ht_nonneg
    have h_coeff_eq : b.repr v i = b.repr w i := by
      exact first_large_index_eq_implies_coeff_eq b v w (σ p) (t p) hv hw
        (h_spaced p).2.1 i hi_large h_v_small_prev h_w_large_i h_w_small_prev ht_nonneg
    have h_u_eq_v : b.repr u i = b.repr v i := by
      have h := congr_arg (fun x => b.repr x i) h_ap
      simp [two_smul] at h
      linarith
    have h_abs_eq : |b.repr u i| = |b.repr v i| := by rw [h_u_eq_v]
    nlinarith [h_u_small i, hi_large, ht_nonneg, h_abs_eq]

/-
If three vectors u, v, w have coefficient sequences with indices m, n, p where m < n = p, then they cannot form a 3-term arithmetic progression in any order.
-/
lemma spaced_implies_no_3AP_max_two {ι : Type*} [LinearOrder ι] {V : Type*} [AddCommGroup V] [Module ℚ V]
  (b : Module.Basis ι ℚ V) (σ : ℕ → List ℚ) (t : ℕ → ℚ)
  (h_spaced : IsSpacedPatternSeq σ t)
  (u v w : V) (m n p : ℕ)
  (hu : coeffSeq b u = σ m) (hv : coeffSeq b v = σ n) (hw : coeffSeq b w = σ p)
  (h_order : m < n ∧ n = p)
  (h_ap : u + v = 2 • w ∨ u + w = 2 • v ∨ v + w = 2 • u) : False := by
    rcases h_ap with ( h_ap | h_ap | h_ap );
    · apply spaced_implies_no_3AP_case2 b σ t h_spaced u w v m p n hu hw hv;
      · grind;
      · exact h_ap;
    · -- Since $n = p$, we can replace $p$ with $n$ in the goal.
      have h_eq : n = p := by
        exact h_order.2;
      subst h_eq;
      apply spaced_implies_no_3AP_case2 b σ t h_spaced u v w m n n hu hv hw ⟨ h_order.1, rfl ⟩ h_ap;
    · apply large_large_small_contradiction b σ t h_spaced u v w m n;
      · exact hu;
      · exact hv;
      · aesop;
      · exact h_order.1;
      · exact h_ap

/-
If a, b, c form a 3-term AP and their coefficient patterns correspond to indices m, n, p, and the patterns are spaced, then we reach a contradiction.
-/
lemma spaced_implies_no_3AP {ι : Type*} [LinearOrder ι] {V : Type*} [AddCommGroup V] [Module ℚ V]
  (b : Module.Basis ι ℚ V) (σ : ℕ → List ℚ) (t : ℕ → ℚ)
  (h_spaced : IsSpacedPatternSeq σ t)
  (a b_vec c : V)
  (ha : ∃ m, coeffSeq b a = σ m)
  (hb : ∃ n, coeffSeq b b_vec = σ n)
  (hc : ∃ p, coeffSeq b c = σ p)
  (h_ap : IsThreeTermAP_V a b_vec c) : False := by
    obtain ⟨ m, hm ⟩ := ha
    obtain ⟨ n, hn ⟩ := hb
    obtain ⟨ p, hp ⟩ := hc
    generalize_proofs at *;
    -- Consider the sorted order of m, n, p.
    obtain ⟨i1, i2, i3, hi⟩ : ∃ i1 i2 i3 : ℕ, i1 ≤ i2 ∧ i2 ≤ i3 ∧ (i1 = m ∧ i2 = n ∧ i3 = p ∨ i1 = m ∧ i2 = p ∧ i3 = n ∨ i1 = n ∧ i2 = m ∧ i3 = p ∨ i1 = n ∧ i2 = p ∧ i3 = m ∨ i1 = p ∧ i2 = m ∧ i3 = n ∨ i1 = p ∧ i2 = n ∧ i3 = m) := by
      cases le_total m n <;> cases le_total n p <;> cases le_total p m <;> first | exact ⟨ m, n, p, by linarith, by linarith, Or.inl ⟨ rfl, rfl, rfl ⟩ ⟩ | exact ⟨ m, p, n, by linarith, by linarith, Or.inr <| Or.inl ⟨ rfl, rfl, rfl ⟩ ⟩ | exact ⟨ n, m, p, by linarith, by linarith, Or.inr <| Or.inr <| Or.inl ⟨ rfl, rfl, rfl ⟩ ⟩ | exact ⟨ n, p, m, by linarith, by linarith, Or.inr <| Or.inr <| Or.inr <| Or.inl ⟨ rfl, rfl, rfl ⟩ ⟩ | exact ⟨ p, m, n, by linarith, by linarith, Or.inr <| Or.inr <| Or.inr <| Or.inr <| Or.inl ⟨ rfl, rfl, rfl ⟩ ⟩ | exact ⟨ p, n, m, by linarith, by linarith, Or.inr <| Or.inr <| Or.inr <| Or.inr <| Or.inr ⟨ rfl, rfl, rfl ⟩ ⟩ ;
    generalize_proofs at *; (
    by_cases h_case1 : i2 < i3;
    · obtain ⟨u, v, w, hu, hv, hw, h_order⟩ : ∃ u v w : V, (coeffSeq b u = σ i1 ∧ coeffSeq b v = σ i2 ∧ coeffSeq b w = σ i3) ∧ i1 < i3 ∧ i2 < i3 ∧ (u + v = 2 • w ∨ u + w = 2 • v ∨ v + w = 2 • u) := by
        rcases hi with ⟨ hi1, hi2, hi3 | hi3 | hi3 | hi3 | hi3 | hi3 ⟩ <;> simp_all +decide [ IsThreeTermAP_V ];
        grind;
        · exact ⟨ a, c, b_vec, ⟨ hm, hp, hn ⟩, by linarith, by simp_all +decide [ two_smul ] ⟩;
        · grind;
        · grind +ring;
        · exact ⟨ c, a, b_vec, ⟨ hp, hm, hn ⟩, by linarith, by simp_all +decide [ two_smul, add_comm ] ⟩;
        · grind
      generalize_proofs at *; (
      exact False.elim ( spaced_implies_no_3AP_max_unique b σ t h_spaced u v w i1 i2 i3 hu.1 hu.2.1 hu.2.2 ⟨ hv, h_case1 ⟩ h_order ));
    · by_cases h_case2 : i1 < i2 ∧ i2 = i3;
      · rcases hi.2.2 with ( ⟨ rfl, rfl, rfl ⟩ | ⟨ rfl, rfl, rfl ⟩ | ⟨ rfl, rfl, rfl ⟩ | ⟨ rfl, rfl, rfl ⟩ | ⟨ rfl, rfl, rfl ⟩ | ⟨ rfl, rfl, rfl ⟩ ) <;> simp_all +decide only [IsThreeTermAP_V];
        all_goals have := spaced_implies_no_3AP_max_two b σ t h_spaced a b_vec c i1 i3 i3; simp_all +decide
        any_goals linarith;
        · have := spaced_implies_no_3AP_max_two b σ t h_spaced b_vec a c i1 i3 i3; simp_all +decide
          linarith;
        · have := spaced_implies_no_3AP_max_two b σ t h_spaced b_vec a c i1 i3 i3; simp_all +decide
          linarith;
        · have := spaced_implies_no_3AP_max_two b σ t h_spaced c a b_vec i1 i3 i3; simp_all +decide
          exact this ( by linarith ) |>.1 ( by rw [ add_comm, h_ap.1 ] );
        · have := spaced_implies_no_3AP_max_two b σ t h_spaced c a b_vec i1 i3 i3; simp_all +decide
          exact this ( by linarith ) |>.1 ( by rw [ add_comm, h_ap.1 ] );
      · exact spaced_implies_no_3AP_case3 b σ t h_spaced a b_vec c m n p hm hn hp ( by omega ) h_ap.1 h_ap.2 |> fun h => by tauto;)

/-
If a good sequence exists, then there exists a set A satisfying the required properties.
-/
def GoodSequence {ι : Type*} [LinearOrder ι] {V : Type*} [AddCommGroup V] [Module ℚ V]
  (b : Module.Basis ι ℚ V) (σ : ℕ → List ℚ) (t : ℕ → ℚ) : Prop :=
  IsSpacedPatternSeq σ t ∧ (∀ S, IsInfiniteAP_V S → ∃ n, ∃ x ∈ S, coeffSeq b x = σ n)

lemma exists_set_if_good_sequence {ι : Type*} [LinearOrder ι] {V : Type*} [AddCommGroup V] [Module ℚ V]
  (b : Module.Basis ι ℚ V) (σ : ℕ → List ℚ) (t : ℕ → ℚ) (h : GoodSequence b σ t) :
  ∃ A : Set V, (¬ ∃ a ∈ A, ∃ b_vec ∈ A, ∃ c ∈ A, IsThreeTermAP_V a b_vec c) ∧ (∀ S, IsInfiniteAP_V S → (S ∩ A).Nonempty) := by
    refine' ⟨ { x | ∃ n, coeffSeq b x = σ n }, _, _ ⟩;
    · simp +zetaDelta at *;
      intro x n hx y m hy z p hz h_ap; exact spaced_implies_no_3AP b σ t h.1 x y z ⟨ n, hx ⟩ ⟨ m, hy ⟩ ⟨ p, hz ⟩ h_ap;
    · obtain ⟨ h₁, h₂ ⟩ := h;
      exact fun S hS => by obtain ⟨ n, x, hxS, hx ⟩ := h₂ S hS; exact ⟨ x, hxS, n, hx ⟩ ;

/-
Given a basis, previous patterns, and an arithmetic progression, there exists a term in the progression and a threshold t such that the term's coefficient sequence is spaced relative to t and t bounds the previous patterns.
-/
lemma exists_next_pattern {ι : Type*} [LinearOrder ι] {V : Type*} [AddCommGroup V] [Module ℚ V]
  (b : Module.Basis ι ℚ V)
  (prev_patterns : List (List ℚ))
  (A_start A_step : V) (h_step : A_step ≠ 0) :
  ∃ (t : ℚ) (c : V),
    (∃ k : ℕ, c = A_start + k • A_step) ∧
    (∀ σ ∈ prev_patterns, ∀ r ∈ σ, |r| ≤ t) ∧
    (∀ r ∈ coeffSeq b c, |r| ≤ t ∨ |r| > 3 * t) ∧
    (∃ r ∈ coeffSeq b c, |r| > 3 * t) := by
      -- Let's choose t to be the maximum of the absolute values of the coefficients of A_start and the elements in prev_patterns.
      obtain ⟨t, ht⟩ : ∃ t : ℚ, (∀ σ ∈ prev_patterns, ∀ r ∈ σ, |r| ≤ t) ∧ (∀ j, |(b.repr A_start) j| ≤ t) := by
        have h_finite_support : Set.Finite (Set.range (fun j => |(b.repr A_start) j|)) := by
          have h_finite_support : Set.Finite {j | (b.repr A_start) j ≠ 0} := by
            exact Set.Finite.subset ( b.repr A_start |> Finsupp.support |> Finset.finite_toSet ) fun x hx => by aesop;
          exact Set.Finite.subset ( h_finite_support.image ( fun j => |( b.repr A_start ) j| ) |> Set.Finite.union <| Set.finite_singleton 0 ) fun x hx => by cases' hx with j hj; by_cases hj' : ( b.repr A_start ) j = 0 <;> aesop;
        generalize_proofs at *;
        have h_finite_prev : Set.Finite (Set.range (fun r => |r|) ∩ {r | ∃ σ ∈ prev_patterns, ∃ r' ∈ σ, r = |r'|}) := by
          refine' Set.Finite.subset ( Set.toFinite ( Finset.image ( fun r : ℚ => |r| ) ( Finset.biUnion ( List.toFinset prev_patterns ) fun σ => List.toFinset σ ) ) ) _ ; intro x ; aesop;
        generalize_proofs at *;
        obtain ⟨ t, ht ⟩ := Set.Finite.bddAbove ( h_finite_support.union h_finite_prev );
        exact ⟨ t, fun σ hσ r hr => ht <| Or.inr ⟨ Set.mem_range_self _, σ, hσ, r, hr, rfl ⟩, fun j => ht <| Or.inl <| Set.mem_range_self _ ⟩;
      obtain ⟨k, hk⟩ : ∃ k : ℕ, ∀ j ∈ (b.repr A_step).support, |(b.repr A_start) j + k * (b.repr A_step) j| > 3 * max t 1 := by
        have := exists_large_coeff_in_AP b A_start A_step h_step ( 3 * max t 1 ) ; aesop;
      refine' ⟨ max t 1, A_start + k • A_step, ⟨ k, rfl ⟩, _, _, _ ⟩ <;> simp_all +decide [ coeffSeq ];
      · exact fun σ hσ r hr => Or.inl ( ht.1 σ hσ r hr );
      · intro j hj; by_cases hj' : ( b.repr A_step ) j = 0 <;> aesop;
      · -- Since $A_step \neq 0$, there exists some $j$ such that $(b.repr A_step) j \neq 0$.
        obtain ⟨j, hj⟩ : ∃ j, (b.repr A_step) j ≠ 0 := by
          exact not_forall.mp fun h => h_step <| b.ext_elem fun i => by simp +decide [ h ] ;
        exact ⟨ j, by specialize hk j hj; contrapose! hk; aesop, hk j hj ⟩

/-
A vector space with a countable basis over the rationals is countable.
-/
lemma countable_of_basis {ι : Type*} [Countable ι] {V : Type*} [AddCommGroup V] [Module ℚ V]
  (b : Module.Basis ι ℚ V) : Countable V := by
    have h_iso : V ≃ₗ[ℚ] ι →₀ ℚ := by
      exact b.repr;
    exact h_iso.injective.countable

/-
In a countable vector space, there exists a GoodSequence of patterns and thresholds.
-/
lemma exists_good_sequence_countable {ι : Type*} [LinearOrder ι] {V : Type*} [AddCommGroup V] [Module ℚ V] [Countable V] [Nontrivial V]
  (b : Module.Basis ι ℚ V) : ∃ σ t, GoodSequence b σ t := by
    have h_countable : Set.Countable {S : Set V | IsInfiniteAP_V S} := by
      have h_countable : Countable (Set.range (fun (p : V × V) => {x : V | ∃ n : ℕ, x = p.1 + n • p.2})) := by
        exact Set.countable_coe_iff.mpr ( Set.countable_range _ );
      exact Set.Countable.mono ( fun x hx => by cases' hx with a b hb; aesop ) h_countable;
    have h_enum : ∃ (S : ℕ → Set V), (∀ n, IsInfiniteAP_V (S n)) ∧ (∀ T : Set V, IsInfiniteAP_V T → ∃ n, T = S n) := by
      have := h_countable.exists_eq_range;
      obtain ⟨f, hf⟩ := this (by
      obtain ⟨ v, hv ⟩ := exists_ne ( 0 : V ) ; exact ⟨ _, ⟨ 0, v, hv, rfl ⟩ ⟩ ;);
      exact ⟨ f, fun n => hf.symm.subset ( Set.mem_range_self n ), fun T hT => by rcases hf.subset hT with ⟨ n, rfl ⟩ ; exact ⟨ n, rfl ⟩ ⟩;
    obtain ⟨ S, hS₁, hS₂ ⟩ := h_enum;
    -- By `exists_next_pattern`, there exists a threshold T and a vector c ∈ A_n such that c's coefficient sequence is spaced relative to T, and T bounds all values in prev_patterns.
    have h_exists_next_pattern : ∀ (prev_patterns : List (List ℚ)) (A_start A_step : V) (h_step : A_step ≠ 0), ∃ (t : ℚ) (c : V),
      (∃ k : ℕ, c = A_start + k • A_step) ∧
      (∀ σ ∈ prev_patterns, ∀ r ∈ σ, |r| ≤ t) ∧
      (∀ r ∈ coeffSeq b c, |r| ≤ t ∨ |r| > 3 * t) ∧
      (∃ r ∈ coeffSeq b c, |r| > 3 * t) := by
        convert exists_next_pattern b using 1;
    choose! t c hc using h_exists_next_pattern;
    -- Define the sequences σ and t recursively.
    have h_rec : ∃ (σ : ℕ → List ℚ) (t_seq : ℕ → ℚ) (A_start : ℕ → V) (A_step : ℕ → V),
      (∀ n, A_step n ≠ 0) ∧
      (∀ n, IsInfiniteAP_V (S n)) ∧
      (∀ n, S n = {x | ∃ k : ℕ, x = A_start n + k • A_step n}) ∧
      (∀ n, σ n = coeffSeq b (c (List.map σ (List.range n)) (A_start n) (A_step n))) ∧
      (∀ n, t_seq n = t (List.map σ (List.range n)) (A_start n) (A_step n)) := by
        choose A_start A_step hA_start hA_step using hS₁;
        have h_rec : ∃ (σ : ℕ → List ℚ), (∀ n, σ n = coeffSeq b (c (List.map σ (List.range n)) (A_start n) (A_step n))) := by
          have h_rec : ∀ (n : ℕ), ∃ σ : ℕ → List ℚ, ∀ m ≤ n, σ m = coeffSeq b (c (List.map σ (List.range m)) (A_start m) (A_step m)) := by
            intro n;
            induction' n with n ih;
            · exact ⟨ fun _ => coeffSeq b ( c [ ] ( A_start 0 ) ( A_step 0 ) ), by simp +decide ⟩;
            · obtain ⟨ σ, hσ ⟩ := ih;
              use fun m => if m ≤ n then σ m else coeffSeq b (c (List.map σ (List.range m)) (A_start m) (A_step m));
              intro m hm; cases hm <;> simp +decide [ *, List.range_succ ] ;
              · congr! 2;
                congr! 1;
                exact List.map_congr_left fun x hx => by rw [ if_pos ( List.mem_range.mp hx |> Nat.le_of_lt ) ] ;
              · rw [ if_pos ‹_›, hσ m ‹_› ];
                congr! 2;
                exact List.map_congr_left fun x hx => by rw [ if_pos ( le_trans ( List.mem_range.mp hx |> Nat.le_of_lt ) ‹_› ) ] ;
          choose σ hσ using h_rec;
          have h_rec : ∀ n m, n ≤ m → ∀ k ≤ n, σ n k = σ m k := by
            intro n m hnm k hk;
            induction' k using Nat.strong_induction_on with k ih;
            rw [ hσ n k hk, hσ m k ( le_trans hk hnm ) ];
            rw [ List.map_congr_left ];
            exact fun a ha => ih a ( List.mem_range.mp ha ) ( by linarith [ List.mem_range.mp ha ] );
          use fun n => σ n n;
          intro n;
          convert hσ n n le_rfl using 1;
          congr! 2;
          refine' List.ext_get _ _ <;> simp +decide
          exact fun m mn => h_rec m n mn.le m le_rfl;
        exact ⟨ h_rec.choose, _, _, _, hA_start, fun n => by rw [ hA_step ] ; exact ⟨ A_start n, A_step n, hA_start n, rfl ⟩, hA_step, h_rec.choose_spec, fun n => rfl ⟩;
    obtain ⟨ σ, t_seq, A_start, A_step, hA_step, hS₁, hS₂, hσ, ht_seq ⟩ := h_rec;
    refine' ⟨ σ, t_seq, _, _ ⟩;
    · intro n;
      simp +decide [ hσ, ht_seq, hc _ _ _ ( hA_step n ) ];
      grind;
    · intro S hS;
      obtain ⟨ n, hn ⟩ := hS₂ |> fun h => ‹∀ T : Set V, IsInfiniteAP_V T → ∃ n, T = _› S hS;
      obtain ⟨ k, hk ⟩ := hc ( List.map σ ( List.range n ) ) ( A_start n ) ( A_step n ) ( hA_step n ) |>.1;
      grind

/-
Given a finite set s and an infinite set t in a linearly ordered type, there exists a strictly monotone map from s to t.
-/
lemma exists_monotone_embedding_from_finite_to_infinite {α : Type*} [LinearOrder α]
  (s : Finset α) (t : Set α) (h_inf : t.Infinite) :
  ∃ f : s → t, StrictMono (fun x => (f x).val) := by
    by_contra h_contra;
    -- Since $t$ is infinite, we can select $|s|$ distinct elements from $t$.
    obtain ⟨t_subset, ht_subset⟩ : ∃ t_subset : Finset α, t_subset.card = s.card ∧ ∀ x ∈ t_subset, x ∈ t := by
      have := h_inf.exists_subset_card_eq s.card; tauto;
    -- Since $t_subset$ is a finite subset of $t$, we can order its elements.
    obtain ⟨t_sorted, ht_sorted⟩ : ∃ t_sorted : Fin t_subset.card → α, StrictMono t_sorted ∧ ∀ i, t_sorted i ∈ t_subset := by
      exact ⟨ fun i => t_subset.orderEmbOfFin rfl i, by simp +decide [ StrictMono ], fun i => t_subset.orderEmbOfFin_mem rfl _ ⟩;
    refine' h_contra ⟨ _, _ ⟩;
    refine' fun x => ⟨ t_sorted ⟨ s.orderIsoOfFin rfl |>.symm x, _ ⟩, ht_subset.2 _ ( ht_sorted.2 _ ) ⟩;
    exact lt_of_lt_of_le ( Fin.is_lt _ ) ( by simp +decide [ ht_subset.1 ] );
    simp +decide [ StrictMono, ht_sorted.1.lt_iff_lt ]

/-
Lift a vector by applying a function to the indices of its basis expansion.
-/
def liftVector {ι : Type*} [LinearOrder ι] {V : Type*} [AddCommGroup V] [Module ℚ V]
  (b : Module.Basis ι ℚ V) (v : V) (f : ι → ι) : V :=
  Finsupp.sum (b.repr v) (fun i c => c • b (f i))

/-
Lifting a vector by an order-preserving map on its support preserves its coefficient sequence.
-/
lemma liftVector_coeffSeq {ι : Type*} [LinearOrder ι] {V : Type*} [AddCommGroup V] [Module ℚ V]
  (b : Module.Basis ι ℚ V) (v : V) (f : ι → ι)
  (hf_mono : StrictMonoOn f (b.repr v).support) :
  coeffSeq b (liftVector b v f) = coeffSeq b v := by
    -- The support of the lifted vector is the image of the support of v under f.
    have h_support : (b.repr (liftVector b v f)).support = Finset.image f (b.repr v).support := by
      ext i; simp [liftVector];
      simp +decide [ Finsupp.sum, Finsupp.single_apply ];
      constructor <;> intro h;
      · exact Exists.elim ( Finset.exists_ne_zero_of_sum_ne_zero h ) fun x hx => ⟨ x, by aesop ⟩;
      · obtain ⟨ a, ha, rfl ⟩ := h;
        rw [ Finset.sum_eq_single a ] <;> simp_all +decide [ hf_mono.eq_iff_eq ];
    unfold coeffSeq;
    -- Since $f$ is strictly monotone on the support of $v$, the sorted list of the image of the support of $v$ under $f$ is the same as the sorted list of the support of $v$.
    have h_sorted : ((Finset.image f (b.repr v).support).sort (· ≤ ·)).Pairwise (· ≤ ·) := by
      exact Finset.pairwise_sort _ _;
    have h_sorted_eq : (Finset.image f (b.repr v).support).sort (· ≤ ·) = List.map f ((b.repr v).support.sort (· ≤ ·)) := by
      have h_sorted_eq : List.Perm ((Finset.image f (b.repr v).support).sort (· ≤ ·)) (List.map f ((b.repr v).support.sort (· ≤ ·))) := by
        rw [ List.perm_iff_count ];
        intro x; by_cases hx : x ∈ Finset.image f ( b.repr v |> Finsupp.support ) <;> simp_all +decide [ List.count_eq_zero_of_not_mem ] ;
        rw [ List.count_eq_one_of_mem ];
        · rw [ List.nodup_map_iff_inj_on ];
          · exact fun x hx y hy hxy => hf_mono.eq_iff_eq ( by aesop ) ( by aesop ) |>.1 hxy;
          · exact Finset.sort_nodup _ _;
        · aesop;
      refine' List.Perm.eq_of_pairwise (fun a b _ _ hab hba => le_antisymm hab hba) h_sorted _ h_sorted_eq;
      refine' List.pairwise_map.mpr _;
      exact List.Pairwise.imp_of_mem ( fun x y hxy => hf_mono.monotoneOn ( by aesop ) ( by aesop ) hxy ) ( Finset.pairwise_sort _ (· ≤ ·) );
    have h_coeff_eq : ∀ i ∈ (b.repr v).support, b.repr (liftVector b v f) (f i) = b.repr v i := by
      intro i hi; rw [ show liftVector b v f = ∑ j ∈ ( b.repr v ).support, ( b.repr v j ) • b ( f j ) from ?_ ] ; simp +decide [ Finset.sum_apply', Finsupp.single_apply]
      · rw [ Finset.sum_eq_single i ] <;> simp_all +decide [ hf_mono.eq_iff_eq ];
      · exact rfl;
    aesop

/-
If a pattern sequence intersects every infinite AP in a subspace spanned by an infinite subset of the basis, then it intersects every infinite AP in the whole space.
-/
lemma lift_good_sequence {ι : Type*} [LinearOrder ι] {V : Type*} [AddCommGroup V] [Module ℚ V]
  (b : Module.Basis ι ℚ V)
  (ι' : Set ι) (h_inf : ι'.Infinite)
  (σ : ℕ → List ℚ)
  (h_good : ∀ (S : Set V), IsInfiniteAP_V S → S ⊆ Submodule.span ℚ (b '' ι') → ∃ n, ∃ x ∈ S, coeffSeq b x = σ n) :
  ∀ S, IsInfiniteAP_V S → ∃ n, ∃ x ∈ S, coeffSeq b x = σ n := by
    intro S hS
    obtain ⟨u, v, hv, hS_def⟩ := hS;
    obtain ⟨I, hI⟩ : ∃ I : Finset ι, (b.repr u).support ⊆ I ∧ (b.repr v).support ⊆ I := by
      exact ⟨ _, Finset.subset_union_left, Finset.subset_union_right ⟩;
    obtain ⟨f, hf_mono, hf_image⟩ : ∃ f : ι → ι, StrictMonoOn f I ∧ ∀ i ∈ I, f i ∈ ι' := by
      have := exists_monotone_embedding_from_finite_to_infinite I ι' h_inf;
      obtain ⟨ f, hf_mono ⟩ := this;
      refine' ⟨ fun i => if hi : i ∈ I then f ⟨ i, hi ⟩ else i, _, _ ⟩ <;> simp_all +decide [ StrictMono, StrictMonoOn ];
    obtain ⟨n, x, hx⟩ : ∃ n : ℕ, ∃ x ∈ {x | ∃ n : ℕ, x = liftVector b u f + n • liftVector b v f}, coeffSeq b x = σ n := by
      apply h_good;
      · refine' ⟨ liftVector b u f, liftVector b v f, _, _ ⟩;
        · contrapose! hv;
          rw [ ← b.repr.injective.eq_iff ];
          ext i; by_cases hi : i ∈ I <;> simp_all +decide [ liftVector ] ;
          · replace hv := congr_arg ( fun x => b.repr x ( f i ) ) hv ; simp_all +decide [ Finsupp.sum ];
            rw [ Finset.sum_eq_single i ] at hv <;> simp_all +decide [ Finsupp.single_apply ];
            exact fun j hj₁ hj₂ => fun hj₃ => hj₂ <| hf_mono.eq_iff_eq ( hI.2 <| by aesop ) hi |>.1 hj₃;
          · exact Classical.not_not.1 fun hi' => hi <| hI.2 <| by simpa using hi';
        · field_simp;
      · rintro x ⟨ n, rfl ⟩;
        simp +decide [ liftVector, Submodule.mem_span ];
        intro p hp;
        refine' p.add_mem _ _;
        · exact p.sum_mem fun i hi => p.smul_mem _ ( hp ( hf_image i ( hI.1 hi ) ) );
        · refine' p.nsmul_mem _ _;
          exact p.sum_mem fun i hi => p.smul_mem _ ( hp ( hf_image i ( hI.2 hi ) ) );
    obtain ⟨ ⟨ k, rfl ⟩, hk ⟩ := hx;
    refine' ⟨ n, u + k • v, hS_def.symm ▸ ⟨ k, rfl ⟩, _ ⟩;
    rw [ ← hk, show liftVector b u f + k • liftVector b v f = liftVector b ( u + k • v ) f from ?_ ];
    · rw [ liftVector_coeffSeq ];
      refine' hf_mono.mono _;
      simp_all +decide [ Finset.subset_iff, Finsupp.mem_support_iff ];
      grind;
    · unfold liftVector; simp +decide [ Finsupp.sum_add_index', add_smul ] ;
      simp +decide [ Finsupp.sum]
      by_cases hk : k = 0 <;> simp +decide [hk, Finset.smul_sum];
      apply Finset.sum_congr rfl
      intro x hx
      rw [← Nat.cast_smul_eq_nsmul ℚ k ((b.repr v) x • b (f x))]
      rw [smul_smul]

/-
The basis of Real numbers over Rationals is infinite.
-/
lemma infinite_basis_index_real_rat : Infinite (Module.Basis.ofVectorSpaceIndex ℚ ℝ) := by
  have h_inf : ¬FiniteDimensional ℚ ℝ := by
    intro h
    have h_countable : Countable ℝ := by
      have h_countable : Nonempty (ℝ ≃ (Fin (Module.finrank ℚ ℝ) → ℚ)) := by
        exact ⟨ ( Module.finBasis ℚ ℝ ).equivFun ⟩
      generalize_proofs at *; (
      exact h_countable.some.countable_iff.mpr ( by infer_instance ) |> fun h => by simp at h;)
    exact absurd h_countable (by
    simp +zetaDelta at *);
  exact Infinite.of_not_fintype fun h => h_inf <| Module.Basis.finiteDimensional_of_finite <| Module.Basis.ofVectorSpace ℚ ℝ

/-
Every infinite type contains a countably infinite subset.
-/
lemma exists_countable_infinite_subset {α : Type*} [Infinite α] : ∃ s : Set α, s.Countable ∧ s.Infinite := by
  -- Take an injective map $f : \mathbb{N} \to \alpha$ since $\alpha$ is infinite.
  obtain ⟨f, hf_inj⟩ : ∃ f : ℕ → α, Function.Injective f := by
    exact ⟨ _, Infinite.natEmbedding α |> Function.Embedding.injective ⟩;
  exact ⟨ Set.range f, Set.countable_range f, Set.infinite_range_of_injective hf_inj ⟩

/-
The span of the image of a subset is equal to the span of the range of the restricted function.
-/
lemma span_image_eq_span_range_restrict {ι : Type*} {V : Type*} [AddCommGroup V] [Module ℚ V]
  (b : ι → V) (ι' : Set ι) :
  Submodule.span ℚ (b '' ι') = Submodule.span ℚ (Set.range (b ∘ (Subtype.val : ι' → ι))) := by
    congr with x ; aesop

/-
The coefficient sequence of a vector in a subspace spanned by a subset of the basis is the same as its coefficient sequence with respect to the restricted basis.
-/
lemma coeffSeq_subspace_eq {ι : Type*} [LinearOrder ι] {V : Type*} [AddCommGroup V] [Module ℚ V]
  (b : Module.Basis ι ℚ V) (ι' : Set ι)
  (x : Submodule.span ℚ (b '' ι')) :
  let b_res := b ∘ (Subtype.val : ι' → ι)
  let h_li := LinearIndependent.comp b.linearIndependent (Subtype.val : ι' → ι) Subtype.val_injective
  let b' := Module.Basis.span h_li
  let h_eq := span_image_eq_span_range_restrict b ι'
  let x' : Submodule.span ℚ (Set.range b_res) := ⟨x.1, h_eq ▸ x.2⟩
  coeffSeq b (x : V) = coeffSeq b' x' := by
    classical
    obtain ⟨xv, hxv⟩ := x
    rw [Finsupp.mem_span_image_iff_linearCombination] at hxv
    obtain ⟨l, hl, rfl⟩ := hxv
    let f : ι' → ι := Subtype.val
    let hf : Set.InjOn f (f ⁻¹' ↑l.support) := Subtype.val_injective.injOn
    let l' : ι' →₀ ℚ := Finsupp.comapDomain f l hf
    let b_res := b ∘ f
    let h_li := LinearIndependent.comp b.linearIndependent f Subtype.val_injective
    let b' := Module.Basis.span h_li
    let h_eq := span_image_eq_span_range_restrict b ι'
    let x' : Submodule.span ℚ (Set.range b_res) :=
      ⟨Finsupp.linearCombination ℚ b l, h_eq ▸ (Finsupp.mem_span_image_iff_linearCombination ℚ).2 ⟨l, hl, rfl⟩⟩
    have h_bij : Set.BijOn f (f ⁻¹' ↑l.support) ↑l.support := by
      refine ⟨?_, hf, ?_⟩
      · intro i hi
        exact hi
      · intro i hi
        exact ⟨⟨i, hl hi⟩, hi, rfl⟩
    have hx'_eq : x' = Finsupp.linearCombination ℚ b' l' := by
      ext
      dsimp [x', b', b_res, l']
      rw [Finsupp.linearCombination_apply, Finsupp.linearCombination_apply]
      simpa [Finsupp.sum, Module.Basis.coe_span_apply, b_res, f] using
        (Finsupp.sum_comapDomain f l (fun i a => a • b i) h_bij).symm
    have hb'_repr : b'.repr x' = l' := by
      rw [hx'_eq]
      exact b'.repr_linearCombination l'
    have h_map_support : (l.support.preimage f hf).map ⟨f, Subtype.val_injective⟩ = l.support := by
      ext i
      constructor
      · intro hi
        obtain ⟨j, hj, rfl⟩ := Finset.mem_map.mp hi
        exact Finset.mem_preimage.mp hj
      · intro hi
        exact Finset.mem_map.mpr ⟨⟨i, hl hi⟩, by simp [Finset.mem_preimage, f, hi], rfl⟩
    have h_sorted_support :
        l.support.sort (· ≤ ·) = List.map (fun i : ι' => i.val) (l'.support.sort (· ≤ ·)) := by
      dsimp [l']
      symm
      calc
        List.map (fun i : ι' => i.val) ((l.support.preimage f hf).sort (· ≤ ·))
            = ((l.support.preimage f hf).map ⟨f, Subtype.val_injective⟩).sort (· ≤ ·) := by
              exact Finset.map_sort (s := l.support.preimage f hf)
                (f := ⟨f, Subtype.val_injective⟩) (r := (· ≤ ·)) (r' := (· ≤ ·)) (by
                  intro a _ b _
                  simp [f])
        _ = l.support.sort (· ≤ ·) := by rw [h_map_support]
    calc
      coeffSeq b (Finsupp.linearCombination ℚ b l) = (l.support.sort (· ≤ ·)).map l := by
        simp [coeffSeq]
      _ = (List.map (fun i : ι' => i.val) (l'.support.sort (· ≤ ·))).map l := by
        rw [h_sorted_support]
      _ = (l'.support.sort (· ≤ ·)).map l' := by
        simp [l', f]
      _ = coeffSeq b' x' := by
        simp [coeffSeq, hb'_repr]

/-
If a sequence is good for a subspace, it is good for the subspace viewed as a subset of the whole space.
-/
lemma good_sequence_lift_lemma {ι : Type*} [LinearOrder ι] {V : Type*} [AddCommGroup V] [Module ℚ V]
  (b : Module.Basis ι ℚ V) (ι' : Set ι)
  (b' : Module.Basis ι' ℚ (Submodule.span ℚ (b '' ι')))
  (σ : ℕ → List ℚ)
  (h_b' : ∀ i : ι', (b' i : V) = b i.val)
  (h_good_sub : ∀ (S : Set (Submodule.span ℚ (b '' ι'))), IsInfiniteAP_V S → ∃ n, ∃ x ∈ S, coeffSeq b' x = σ n) :
  ∀ (S : Set V), IsInfiniteAP_V S → S ⊆ Submodule.span ℚ (b '' ι') → ∃ n, ∃ x ∈ S, coeffSeq b x = σ n := by
    intro S hS hS_sub
    obtain ⟨a, d, hd_ne_zero, hS_eq⟩ := hS
    have ha : a ∈ Submodule.span ℚ (b '' ι') := by
      exact hS_sub ( hS_eq.symm ▸ ⟨ 0, by simp +decide ⟩ )
    have hd : d ∈ Submodule.span ℚ (b '' ι') := by
      have := hS_sub ( show a + 1 • d ∈ S from hS_eq.symm ▸ ⟨ 1, by simp +decide ⟩ ) ; simp_all +decide [ Submodule.add_mem_iff_right ] ;
    obtain ⟨a', ha'⟩ : ∃ a' : Submodule.span ℚ (b '' ι'), (a' : V) = a := by
      exact ⟨ ⟨ a, ha ⟩, rfl ⟩
    obtain ⟨d', hd'⟩ : ∃ d' : Submodule.span ℚ (b '' ι'), (d' : V) = d := by
      exact ⟨ ⟨ d, hd ⟩, rfl ⟩
    have hS'_eq : {x' : Submodule.span ℚ (b '' ι') | ∃ k : ℕ, x' = a' + k • d'} = {x' : Submodule.span ℚ (b '' ι') | (x' : V) ∈ S} := by
      aesop
    have hS'_inf : IsInfiniteAP_V {x' : Submodule.span ℚ (b '' ι') | ∃ k : ℕ, x' = a' + k • d'} := by
      exact ⟨ a', d', by aesop ⟩
    obtain ⟨n, x', hx', hcoeff⟩ := h_good_sub {x' : Submodule.span ℚ (b '' ι') | ∃ k : ℕ, x' = a' + k • d'} hS'_inf
    use n, x'.val
    simp_all +decide [ Set.subset_def ];
    convert coeffSeq_subspace_eq b ι' x' using 1;
    convert hcoeff.symm using 1;
    simp +decide [ coeffSeq, Module.Basis.span ];
    congr! 1;
    · convert rfl;
      convert rfl;
      convert LinearEquiv.symm_apply_eq _ |>.2 _;
      ext; simp +decide ;
      conv_lhs => rw [ ← b'.linearCombination_repr x' ] ;
      simp +decide [ Finsupp.linearCombination_apply, Finsupp.sum ];
      exact Finset.sum_congr rfl fun _ _ => by aesop;
    · congr! 2;
      convert LinearEquiv.symm_apply_eq _ |>.2 _;
      ext; simp +decide ;
      conv_lhs => rw [ ← b'.linearCombination_repr x' ] ;
      simp +decide [ Finsupp.linearCombination_apply, Finsupp.sum ];
      exact Finset.sum_congr rfl fun _ _ => by aesop;

/-
A set is a Baumgartner set if it contains no 3-term arithmetic progression but intersects every infinite arithmetic progression.
-/
def IsBaumgartnerSet (A : Set ℝ) : Prop :=
  (∀ a ∈ A, ∀ b ∈ A, ∀ c ∈ A, ¬ IsThreeTermAP a b c) ∧ (∀ S, IsInfiniteAP S → (S ∩ A).Nonempty)

/-
There exists a subset of R that contains no 3-term arithmetic progression but intersects every infinite arithmetic progression.
-/
theorem exists_baumgartner_set_real : ∃ A : Set ℝ, IsBaumgartnerSet A := by
  -- Let's choose any countable subset of the basis and construct a good sequence for it.
  obtain ⟨ι', h_inf, h_count⟩ : ∃ ι' : Set (Module.Basis.ofVectorSpaceIndex ℚ ℝ), ι'.Infinite ∧ ι'.Countable := by
    have h_countable_infinite : ∃ ι' : Set (Module.Basis.ofVectorSpaceIndex ℚ ℝ), ι'.Infinite ∧ Set.Countable ι' := by
      have h_infinite : Infinite (Module.Basis.ofVectorSpaceIndex ℚ ℝ) := by
        exact infinite_basis_index_real_rat
      have := exists_countable_infinite_subset ( α := Module.Basis.ofVectorSpaceIndex ℚ ℝ ) ; aesop;
    exact h_countable_infinite;
  -- Let's obtain the basis b' for the subspace spanned by ι'.
  obtain ⟨b', hb'⟩ : ∃ b' : Module.Basis ι' ℚ (Submodule.span ℚ (Set.image (Module.Basis.ofVectorSpace ℚ ℝ) ι')), ∀ i : ι', (b' i : ℝ) = (Module.Basis.ofVectorSpace ℚ ℝ) i.val := by
    have h_basis_subspace : LinearIndependent ℚ (fun i : ι' => (Module.Basis.ofVectorSpace ℚ ℝ) i.val) := by
      exact ( Module.Basis.ofVectorSpace ℚ ℝ ).linearIndependent.comp _ Subtype.coe_injective
    refine' ⟨ _, _ ⟩;
    refine' Module.Basis.span h_basis_subspace |> fun h => h.map _;
    refine' LinearEquiv.ofEq _ _ _;
    exact congr_arg _ ( by ext; simp +decide );
    simp +zetaDelta at *;
  -- Let's obtain the good sequence (σ, t) for the subspace spanned by ι'.
  obtain ⟨σ, t, h_good⟩ : ∃ σ : ℕ → List ℚ, ∃ t : ℕ → ℚ, GoodSequence b' σ t := by
    convert exists_good_sequence_countable b';
    · convert countable_of_basis b';
      exact h_count.to_subtype;
    · refine' ⟨ _, _ ⟩;
      exact ⟨ 0, Submodule.zero_mem _ ⟩;
      by_contra! h;
      have := h ( b' ⟨ Classical.choose ( h_inf.nonempty ), Classical.choose_spec ( h_inf.nonempty ) ⟩ ) ; simp_all +decide [ Subtype.ext_iff ] ;
      rw [ eq_comm ] at this ; specialize h ( 2 * ( Classical.choose ( h_inf.nonempty ) ) ) ; simp_all +decide;
      have := Module.Basis.ofVectorSpace ℚ ℝ |>.linearIndependent.ne_zero ( Classical.choose ( h_inf.nonempty ) ) ; aesop;
  -- Let's obtain the good sequence (σ, t) for the entire space.
  obtain ⟨h_good_space, h_lift⟩ : GoodSequence (Module.Basis.ofVectorSpace ℚ ℝ) σ t ∧ ∀ S : Set ℝ, IsInfiniteAP_V S → S ⊆ Submodule.span ℚ (Set.image (Module.Basis.ofVectorSpace ℚ ℝ) ι') → ∃ n, ∃ x ∈ S, coeffSeq (Module.Basis.ofVectorSpace ℚ ℝ) x = σ n := by
    apply And.intro;
    · apply And.intro h_good.left;
      apply lift_good_sequence;
      exact h_inf;
      apply good_sequence_lift_lemma (Module.Basis.ofVectorSpace ℚ ℝ) ι' b' σ hb' h_good.2
    · apply good_sequence_lift_lemma (Module.Basis.ofVectorSpace ℚ ℝ) ι' b' σ hb' h_good.2;
  obtain ⟨A, hA⟩ : ∃ A : Set ℝ, (¬ ∃ a ∈ A, ∃ b_vec ∈ A, ∃ c ∈ A, IsThreeTermAP_V a b_vec c) ∧ (∀ S, IsInfiniteAP_V S → (S ∩ A).Nonempty) := by
    apply exists_set_if_good_sequence (Module.Basis.ofVectorSpace ℚ ℝ) σ t h_good_space;
  use A;
  constructor;
  · intro a ha b hb c hc h; exact hA.1 ⟨ a, ha, b, hb, c, hc, by
      constructor <;> norm_cast at *;
      · convert h.1 using 1 ; ring;
      · exact h.2 ⟩ ;
  · convert hA.2 using 1;
    unfold IsInfiniteAP IsInfiniteAP_V; aesop;

/-
The conjecture "If A has no 3-term AP, then R \ A contains an infinite AP" is false.
-/
def Conjecture : Prop :=
  ∀ A : Set ℝ, (∀ a ∈ A, ∀ b ∈ A, ∀ c ∈ A, ¬ IsThreeTermAP a b c) →
    (∃ S : Set ℝ, IsInfiniteAP S ∧ S ⊆ (Set.univ \ A))

theorem disproof_of_conjecture : ¬ Conjecture := by
  -- By definition of conjecture, we need to show that there exists a subset A of ℝ such that A has no 3-term arithmetic progression but R \ A does not contain an infinite arithmetic progression.
  simp [Conjecture];
  obtain ⟨ A, hA ⟩ := exists_baumgartner_set_real;
  cases hA;
  rename_i h₁ h₂;
  exact ⟨ A, h₁, fun S hS hS' => by obtain ⟨ x, hx₁, hx₂ ⟩ := h₂ S hS; exact hS' hx₁ |>.2 hx₂ ⟩

#print axioms disproof_of_conjecture
-- 'Erdos199.disproof_of_conjecture' depends on axioms: [propext, Classical.choice, Quot.sound]

end

end Erdos199
