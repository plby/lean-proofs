    -- proven by Numina
    have h_sub2 : ((m * (x + s₁ * p) - h2 * p : ℕ) : ZMod a) = (m * (x + s₁ * p) : ZMod a) - (h2 * p : ZMod a) := by
      rw [Nat.cast_sub h2_le]
      simp
    rw [h_sub1, h_sub2] at h_mod_a
    have h_add : (m * (x + s₁ * p) : ZMod a) + -(h1 * p : ZMod a) = (m * (x + s₁ * p) : ZMod a) + -(h2 * p : ZMod a) := by
      calc (m * (x + s₁ * p) : ZMod a) + -(h1 * p : ZMod a) = (m * (x + s₁ * p) : ZMod a) - (h1 * p : ZMod a) := by rw [sub_eq_add_neg]
        _ = (m * (x + s₁ * p) : ZMod a) - (h2 * p : ZMod a) := h_mod_a
        _ = (m * (x + s₁ * p) : ZMod a) + -(h2 * p : ZMod a) := by rw [sub_eq_add_neg]
    have h_neg : -(h1 * p : ZMod a) = -(h2 * p : ZMod a) := add_left_cancel h_add
    have h_eq_hp : (h1 * p : ZMod a) = (h2 * p : ZMod a) := by
      calc (h1 * p : ZMod a) = - -(h1 * p : ZMod a) := by rw [neg_neg]
        _ = - -(h2 * p : ZMod a) := by rw [h_neg]
        _ = (h2 * p : ZMod a) := by rw [neg_neg]
    have h_dvd_a : (a : ℤ) ∣ ((h1 * p : ℕ) : ℤ) - ((h2 * p : ℕ) : ℤ) := by
      apply ZMod.intCast_eq_intCast_iff_dvd_sub _ _ a |>.mp
      push_cast
      exact h_eq_hp.symm
    have h_dvd_q : (q : ℤ) ∣ (h1 : ℤ) - (h2 : ℤ) := by
      have e1 : (a : ℤ) = p * q := by exact_mod_cast ha_eq
      have e2 : ((h1 * p : ℕ) : ℤ) = (h1 : ℤ) * (p : ℤ) := by push_cast; rfl
      have e3 : ((h2 * p : ℕ) : ℤ) = (h2 : ℤ) * (p : ℤ) := by push_cast; rfl
      rw [e1, e2, e3] at h_dvd_a
      obtain ⟨k, hk⟩ := h_dvd_a
      have h_diff : (h1 : ℤ) * p - (h2 : ℤ) * p = ((h1 : ℤ) - (h2 : ℤ)) * p := by ring
      rw [h_diff] at hk
      have hp_ne_zero : (p : ℤ) ≠ 0 := by omega
      have hk2 : ((h1 : ℤ) - (h2 : ℤ)) * p = (k * q) * p := by
        calc ((h1 : ℤ) - (h2 : ℤ)) * p = p * q * k := hk
          _ = (k * q) * p := by ring
      have hk3 : (h1 : ℤ) - (h2 : ℤ) = k * q := Int.eq_of_mul_eq_mul_right hp_ne_zero hk2
      rw [mul_comm] at hk3
      exact ⟨k, hk3⟩
    obtain ⟨k, hk⟩ := h_dvd_q
    by_cases hk0 : k = 0
    · rw [hk0, mul_zero] at hk
      omega
    -- finished by Numina
    · by_cases hk_pos : k > 0
      · have h_k_ge : k ≥ 1 := by omega
        have h_q_pos : (q : ℤ) > 0 := by omega
        have hh1_le : (h1 : ℤ) ≤ q - s₁ - 1 := by
          have : h1 ≤ q - s₁ - 1 := hh1.2
          have : s₁ + 1 ≤ q := by omega
          omega
        have hh2_ge : (h2 : ℤ) ≥ 1 := by omega
        have h_lhs_ub : (h1 : ℤ) - (h2 : ℤ) ≤ (q : ℤ) - (s₁ : ℤ) - 2 := by omega
        have h_q_s1_bound : (q : ℤ) - (s₁ : ℤ) - 2 < (q : ℤ) := by
          have : (s₁ : ℤ) ≥ 0 := by omega
          omega
        have h_lhs_lt_q : (h1 : ℤ) - (h2 : ℤ) < (q : ℤ) := by omega
        have h_rhs_ge_q : k * (q : ℤ) ≥ q := by nlinarith
        have : (h1 : ℤ) - (h2 : ℤ) ≠ (q : ℤ) * k := by
          intro heq
          rw [mul_comm] at heq
          rw [heq] at h_lhs_lt_q
          exact absurd h_lhs_lt_q (not_lt_of_ge h_rhs_ge_q)
        exact absurd hk this
      · have h_k_le : k ≤ -1 := by omega
        have h_q_pos : (q : ℤ) > 0 := by omega
        have hh2_le : (h2 : ℤ) ≤ q - s₁ - 1 := by
          have : h2 ≤ q - s₁ - 1 := hh2.2
          have : s₁ + 1 ≤ q := by omega
          omega
        have hh1_ge : (h1 : ℤ) ≥ 1 := by omega
        have h_lhs_lb : (h1 : ℤ) - (h2 : ℤ) ≥ 1 - ((q : ℤ) - (s₁ : ℤ) - 1) := by omega
        have h_lhs_gt_neg_q : (h1 : ℤ) - (h2 : ℤ) > -(q : ℤ) := by
          have h_s1_pos : (s₁ : ℤ) ≥ 0 := by omega
          have : 1 - ((q : ℤ) - (s₁ : ℤ) - 1) > -(q : ℤ) := by omega
          omega
        have h_rhs_le_neg_q : k * (q : ℤ) ≤ -q := by nlinarith
        have : (h1 : ℤ) - (h2 : ℤ) ≠ (q : ℤ) * k := by
          intro heq
          rw [mul_comm] at heq
          rw [heq] at h_lhs_gt_neg_q
          have : -(q : ℤ) < k * (q : ℤ) := h_lhs_gt_neg_q
          exact absurd this (not_lt_of_ge h_rhs_le_neg_q)
        exact absurd hk this
  have h_H_sub : (H : Set (ZMod a)) ⊆ Sk_bar + (G : Set (ZMod a)) := by
    intro z hz
    simp only [H, Finset.coe_image, Set.mem_image, Finset.mem_coe, Finset.mem_Icc] at hz
    obtain ⟨h, ⟨h_ge, h_le⟩, rfl⟩ := hz
    exact h_yh_bar_in_Sk_bar_plus_G h h_ge h_le
  have h_H_disj : Disjoint (H : Set (ZMod a)) Sk_bar := by
    rw [Set.disjoint_left]
    intro z hz
    simp only [H, Finset.coe_image, Set.mem_image, Finset.mem_coe, Finset.mem_Icc] at hz
    obtain ⟨h, ⟨h_ge, h_le⟩, rfl⟩ := hz
    exact h_yh_bar_notin_Sk_bar h h_ge h_le
  exact ⟨H, h_H_card, h_H_sub, h_H_disj⟩
lemma lemma_3_1_case_3_gap_calc (a p q k x s₁ n : ℕ) (ha : a > 0) (E : Finset ℕ)
  (ha_eq : a = p * q) (hp : p > 1) (hq : q > 1)
  (hk : k ≥ 1)
  (hx_range : x ∈ Finset.Icc 1 (p - 1))
  (hE_sub : (E : Set ℕ) ⊆ Set.Icc 1 a)
  (h_s1_bound : x + s₁ * p > a / 2)
  (h_s1_in_E : x + s₁ * p ∈ E)
  (h_s1_min : ∀ n ∈ E, n % p = x % p → n ≥ x + s₁ * p)
  (h_n_def : n * (x + s₁ * p) ≤ (k - 1) * a ∧ (k - 1) * a < (n + 1) * (x + s₁ * p))
  (hn : ¬ (n + 1 ≥ p - 1))
  (hx_p_gcd1_val : x.gcd p = 1)
  (hE_sub_case3 : ↑E ⊆ ↑(Finset.image (fun i => i * p) (Finset.Icc 1 q)) ∪ ↑(Finset.image (fun i => x + i * p) (Finset.range q))) :
  letI : NeZero a := ⟨ha.ne'⟩
  (let Sk_bar := (fun n : ℕ => (n : ZMod a)) '' (S_k a (S E : Set ℕ) k)
   let G := AddSubgroup.closure {(p : ZMod a)}
   (Sk_bar + (G : Set (ZMod a))).ncard ≥ min a (Sk_bar.ncard + q - s₁ - 1)) := by
  let Sk_bar := (fun n : ℕ => (n : ZMod a)) '' (S_k a (S E : Set ℕ) k)
  let G := AddSubgroup.closure {(p : ZMod a)}
  have h_exclusions : (S_k a (S E : Set ℕ) k ∩ {y | y ≡ (n + 1) * x [MOD p] ∧ y < (n + 1) * (x + s₁ * p)}) = ∅ ∧
                      (S_k a (S E : Set ℕ) k ∩ {y | y ≡ (n + 2) * x [MOD p] ∧ y < (n + 2) * (x + s₁ * p)}) = ∅ := by
    have h1 := lemma_3_1_case_3_n_plus_m_helper a p q k x s₁ (n + 1) E hp h_s1_min hx_p_gcd1_val hE_sub_case3 (by omega)
    have h2 := lemma_3_1_case_3_n_plus_m_helper a p q k x s₁ (n + 2) E hp h_s1_min hx_p_gcd1_val hE_sub_case3 (by omega)
    exact ⟨h1, h2⟩
  have hs1_lt : s₁ < q := by
      have h1 : x + s₁ * p ≤ p * q := by rw [← ha_eq]; exact (hE_sub h_s1_in_E).2
      have h2 : x ≥ 1 := (Finset.mem_Icc.mp hx_range).1
      have : p ≥ 2 := (hp : p > 1)
      zify [h1, h2, this]
      nlinarith
  have h_m_exists : ∃ m : ℕ, (m = n + 1 ∨ m = n + 2) ∧
    (k - 1) * a < m * (x + s₁ * p) ∧
    m * (x + s₁ * p) - ((k - 1) * a + 1) ≥ p * (q - s₁ - 1) ∧
    m * (x + s₁ * p) ≤ k * a ∧
    ∀ h, 1 ≤ h → h ≤ q - s₁ - 1 → m * (x + s₁ * p) - h * p ≤ k * a := by
    have h_s1_le_a : x + s₁ * p ≤ a := (hE_sub h_s1_in_E).2
    have h_n1_le : (n + 1) * (x + s₁ * p) ≤ k * a := by
      have h_ka : (k - 1) * a + a = k * a := by
        nth_rw 2 [← Nat.one_mul a]
        rw [← Nat.add_mul, Nat.sub_add_cancel hk]
      rw [Nat.add_mul, one_mul]
      exact (Nat.add_le_add h_n_def.1 h_s1_le_a).trans_eq h_ka
    by_cases h_gap : (n + 1) * (x + s₁ * p) - ((k - 1) * a + 1) ≥ p * (q - s₁ - 1)
    · use n + 1
      refine ⟨Or.inl rfl, h_n_def.2, h_gap, h_n1_le, ?_⟩
      intro h _ _
      calc (n + 1) * (x + s₁ * p) - h * p
          ≤ (n + 1) * (x + s₁ * p) := Nat.sub_le _ _
        _ ≤ k * a := h_n1_le
    · use n + 2
      constructor; exact Or.inr rfl
      constructor
      · -- (k-1)*a < (n+2)*(x+s1*p)
        apply h_n_def.2.trans
        have : x + s₁ * p ≥ 1 := (Finset.mem_Icc.mp hx_range).1.trans (Nat.le_add_right _ _)
        calc (n + 1) * (x + s₁ * p) < (n + 1) * (x + s₁ * p) + (x + s₁ * p) := Nat.lt_add_of_pos_right this
          _ = (n + 2) * (x + s₁ * p) := by ring
      have h_2sp_gt_a : 2 * (x + s₁ * p) > a := by omega
      -- finished by Numina
      have h_sp_ge : x + s₁ * p ≥ p * (q - s₁ - 1) := by
        have h_key : 2 * (x + s₁ * p) > p * q := by rw [← ha_eq]; exact h_2sp_gt_a
        have h_x_pos : x ≥ 1 := (Finset.mem_Icc.mp hx_range).1
        have h_q_bound : q < 2 * s₁ + 2 := by
          by_contra h_not
          push Not at h_not
          have h1 : p * q ≥ p * (2 * s₁ + 2) := Nat.mul_le_mul_left p h_not
          have h2 : p * (2 * s₁ + 2) = 2 * s₁ * p + 2 * p := by ring
          rw [h2] at h1
          have h3 : 2 * (x + s₁ * p) = 2 * x + 2 * s₁ * p := by ring
          rw [h3] at h_key
          have hx_le : x ≤ p - 1 := (Finset.mem_Icc.mp hx_range).2
          have : 2 * x ≤ 2 * (p - 1) := by omega
          have : 2 * (p - 1) = 2 * p - 2 := by omega
          have : 2 * x ≤ 2 * p - 2 := by omega
          have : 2 * x + 2 * s₁ * p ≤ 2 * p - 2 + 2 * s₁ * p := by omega
          have : 2 * p - 2 + 2 * s₁ * p = 2 * s₁ * p + 2 * p - 2 := by omega
          have : 2 * x + 2 * s₁ * p ≤ 2 * s₁ * p + 2 * p - 2 := by omega
          have : 2 * s₁ * p + 2 * p - 2 < 2 * s₁ * p + 2 * p := by omega
          omega
        have h_qs1 : q - s₁ - 1 ≤ s₁ := by omega
        have h_ps1 : p * (q - s₁ - 1) ≤ p * s₁ := Nat.mul_le_mul_left p h_qs1
        have : x + s₁ * p > p * (q - s₁ - 1) :=
          calc x + s₁ * p
              = s₁ * p + x := by ring
            _ ≥ s₁ * p + 1 := by omega
            _ = p * s₁ + 1 := by ring
            _ > p * s₁ := by omega
            _ ≥ p * (q - s₁ - 1) := h_ps1
        exact Nat.le_of_lt this
      constructor
      · -- (n+2)*X - ((k-1)*a + 1) ≥ p*(q-s1-1)
        have h_n2 : (n + 2) * (x + s₁ * p) = (n + 1) * (x + s₁ * p) + (x + s₁ * p) := by ring
        rw [h_n2]
        calc (n + 1) * (x + s₁ * p) + (x + s₁ * p) - ((k - 1) * a + 1)
            ≥ x + s₁ * p := by
              have : (n + 1) * (x + s₁ * p) ≥ (k - 1) * a + 1 := h_n_def.2
              omega
          _ ≥ p * (q - s₁ - 1) := h_sp_ge
      · have h_gap_lt : (n + 1) * (x + s₁ * p) - ((k - 1) * a + 1) < p * (q - s₁ - 1) := Nat.lt_of_not_ge h_gap
        have hx_le : x ≤ p - 1 := (Finset.mem_Icc.mp hx_range).2
        have h_ka : (k - 1) * a + a = k * a := by
          nth_rw 2 [← Nat.one_mul a]
          rw [← Nat.add_mul, Nat.sub_add_cancel hk]
        have h_mX_le_ka : (n + 2) * (x + s₁ * p) ≤ k * a := by
          calc (n + 2) * (x + s₁ * p)
              = (n + 1) * (x + s₁ * p) + (x + s₁ * p) := by ring
            _ ≤ (k - 1) * a + a := by
                  have : (n + 1) * (x + s₁ * p) < (k - 1) * a + 1 + p * (q - s₁ - 1) := by omega
                  have : (n + 1) * (x + s₁ * p) + (x + s₁ * p) < (k - 1) * a + 1 + p * (q - s₁ - 1) + (x + s₁ * p) := by omega
                  have : x + s₁ * p ≤ a := h_s1_le_a
                  have : p * (q - s₁ - 1) + (x + s₁ * p) ≤ a := by
                    rw [ha_eq]
                    have hs1_lt' : s₁ < q := by omega
                    have : p * (q - s₁ - 1) + (x + s₁ * p) ≤ p * q := by
                      have h1 : p * (q - s₁ - 1) = p * q - p * (s₁ + 1) := by
                        have : s₁ + 1 ≤ q := by omega
                        have : q - s₁ - 1 = q - (s₁ + 1) := by omega
                        rw [this, Nat.mul_sub_left_distrib]
                      rw [h1]
                      have h2 : x + s₁ * p ≤ p * (s₁ + 1) := by
                        have : x ≤ p - 1 := hx_le
                        have : x + s₁ * p ≤ (p - 1) + s₁ * p := by omega
                        have : (p - 1) + s₁ * p = s₁ * p + p - 1 := by omega
                        have : s₁ * p + p - 1 < s₁ * p + p := by omega
                        have : s₁ * p + p = p * s₁ + p := by ring
                        have : p * s₁ + p = p * (s₁ + 1) := by ring
                        omega
                      omega
                    omega
                  have : 1 + p * (q - s₁ - 1) + (x + s₁ * p) ≤ 1 + a := by omega
                  omega
            _ = k * a := h_ka
        refine ⟨h_mX_le_ka, ?_⟩
        intro h hh1 hh_bound
        calc (n + 2) * (x + s₁ * p) - h * p
            ≤ (n + 2) * (x + s₁ * p) := Nat.sub_le _ _
          _ ≤ k * a := h_mX_le_ka
  obtain ⟨m, hm_cases, hm_gt, hm_gap, hm_leka, hm_le⟩ := h_m_exists
  have h_H_exists : ∃ (H : Finset (ZMod a)), H.card = q - s₁ - 1 ∧
    (H : Set (ZMod a)) ⊆ Sk_bar + (G : Set (ZMod a)) ∧ Disjoint (H : Set (ZMod a)) Sk_bar :=
    lemma_3_1_case_3_H_exists a p q k x s₁ n m ha E ha_eq hp hq hk h_s1_in_E
      hs1_lt hm_cases hm_gt hm_gap hm_leka hm_le h_exclusions
  obtain ⟨H, H_card, H_sub, H_disj⟩ := h_H_exists
  have h_ncard_add : Sk_bar.ncard + (q - s₁ - 1) ≤ (Sk_bar + (G : Set (ZMod a))).ncard := by
    have h_union : Sk_bar ∪ (H : Set (ZMod a)) ⊆ Sk_bar + (G : Set (ZMod a)) := by
      intro x hx
      cases hx with
      | inl hx_Sk =>
        have h0 : (0 : ZMod a) ∈ (G : Set (ZMod a)) := AddSubgroup.zero_mem G
        have : x + 0 ∈ Sk_bar + (G : Set (ZMod a)) := Set.add_mem_add hx_Sk h0
        rw [add_zero] at this
        exact this
      | inr hx_H => exact H_sub hx_H
    have h_ncard_union : (Sk_bar ∪ (H : Set (ZMod a))).ncard = Sk_bar.ncard + (H : Set (ZMod a)).ncard := by
      refine Set.ncard_union_eq ?_ ?_ ?_
      · exact H_disj.symm
      · letI : NeZero a := ⟨ha.ne'⟩
        exact Set.toFinite _
      · exact Set.toFinite _
    have h_H_ncard : (H : Set (ZMod a)).ncard = q - s₁ - 1 := by
      rw [Set.ncard_coe_finset]
      exact H_card
    rw [← h_H_ncard, ← h_ncard_union]
    letI : NeZero a := ⟨ha.ne'⟩
    haveI : Finite (ZMod a) := inferInstance
    exact Set.ncard_le_ncard h_union
  have h_ncard_add' : Sk_bar.ncard + q - s₁ - 1 ≤ (Sk_bar + (G : Set (ZMod a))).ncard := by
    calc Sk_bar.ncard + q - s₁ - 1
      ≤ Sk_bar.ncard + (q - s₁ - 1) := by omega
      _ ≤ (Sk_bar + (G : Set (ZMod a))).ncard := h_ncard_add
  exact le_trans (min_le_right a _) h_ncard_add'
-- proven by Numina
lemma sk_image_injective (a j : ℕ) (_ha : a > 0) (S_set : Set ℕ) :
    Set.InjOn (fun n : ℕ => (n : ZMod a)) (S_k a S_set j) := by
  intro x hx y hy h_eq
  simp only [S_k, Set.mem_inter_iff, Set.mem_Icc] at hx hy
  -- Both x and y are in [(j-1)*a+1, j*a], so |x - y| < a, so x ≡ y mod a → x = y
  have hx_range := hx.2
  have hy_range := hy.2
  have h_mod : x ≡ y [MOD a] := (ZMod.natCast_eq_natCast_iff x y a).mp h_eq
  apply Nat.ModEq.eq_of_abs_lt h_mod
  have hx_lower : (j - 1) * a + 1 ≤ x := hx_range.1
  have hx_upper : x ≤ j * a := hx_range.2
  have hy_lower : (j - 1) * a + 1 ≤ y := hy_range.1
  have hy_upper : y ≤ j * a := hy_range.2
  -- The interval [(j-1)*a+1, j*a] has length at most a - 1
  -- So the difference is at most a - 1 < a
  by_cases h : x ≤ y
  · have h_diff : 0 ≤ (y : ℤ) - (x : ℤ) := by omega
    rw [abs_of_nonneg h_diff]
    have eq : (y : ℤ) - (x : ℤ) = ↑(y - x) := by omega
    rw [eq]
    norm_cast
    -- y ≤ j*a and x ≥ (j-1)*a + 1, so y - x ≤ j*a - (j-1)*a - 1 = a - 1 < a
    by_cases hj : j = 0
    · subst hj
      simp at hx_lower hy_upper
      omega
    · -- j ≥ 1, so (j-1)*a + a = j*a
      have hj_pos : j ≥ 1 := Nat.one_le_iff_ne_zero.mpr hj
      -- y - x ≤ j*a - ((j-1)*a + 1)
      -- We prove using the fact that  y ≤ j*a and x ≥ (j-1)*a + 1
      -- When j ≥ 1, (j-1)*a + 1 + (a-1) = (j-1)*a + a = j*a
      have h_upper : y ≤ j * a := hy_upper
      have h_lower : (j - 1) * a + 1 ≤ x := hx_lower
      -- From h_lower, we get x - 1 ≥ (j-1)*a
      -- From h_upper, we get y - x ≤ j*a - x ≤ j*a - ((j-1)*a + 1)
      -- When j ≥ 1, j*a - (j-1)*a = a, so j*a - ((j-1)*a + 1) = a - 1
      have : y < x + a := by
        -- Since j ≥ 1, we have j * a ≥ a and j * a - (j-1)*a = a
        -- We know y ≤ j*a and x ≥ (j-1)*a + 1
        -- So y - x ≤ j*a - ((j-1)*a + 1) < a
        have key : j * a = (j - 1) * a + a := by
          have hj_succ : j = j - 1 + 1 := by omega
          conv_lhs => rw [hj_succ]
          ring
        omega
      omega
  · push Not at h
    have h_diff : (y : ℤ) - (x : ℤ) ≤ 0 := by omega
    rw [abs_of_nonpos h_diff]
    have : -(↑y - ↑x) = (↑x - ↑y : ℤ) := by ring
    rw [this]
    have eq : (x : ℤ) - (y : ℤ) = ↑(x - y) := by omega
    rw [eq]
    norm_cast
    -- x ≤ j*a and y ≥ (j-1)*a + 1, so x - y ≤ j*a - (j-1)*a - 1 = a - 1 < a
    by_cases hj : j = 0
    · subst hj
      simp at hx_upper hy_lower
      omega
    · have hj_pos : j ≥ 1 := Nat.one_le_iff_ne_zero.mpr hj
      have h_upper : x ≤ j * a := hx_upper
      have h_lower : (j - 1) * a + 1 ≤ y := hy_lower
      have : x < y + a := by
        have key : j * a = (j - 1) * a + a := by
          have hj_succ : j = j - 1 + 1 := by omega
          conv_lhs => rw [hj_succ]
          ring
        omega
      omega
lemma lemma_3_1_step_b_h_FG_lower (a p q x s1 : ℕ) (ha_pos : a > 0) (ha_eq_pq : a = p * q)
  (hp : p > 0) (hq : q > 0) (hp1_val : p > 1) (hq1_val : q > 1)
  (S1_finset : Finset ℕ) (hS1_sub : (S1_finset : Set ℕ) ⊆ Set.Icc 1 a)
