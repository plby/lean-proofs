lemma lower_bound_set_card (a b : ℕ) (hb_ge_2 : b ≥ 2) (hb_lt_a : b < a) :
  (lower_bound_set a b).card = b := by
  rw [lower_bound_set, Nat.card_Icc]
  omega
-- proven by project Numina
lemma lower_bound_set_gcd (a b : ℕ) (hb_ge_2 : b ≥ 2) (hb_lt_a : b < a) :
  (lower_bound_set a b).gcd id = 1 := by
  rw [lower_bound_set]
