           ∑ r ∈ insert (x : ZMod p) (S_fin.erase (x : ZMod p)), (F ∩ f_mod_p ⁻¹' {r}).ncard by
            rw [← h_decomp]]
      rw [Finset.sum_insert (Finset.notMem_erase (x : ZMod p) S_fin)]
      have h_FiberX_eq : (F ∩ f_mod_p ⁻¹' {(x : ZMod p)}) = FiberX := rfl
      rw [h_FiberX_eq]
      have h_card_pos : S_fin.card ≥ 1 := by omega
      have h_s1_le_q : s1 < q := hs1_lt_q
      have h_total : FiberX.ncard + ∑ r ∈ S_fin.erase ↑x, (F ∩ f_mod_p ⁻¹' {r}).ncard
                      ≤ (q - s1) + (S_fin.card - 1) * q :=
        Nat.add_le_add hx_bound h_sum_le
      calc FiberX.ncard + ∑ r ∈ S_fin.erase ↑x, (F ∩ f_mod_p ⁻¹' {r}).ncard
          ≤ (q - s1) + (S_fin.card - 1) * q := h_total
        _ = q - s1 + (S_fin.card * q - q) := by
            have h_ge_1 : S_fin.card ≥ 1 := h_card_pos
            have : (S_fin.card - 1) * q = S_fin.card * q - q := by
              conv_lhs => rw [Nat.sub_mul]
              rw [one_mul]
            rw [this]
        _ = S_fin.card * q - s1 := by
            have h1 : s1 ≤ q := Nat.le_of_lt h_s1_le_q
            have h2 : q ≤ S_fin.card * q := by
              calc q = 1 * q := by ring
                _ ≤ S_fin.card * q := Nat.mul_le_mul_right q h_card_pos
            omega
    -- proved by Numina
    calc F.ncard + s1
        ≤ S_fin.card * q - s1 + s1 := by omega
      _ = S_fin.card * q := by
            have h_s1_bound : s1 ≤ S_fin.card * q := by
              have : s1 < q := hs1_lt_q
              have : s1 < S_fin.card * q := by
                calc s1 < q := hs1_lt_q
                  _ = 1 * q := by ring
                  _ ≤ S_fin.card * q := Nat.mul_le_mul_right q h_S_card_pos
              omega
            omega
      _ = (f_mod_p '' F).ncard * q := by rw [← hS_eq]
  -- proven by Numina
  have h_FG_lower_final : (F + (G : Set (ZMod a))).ncard ≥ min a (F.ncard + s1) := by
    rw [h_F_plus_G_card]
    rw [min_eq_right]
    · exact h_le_res
    · letI : NeZero p := ⟨hp.ne'⟩
      have h_img_le_p : (f_mod_p '' F).ncard ≤ p := by
        have h_sub : (f_mod_p '' F) ⊆ Set.univ := Set.subset_univ _
        have h1 : (f_mod_p '' F).ncard ≤ Set.univ.ncard := Set.ncard_le_ncard h_sub (Set.toFinite _)
        rw [Set.ncard_univ] at h1
        have h2 : Nat.card (ZMod p) = Fintype.card (ZMod p) := Nat.card_eq_fintype_card
        have h3 : Fintype.card (ZMod p) = p := ZMod.card p
        rw [h2, h3] at h1
        exact h1
      calc F.ncard + s1
          ≤ (f_mod_p '' F).ncard * q := h_le_res
        _ ≤ p * q := Nat.mul_le_mul_right q h_img_le_p
        _ = a := ha_eq_pq.symm
  exact h_FG_lower_final
-- proven by Numina
lemma add_subgroup_ncard_ge_card {a : ℕ} [NeZero a]
    {G : AddSubgroup (ZMod a)} {S : Set (ZMod a)} (hS : S.Nonempty) :
    Nat.card G ≤ (S + (G : Set (ZMod a))).ncard := by
  obtain ⟨s, hs⟩ := hS
  have h_inj : Function.Injective (fun g : ZMod a => s + g) := fun _ _ => add_left_cancel
  have : {s} + (G : Set (ZMod a)) = (fun g => s + g) '' (G : Set (ZMod a)) := by
    rw [Set.singleton_add]
  have h_card_eq : ({s} + (G : Set (ZMod a))).ncard = (G : Set (ZMod a)).ncard := by
    rw [this, Set.ncard_image_of_injective _ h_inj]
  have h_sub : {s} + (G : Set (ZMod a)) ⊆ S + (G : Set (ZMod a)) := by
    apply Set.add_subset_add_right
    exact Set.singleton_subset_iff.mpr hs
  rw [← Nat.card_coe_set_eq]
  calc Nat.card ↥G = (G : Set (ZMod a)).ncard := Nat.card_coe_set_eq (G : Set (ZMod a))
    _ = ({s} + (G : Set (ZMod a))).ncard := h_card_eq.symm
    _ ≤ (S + (G : Set (ZMod a))).ncard := Set.ncard_le_ncard h_sub
-- proven by Numina
lemma kneser_raw_bound (a FG_ncard SkG_ncard FSk_ncard F_ncard Sk_ncard s1 q : ℕ)
    (hs1_lt_q : s1 < q)
    (h_a_ge_q : a ≥ q)
    (h_FG_ge : min a (F_ncard + s1) ≤ FG_ncard)
    (h_Sk_ge : min a (Sk_ncard + q - s1 - 1) ≤ SkG_ncard)
    (h_kneser : FG_ncard + SkG_ncard - q ≤ FSk_ncard)
    (h_FG_le_a : FG_ncard ≤ a)
    (h_Sk_le_a : SkG_ncard ≤ a)
    (h_FG_ge_q : q ≤ FG_ncard)
    (h_SkG_ge_q : q ≤ SkG_ncard) :
    min a (F_ncard + Sk_ncard - 1) ≤ FSk_ncard := by
  -- Key idea: use h_kneser with bounds from h_FG_ge and h_Sk_ge
  -- h_kneser: FG_ncard + SkG_ncard - q ≤ FSk_ncard
  -- We want: min a (F_ncard + Sk_ncard - 1) ≤ FSk_ncard
  -- First establish: min a (F_ncard + s1) + min a (Sk_ncard + q - s1 - 1) ≤ FG_ncard + SkG_ncard
  have h_sum_mins : min a (F_ncard + s1) + min a (Sk_ncard + q - s1 - 1) ≤ FG_ncard + SkG_ncard := by
    calc min a (F_ncard + s1) + min a (Sk_ncard + q - s1 - 1)
        ≤ FG_ncard + min a (Sk_ncard + q - s1 - 1) := by omega
      _ ≤ FG_ncard + SkG_ncard := by omega
  -- Now we need to show that min a (F_ncard + Sk_ncard - 1) ≤ min a (F_ncard + s1) + min a (Sk_ncard + q - s1 - 1) - q + 1
  -- Actually, let's use a more direct argument
  by_cases h1 : F_ncard + s1 ≤ a
  · -- Case: F_ncard + s1 ≤ a
    by_cases h2 : Sk_ncard + q - s1 - 1 ≤ a
    · -- Both mins are their left sides
      have hFG : F_ncard + s1 ≤ FG_ncard := by simpa [Nat.min_eq_right h1] using h_FG_ge
      have hSkG : Sk_ncard + q - s1 - 1 ≤ SkG_ncard := by simpa [Nat.min_eq_right h2] using h_Sk_ge
      -- From h_kneser: FG_ncard + SkG_ncard - q ≤ FSk_ncard
      -- We have: F_ncard + s1 + Sk_ncard + q - s1 - 1 ≤ FG_ncard + SkG_ncard
      -- So: F_ncard + Sk_ncard + q - 1 ≤ FG_ncard + SkG_ncard
      -- Therefore: F_ncard + Sk_ncard - 1 ≤ FG_ncard + SkG_ncard - q
      have : F_ncard + Sk_ncard - 1 + q ≤ FG_ncard + SkG_ncard := by omega
      have : F_ncard + Sk_ncard - 1 ≤ FG_ncard + SkG_ncard - q := by omega
      calc min a (F_ncard + Sk_ncard - 1)
          ≤ F_ncard + Sk_ncard - 1 := Nat.min_le_right _ _
        _ ≤ FG_ncard + SkG_ncard - q := this
        _ ≤ FSk_ncard := h_kneser
    · -- min a (Sk_ncard + q - s1 - 1) = a, so SkG_ncard = a
      have ha_le : a ≤ SkG_ncard := by
        have : Sk_ncard + q - s1 - 1 > a := Nat.lt_of_not_le h2
        have : min a (Sk_ncard + q - s1 - 1) = a := Nat.min_eq_left (Nat.le_of_lt this)
        rw [this] at h_Sk_ge
        exact h_Sk_ge
      have hSkG_eq : SkG_ncard = a := Nat.le_antisymm h_Sk_le_a ha_le
      rw [hSkG_eq] at h_kneser
      -- From h_kneser: FG_ncard + a - q ≤ FSk_ncard
      -- We need: min a (F_ncard + Sk_ncard - 1) ≤ FSk_ncard
      -- Since FG_ncard ≤ a and q ≤ FG_ncard, we have FG_ncard + a - q ≥ a
      have : a ≤ FG_ncard + a - q := by omega
      calc min a (F_ncard + Sk_ncard - 1)
          ≤ a := Nat.min_le_left _ _
        _ ≤ FG_ncard + a - q := this
        _ ≤ FSk_ncard := h_kneser
  · -- min a (F_ncard + s1) = a, so FG_ncard = a
    have ha_le : a ≤ FG_ncard := by
      have : F_ncard + s1 > a := Nat.lt_of_not_le h1
      have : min a (F_ncard + s1) = a := Nat.min_eq_left (Nat.le_of_lt this)
      rw [this] at h_FG_ge
      exact h_FG_ge
    have hFG_eq : FG_ncard = a := Nat.le_antisymm h_FG_le_a ha_le
    rw [hFG_eq] at h_kneser
    -- From h_kneser: a + SkG_ncard - q ≤ FSk_ncard
    -- We need: min a (F_ncard + Sk_ncard - 1) ≤ FSk_ncard
    have : a ≤ a + SkG_ncard - q := by omega
    calc min a (F_ncard + Sk_ncard - 1)
        ≤ a := Nat.min_le_left _ _
      _ ≤ a + SkG_ncard - q := this
      _ ≤ FSk_ncard := h_kneser
lemma lemma_3_1 (a b : ℕ) (E : Finset ℕ) (hE_sub : (E : Set ℕ) ⊆ Set.Icc 1 a)
  (hE_card : E.card = b) (hE_max : a ∈ E) (hE_gcd : Finset.gcd E id = 1) (k : ℕ) (hk : k ≥ 1) :
  let S_set := (S E : Set ℕ)
  (S_k a S_set (k + 1)).ncard ≥ min a (b + (S_k a S_set k).ncard - 1) := by
  let S_set := (S E : Set ℕ)
  -- Step 1.1: Replace E with S_1.
  have h_S1_card_sub : (E : Set ℕ) ⊆ S_k a S_set 1 := by
    intro x hx
    simp only [S_k, Set.mem_inter_iff, Set.mem_Icc]
    refine ⟨AddSubsemigroup.subset_closure hx, ?_⟩
    simp only [one_mul, Nat.sub_self, zero_mul, zero_add]
    exact hE_sub hx
  -- Step 1.2: Sum-stability.
  have h_sum_stable_S1 : ∀ x y, x ∈ S_k a S_set 1 → y ∈ S_k a S_set 1 → x + y ≤ a → x + y ∈ S_k a S_set 1 := by
    intro x y hx hy hxy
    simp only [S_k, Set.mem_inter_iff, Set.mem_Icc] at hx hy ⊢
    refine ⟨AddSubsemigroup.add_mem _ hx.1 hy.1, ?_⟩
    simp only [one_mul, Nat.sub_self, zero_mul, zero_add] at hx hy ⊢
    omega
  -- Step 1.3: Map to ZMod a.
  have ha_pos_S1 : a > 0 := by
    have : a ∈ Set.Icc 1 a := hE_sub (Finset.mem_coe.mpr hE_max)
    simp only [Set.mem_Icc] at this
    exact this.1
  letI : NeZero a := ⟨ha_pos_S1.ne'⟩
  have h_S1_fin_inst : (S_k a S_set 1).Finite := Set.Finite.inter_of_right (Set.finite_Icc _ _) _
  haveI : Fintype (S_k a S_set 1) := h_S1_fin_inst.fintype
  let F := (fun n : ℕ => (n : ZMod a)) '' (S_k a S_set 1)
  have h_Sk_fin_inst : (S_k a S_set k).Finite := Set.Finite.inter_of_right (Set.finite_Icc _ _) _
  haveI : Fintype (S_k a S_set k) := h_Sk_fin_inst.fintype
  let Sk_bar := (fun n : ℕ => (n : ZMod a)) '' (S_k a S_set k)
  -- Step 1.4: Sk+1 image inclusion.
  have h_image_inc_S1 : (F : Set (ZMod a)) + Sk_bar ⊆ (fun n : ℕ => (n : ZMod a)) '' (S_k a S_set (k + 1)) := by
    rw [add_comm]
    exact lemma_2_3 a (E : Set ℕ) (by exact hE_max) k 1 hk (by omega)
  -- Step 2.1: Invoke lemma_3_1_kneser_step.
  let S1_finset := (S_k a S_set 1).toFinset
  have hS1_card_vals : S1_finset.card = (S_k a S_set 1).ncard := by
    rw [Set.ncard_eq_toFinset_card _ h_S1_fin_inst]
    apply congr_arg Finset.card
    apply Finset.ext; intro x; simp [S1_finset]
  have hS1_max_val : a ∈ S1_finset := by
    rw [Set.mem_toFinset]
    exact h_S1_card_sub (Finset.mem_coe.mpr hE_max)
  have hS1_gcd_val : S1_finset.gcd id = 1 := by
    refine' Nat.eq_one_of_dvd_one _
    rw [← hE_gcd]
    apply Finset.gcd_mono
    intro x hx
    rw [Set.mem_toFinset]
    exact h_S1_card_sub hx
  have hS1_sub : S1_finset ⊆ Finset.Icc 1 a := by
    simp [S1_finset, S_k]
  obtain ⟨p, q, hp, hq, hpq_val, h_kneser⟩ := lemma_3_1_kneser_step a (S_k a S_set 1).ncard ha_pos_S1 S1_finset k hS1_card_vals hS1_max_val hS1_gcd_val hk hS1_sub
  have h_S_unify : (S S1_finset : Set ℕ) = S_set := by
    apply Set.ext; intro x; constructor <;> intro h
    · refine AddSubsemigroup.closure_induction ?_ ?_ h
      · intro y hy
        change y ∈ (S_k a S_set 1).toFinset at hy
        rw [Set.mem_toFinset] at hy
        exact hy.1
      · intro y z _ _ hy hz
        exact (S E).add_mem hy hz
    · have h_E_sub_S1 : (E : Set ℕ) ⊆ S1_finset := by
        intro z hz
        change z ∈ (S_k a S_set 1).toFinset
        rw [Set.mem_toFinset]
        exact h_S1_card_sub hz
      apply AddSubsemigroup.closure_mono h_E_sub_S1 h
  -- Step 2.2: Branch 1 (Immediate): If meeting induction bound or full coverage.
