lemma lemma_3_1_case_3_n_plus_m_helper (a p q k x s₁ m : ℕ) (E : Finset ℕ)
  (hp : p > 1) (h_s1_min : ∀ n ∈ E, n % p = x % p → n ≥ x + s₁ * p)
  (hx_p_gcd1_val : x.gcd p = 1)
  (hE_sub_case3 : ↑E ⊆ ↑(Finset.image (fun i => i * p) (Finset.Icc 1 q)) ∪ ↑(Finset.image (fun i => x + i * p) (Finset.range q)))
  (hm_bounds : 1 ≤ m ∧ m ≤ p - 1) :
  (S_k a (S E : Set ℕ) k ∩ {y | y ≡ m * x [MOD p] ∧ y < m * (x + s₁ * p)}) = ∅ := by
  have h_structure : ∀ y ∈ (S (E : Set ℕ) : Set ℕ), ∃ C K : ℕ, y = C * x + K * p ∧ y ≥ C * (x + s₁ * p) := by
    intro y hy
    induction hy using AddSubsemigroup.closure_induction with
    | mem e he =>
      have he_form : e ∈ ↑(Finset.image (fun i => i * p) (Finset.Icc 1 q) ∪ Finset.image (fun i => x + i * p) (Finset.range q)) := hE_sub_case3 he
      have he_mem : e ∈ Finset.image (fun i => i * p) (Finset.Icc 1 q) ∨ e ∈ Finset.image (fun i => x + i * p) (Finset.range q) := Finset.mem_union.mp he_form
      rcases he_mem with h_ip | h_xip
      · have ⟨i, hi, heq⟩ : ∃ a ∈ Finset.Icc 1 q, a * p = e := by
          simp only [Finset.mem_image] at h_ip
          exact h_ip
        use 0, i
        constructor
        · omega
        · omega
      · have ⟨i, hi, heq⟩ : ∃ a ∈ Finset.range q, x + a * p = e := by
          simp only [Finset.mem_image] at h_xip
          exact h_xip
        use 1, i
        constructor
        · omega
        · have he_mod : e % p = x % p := by
            rw [← heq]
            have h_eq : x + i * p = x + p * i := by ring
            rw [h_eq, Nat.add_mul_mod_self_left]
          have h_ge := h_s1_min e he he_mod
          linarith
    | add y1 y2 hy1 hy2 ih1 ih2 =>
      rcases ih1 with ⟨C1, K1, hy1_eq, hy1_ge⟩
      rcases ih2 with ⟨C2, K2, hy2_eq, hy2_ge⟩
      use C1 + C2, K1 + K2
      constructor
      · linarith
      · nlinarith
  rw [Set.eq_empty_iff_forall_notMem]
  intro y hy
  rcases hy with ⟨⟨hy_S, _⟩, hy_mod, hy_lt⟩
  rcases h_structure y hy_S with ⟨C, K, hy_eq, hy_ge⟩
  have hy_mod_p : y ≡ C * x [MOD p] := by
    rw [hy_eq]
    have h_mod_add : (C * x + K * p) % p = (C * x) % p := by
      have h_eq : C * x + K * p = C * x + p * K := by ring
      rw [h_eq, Nat.add_mul_mod_self_left]
    exact h_mod_add
  have h_Cx_mx : C * x ≡ m * x [MOD p] := hy_mod_p.symm.trans hy_mod
  -- Since gcd(x, p) = 1, C ≡ m [MOD p]
  have h_gcd_p_x : Nat.gcd p x = 1 := by
    rw [Nat.gcd_comm]
    exact hx_p_gcd1_val
  have h_C_m : C ≡ m [MOD p] := Nat.ModEq.cancel_right_of_coprime h_gcd_p_x h_Cx_mx
  -- Since C ≡ m [MOD p], and 1 ≤ m ≤ p - 1, we must have C ≥ m.
  have h_C_ge_m : C ≥ m := by
    have hC_eq : C % p = m % p := h_C_m
    have hp_pos : p > 0 := by omega
    have hm_mod : m % p = m := Nat.mod_eq_of_lt (by omega)
    rw [hm_mod] at hC_eq
    have h_le : m ≤ C % p := by omega
    have h_mod_le : C % p ≤ C := Nat.mod_le C p
    exact le_trans h_le h_mod_le
  have hy_ge_m : y ≥ m * (x + s₁ * p) := by
    calc y ≥ C * (x + s₁ * p) := hy_ge
      _ ≥ m * (x + s₁ * p) := Nat.mul_le_mul_right (x + s₁ * p) h_C_ge_m
  linarith
