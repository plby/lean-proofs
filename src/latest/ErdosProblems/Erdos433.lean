    (H : Set (ZMod a)) ⊆ Sk_bar + (G : Set (ZMod a)) ∧ Disjoint (H : Set (ZMod a)) Sk_bar := by
  let Sk_bar := (fun n : ℕ => (n : ZMod a)) '' (S_k a (S E : Set ℕ) k)
  let G := AddSubgroup.closure {(p : ZMod a)}
  have hm_pos : m ≥ 1 := by omega
