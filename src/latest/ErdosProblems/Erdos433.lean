/-
Let S be the additive subsemigroup of N generated by E. Let G(E) be the greatest element of N \ S.
-/
def S (E : Set ℕ) : AddSubsemigroup ℕ := AddSubsemigroup.closure E
def S_k (a : ℕ) (S : Set ℕ) (k : ℕ) : Set ℕ := S ∩ Set.Icc ((k - 1) * a + 1) (k * a)

noncomputable def G (E : Set ℕ) : ℕ := sSup {n | n ∉ S E}

/-- g(b, a) is the maximum of G(E) over systems E ⊆ [1, a] with |E| = b and gcd(E) = 1. -/
noncomputable def g (b a : ℕ) : ℕ :=
  sSup {G E | (E : Finset ℕ)
    (_hE_sub : (E : Set ℕ) ⊆ Set.Icc 1 a)
    (_hE_card : E.card = b)
    (_hE_gcd : Finset.gcd E id = 1)}
/-
If B is an almost subgroup with special element b0, and x is in B but not in the subgroup generated by b0, then x + k*b0 is in B for all natural numbers k.
-/
def IsAlmostSubgroup {A : Type*} [AddCommGroup A] (B : Set A) (b₀ : A) : Prop :=
  b₀ ∈ B ∧ ∀ b ∈ B, ∀ b' ∈ B, b = b₀ ∧ b' = b₀ ∨ b + b' ∈ B
lemma lemma_2_1_helper_1 {A : Type*} [AddCommGroup A] [Finite A] (B : Set A) (b₀ : A)
  (h : IsAlmostSubgroup B b₀) (x : A) (hx : x ∈ B) (hxB₀ : x ∉ AddSubgroup.closure {b₀}) :
  ∀ k : ℕ, x + k • b₀ ∈ B := by
    cases h;
    rename_i hB₀ h_add;
    refine' fun k ↦ Nat.recOn k _ _ <;> simp_all +decide;
    intro n hn; specialize h_add _ hn _ hB₀; simp_all +decide [ add_smul ] ;
    simp_all +decide [ ← add_assoc ];
    exact h_add.resolve_left fun h => hxB₀ <| by rw [ show x = ( 1 - n : ℤ ) • b₀ by { rw [ sub_smul, one_smul, ← eq_sub_iff_add_eq ] at *; aesop } ] ; exact AddSubgroup.zsmul_mem _ ( AddSubgroup.subset_closure <| Set.mem_singleton _ ) _;
/-
If B is an almost subgroup with special element b0, and there is an element x in B outside the subgroup generated by b0, then B is a subgroup.
-/
lemma lemma_2_1_case_1 {A : Type*} [AddCommGroup A] [Finite A] (B : Set A) (b₀ : A)
  (h : IsAlmostSubgroup B b₀) (x : A) (hx : x ∈ B) (hxB₀ : x ∉ AddSubgroup.closure {b₀}) :
  ∃ S : AddSubgroup A, (S : Set A) = B := by
    -- Let $B_0 = \langle b_0 \rangle$.
    set B0 := AddSubgroup.closure {b₀} with hB0_def
    have hB0 : B0 ≤ B := by
      -- Since $C$ is a subgroup and $C \neq \{0\}$ (as $\pi(x) \in C$ and $\pi(x) \neq 0$), there exists $y \in B \setminus B'_0$ such that $\pi(x) + \pi(y) = 0$.
      obtain ⟨y, hyB, hyB₀, hy⟩ : ∃ y ∈ B, y ∉ B0 ∧ (QuotientAddGroup.mk x : A ⧸ B0) + (QuotientAddGroup.mk y : A ⧸ B0) = 0 := by
        -- Since $C$ is a subgroup and $C \neq \{0\}$ (as $\pi(x) \in C$ and $\pi(x) \neq 0$), there exists $y \in B \setminus B'_0$ such that $\pi(x) + \pi(y) = 0$. Use this fact to find such a $y$.
        have hC_subgroup : ∀ c ∈ (fun y : A => QuotientAddGroup.mk y : A → A ⧸ B0) '' B, -c ∈ (fun y : A => QuotientAddGroup.mk y : A → A ⧸ B0) '' B := by
          intro c hc
          obtain ⟨y, hyB, hy⟩ : ∃ y ∈ B, (QuotientAddGroup.mk y : A ⧸ B0) = c := by
            exact hc
          have h_add : ∀ c1 c2 : A ⧸ B0, c1 ∈ (fun y : A => QuotientAddGroup.mk y : A → A ⧸ B0) '' B → c2 ∈ (fun y : A => QuotientAddGroup.mk y : A → A ⧸ B0) '' B → c1 + c2 ∈ (fun y : A => QuotientAddGroup.mk y : A → A ⧸ B0) '' B := by
            rintro _ _ ⟨ y1, hy1, rfl ⟩ ⟨ y2, hy2, rfl ⟩ ; exact (by
            cases h.2 y1 hy1 y2 hy2 <;> aesop);
          have h_subgroup : ∀ c : A ⧸ B0, c ∈ (fun y : A => QuotientAddGroup.mk y : A → A ⧸ B0) '' B → -c ∈ (fun y : A => QuotientAddGroup.mk y : A → A ⧸ B0) '' B := by
            intro c hc
            obtain ⟨y, hyB, hy⟩ : ∃ y ∈ B, (QuotientAddGroup.mk y : A ⧸ B0) = c := by
              exact hc
            have h_order : ∃ n : ℕ, n > 0 ∧ n • c = 0 := by
              exact ⟨ Nat.card ( A ⧸ B0 ), Nat.card_pos, by simp +decide ⟩
            obtain ⟨n, hn_pos, hn⟩ : ∃ n : ℕ, n > 0 ∧ n • c = 0 := h_order
            have h_neg : -c = (n - 1) • c := by
              rcases n with ( _ | _ | n ) <;> simp_all +decide [ add_smul ];
              exact neg_eq_of_add_eq_zero_right ( by rw [ ← hn ] ; abel1 )
            have h_neg_in_image : (n - 1) • c ∈ (fun y : A => QuotientAddGroup.mk y : A → A ⧸ B0) '' B := by
              have h_neg_in_image : ∀ m : ℕ, m > 0 → m • c ∈ (fun y : A => QuotientAddGroup.mk y : A → A ⧸ B0) '' B := by
                intro m hm_pos
                induction' hm_pos with m hm ih;
                · simpa using hc;
                · simpa only [ Nat.succ_eq_add_one, add_smul, one_smul ] using h_add _ _ ih hc;
              rcases n with ( _ | _ | n ) <;> simp_all +decide
            rw [h_neg] at *
            exact h_neg_in_image
          exact h_subgroup c hc;
        obtain ⟨ y, hyB, hy ⟩ := hC_subgroup _ ⟨ x, hx, rfl ⟩;
        refine' ⟨ y, hyB, _, _ ⟩ <;> simp_all +decide;
        intro hyB₀xB₀;
        -- Since $y \in B0$, we have $y = kb₀$ for some integer $k$.
        obtain ⟨k, hk⟩ : ∃ k : ℤ, y = k • b₀ := by
          rw [ AddSubgroup.mem_closure_singleton ] at hyB₀xB₀ ; tauto;
        erw [ QuotientAddGroup.eq ] at hy ; simp_all +decide [ AddSubgroup.mem_closure_singleton ];
        obtain ⟨ n, hn ⟩ := hy; exact hxB₀ ( -n - k ) ( by simp_all +decide [ sub_eq_add_neg, add_smul ] ) ;
      -- For every $n \in \mathbb{N}$, one has $x+nb_0 \neq b_0$ (since $x \notin B_0$), whence $(x+nb_0)+y \in B$.
      have h_forall_n : ∀ n : ℕ, (x + n • b₀) + y ∈ B := by
        intro n
        have h_forall_n_step : x + n • b₀ ∈ B := by
          exact lemma_2_1_helper_1 B b₀ h x hx hxB₀ n;
        have := h.2 _ h_forall_n_step _ hyB; aesop;
      -- But $(x+y)+\mathbb{N}b_0 = B_0$ (since $x+y \in B_0$ and $\mathbb{N}b_0 = B_0$).
      have h_coset : ∀ z ∈ B0, ∃ n : ℕ, z = x + y + n • b₀ := by
        intro z hz
        obtain ⟨n, hn⟩ : ∃ n : ℤ, z = x + y + n • b₀ := by
          obtain ⟨ n, hn ⟩ := AddSubgroup.mem_closure_singleton.mp hz;
          erw [ QuotientAddGroup.eq_zero_iff ] at hy;
          obtain ⟨ m, hm ⟩ := AddSubgroup.mem_closure_singleton.mp hy;
          exact ⟨ n - m, by simp +decide [ ← hn, ← hm, sub_smul ] ⟩;
        -- Since $n$ is an integer, we can write it as $n = k + m \cdot \text{order}(b₀)$ for some $k \in \{0, 1, ..., \text{order}(b₀) - 1\}$ and $m \in \mathbb{Z}$.
        obtain ⟨k, m, hk⟩ : ∃ k : ℕ, ∃ m : ℤ, n = k + m * (addOrderOf b₀) := by
          use Int.toNat (n % addOrderOf b₀);
          use n / addOrderOf b₀;
          rw [ Int.toNat_of_nonneg ( Int.emod_nonneg _ ( Nat.cast_ne_zero.mpr ( ne_of_gt ( addOrderOf_pos b₀ ) ) ) ), Int.emod_add_ediv_mul ];
        simp_all +decide [ add_smul, mul_smul ];
        exact ⟨ k, rfl ⟩;
      intro z hz; obtain ⟨ n, rfl ⟩ := h_coset z hz; convert h_forall_n n using 1; abel1;
    -- Let $C = \pi(B)$ where $\pi : A \to A/B0$ is the quotient map.
    set C := Set.image (QuotientAddGroup.mk' B0) B with hC_def
    have hC : ∀ c ∈ C, ∀ c' ∈ C, c + c' ∈ C := by
      rintro _ ⟨ b, hb, rfl ⟩ _ ⟨ b', hb', rfl ⟩ ; simp +decide [ ← QuotientAddGroup.mk_add ] ;
      cases h.2 b hb b' hb' <;> aesop
    have hC_subgroup : ∃ S : AddSubgroup (A ⧸ B0), (S : Set (A ⧸ B0)) = C := by
      have hC_subgroup : ∀ c ∈ C, ∀ c' ∈ C, c - c' ∈ C := by
        intro c hc c' hc';
        -- Since $A/B0$ is finite, there exists some $n \in \mathbb{N}$ such that $n \cdot c' = 0$.
        obtain ⟨n, hn⟩ : ∃ n : ℕ, n > 0 ∧ n • c' = 0 := by
          exact ⟨ Nat.card ( A ⧸ B0 ), Nat.card_pos, by simp +decide ⟩;
        -- Since $n \cdot c' = 0$, we have $c - c' = c + (n - 1) \cdot c'$.
        have h_diff : c - c' = c + (n - 1) • c' := by
          rcases n with ( _ | n ) <;> simp_all +decide [ add_smul, sub_eq_add_neg ];
          exact neg_eq_of_add_eq_zero_left hn;
        -- Since $c' \in C$, we have $(n - 1) \cdot c' \in C$.
        have h_mul : (n - 1) • c' ∈ C := by
          rcases n with ( _ | _ | n ) <;> simp_all +decide [ add_smul ];
          refine' Nat.recOn n _ _ <;> simp_all +decide [ add_smul ];
          intro n x hx hx'; obtain ⟨ y, hy, hy' ⟩ := hc'; specialize hC x hx y hy; aesop;
        exact h_diff.symm ▸ hC _ hc _ h_mul;
      refine' ⟨ { carrier := C, add_mem' := _, zero_mem' := _, neg_mem' := _ }, rfl ⟩ <;> simp_all +decide [ Set.ext_iff ];
      · rintro a b x hx rfl y hy rfl; exact hC x hx y hy;
      · exact ⟨ 0, hB0 ( AddSubgroup.zero_mem _ ), AddSubgroup.zero_mem _ ⟩;
      · exact fun a ha => by obtain ⟨ x, hx, hx' ⟩ := hC_subgroup 0 ( hB0 ( AddSubgroup.zero_mem _ ) ) a ha; exact ⟨ x, hx, by simpa using hx' ⟩ ;
    -- Now we show $B = \pi^{-1}(C)$.
    have hB_eq_preimage : B = (QuotientAddGroup.mk' B0) ⁻¹' C := by
      refine' Set.Subset.antisymm _ _ <;> intro a ha <;> simp_all +decide [ Set.subset_def ];
      · exact ⟨ a, ha, rfl ⟩;
      · obtain ⟨ y, hy, hy' ⟩ := ha; specialize hC y hy x hx; simp_all +decide [ QuotientAddGroup.eq ] ;
        -- Since $-y + a \in B0$, we have $a = y + (-y + a) \in B + B0$.
        have ha_in_B_plus_B0 : a ∈ B + B0 := by
          exact ⟨ y, hy, -y + a, hy', by simp +decide ⟩;
        obtain ⟨ b, hb, c, hc, rfl ⟩ := ha_in_B_plus_B0; exact h.2 _ hb _ ( hB0 _ hc ) |> Or.rec ( fun h => by aesop ) fun h => by aesop;
    rcases hC_subgroup with ⟨ S, hS ⟩ ; use S.comap ( QuotientAddGroup.mk' B0 ) ; simp +decide [ hS, hB_eq_preimage ] ;
/-
If B contains k (where 2 <= k <= n), then B contains all j in [k, n].
-/
lemma zmod_nat_cast_ne_one_of_two_le_lt (n j : ℕ) (hn : n > 0) (hj2 : 2 ≤ j) (hjlt : j < n) :
  (j : ZMod n) ≠ 1 := by
  intro h
  have hcast : (j : ZMod n) = ((1 : ℕ) : ZMod n) := by simpa using h
  have hmod : j ≡ 1 [MOD n] := (ZMod.natCast_eq_natCast_iff j 1 n).mp hcast
  rw [Nat.ModEq] at hmod
  have hjmod : j % n = j := Nat.mod_eq_of_lt hjlt
  have h1mod : 1 % n = 1 := Nat.mod_eq_of_lt (by omega)
  omega
lemma lemma_2_1_cyclic_interval (n : ℕ) (hn : n > 0) (B : Set (ZMod n)) (h1 : 1 ∈ B)
  (h_add : ∀ x ∈ B, ∀ y ∈ B, x = 1 ∧ y = 1 ∨ x + y ∈ B)
  (k : ℕ) (hk_le : 2 ≤ k) (hk_le_n : k ≤ n) (hk_in : (k : ZMod n) ∈ B) :
  ∀ j, k ≤ j → j ≤ n → (j : ZMod n) ∈ B := by
  -- We proceed by induction on $j$ starting from $k$.
  intro j hj_k hj_n
  induction' hj_k with j hj_k ih
  · exact hk_in
  · have hj_lt_n : j < n := Nat.lt_of_succ_le hj_n
    have hj_ge_two : 2 ≤ j := le_trans hk_le hj_k
    have hne : (j : ZMod n) ≠ 1 :=
      zmod_nat_cast_ne_one_of_two_le_lt n j hn hj_ge_two hj_lt_n
    have hstep := h_add (j : ZMod n) (ih (Nat.le_of_succ_le hj_n)) 1 h1
    cases hstep with
    | inl hbad => exact False.elim (hne hbad.1)
    | inr hmem =>
        simpa [Nat.cast_succ, add_comm] using hmem
/-
If B contains x1 (where 2 <= x1 < n) and n-1, then B contains x1-1.
-/
lemma lemma_2_1_cyclic_sub_one (n : ℕ) (hn : n > 0) (B : Set (ZMod n)) (h1 : 1 ∈ B)
  (h_add : ∀ x ∈ B, ∀ y ∈ B, x = 1 ∧ y = 1 ∨ x + y ∈ B)
  (x1 : ℕ) (hx1_le : 2 ≤ x1) (hx1_lt : x1 < n) (hx1_in : (x1 : ZMod n) ∈ B)
  (hn_minus_1_in : (n - 1 : ZMod n) ∈ B) :
  (x1 - 1 : ZMod n) ∈ B := by
  have hne : (x1 : ZMod n) ≠ 1 :=
    zmod_nat_cast_ne_one_of_two_le_lt n x1 hn hx1_le hx1_lt
  have hstep := h_add (x1 : ZMod n) hx1_in (n - 1 : ZMod n) hn_minus_1_in
  cases hstep with
  | inl hbad => exact False.elim (hne hbad.1)
  | inr hmem =>
      have h_eq : (x1 : ZMod n) + (n - 1 : ZMod n) = (x1 - 1 : ZMod n) := by
        rw [ZMod.natCast_self]
        abel
      simpa [h_eq, sub_eq_add_neg] using hmem
/-
If x1 is the smallest element in B greater than or equal to 2, and x1-1 is in B, then x1 must be 2.
-/
lemma lemma_2_1_cyclic_min (n : ℕ) (_hn : n > 0) (B : Set (ZMod n)) (_h1 : 1 ∈ B)
  (x1 : ℕ) (hx1_le : 2 ≤ x1) (_hx1_lt : x1 < n) (_hx1_in : (x1 : ZMod n) ∈ B)
  (h_min : ∀ k, 2 ≤ k → k < x1 → (k : ZMod n) ∉ B)
  (hx1_sub_1_in : (x1 - 1 : ZMod n) ∈ B) :
  x1 = 2 := by
    contrapose! h_min;
    use x1 - 1;
    exact ⟨ Nat.le_sub_one_of_lt ( lt_of_le_of_ne hx1_le ( Ne.symm h_min ) ), Nat.pred_lt ( ne_bot_of_gt hx1_le ), by rwa [ Nat.cast_pred ( by linarith ) ] ⟩
/-
Lemma 2.1 for the cyclic group Z/nZ.
-/
lemma lemma_2_1_cyclic_final (n : ℕ) (hn : n > 0) (B : Set (ZMod n)) (h1 : 1 ∈ B)
  (h_add : ∀ x ∈ B, ∀ y ∈ B, x = 1 ∧ y = 1 ∨ x + y ∈ B) :
  B = {1} ∨ B = {0, 1} ∨ B = Set.univ := by
  -- Let's consider the two cases: $n = 1$ or $n > 1$.
  by_cases hn_one : n = 1
  · subst hn_one
    left
    exact Set.eq_singleton_iff_unique_mem.mpr
      ⟨h1, fun x _hx => Subsingleton.elim x 1⟩
  · have hn_two : 2 ≤ n := by omega
    haveI : NeZero n := ⟨Nat.ne_of_gt hn⟩
    -- Let's consider the two cases: some element between 2 and n - 1 lies in B, or none does.
    by_cases hk : ∃ k : ℕ, 2 ≤ k ∧ k < n ∧ (k : ZMod n) ∈ B
    · let P : ℕ → Prop := fun k => 2 ≤ k ∧ k < n ∧ (k : ZMod n) ∈ B
      have hP : ∃ k, P k := hk
      let k := Nat.find hP
      have hk_spec : P k := Nat.find_spec hP
      have hk_min : ∀ j, j < k → ¬ P j := fun j hj => Nat.find_min hP hj
      have hk_eq_two : k = 2 := by
        apply lemma_2_1_cyclic_min n hn B h1 k hk_spec.1 hk_spec.2.1 hk_spec.2.2
        · intro j hj_two hj_lt hj_mem
          exact hk_min j hj_lt ⟨hj_two, by omega, hj_mem⟩
        · have h_ind : ∀ j, k ≤ j → j ≤ n → (j : ZMod n) ∈ B :=
            lemma_2_1_cyclic_interval n hn B h1 h_add k hk_spec.1 hk_spec.2.1.le hk_spec.2.2
          have hn_minus_one_mem : (n - 1 : ZMod n) ∈ B := by
            have hmem_nat : ((n - 1 : ℕ) : ZMod n) ∈ B :=
              h_ind (n - 1) (Nat.le_sub_one_of_lt hk_spec.2.1) (Nat.sub_le _ _)
            have h_eq : ((n - 1 : ℕ) : ZMod n) = (n - 1 : ZMod n) := by
              rw [Nat.cast_sub (by omega : 1 ≤ n)]
              norm_num
            simpa [h_eq] using hmem_nat
          exact lemma_2_1_cyclic_sub_one n hn B h1 h_add k hk_spec.1 hk_spec.2.1 hk_spec.2.2 hn_minus_one_mem
      right
      right
      apply Set.eq_univ_of_forall
      intro x
      let xval := x.val
      have hxval_lt : xval < n := ZMod.val_lt x
      have hx_cast : (xval : ZMod n) = x := by
        simp [xval]
      have hxval_le : xval ≤ n := Nat.le_of_lt hxval_lt
      by_cases hx0 : xval = 0
      · have h_ind' : ∀ j, k ≤ j → j ≤ n → (j : ZMod n) ∈ B :=
          lemma_2_1_cyclic_interval n hn B h1 h_add k hk_spec.1 hk_spec.2.1.le hk_spec.2.2
        have hn_mem : (n : ZMod n) ∈ B := h_ind' n (by omega) le_rfl
        have hzero_mem : (0 : ZMod n) ∈ B := by
          simpa [ZMod.natCast_self] using hn_mem
        have hx_eq_zero : x = 0 := by
          rw [← hx_cast, hx0]
          simp
        simpa [hx_eq_zero] using hzero_mem
      · have hxpos : 0 < xval := Nat.pos_of_ne_zero hx0
        by_cases hx_one : xval = 1
        · have hx_eq_one : x = 1 := by
            rw [← hx_cast, hx_one]
            simp
          simpa [hx_eq_one] using h1
        · have hx_two : 2 ≤ xval := by omega
          have h_ind : ∀ j, 2 ≤ j → j ≤ n → (j : ZMod n) ∈ B := by
            intro j hj_two hj_le
            have h_ind' : ∀ j, k ≤ j → j ≤ n → (j : ZMod n) ∈ B :=
              lemma_2_1_cyclic_interval n hn B h1 h_add k hk_spec.1 hk_spec.2.1.le hk_spec.2.2
            simpa [hk_eq_two] using h_ind' j (by simpa [hk_eq_two] using hj_two) hj_le
          have hx_mem := h_ind xval hx_two hxval_le
          simpa [hx_cast] using hx_mem
    · push Not at hk
      by_cases h0 : (0 : ZMod n) ∈ B
      · right
        left
        apply Set.eq_of_subset_of_subset
        · intro x hx
          let xval := x.val
          have hxval_lt : xval < n := ZMod.val_lt x
          have hx_cast : (xval : ZMod n) = x := by
            simp [xval]
          by_cases hx0 : xval = 0
          · left
            rw [← hx_cast, hx0]
            simp
          · have hxpos : 0 < xval := Nat.pos_of_ne_zero hx0
            by_cases hx1 : xval = 1
            · right
              rw [← hx_cast, hx1]
              simp
            · exfalso
              have hx2 : 2 ≤ xval := by omega
              exact hk xval hx2 hxval_lt (by simpa [hx_cast] using hx)
        · intro x hx
          rcases hx with hx | hx
          · simpa [hx] using h0
          · have hx_eq : x = 1 := by simpa using hx
            simpa [hx_eq] using h1
      · left
        apply Set.eq_singleton_iff_unique_mem.mpr
        constructor
        · exact h1
        · intro x hx
          let xval := x.val
          have hxval_lt : xval < n := ZMod.val_lt x
          have hx_cast : (xval : ZMod n) = x := by
            simp [xval]
          by_cases hx0 : xval = 0
          · exfalso
            have hx_eq_zero : x = 0 := by
              rw [← hx_cast, hx0]
              simp
            exact h0 (by simpa [hx_eq_zero] using hx)
          · have hxpos : 0 < xval := Nat.pos_of_ne_zero hx0
            by_cases hx1 : xval = 1
            · rw [← hx_cast, hx1]
              simp
            · exfalso
              have hx2 : 2 ≤ xval := by omega
              exact hk xval hx2 hxval_lt (by simpa [hx_cast] using hx)
/-
If E is a subset of [1, a] with size b > a/2, then a+1 is in the semigroup generated by E.
-/
lemma lemma_2_2_step1 (a b : ℕ) (_ha : a > 0) (_hb : b > 0) (E : Finset ℕ)
  (hE_subset : E ⊆ Finset.Icc 1 a) (hE_card : E.card = b) (hb_gt : b > a / 2) :
  a + 1 ∈ S (E : Set ℕ) := by
    -- By the pigeonhole principle, since E has more than half the elements of [1, a], there must be at least two elements in E whose sum is a + 1.
    obtain ⟨x, y, hx, hy, hxy⟩ : ∃ x y : ℕ, x ∈ E ∧ y ∈ E ∧ x + y = a + 1 := by
      by_contra h_contra;
      have h_pigeonhole : Finset.card (E ∪ Finset.image (fun x => a + 1 - x) E) ≤ a := by
        exact le_trans ( Finset.card_le_card ( show E ∪ Finset.image ( fun x => a + 1 - x ) E ⊆ Finset.Icc 1 a from Finset.union_subset hE_subset <| Finset.image_subset_iff.2 fun x hx => Finset.mem_Icc.2 ⟨ Nat.sub_pos_of_lt <| by linarith [ Finset.mem_Icc.1 <| hE_subset hx ], Nat.sub_le_of_le_add <| by linarith [ Finset.mem_Icc.1 <| hE_subset hx ] ⟩ ) ) <| by simp;
      rw [ Finset.card_union_of_disjoint ] at h_pigeonhole;
      · rw [ Finset.card_image_of_injOn fun x hx y hy hxy => by rw [ tsub_right_inj ] at hxy <;> linarith [ Finset.mem_Icc.1 <| hE_subset hx, Finset.mem_Icc.1 <| hE_subset hy ] ] at h_pigeonhole ; omega;
      · exact Finset.disjoint_left.mpr fun x hx hx' => h_contra <| by obtain ⟨ y, hy, hy' ⟩ := Finset.mem_image.mp hx'; exact ⟨ y, x, hy, hx, by linarith [ Nat.sub_add_cancel ( show y ≤ a + 1 from by linarith [ Finset.mem_Icc.1 <| hE_subset hy ] ) ] ⟩ ; ;
    exact hxy ▸ AddSubsemigroup.add_mem _ ( AddSubsemigroup.subset_closure hx ) ( AddSubsemigroup.subset_closure hy )
/-
If E is a subset of [1, a] with size b > a/2, then S(E) contains all integers >= a+1.
-/
lemma lemma_2_2_part1 (a b : ℕ) (ha : a > 0) (hb : b > 0) (E : Finset ℕ)
  (hE_subset : E ⊆ Finset.Icc 1 a) (hE_card : E.card = b) (hb_gt : b > a / 2) :
  ∀ n, a + 1 ≤ n → n ∈ S (E : Set ℕ) := by
    -- By induction on $k$ where $n = a + k$, we show that $a + k \in S(E)$ for all $k \geq 1$.
    have h_ind : ∀ k ≥ 1, a + k ∈ S (E : Set ℕ) := by
      intro k hk_ge_1
      induction' k using Nat.strong_induction_on with k ih;
      rcases k with ( _ | _ | k ) <;> simp_all +arith +decide;
      · exact lemma_2_2_step1 a b ha hb E hE_subset hE_card hb_gt;
      · -- Apply Lemma 2.2.1 to $E' = E \cup \{a+1, \dots, a+k+1\}$.
        have h_apply_lemma : a + k + 2 ∈ S (E ∪ Finset.Icc (a + 1) (a + k + 1) : Set ℕ) := by
          convert lemma_2_2_step1 ( a + k + 1 ) ( b + k + 1 ) ( by linarith ) ( by linarith ) ( E ∪ Finset.Icc ( a + 1 ) ( a + k + 1 ) ) _ _ _ using 1;
          · aesop;
          · exact Finset.union_subset ( hE_subset.trans ( Finset.Icc_subset_Icc_right ( by linarith ) ) ) ( Finset.Icc_subset_Icc ( by linarith ) ( by linarith ) );
          · rw [ Finset.card_union_of_disjoint ] <;> norm_num [ hE_card ];
            · omega;
            · exact Finset.disjoint_left.mpr fun x hx hx' => by linarith [ Finset.mem_Icc.mp ( hE_subset hx ), Finset.mem_Icc.mp hx' ] ; ;
          · omega;
        -- Since $S(E') = S(E)$, we have $a + k + 2 \in S(E)$.
        have h_S_eq : S (E ∪ Finset.Icc (a + 1) (a + k + 1) : Set ℕ) = S (E : Set ℕ) := by
          refine' le_antisymm _ _ <;> simp_all +decide [ S ];
          · intro x hx; specialize ih ( x - a ) ( by rw [ tsub_le_iff_left ] ; linarith [ Set.mem_Icc.mp hx ] ) ( Nat.sub_pos_of_lt ( by linarith [ Set.mem_Icc.mp hx ] ) ) ; simp_all +decide [ add_tsub_cancel_of_le ( by linarith [ Set.mem_Icc.mp hx ] : a ≤ x ) ] ;
          · exact fun x hx => AddSubsemigroup.subset_closure <| Set.mem_union_left _ hx;
        exact h_S_eq ▸ h_apply_lemma;
    exact fun n hn => by simpa using h_ind ( n - a ) ( Nat.sub_pos_of_lt hn ) |> fun h => by rwa [ add_tsub_cancel_of_le ( by linarith ) ] at h;
/-
If a-1 or a is not in S, then the number of elements of S in [1, a] is at most the number of elements of S in [1, a-2] plus 1.
-/
lemma lemma_2_2_card_ineq (S : Set ℕ) (a : ℕ) (ha : a ≥ 2) (h_not_in : a - 1 ∉ S ∨ a ∉ S) :
  (Finset.filter (fun x => x ∈ S) (Finset.Icc 1 a)).card ≤ (Finset.filter (fun x => x ∈ S) (Finset.Icc 1 (a - 2))).card + 1 := by
    -- Since $a-1 \notin S$ or $a \notin S$, we have $|S \cap [1, a]| = |S \cap [1, a-2]| + |S \cap \{a-1, a\}|$.
    have h_card_split : (Finset.filter (fun x => x ∈ S) (Finset.Icc 1 a)).card = (Finset.filter (fun x => x ∈ S) (Finset.Icc 1 (a - 2))).card + (Finset.filter (fun x => x ∈ S) ({a - 1, a})).card := by
      rw [ ← Finset.card_union_of_disjoint ];
      · congr with x ; rcases a with ( _ | _ | a ) <;> simp_all +arith +decide;
        grind +ring;
      · rcases a with ( _ | _ | a ) <;> simp_all +arith +decide [ Finset.disjoint_left ];
        grind;
    rcases a with ( _ | _ | a ) <;> simp_all +arith +decide [ Finset.filter_insert, Finset.filter_singleton ];
    grind
/-
If E' is a subset of the semigroup generated by E, then the semigroup generated by E' is a subset of the semigroup generated by E.
-/
lemma lemma_closure_subset (E : Set ℕ) (E' : Set ℕ) (h : E' ⊆ S E) :
  S E' ≤ S E := by
    exact AddSubsemigroup.closure_le.mpr h
/-
If a-1 or a is not in S(E), then there exists a subset E' of S(E) in [1, a-2] with size > (a-2)/2.
-/
lemma lemma_2_2_existence_E' (a b : ℕ) (ha : a ≥ 3) (_hb : b > 0) (E : Finset ℕ)
  (hE_subset : E ⊆ Finset.Icc 1 a) (hE_card : E.card = b) (hb_gt : b > a / 2)
  (h_not_in : a - 1 ∉ S (E : Set ℕ) ∨ a ∉ S (E : Set ℕ)) :
  ∃ E' : Finset ℕ, E' ⊆ Finset.Icc 1 (a - 2) ∧ E'.card > (a - 2) / 2 ∧ (E' : Set ℕ) ⊆ S (E : Set ℕ) := by
    -- By `lemma_2_2_card_ineq`, $|S \cap [1, a]| \le |S \cap [1, a-2]| + 1$.
    have lemma_2_2_card_ineq_applied : (Finset.filter (fun x => x ∈ S E) (Finset.Icc 1 a)).card ≤ (Finset.filter (fun x => x ∈ S E) (Finset.Icc 1 (a - 2))).card + 1 := by
      convert lemma_2_2_card_ineq ( S ( E : Set ℕ ) ) a ( by linarith ) h_not_in using 1;
    -- Since $E \subseteq S \cap [1, a]$, we have $|S \cap [1, a]| \ge b$.
    have lemma_2_2_card_ge_b : (Finset.filter (fun x => x ∈ S E) (Finset.Icc 1 a)).card ≥ b := by
      exact hE_card ▸ Finset.card_le_card fun x hx => Finset.mem_filter.mpr ⟨ hE_subset hx, AddSubsemigroup.subset_closure <| Finset.mem_coe.mpr hx ⟩;
    refine' ⟨ Finset.filter ( fun x => x ∈ S E ) ( Finset.Icc 1 ( a - 2 ) ), _, _, _ ⟩ <;> norm_num;
    · omega;
    · exact fun x hx => hx.2
/-
Inductive step for Lemma 2.2: If the lemma holds for a-2, then it holds for a (assuming a >= 3).
-/
lemma lemma_2_2_inductive_step (a b : ℕ) (ha : a ≥ 3) (hb : b > 0) (E : Finset ℕ)
  (hE_subset : E ⊆ Finset.Icc 1 a) (hE_card : E.card = b) (hb_gt : b > a / 2)
  (IH : ∀ (b' : ℕ) (E' : Finset ℕ), E' ⊆ Finset.Icc 1 (a - 2) → E'.card = b' → b' > (a - 2) / 2 →
    ∀ n, (a - 2) - 1 ≤ n → n > 0 → n ∈ S (E' : Set ℕ)) :
  ∀ n, a - 1 ≤ n → n > 0 → n ∈ S (E : Set ℕ) := by
    have h_part1 : ∀ n, a + 1 ≤ n → n ∈ S (E : Set ℕ) := by
      apply lemma_2_2_part1 a b (by linarith) hb E hE_subset hE_card hb_gt
    have h_a_minus_1_and_a : a - 1 ∈ S (E : Set ℕ) ∧ a ∈ S (E : Set ℕ) := by
      by_contra h_contra
      push Not at h_contra
      have h_not_in : a - 1 ∉ S (E : Set ℕ) ∨ a ∉ S (E : Set ℕ) := by
        by_cases h : a - 1 ∈ S (E : Set ℕ)
        . right; exact h_contra h
        . left; exact h
      obtain ⟨E', hE'_subset, hE'_card, hE'_sub_S⟩ :=
        lemma_2_2_existence_E' a b ha hb E hE_subset hE_card hb_gt h_not_in
      have h_S_E'_sub : S (E' : Set ℕ) ≤ S (E : Set ℕ) :=
        lemma_closure_subset (E : Set ℕ) (E' : Set ℕ) hE'_sub_S
      have h_IH_app : ∀ n, a - 3 ≤ n → n > 0 → n ∈ S (E' : Set ℕ) :=
        IH E'.card E' hE'_subset rfl hE'_card
      have h_a_minus_1_in : a - 1 ∈ S (E : Set ℕ) := by
        apply h_S_E'_sub
        apply h_IH_app
        . omega
        . omega
      have h_a_in : a ∈ S (E : Set ℕ) := by
        apply h_S_E'_sub
        apply h_IH_app
        . omega
        . omega
      cases h_not_in with
      | inl h => contradiction
      | inr h => contradiction
    intro n hn hn_pos
    rcases h_a_minus_1_and_a with ⟨ha_minus_1, ha⟩
    by_cases h_eq : n = a - 1
    . rw [h_eq]; exact ha_minus_1
    by_cases h_eq2 : n = a
    . rw [h_eq2]; exact ha
    have : n ≥ a + 1 := by omega
    exact h_part1 n this
/-
Under the inductive hypothesis of Lemma 2.2, a-1 and a are in S(E).
-/
lemma lemma_2_2_base_elements (a b : ℕ) (ha : a ≥ 3) (hb : b > 0) (E : Finset ℕ)
  (hE_subset : E ⊆ Finset.Icc 1 a) (hE_card : E.card = b) (hb_gt : b > a / 2)
  (IH : ∀ (b' : ℕ) (E' : Finset ℕ), E' ⊆ Finset.Icc 1 (a - 2) → E'.card = b' → b' > (a - 2) / 2 →
    ∀ n, (a - 2) - 1 ≤ n → n > 0 → n ∈ S (E' : Set ℕ)) :
  a - 1 ∈ S (E : Set ℕ) ∧ a ∈ S (E : Set ℕ) := by
    -- By the inductive hypothesis, $a-1 \in S(E)$ and $a \in S(E)$.
    have h_inductive_step : ∀ n, a - 1 ≤ n → n > 0 → n ∈ S (E : Set ℕ) := by
      apply lemma_2_2_inductive_step a b ha hb E hE_subset hE_card hb_gt IH;
    exact ⟨ h_inductive_step _ le_rfl ( Nat.sub_pos_of_lt ( by linarith ) ), h_inductive_step _ ( Nat.sub_le _ _ ) ( by linarith ) ⟩
/-
Inductive step for Lemma 2.2: If the lemma holds for a-2, then it holds for a (assuming a >= 3).
-/
lemma lemma_2_2_inductive_step_v2 (a b : ℕ) (ha : a ≥ 3) (hb : b > 0) (E : Finset ℕ)
  (hE_subset : E ⊆ Finset.Icc 1 a) (hE_card : E.card = b) (hb_gt : b > a / 2)
  (IH : ∀ (b' : ℕ) (E' : Finset ℕ), E' ⊆ Finset.Icc 1 (a - 2) → E'.card = b' → b' > (a - 2) / 2 →
    ∀ n, (a - 2) - 1 ≤ n → n > 0 → n ∈ S (E' : Set ℕ)) :
  ∀ n, a - 1 ≤ n → n > 0 → n ∈ S (E : Set ℕ) := by
    have h_part1 : ∀ n, a + 1 ≤ n → n ∈ S (E : Set ℕ) := by
      apply lemma_2_2_part1 a b (by linarith) hb E hE_subset hE_card hb_gt
    have h_base : a - 1 ∈ S (E : Set ℕ) ∧ a ∈ S (E : Set ℕ) := by
      apply lemma_2_2_base_elements a b ha hb E hE_subset hE_card hb_gt IH
    intro n hn hn_pos
    rcases h_base with ⟨ha_minus_1, ha⟩
    by_cases h_eq : n = a - 1
    . rw [h_eq]; exact ha_minus_1
    by_cases h_eq2 : n = a
    . rw [h_eq2]; exact ha
    have : n ≥ a + 1 := by omega
    exact h_part1 n this
/-
Lemma 2.2: Let a, b be integers > 0, E a subset of [1, a] with b elements. If b > a/2, then S(E) contains all integers n >= a-1 such that n > 0.
-/
lemma lemma_2_2_final (a b : ℕ) (ha : a > 0) (hb : b > 0) (E : Finset ℕ)
  (hE_subset : E ⊆ Finset.Icc 1 a) (hE_card : E.card = b) (hb_gt : b > a / 2) :
  ∀ n, a - 1 ≤ n → n > 0 → n ∈ S (E : Set ℕ) := by
    induction' a using Nat.strongRecOn with a ih generalizing b E;
    -- Consider two cases: $a \leq 2$ and $a \geq 3$.
    by_cases ha_le_2 : a ≤ 2;
    · interval_cases a <;> simp_all +decide;
      · rcases hE_subset with ( rfl | rfl ) <;> simp_all +decide [ S ];
        intro n hn; induction hn <;> aesop;
      · -- Since $E$ is a subset of $\{1, 2\}$ with cardinality greater than $1$, it must be $\{1, 2\}$ itself.
        have hE_eq : E = {1, 2} := by
          exact Finset.eq_of_subset_of_card_le hE_subset ( by norm_num; linarith )
        simp_all +decide [ S ];
        intro n hn hn'; induction hn <;> simp_all +decide [ AddSubsemigroup.mem_closure ] ;
        · exact fun S hS => hS ( Set.mem_insert _ _ );
        · intro S hS; specialize ‹0 < _ → ∀ S : AddSubsemigroup ℕ, { 1, b } ⊆ ( S : Set ℕ ) → _ ∈ S› ‹_› S hS; exact AddSubsemigroup.add_mem _ ‹_› ( hS ( by norm_num ) ) ;
    · exact lemma_2_2_inductive_step_v2 a b ( by linarith ) hb E hE_subset hE_card hb_gt ( fun b' E' hE'_subset hE'_card hb'_gt n hn hn' => ih ( a - 2 ) ( Nat.sub_lt ha zero_lt_two ) b' ( Nat.le_sub_of_add_le ( by omega ) ) ( by omega ) E' hE'_subset hE'_card hb'_gt n hn hn' )
/-
Lemma 2.3: The sum of the images of S_k and S_k' in Z/aZ is contained in the image of S_{k+k'}.
Gemini messed with the signature, and then made strides towards proof which was ultimately finished by
Project Numina
-/
lemma lemma_2_3 (a : ℕ) (E : Set ℕ) (ha_in_E : a ∈ E)
  (k k' : ℕ) (hk : k ≥ 1) (hk' : k' ≥ 1) :
  let S_set := S E
  let S_bar (m : ℕ) := (fun (n : ℕ) => (n : ZMod a)) '' (S_k a S_set m)
  (S_bar k : Set (ZMod a)) + S_bar k' ⊆ S_bar (k + k') := by
    intros S_set S_bar z hz
    obtain ⟨f, hf, s, hs, rfl⟩ := Set.mem_add.1 hz
    obtain ⟨nf, hnf, rfl⟩ := (Set.mem_image _ _ _).1 hf
    obtain ⟨ns, hns, rfl⟩ := (Set.mem_image _ _ _).1 hs
    simp only [S_k, Set.mem_inter_iff, Set.mem_Icc] at hnf hns
    let n_sum := nf + ns
    have h_sum_S : n_sum ∈ S E := AddSubsemigroup.add_mem _ hnf.1 hns.1
    by_cases h_range : n_sum > (k + k' - 1) * a
    · use n_sum
      constructor
      · constructor
        · exact h_sum_S
        · dsimp [n_sum] at *; constructor <;> linarith [hnf.2.2, hns.2.2]
      · dsimp [n_sum]; push_cast; rfl
    · let n_next := n_sum + a
      use n_next
      constructor
      · constructor
        · exact AddSubsemigroup.add_mem _ h_sum_S (AddSubsemigroup.subset_closure ha_in_E)
        · dsimp [n_next, n_sum] at *
          constructor
          · have h1 := hnf.2.1  -- (k - 1) * a + 1 ≤ nf
            have h2 := hns.2.1  -- (k' - 1) * a + 1 ≤ ns
            have hk_pos : 1 ≤ k := hk
            have hk'_pos : 1 ≤ k' := hk'
            -- Use the fact that k ≥ 1 and k' ≥ 1 to work with k = (k - 1) + 1 etc.
            have key_ineq : (k - 1) * a + 1 + ((k' - 1) * a + 1) ≤ nf + ns := by omega
            -- Simplify LHS of key_ineq
            have lhs_simp : (k - 1) * a + 1 + ((k' - 1) * a + 1) = (k - 1) * a + (k' - 1) * a + 2 := by ring
            rw [lhs_simp] at key_ineq
            -- Now we want to show (k + k' - 1) * a + 1 ≤ nf + ns + a
            -- Note: k + k' = (k - 1) + 1 + (k' - 1) + 1 = (k - 1) + (k' - 1) + 2
            -- So k + k' - 1 = (k - 1) + (k' - 1) + 1
            have eq1 : k + k' = (k - 1) + 1 + (k' - 1) + 1 := by omega
            have eq2 : k + k' - 1 = (k - 1) + (k' - 1) + 1 := by omega
            have expand : (k + k' - 1) * a = ((k - 1) + (k' - 1) + 1) * a := by
              rw [eq2]
            have expand2 : ((k - 1) + (k' - 1) + 1) * a = (k - 1) * a + (k' - 1) * a + a := by ring
            rw [expand, expand2]
            -- So we need (k - 1) * a + (k' - 1) * a + a + 1 ≤ nf + ns + a
            -- From key_ineq: (k - 1) * a + (k' - 1) * a + 2 ≤ nf + ns
            omega
          · have h_not_too_big : nf + ns ≤ (k + k' - 1) * a := by omega
            have hk_pos : 1 ≤ k := hk
            have hk'_pos : 1 ≤ k' := hk'
            -- Show (k + k') * a = (k + k' - 1) * a + a
            have key : (k + k') * a = (k + k' - 1) * a + a := by
              have eq1 : k + k' = (k + k' - 1) + 1 := by omega
              have step1 : (k + k') * a = ((k + k' - 1) + 1) * a := by
                congr 1
              rw [step1]
              ring
            rw [key]
            omega
      · dsimp [n_next, n_sum]; push_cast; simp
/-
Lemma 2.3: If S is a subsemigroup of N, and c+1 is in S, then the number of elements of S in [r, r+c] is at most the number of elements of S in [s, s+d] provided r <= s and c <= d.
-/
lemma lemma_card_ineq (S : AddSubsemigroup ℕ) (r c s d : ℕ)
  (_hr : r > 0) (hs : s > 0) (hrs : r ≤ s) (hcd : c ≤ d) (hc : c + 1 ∈ S) :
  ((Finset.Icc r (r + c)).filter (fun x => x ∈ S)).card ≤
  ((Finset.Icc s (s + d)).filter (fun x => x ∈ S)).card := by
    -- Applying the translation $\tau$ repeatedly, we can shift the interval $[r, r+c]$ to the right until it is contained in or to the right of $[s, s+d]$.
    have h_shift : ∀ k : ℕ, Finset.card (Finset.filter (fun x => x ∈ S) (Finset.Icc r (r + c))) ≤ Finset.card (Finset.filter (fun x => x ∈ S) (Finset.Icc (r + k * (c + 1)) (r + k * (c + 1) + c))) := by
      intro k
      induction' k with k ih;
      · norm_num;
      · refine le_trans ih ?_;
        have h_image : Finset.image (fun x => x + (c + 1)) (Finset.filter (fun x => x ∈ S) (Finset.Icc (r + k * (c + 1)) (r + k * (c + 1) + c))) ⊆ Finset.filter (fun x => x ∈ S) (Finset.Icc (r + (k + 1) * (c + 1)) (r + (k + 1) * (c + 1) + c)) := by
          simp +decide [ Finset.subset_iff ];
          rintro x y hy₁ hy₂ hy₃ rfl; exact ⟨ ⟨ by linarith, by linarith ⟩, S.add_mem hy₃ hc ⟩ ;
        exact le_trans ( by rw [ Finset.card_image_of_injective _ ( add_left_injective _ ) ] ) ( Finset.card_mono h_image );
    -- Let $k$ be such that $r' = r + k(c+1)$ satisfies $r' \le s < r' + c + 1$.
    obtain ⟨k, hk⟩ : ∃ k : ℕ, r + k * (c + 1) ≤ s ∧ s < r + k * (c + 1) + c + 1 := by
      exact ⟨ ( s - r ) / ( c + 1 ), by linarith [ Nat.div_mul_le_self ( s - r ) ( c + 1 ), Nat.sub_add_cancel hrs ], by linarith [ Nat.div_add_mod ( s - r ) ( c + 1 ), Nat.mod_lt ( s - r ) ( Nat.succ_pos c ), Nat.sub_add_cancel hrs ] ⟩;
    refine le_trans ( h_shift k ) ?_;
    have h_card_image : Finset.card (Finset.filter (fun x => x ∈ S) (Finset.Icc (r + k * (c + 1)) (r + k * (c + 1) + c))) ≤ Finset.card (Finset.filter (fun x => x ∈ S) (Finset.Icc s (r + k * (c + 1) + c))) + Finset.card (Finset.filter (fun x => x ∈ S) (Finset.Icc (r + k * (c + 1)) (s - 1))) := by
      have h_card_image : Finset.filter (fun x => x ∈ S) (Finset.Icc (r + k * (c + 1)) (r + k * (c + 1) + c)) ⊆ Finset.filter (fun x => x ∈ S) (Finset.Icc s (r + k * (c + 1) + c)) ∪ Finset.filter (fun x => x ∈ S) (Finset.Icc (r + k * (c + 1)) (s - 1)) := by
        simp +contextual [ Finset.subset_iff ];
        exact fun x hx₁ hx₂ hx₃ => Classical.or_iff_not_imp_left.2 fun hx₄ => Nat.le_sub_one_of_lt <| lt_of_not_ge hx₄;
      exact le_trans ( Finset.card_le_card h_card_image ) ( Finset.card_union_le _ _ );
    have h_card_image : Finset.card (Finset.filter (fun x => x ∈ S) (Finset.Icc (r + k * (c + 1)) (s - 1))) ≤ Finset.card (Finset.filter (fun x => x ∈ S) (Finset.Icc (r + k * (c + 1) + c + 1) (s + c))) := by
      have h_card_image : Finset.image (fun x => x + (c + 1)) (Finset.filter (fun x => x ∈ S) (Finset.Icc (r + k * (c + 1)) (s - 1))) ⊆ Finset.filter (fun x => x ∈ S) (Finset.Icc (r + k * (c + 1) + c + 1) (s + c)) := by
        simp_all +decide [ Finset.subset_iff ];
        rintro x y hy₁ hy₂ hy₃ rfl; exact ⟨ ⟨ by linarith, by linarith [ Nat.sub_add_cancel hs ] ⟩, by exact S.add_mem hy₃ hc ⟩ ;
      exact le_trans ( by rw [ Finset.card_image_of_injective _ ( add_left_injective _ ) ] ) ( Finset.card_mono h_card_image );
    refine le_trans ‹_› ?_;
    refine le_trans ( add_le_add_right h_card_image _ ) ?_;
    rw [ ← Finset.card_union_of_disjoint ];
    · refine Finset.card_mono ?_;
      simp +decide [ Finset.subset_iff ];
      rintro x ( hx | hx ) <;> exact ⟨ ⟨ by linarith, by linarith ⟩, hx.2 ⟩;
    · exact Finset.disjoint_left.mpr fun x hx₁ hx₂ => by linarith [ Finset.mem_Icc.mp ( Finset.mem_filter.mp hx₁ |>.1 ), Finset.mem_Icc.mp ( Finset.mem_filter.mp hx₂ |>.1 ) ] ;
/-
The cyclic subgroup generated by an element $x$ of positive order is isomorphic to ZMod of its order.
-/
lemma closure_equiv_zmod {G : Type*} [AddCommGroup G] (x : G) (_h : addOrderOf x > 0) :
  Nonempty (AddSubgroup.closure {x} ≃+ ZMod (addOrderOf x)) := by
    refine' ⟨ _ ⟩;
    have h_iso : AddSubgroup.closure {x} ≃+ ZMod (Nat.card (AddSubgroup.closure {x})) := by
      have h_iso : AddSubgroup.closure {x} ≃+ ZMod (Nat.card (AddSubgroup.closure {x})) := by
        have h_cyclic : IsAddCyclic (AddSubgroup.closure {x}) := by
          refine' ⟨ ⟨ x, AddSubgroup.subset_closure rfl ⟩, _ ⟩;
          intro y;
          obtain ⟨ k, hk ⟩ := AddSubgroup.mem_closure_singleton.mp y.2;
          exact ⟨ k, Subtype.ext hk ⟩
        exact (zmodAddCyclicAddEquiv h_cyclic).symm;
      exact h_iso;
    convert h_iso;
    · have h_card : Nat.card (AddSubgroup.zmultiples x) = addOrderOf x := by
        rw [ Nat.card_zmultiples ];
      rw [ ← h_card, AddSubgroup.zmultiples_eq_closure ];
    · rw [ show AddSubgroup.closure { x } = AddSubgroup.zmultiples x from ?_, Nat.card_zmultiples ];
      simp +decide [ AddSubgroup.zmultiples_eq_closure ]
/-
There exists an isomorphism from the cyclic subgroup generated by x to ZMod(order of x) that maps x to 1.
-/
lemma cyclic_iso_generator {G : Type*} [AddCommGroup G] (x : G) (h : addOrderOf x > 0) :
  ∃ f : AddSubgroup.closure {x} ≃+ ZMod (addOrderOf x), f ⟨x, AddSubgroup.subset_closure (Set.mem_singleton x)⟩ = 1 := by
    obtain ⟨ f, hf ⟩ := @closure_equiv_zmod G _ x h;
    -- Let's denote the isomorphism from the cyclic subgroup generated by x to ZMod(addOrderOf x) by f.
    obtain ⟨f, hf⟩ : ∃ f : AddSubgroup.closure {x} ≃+ ZMod (addOrderOf x), f ⟨x, AddSubgroup.mem_closure_singleton_self x⟩ = 1 := by
      have h_iso : Nonempty (AddSubgroup.closure {x} ≃+ ZMod (addOrderOf x)) := by
        exact ⟨ { Equiv.ofBijective f ⟨ f.injective, f.surjective ⟩ with map_add' := hf } ⟩
      obtain ⟨ g ⟩ := h_iso;
      -- Since $g$ is an isomorphism, $g(x)$ is a generator of $ZMod (addOrderOf x)$.
      have hg_gen : ∀ y : ZMod (addOrderOf x), ∃ k : ℕ, y = k • g ⟨x, AddSubgroup.mem_closure_singleton_self x⟩ := by
        intro y
        obtain ⟨k, hk⟩ : ∃ k : ℕ, g.symm y = k • ⟨x, AddSubgroup.mem_closure_singleton_self x⟩ := by
          have hg_gen : ∀ y : AddSubgroup.closure {x}, ∃ k : ℕ, y = k • ⟨x, AddSubgroup.mem_closure_singleton_self x⟩ := by
            simp +decide [ AddSubgroup.mem_closure_singleton ];
            intro a
            use Int.toNat (a % addOrderOf x);
            rw [ ← Int.emod_add_mul_ediv a ( addOrderOf x ) ] ; simp +decide [ add_smul, mul_smul ] ;
            rw [ ← Int.toNat_of_nonneg ( Int.emod_nonneg _ ( by positivity ) ) ] ; norm_cast;
          exact hg_gen _;
        use k;
        convert congr_arg g hk using 1;
        · rw [ g.apply_symm_apply ];
        · exact Eq.symm (map_nsmul g k ⟨x, AddSubgroup.mem_closure_singleton_self x⟩);
      obtain ⟨ k, hk ⟩ := hg_gen 1;
      refine' ⟨ g.trans ( AddEquiv.ofBijective ( AddMonoidHom.mulLeft ( k : ZMod ( addOrderOf x ) ) ) ⟨ _, _ ⟩ ), _ ⟩ <;> simp_all +decide [ AddMonoidHom.mulLeft ];
      · intro a b hab;
        grind;
      · exact fun y => ⟨ y * g ⟨ x, AddSubgroup.mem_closure_singleton_self x ⟩, by linear_combination' y * hk.symm ⟩;
    exact ⟨ f, hf ⟩
lemma lemma_2_1_subgroup_case {G : Type*} [AddCommGroup G] [Finite G] (B : Set G) (b₀ : G)
  (h : IsAlmostSubgroup B b₀) (h_subset : B ⊆ AddSubgroup.closure {b₀}) :
  B = {b₀} ∨ B = {0, b₀} ∨ B = AddSubgroup.closure {b₀} := by
    -- Let $B' = \{x \in \langle b_0 \rangle \mid x \in B\}$. $B'$ is an almost subgroup of $\langle b_0 \rangle$.
    set B' : Set (AddSubgroup.closure {b₀}) := {x : AddSubgroup.closure {b₀} | x.val ∈ B} with hB'
    have hB'_almost_subgroup : IsAlmostSubgroup B' ⟨b₀, AddSubgroup.subset_closure (Set.mem_singleton b₀)⟩ := by
      unfold IsAlmostSubgroup at *; aesop;
    obtain ⟨f, hf⟩ : ∃ f : AddSubgroup.closure {b₀} ≃+ (ZMod (addOrderOf b₀)), f ⟨b₀, AddSubgroup.subset_closure (Set.mem_singleton b₀)⟩ = 1 := by
      convert cyclic_iso_generator b₀ _;
      exact addOrderOf_pos b₀;
    -- By `lemma_2_1_cyclic_final`, $B'' = \{1\}$ or $B'' = \{0, 1\}$ or $B'' = \mathbb{Z}/n\mathbb{Z}$.
    have hB''_cases : f '' B' = {1} ∨ f '' B' = {0, 1} ∨ f '' B' = Set.univ := by
      apply lemma_2_1_cyclic_final;
      · exact addOrderOf_pos b₀;
      · exact ⟨ _, hB'_almost_subgroup.1, hf ⟩;
      · rintro _ ⟨ x, hx, rfl ⟩ _ ⟨ y, hy, rfl ⟩;
        cases' hB'_almost_subgroup.2 x hx y hy with hxy hxy <;> simp_all +decide [ ← map_add ];
    -- Since $f$ is an isomorphism, this implies $B' = \{b_0\}$ or $B' = \{0, b_0\}$ or $B' = \langle b_0 \rangle$.
    have hB'_cases : B' = {⟨b₀, AddSubgroup.subset_closure (Set.mem_singleton b₀)⟩} ∨ B' = {⟨0, AddSubgroup.zero_mem _⟩, ⟨b₀, AddSubgroup.subset_closure (Set.mem_singleton b₀)⟩} ∨ B' = Set.univ := by
      have hB'_cases : B' = f.symm '' (f '' B') := by
        ext a
        constructor
        · intro ha
          exact ⟨f a, ⟨a, ha, rfl⟩, by simp⟩
        · rintro ⟨x, ⟨a, ha, rfl⟩, hx'⟩
          simpa [← hx'] using ha
      rcases hB''_cases with h | h | h <;> rw [ hB'_cases, h ] <;> simp +decide [ Set.ext_iff ];
      · exact Or.inl ( by rw [ ← hf, f.symm_apply_apply ] );
      · refine' Or.inr ( Or.inl _ );
        intro a ha; rw [ ← hf ] ; simp +decide [ Subtype.ext_iff ] ;
        tauto;
    simp_all +decide [ Set.ext_iff ];
    exact Or.imp ( fun h x => ⟨ fun hx => h x ( h_subset hx ) |>.1 hx, fun hx => h x ( by aesop ) |>.2 hx ⟩ ) ( Or.imp ( fun h x => ⟨ fun hx => h x ( h_subset hx ) |>.1 hx, fun hx => h x ( by aesop ) |>.2 hx ⟩ ) ( fun h x => ⟨ fun hx => h_subset hx, fun hx => h x hx ⟩ ) ) hB'_cases
/-
If B is an almost subgroup of G with special element b0, and B is not contained in the subgroup generated by b0, then B is a subgroup of G.
-/
lemma lemma_2_1_not_subset_case {G : Type*} [AddCommGroup G] [Finite G] (B : Set G) (b₀ : G)
  (h : IsAlmostSubgroup B b₀) (h_not_subset : ¬ (B ⊆ AddSubgroup.closure {b₀})) :
  ∃ S : AddSubgroup G, B = S := by
    have := @lemma_2_1_case_1 G _ _ B b₀ h;
    exact Exists.elim ( Set.not_subset.mp h_not_subset ) fun x hx => Exists.elim ( this x hx.1 hx.2 ) fun S hS => ⟨ S, hS.symm ⟩
/-
Lemma 2.1: Let A be a finite commutative group, B a subset of A, and b0 an element of B, with the following property: if b, b' in B, then b+b' in B, except possibly if b=b'=b0. Then B={b0}, or B={0, b0}, or B is a subgroup of A.
-/
lemma lemma_2_1_general {G : Type*} [AddCommGroup G] [Finite G] (B : Set G) (b₀ : G)
  (h_b0 : b₀ ∈ B)
  (h_add : ∀ b ∈ B, ∀ b' ∈ B, (b = b₀ ∧ b' = b₀) ∨ b + b' ∈ B) :
  B = {b₀} ∨ B = {0, b₀} ∨ ∃ S : AddSubgroup G, B = S := by
    by_cases h_subset : B ⊆ AddSubgroup.closure {b₀};
    · have := lemma_2_1_subgroup_case B b₀ ⟨ h_b0, h_add ⟩ h_subset; aesop;
    · have := lemma_2_1_not_subset_case B b₀ ⟨ h_b0, h_add ⟩ h_subset;
      exact Or.inr <| Or.inr this
/-
If E is a subset of E' and E' is periodic with period p, and the cardinality gap is small,
then for any representative x in E', there is a hitting time u such that x + up is in E.
Lemma suggested by Gemini 3.0 Flash (proof more or less copied verbatim from Aristotle's
original proof in `lemma_2_2_disjoint_sum`)
-/
lemma obtain_min_hitting_time (p q : ℕ) (hp : p > 0) (E E' : Finset ℕ) (hE_sub : E ⊆ E')
  (hE_card : E'.card ≤ E.card + q - 2)
  (h_periodic : ∀ x, x ∈ E' ↔ (x ∈ Finset.Icc 1 (p * q) ∧ ∃ y ∈ E', x ≡ y [MOD p]))
  (x : ℕ) (hx : x ∈ E' ∩ Finset.Icc 1 p) :
  ∃ u, x + u * p ∈ E ∧ ∀ v < u, x + v * p ∉ E := by
  have h_exists_u : ∃ u, x + u * p ∈ E := by
    contrapose! hE_card
    have h_card_eq : Finset.card (Finset.image (fun k => x + k * p) (Finset.range q)) ≤ Finset.card (E' \ E) := by
      refine Finset.card_le_card ?_;
      simp +contextual [ Finset.subset_iff, hE_card ];
      intro a ha; specialize h_periodic ( x + a * p ) ; simp +decide [ Nat.ModEq ] at *;
      exact h_periodic.mpr ⟨ ⟨ by nlinarith, by nlinarith ⟩, x, hx.1, rfl ⟩;
    rw [ Finset.card_image_of_injective _ fun a b h => by nlinarith ] at h_card_eq ; norm_num at *;
    grind
  use Nat.find h_exists_u
  exact ⟨Nat.find_spec h_exists_u, fun v hv => Nat.find_min h_exists_u hv⟩
/-
If x and y are distinct representatives in E' (mod p), then their sum (mod p) is in E (mod p).
Edited by Gemini 3.0 Flash to use obtain_min_hitting_time
-/
lemma lemma_2_2_disjoint_sum (p q : ℕ) (hp : p > 1) (hq : q > 1)
  (E E' : Finset ℕ) (h_subset : E ⊆ E')
  (h_card : E'.card ≤ E.card + q - 2)
  (h_add : ∀ x ∈ E, ∀ y ∈ E, x + y ≤ p * q → x + y ∈ E)
  (h_periodic : ∀ x, x ∈ E' ↔ (x ∈ Finset.Icc 1 (p * q) ∧ ∃ y ∈ E', x ≡ y [MOD p]))
  (x y : ℕ) (hx : x ∈ E' ∩ Finset.Icc 1 p) (hy : y ∈ E' ∩ Finset.Icc 1 p)
  (h_neq : x ≠ y) :
  ∃ z ∈ E, z ≡ x + y [MOD p] := by
    -- Let $u$ be the smallest $k$ such that $x + kp \in E$.
    obtain ⟨u, hu⟩ := obtain_min_hitting_time p q (by omega) E E' h_subset h_card h_periodic x hx
    -- Let $v$ be the smallest $k$ such that $y + kp \in E$.
    obtain ⟨v, hv⟩ := obtain_min_hitting_time p q (by omega) E E' h_subset h_card h_periodic y hy
    -- The elements $x, x+p, \dots, x+(u-1)p$ are in $E' \setminus E$.
    have h_elements_x : Finset.image (fun k => x + k * p) (Finset.range u) ⊆ E' \ E := by
      simp +contextual [ Finset.subset_iff, hu.2 ];
      intro a ha;
      rw [ h_periodic ];
      refine' ⟨ Finset.mem_Icc.mpr ⟨ _, _ ⟩, x, _, _ ⟩ <;> norm_num [ Nat.ModEq ];
      · nlinarith [ Finset.mem_Icc.mp ( Finset.mem_inter.mp hx |>.2 ) ];
      · have := h_periodic ( x + u * p ) ; norm_num [ Nat.ModEq ] at *;
        exact le_trans ( by nlinarith only [ ha, hp, hx.2.2 ] ) ( this.mp ( h_subset hu.1 ) |>.1 |>.2 );
      · exact Finset.mem_of_mem_inter_left hx
    -- The elements $y, y+p, \dots, y+(v-1)p$ are in $E' \setminus E$.
    have h_elements_y : Finset.image (fun k => y + k * p) (Finset.range v) ⊆ E' \ E := by
      simp +contextual [ Finset.subset_iff, hv.2 ];
      intro a ha;
      rw [ h_periodic ];
      refine' ⟨ Finset.mem_Icc.mpr ⟨ _, _ ⟩, y, _, _ ⟩ <;> norm_num [ Nat.ModEq ];
      · nlinarith [ Finset.mem_Icc.mp ( Finset.mem_inter.mp hy |>.2 ) ];
      · have := h_periodic ( y + v * p ) ; simp +decide [ Nat.ModEq ] at this;
        nlinarith [ this.mp ( h_subset hv.1 ), Finset.mem_Icc.mp ( Finset.mem_inter.mp hy |>.2 ) ];
      · exact Finset.mem_of_mem_inter_left hy
    -- Since $x \neq y$ and $x, y \in [1, p]$, these two sets of elements are disjoint.
    have h_disjoint : Disjoint (Finset.image (fun k => x + k * p) (Finset.range u)) (Finset.image (fun k => y + k * p) (Finset.range v)) := by
      norm_num [ Finset.disjoint_left ] at *;
      intro a ha b hb H; exact h_neq <| by nlinarith [ show a = b by nlinarith ] ;
    -- Thus, the total number of elements in $E' \setminus E$ is at least $u+v$.
    have h_card_diff : (E' \ E).card ≥ u + v := by
      have h_card_diff : (Finset.image (fun k => x + k * p) (Finset.range u) ∪ Finset.image (fun k => y + k * p) (Finset.range v)).card ≥ u + v := by
        rw [ Finset.card_union_of_disjoint h_disjoint, Finset.card_image_of_injective, Finset.card_image_of_injective ] <;> norm_num [ Function.Injective, hp.ne' ];
        · exact fun a b h => h.resolve_right hp.ne_bot;
        · exact fun a b h => h.resolve_right hp.ne_bot;
      exact h_card_diff.trans ( Finset.card_mono <| Finset.union_subset h_elements_x h_elements_y )
    -- So $u+v \le |E' \setminus E| \le q-2$.
    have h_uv_le_q_minus_2 : u + v ≤ q - 2 := by
      grind
    -- Then $(x+up) + (y+vp) = x+y + (u+v)p \le 2p + (q-2)p = qp$.
    have h_sum_le_qp : (x + u * p) + (y + v * p) ≤ p * q := by
      nlinarith only [ h_uv_le_q_minus_2, Nat.sub_add_cancel ( by linarith : 2 ≤ q ), Finset.mem_Icc.mp ( Finset.mem_inter.mp hx |>.2 ), Finset.mem_Icc.mp ( Finset.mem_inter.mp hy |>.2 ) ]
    -- Since $x+up \in E$ and $y+vp \in E$, their sum is in $E$.
    have h_sum_in_E : (x + u * p) + (y + v * p) ∈ E := by
      exact h_add _ hu.1 _ hv.1 h_sum_le_qp
    -- The sum is congruent to $x+y \pmod p$.
    have h_sum_mod_p : ((x + u * p) + (y + v * p)) ≡ x + y [MOD p] := by
      norm_num [ ← ZMod.natCast_eq_natCast_iff ]
    -- Therefore, there exists $z \in E$ such that $z \equiv x + y \pmod p$.
    use ((x + u * p) + (y + v * p))
/-
For a set S in a commutative group, S + Stab(S) = S.
-/
lemma lemma_stabilizer_is_period {G : Type*} [AddCommGroup G] (S : Set G) :
  let H := AddAction.stabilizer G S
  S + (H : Set G) = S := by
    refine' le_antisymm _ _;
    · intro x hx; aesop;
    · intro x hx; exact ⟨ x, hx, 0, by simp +decide ⟩ ;
/-
Structure of subgroups of Z/aZ: Every subgroup H is cyclic, generated by p = a/|H|, where |H| divides a.
-/
lemma lemma_subgroup_structure (a : ℕ) (ha : a > 0) (H : AddSubgroup (ZMod a)) :
  ∃ p q : ℕ, p > 0 ∧ q > 0 ∧ p * q = a ∧
  Nat.card ↥H = q ∧
  H = AddSubgroup.closure {(p : ZMod a)} := by
    obtain ⟨q, hq⟩ : ∃ q : ℕ, q ∣ a ∧ H = AddSubgroup.zmultiples (q : ZMod a) := by
      -- Since $H$ is a subgroup of the cyclic group $\mathbb{Z}/a\mathbb{Z}$, it must be cyclic.
      have h_cyclic : IsAddCyclic H := by
        cases a <;> [ aesop_cat; infer_instance ];
      obtain ⟨g, hg⟩ : ∃ g : ZMod a, H = AddSubgroup.zmultiples g := by
        obtain ⟨ g, hg ⟩ := h_cyclic.exists_generator;
        refine' ⟨ g, le_antisymm _ _ ⟩;
        · exact fun x hx => by obtain ⟨ k, hk ⟩ := hg ⟨ x, hx ⟩ ; exact ⟨ k, by simpa [ Subtype.ext_iff ] using hk ⟩ ;
        · aesop;
      refine' ⟨ g.val.gcd a, Nat.gcd_dvd_right _ _, hg.trans _ ⟩;
      refine' le_antisymm _ _ <;> simp +decide;
      · obtain ⟨ k, hk ⟩ := Nat.gcd_dvd_left ( g.val ) a;
        use k;
        cases a <;> norm_num [ ZMod.natCast_eq_zero_iff ] at *;
        rw [ mul_comm, ← Nat.cast_mul, ← hk, ZMod.natCast_zmod_val ];
      · -- Since $g.val$ and $a$ are coprime, there exists an integer $k$ such that $k * g.val \equiv \gcd(g.val, a) \pmod{a}$.
        obtain ⟨k, hk⟩ : ∃ k : ℤ, k * g.val ≡ Nat.gcd g.val a [ZMOD a] := by
          have := Nat.gcd_eq_gcd_ab g.val a;
          exact ⟨ Nat.gcdA g.val a, by rw [ this ] ; ring_nf; norm_num [ Int.ModEq, Int.add_emod, Int.mul_emod ] ⟩;
        use k;
        simp_all +decide [ ← ZMod.intCast_eq_intCast_iff ];
        cases a <;> aesop;
    cases' hq.1 with k hk;
    use q, k;
    have h_card : Nat.card (AddSubgroup.zmultiples (q : ZMod a)) = a / Nat.gcd q a := by
      cases a <;> simp_all +decide;
      rw [ Fintype.card_zmultiples ];
      rw [ addOrderOf_eq_iff ] <;> norm_num;
      · norm_cast;
        rw [ ZMod.natCast_eq_zero_iff ];
        exact ⟨ ⟨ 1, by linarith ⟩, fun m hm₁ hm₂ => by rw [ ZMod.natCast_eq_zero_iff ] ; exact Nat.not_dvd_of_pos_of_lt ( by nlinarith ) ( by nlinarith ) ⟩;
      · linarith;
    simp_all +decide [ AddSubgroup.zmultiples_eq_closure ]
