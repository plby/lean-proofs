    -- Since $kl \ge m - 1$ for $k \ge K$, the intervals $I_k$ and $I_{k+1}$ overlap.
    have int_overlap : ∀ k ≥ Nat.floor ((a - 2 : ℝ) / (b - 1 : ℝ)), ∀ n, k * (a - b + 1) ≤ n ∧ n ≤ k * a → ∃ k', k' ≥ 1 ∧ k' * (a - b + 1) ≤ n + 1 ∧ n + 1 ≤ k' * a := by
      intro k hk n hn;
      -- Since $kl \ge m - 1$, we have $k(m+l) \ge (k+1)m - 1$, so the intervals overlap.
      have h_overlap : k * (b - 1) ≥ a - b := by
        contrapose! hk;
        refine Nat.le_floor ?_;
        rw [ le_div_iff₀ ] <;> norm_num <;> try linarith [ show ( b : ℝ ) ≥ 2 by norm_cast ];
        norm_cast;
        rw [ Int.subNatNat_eq_coe, Int.subNatNat_eq_coe ] ; push_cast ; nlinarith [ Nat.sub_add_cancel ( by linarith : 1 ≤ b ), Nat.sub_add_cancel ( by linarith : b ≤ a ) ];
      by_cases h_case : n + 1 ≤ k * a;
      · exact ⟨ k, Nat.pos_of_ne_zero ( by rintro rfl; nlinarith ), by linarith, by linarith ⟩;
      · use k + 1;
        exact ⟨ Nat.succ_pos _, by nlinarith only [ hn.1, hn.2, h_case, h_overlap, Nat.sub_add_cancel ( by linarith : b ≤ a ), Nat.sub_add_cancel ( by linarith : 1 ≤ b ) ], by nlinarith only [ hn.1, hn.2, h_case, h_overlap, Nat.sub_add_cancel ( by linarith : b ≤ a ), Nat.sub_add_cancel ( by linarith : 1 ≤ b ) ] ⟩;
    -- By induction on $n$, we can show that for any $n \ge Km$, $n \in S(E)$.
    have h_ind : ∀ n ≥ Nat.floor ((a - 2 : ℝ) / (b - 1 : ℝ)) * (a - b + 1), ∃ k ≥ 1, k * (a - b + 1) ≤ n ∧ n ≤ k * a := by
      intro n hn
      induction' n, hn using Nat.le_induction with n hn ih;
      · refine' ⟨ ⌊ ( ( a : ℝ ) - 2 ) / ( b - 1 ) ⌋₊, _, _, _ ⟩ <;> norm_num;
        · rw [ le_div_iff₀ ] <;> linarith [ show ( b : ℝ ) ≥ 2 by norm_cast, show ( a : ℝ ) ≥ b + 1 by norm_cast ];
        · exact Nat.mul_le_mul_left _ ( Nat.succ_le_of_lt ( Nat.sub_lt ( by linarith ) ( by linarith ) ) );
      · obtain ⟨ k, hk₁, hk₂, hk₃ ⟩ := ih;
        by_cases hk : k ≥ Nat.floor ((a - 2 : ℝ) / (b - 1 : ℝ));
        · exact int_overlap k hk n ⟨ hk₂, hk₃ ⟩;
        · exact ⟨ k + 1, by linarith, by nlinarith [ Nat.sub_add_cancel hb_lt_a.le ], by nlinarith [ Nat.sub_add_cancel hb_lt_a.le ] ⟩;
    exact fun n hn => by obtain ⟨ k, hk₁, hk₂, hk₃ ⟩ := h_ind n hn; exact mem_closure_lower_bound_set a b hb_ge_2 hb_lt_a n |>.2 ⟨ k, hk₁, hk₂, hk₃ ⟩ ;
