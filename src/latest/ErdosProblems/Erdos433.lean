-- proven and stated by Aristotle
lemma large_elements_in_S (a b : ℕ) (hb_ge_2 : b ≥ 2) (hb_lt_a : b < a) :
  let m := a - b + 1
  let K := Nat.floor ((a - 2 : ℝ) / (b - 1 : ℝ))
