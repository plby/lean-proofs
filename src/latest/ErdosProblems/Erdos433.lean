  have hd_dvd : ∀ x ∈ Finset.Icc (a - b + 1) a, d ∣ x := by
    intro x hx
    exact Finset.gcd_dvd hx
  have ha_mem : a ∈ Finset.Icc (a - b + 1) a := by
    simp [Finset.mem_Icc]
    omega
  have ha_minus_1_mem : a - 1 ∈ Finset.Icc (a - b + 1) a := by
    simp [Finset.mem_Icc]
    omega
