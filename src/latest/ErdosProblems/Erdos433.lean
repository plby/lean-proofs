        simp only [Nat.cast_add, Nat.cast_mul, ZMod.natCast_self, mul_zero, add_zero]
      rw [this]
      exact h_E'_to_F_local _ h_sum_in_E'
lemma lemma_2_2_2x_mem_case_C (p : ℕ) (E' : Finset ℕ)
    (e x : ℕ) (he_E' : e ∈ E') (hx_E' : x ∈ E') (hx_ge_1 : 1 ≤ x)
    (hx_lt_p : x < p) (he_le_p : e ≤ p) (he_ge_1 : 1 ≤ e)
    (he_le_all : ∀ y ∈ E', e ≤ y) (h_neq_e : x ≠ e)
    (F_fin : Set (ZMod p)) (h_E'_to_F : ∀ w ∈ E', (w : ZMod p) ∈ F_fin)
    (h_cases_C : F_fin = {0, (x : ZMod p)}) :
    (2 * (x : ZMod p)) ∈ F_fin := by
  exfalso
  have he_mod_F : (e : ZMod p) ∈ F_fin := h_E'_to_F e he_E'
  rw [h_cases_C] at he_mod_F
  have he_mod : (e : ZMod p) = 0 ∨ (e : ZMod p) = (x : ZMod p) := Set.mem_insert_iff.mp he_mod_F
  have hx_mod_nz : (x : ZMod p) ≠ 0 := by
    intro h
    have h_p_div : p ∣ x := (ZMod.natCast_eq_zero_iff x p).mp h
    have : x = 0 := Nat.eq_zero_of_dvd_of_lt h_p_div hx_lt_p
    omega
  cases he_mod with
  | inl h0 =>
      have he_p : e = p := by
        have h_div : p ∣ e := (ZMod.natCast_eq_zero_iff e p).mp h0
        exact Nat.le_antisymm he_le_p (Nat.le_of_dvd he_ge_1 h_div)
      have hxe : e ≤ x := he_le_all x hx_E'
      rw [he_p] at hxe
      omega
  | inr hx_eq =>
      absurd h_neq_e
      have h_mod : e ≡ x [MOD p] := (ZMod.natCast_eq_natCast_iff e x p).mp hx_eq
      apply (Nat.ModEq.eq_of_lt_of_lt h_mod ?_ hx_lt_p).symm
      cases Nat.eq_or_lt_of_le he_le_p with
      | inl hp_eq =>
          rw [hp_eq, ZMod.natCast_self] at hx_eq
          absurd hx_mod_nz; exact hx_eq.symm
      | inr hlt => exact hlt
lemma lemma_2_2_same_sum (p q : ℕ) (a : ℕ) (ha : a = p * q) (hp : p > 1) (hq : q > 1)
    (E E' : Finset ℕ) (hE_sub : E ⊆ E') (hE_nonempty : E.Nonempty)
    (hE_card : E'.card ≤ E.card + q - 2)
    (hE_add : ∀ x y, x ∈ E → y ∈ E → x + y ≤ a → x + y ∈ E)
    (hE'_periodic : ∀ x, x ∈ E' ↔ (x ∈ Finset.Icc 1 a ∧ ∃ y ∈ E', x ≡ y [MOD p]))
    (e : ℕ) (he_min : e = Finset.min' E' (hE_nonempty.mono hE_sub))
    (x : ℕ) (hx : x ∈ E' ∩ Finset.Icc 1 p) (h_neq_e : x ≠ e) :
    ∃ z ∈ E, z ≡ 2 * x [MOD p] := by
  have he_le_p : e ∈ Finset.Icc 1 p := by
    apply lemma_2_2_full_e_le_p p q hp hq E E' hE_sub hE_nonempty (ha ▸ hE'_periodic) e he_min
  have hx_E' : x ∈ E' := (Finset.mem_inter.mp hx).1
  have hx_ge_1 : 1 ≤ x := (Finset.mem_Icc.mp (Finset.mem_inter.mp hx).2).1
  have he_E' : e ∈ E' := he_min.symm ▸ Finset.min'_mem E' (hE_nonempty.mono hE_sub)
  have he_ge_1 : 1 ≤ e := (Finset.mem_Icc.mp he_le_p).1
  -- Define hitting times u for x and v for e
  obtain ⟨u, hu_mem, hu_min⟩ : ∃ u, x + u * p ∈ E ∧ ∀ v < u, x + v * p ∉ E := by
    have h_exists_u : ∃ u, x + u * p ∈ E := by
      contrapose! hE_card
      have h_card_diff : Finset.card (Finset.image (fun k => x + k * p) (Finset.range q)) ≤ (E' \ E).card := by
        refine Finset.card_le_card ?_
        intro a' ha'
        simp only [Finset.mem_image, Finset.mem_range] at ha'
        obtain ⟨k, hk, rfl⟩ := ha'
        rw [Finset.mem_sdiff]
        refine ⟨?_, hE_card k⟩
        rw [hE'_periodic]
        constructor
        · rw [Finset.mem_Icc]
          constructor
          · have : 1 ≤ x + k * p := Nat.le_trans hx_ge_1 (Nat.le_add_right x (k * p))
            linarith
          · have hx_le_p : x ≤ p := (Finset.mem_Icc.mp (Finset.mem_inter.mp hx).2).2
            calc x + k * p ≤ p + k * p := Nat.add_le_add_right hx_le_p _
                 _ = (k + 1) * p := by ring
                 _ ≤ q * p := Nat.mul_le_mul_right p (Nat.succ_le_of_lt hk)
                 _ = a := by rw [Nat.mul_comm, ha]
        · use x, hx_E', by simp [Nat.ModEq]
      rw [Finset.card_image_of_injective _ (fun a' b' h => by nlinarith)] at h_card_diff
      simp only [Finset.card_range] at h_card_diff
      rw [Finset.card_sdiff_of_subset hE_sub] at h_card_diff
      have h_E_le_E' : E.card ≤ E'.card := Finset.card_mono hE_sub
      omega
    use Nat.find h_exists_u
    exact ⟨Nat.find_spec h_exists_u, fun v hv => Nat.find_min h_exists_u hv⟩
  obtain ⟨v, hv_mem, hv_min⟩ : ∃ v, e + v * p ∈ E ∧ ∀ w < v, e + w * p ∉ E := by
    have h_exists_v : ∃ v, e + v * p ∈ E := by
      contrapose! hE_card
      have h_card_diff : Finset.card (Finset.image (fun k => e + k * p) (Finset.range q)) ≤ (E' \ E).card := by
        refine Finset.card_le_card ?_
        intro a' ha'
        simp only [Finset.mem_image, Finset.mem_range] at ha'
        obtain ⟨k, hk, rfl⟩ := ha'
        rw [Finset.mem_sdiff]
        refine ⟨?_, hE_card k⟩
        rw [hE'_periodic]
        constructor
        · rw [Finset.mem_Icc]; constructor
          · have : 1 ≤ e + k * p := Nat.le_trans he_ge_1 (Nat.le_add_right e _)
            linarith
          · have he_le_p' : e ≤ p := (Finset.mem_Icc.mp he_le_p).2
            calc e + k * p ≤ p + k * p := Nat.add_le_add_right he_le_p' _
                 _ = (k + 1) * p := by ring
                 _ ≤ q * p := Nat.mul_le_mul_right p (Nat.succ_le_of_lt hk)
                 _ = a := by rw [Nat.mul_comm, ha]
        · use e, he_E', by simp [Nat.ModEq]
      rw [Finset.card_image_of_injective _ (fun a' b' h => by nlinarith)] at h_card_diff
      simp only [Finset.card_range] at h_card_diff
      rw [Finset.card_sdiff_of_subset hE_sub] at h_card_diff
      have h_E_le_E' : E.card ≤ E'.card := Finset.card_mono hE_sub
      omega
    use Nat.find h_exists_v
    exact ⟨Nat.find_spec h_exists_v, fun w hw => Nat.find_min h_exists_v hw⟩
  -- Bounding u + v ≤ q - 2 using the same logic as lemma_2_2_disjoint_sum
  have h_uv_le : u + v ≤ q - 2 := by
    have hx_orbit : Finset.image (fun k => x + k * p) (Finset.range u) ⊆ E' \ E := by
      intro a' ha'
      simp only [Finset.mem_image, Finset.mem_range] at ha'
      obtain ⟨k, hk, rfl⟩ := ha'
      rw [Finset.mem_sdiff]
      constructor
      · rw [hE'_periodic]
        constructor
        · have h_mem_Icc : x + u * p ∈ Finset.Icc 1 a := ((hE'_periodic (x + u * p)).mp (hE_sub hu_mem)).1
          have hup_le_a : x + u * p ≤ a := (Finset.mem_Icc.mp h_mem_Icc).2
          rw [Finset.mem_Icc]
          constructor
          · have : 1 ≤ x + k * p := Nat.le_trans hx_ge_1 (Nat.le_add_right x (k * p))
            exact this
          · have : x + k * p ≤ x + u * p := Nat.add_le_add_left (Nat.mul_le_mul_right p hk.le) x
            exact Nat.le_trans this hup_le_a
        · use x, hx_E', by simp [Nat.ModEq]
      · exact hu_min k hk
    have he_orbit : Finset.image (fun k => e + k * p) (Finset.range v) ⊆ E' \ E := by
      intro a' ha'
      simp only [Finset.mem_image, Finset.mem_range] at ha'
      obtain ⟨k, hk, rfl⟩ := ha'
      rw [Finset.mem_sdiff]
      constructor
      · rw [hE'_periodic]
        constructor
        · have h_mem_Icc : e + v * p ∈ Finset.Icc 1 a := ((hE'_periodic (e + v * p)).mp (hE_sub hv_mem)).1
          have hvp_le_a : e + v * p ≤ a := (Finset.mem_Icc.mp h_mem_Icc).2
          rw [Finset.mem_Icc]
          constructor
          · have : 1 ≤ e + k * p := Nat.le_trans he_ge_1 (Nat.le_add_right e (k * p))
            exact this
          · have : e + k * p ≤ e + v * p := Nat.add_le_add_left (Nat.mul_le_mul_right p hk.le) e
            exact Nat.le_trans this hvp_le_a
        · use e, he_E', by simp [Nat.ModEq]
      · exact hv_min k hk
    have h_disjoint : Disjoint (Finset.image (fun k => x + k * p) (Finset.range u)) (Finset.image (fun k => e + k * p) (Finset.range v)) := by
      rw [Finset.disjoint_left]
      intro y hy_x hy_e
      simp only [Finset.mem_image, Finset.mem_range] at hy_x hy_e
      obtain ⟨k1, _, rfl⟩ := hy_x
      obtain ⟨k2, _, hk2_eq⟩ := hy_e
      have hmod : x ≡ e [MOD p] := by
        rw [Nat.ModEq]
        have : (x + k1 * p) % p = (e + k2 * p) % p := by rw [hk2_eq]
        simpa using this
      have h_eq : x = e := by
        have hx_range : x ∈ Finset.Icc 1 p := (Finset.mem_inter.mp hx).2
        have he_range : e ∈ Finset.Icc 1 p := he_le_p
        rw [Finset.mem_Icc] at hx_range he_range
        by_cases hxp : x < p
        · by_cases hep : e < p
          · exact Nat.ModEq.eq_of_lt_of_lt hmod hxp hep
          · have hep_eq : e = p := by linarith
            have hx_mod : x % p = 0 := by
              rw [Nat.ModEq] at hmod
              rw [hep_eq] at hmod
              simpa using hmod
            have : x = 0 := Nat.eq_zero_of_dvd_of_lt (Nat.modEq_zero_iff_dvd.mp hx_mod) hxp
            linarith
        · have hxp_eq : x = p := by linarith
          have he_mod : e % p = 0 := by
            rw [Nat.ModEq] at hmod
            rw [hxp_eq] at hmod
            simpa using hmod.symm
          have hep_eq : e = p := by
            have : p ∣ e := Nat.modEq_zero_iff_dvd.mp he_mod
            obtain ⟨k, rfl⟩ := this
            have h_range : 1 ≤ p * k ∧ p * k ≤ p := Finset.mem_Icc.mp he_le_p
            if hk1 : k ≤ 1 then
              if hk0 : k = 0 then
                have : k = 0 := hk0
                simp [this] at h_range
              else
                have : k = 1 := by omega
                simp [this]
            else
              have : k ≥ 2 := by omega
              have : p < p * k := by
                have : 0 < p := by omega
                calc p < 2 * p := by linarith
                     _ ≤ k * p := Nat.mul_le_mul_right p (by omega)
                     _ = p * k := Nat.mul_comm k p
              linarith
          exact hxp_eq.trans hep_eq.symm
      exact h_neq_e h_eq
    have h_union : (Finset.image (fun k => x + k * p) (Finset.range u) ∪ Finset.image (fun k => e + k * p) (Finset.range v)) ⊆ E' \ E := Finset.union_subset hx_orbit he_orbit
    have h_card := Finset.card_mono h_union
    rw [Finset.card_union_of_disjoint h_disjoint] at h_card
    rw [Finset.card_image_of_injective _ (fun a' b' h => by nlinarith), Finset.card_image_of_injective _ (fun a' b' h => by nlinarith)] at h_card
    simp only [Finset.card_range] at h_card
    rw [Finset.card_sdiff_of_subset hE_sub] at h_card
    omega
  -- Let yx = x + u*p and ye = e + v*p. Both are in E.
  let yx := x + u * p
  let ye := e + v * p
  have hyx_E : yx ∈ E := hu_mem
  have hye_E : ye ∈ E := hv_mem
  -- Proof by casework on yx ≤ ye or yx > ye
  -- Case split on whether column x has few holes
  if h2u : 2 * u ≤ q - 2 then
    let z := 2 * (x + u * p)
    have hz_le_a : z ≤ a := by
      rw [ha]
      have hx_le_p : x ≤ p := (Finset.mem_Icc.mp (Finset.mem_inter.mp hx).2).2
      calc 2 * (x + u * p) = 2 * x + 2 * u * p := by ring
           _ ≤ 2 * p + (q - 2) * p := by gcongr
           _ = (2 + (q - 2)) * p := by rw [Nat.add_mul]
           _ = q * p := by
             congr
             omega
           _ = p * q := by rw [Nat.mul_comm]
    simp [z] at hz_le_a
    rw [two_mul] at hz_le_a
    have hz_E : (x + u * p) + (x + u * p) ∈ E := hE_add (x + u * p) (x + u * p) hu_mem hu_mem hz_le_a
    rw [← two_mul] at hz_E
    use z
    constructor
    · exact hz_E
    · dsimp [z]; rw [Nat.mul_add, ← Nat.mul_assoc]; simp [Nat.ModEq]
  else
    -- Column x has many holes: 2 * u > q - 2.
    -- Since u + v ≤ q - 2, this implies v < u.
    -- If x = p, then 2 * x = 2 * p ≡ p [MOD p], and p ∈ reps.
    by_cases hxp : x = p
    · use x + u * p
      constructor
      · exact hu_mem
      · simp [hxp, Nat.ModEq, two_mul]
    · -- Now x < p.
      let reps := E' ∩ Finset.Icc 1 p
      have hx_lt_p : x < p := (Finset.mem_Icc.mp (Finset.mem_inter.mp hx).2).2.lt_of_ne hxp
      have he_le_p' : e ≤ p := (Finset.mem_Icc.mp he_le_p).2
      -- The total number of holes (missing hits) in E' \ E is at most q-2.
      -- Orbit x has u holes, where 2u > q-2.
      -- Orbit e has v holes, and since u + v ≤ q-2, we must have v < u.
      have h_v_small : 2 * v ≤ q - 2 := by omega
      -- proven by Numina
      have h_sum_le_a : yx + ye ≤ a := by
        dsimp [yx, ye]; rw [ha]
        have hx_le_p : x ≤ p := (Finset.mem_Icc.mp (Finset.mem_inter.mp hx).2).2
        calc (x + u * p) + (e + v * p) = (x + e) + (u + v) * p := by ring
          _ ≤ (p + p) + (q - 2) * p := by gcongr
          _ = 2 * p + (q - 2) * p := by ring
          _ = (2 + (q - 2)) * p := by rw [Nat.add_mul]
          _ = q * p := by congr; omega
          _ = p * q := by rw [Nat.mul_comm]
      have h_yxye_in_E : yx + ye ∈ E := hE_add yx ye hyx_E hye_E h_sum_le_a
      -- x is the unique residue in reps with more than (q-2)/2 holes.
      -- This implies that any residue w ≠ x satisfies 2 * u_w ≤ q - 2.
      have h_2e_stable : ye + ye ∈ E := by
        have : ye + ye ≤ a := by
          dsimp [ye]; rw [ha]
          calc (e + v * p) + (e + v * p) = (e + e) + (v + v) * p := by ring
            _ ≤ 2 * p + (q - 2) * p := by
              gcongr
              · calc e + e ≤ p + p := Nat.add_le_add he_le_p' he_le_p'
                     _ = 2 * p := by ring
              · calc v + v = 2 * v := by ring
                     _ ≤ q - 2 := h_v_small
            _ = q * p := by
              have : 2 + (q - 2) = q := by omega
              calc 2 * p + (q - 2) * p = (2 + (q - 2)) * p := by rw [Nat.add_mul]
                   _ = q * p := by rw [this]
            _ = p * q := by rw [Nat.mul_comm]
        exact hE_add ye ye hye_E hye_E this
      -- In an almost-subgroup with unique "large" element x,
      -- any combination of "small" elements and x must land in F_fin.
      -- Specifically, 2x mod p is either 2 * (x+e) - 2e or similar residue combinations.
      -- Since these residues form the stable structure of Case 3, 2x is in F_fin.
      have h_xe_in_E : ∃ z ∈ E, z ≡ x + e [MOD p] := by
        use yx + ye, h_yxye_in_E
        dsimp [yx, ye]; rw [Nat.ModEq, Nat.add_mod, Nat.add_mul_mod_self_right, Nat.add_mul_mod_self_right, ← Nat.add_mod]
      -- proven by Numina
      have h_2e_in_E : ∃ z ∈ E, z ≡ 2 * e [MOD p] := by
        use ye + ye, h_2e_stable
        rw [Nat.ModEq, two_mul]
        dsimp [ye]
        simp [Nat.add_mod]
      -- Let F be the set of residues in ZMod p that have hits in E.
      -- We have e ∈ F, x ∈ F, x + e ∈ F, 2e ∈ F.
      -- Since 2u > q - 2, for any w ∈ F, w ≠ x, we have u_w ≤ q - 2 - u < (q - 2) / 2.
      -- Thus for any such w, w', we have u_w + u_w' ≤ q - 2, so w + w' ∈ F.
      -- This makes F \ {x} a set closed under addition (a subgroup if 0 ∈ F).
      -- Since x + e ∈ F and x + e ≠ x (as e ≠ 0), x + e is in the "stable" part.
      -- Then (x + e) + (x + e) - 2e = 2x is forced into F by the almost-subgroup
      -- axioms or the gap between u_x and the remaining hole budget.
      have h_final_residue_in_F : ∃ z ∈ E, z ≡ 2 * x [MOD p] := by
        -- Residency logic: residues of E' form an almost-subgroup F_fin.
        -- Since x ≠ e, and total holes ≤ q-2, 2x mod p must be in F_fin.
        have h_2x_in_F : ∃ y ∈ E', y ≡ 2 * x [MOD p] := by
          let F_fin : Finset (ZMod p) := (reps).image (fun (r : ℕ) => (r : ZMod p))
          have h_E'_to_F_local : ∀ w ∈ E', (w : ZMod p) ∈ F_fin := by
            intro w hw
            let r := if (w % p = 0) then p else w % p
            have hr_mod : r ≡ w [MOD p] := by dsimp [r]; split_ifs with h0; simp [Nat.ModEq, h0]; simp [Nat.ModEq]
            have hr_range : r ∈ Finset.Icc 1 p := by
              dsimp [r]; split_ifs with h0
              · exact Finset.mem_Icc.mpr ⟨Nat.pos_of_ne_zero (by omega), le_rfl⟩
              · exact Finset.mem_Icc.mpr ⟨Nat.pos_of_ne_zero h0, Nat.le_of_lt (Nat.mod_lt _ (by omega))⟩
            have hr_E' : r ∈ E' := by
              rw [hE'_periodic]; refine ⟨?_, _, hw, hr_mod⟩
              rw [Finset.mem_Icc]; exact ⟨(Finset.mem_Icc.mp hr_range).1, (Finset.mem_Icc.mp hr_range).2.trans (by rw [ha]; exact Nat.le_mul_of_pos_right p (by omega))⟩
            exact Finset.mem_image.mpr ⟨r, Finset.mem_inter.mpr ⟨hr_E', hr_range⟩, ZMod.natCast_eq_natCast_iff .. |>.mpr hr_mod⟩
          have h_almost : IsAlmostSubgroup (F_fin : Set (ZMod p)) (x : ZMod p) := by
            apply lemma_2_2_h_almost p q a ha hp hq E E' hE_sub hE_card hE_add hE'_periodic e x hx h_neq_e hx_E' hx_ge_1 u hu_mem hu_min v h_uv_le yx rfl h2u hxp reps rfl hx_lt_p F_fin rfl h_E'_to_F_local
          haveI : NeZero p := ⟨by omega⟩
          haveI : Finite (ZMod p) := inferInstance
          have h_gen := lemma_2_1_general (F_fin : Set (ZMod p)) (x : ZMod p) h_almost.1 h_almost.2
          rcases h_gen with h_cases_B | h_cases_C | ⟨S_sub, h_cases_A⟩
          · -- Case B: F = {x}. Then e = x, contradiction.
            have heF_mem : (e : ZMod p) ∈ (F_fin : Set (ZMod p)) := h_E'_to_F_local e he_E'
            rw [h_cases_B] at heF_mem
            have he_eq_x : (e : ZMod p) = x := Set.mem_singleton_iff.mp heF_mem
            absurd h_neq_e
            have h_mod : e ≡ x [MOD p] := (ZMod.natCast_eq_natCast_iff ..).mp he_eq_x
            apply (Nat.ModEq.eq_of_lt_of_lt h_mod ?_ hx_lt_p).symm
            have he_le_p_val : e ≤ p := (Finset.mem_Icc.mp he_le_p).2
            by_cases he_p : e = p
            · exfalso;
              have h_eq : (x : ZMod p) = 0 := by rw [← he_eq_x, he_p, ZMod.natCast_self]
              have h_div : p ∣ x := (ZMod.natCast_eq_zero_iff x p).mp h_eq
              have : x = p := by
                have hx_mem := (Finset.mem_inter.mp hx).2
                have hx_le := (Finset.mem_Icc.mp hx_mem).2
                have hx_pos := (Finset.mem_Icc.mp hx_mem).1
                exact Nat.le_antisymm hx_le (Nat.le_of_dvd hx_pos h_div)
              exact hxp this
            · exact he_le_p_val.lt_of_ne he_p
          · -- Case C: F = {0, x}. Then 2x is 0 or x?
            have h2x_F_mem : (2 * (x : ZMod p)) ∈ (F_fin : Set (ZMod p)) := by
              apply lemma_2_2_2x_mem_case_C p E' e x he_E' hx_E' hx_ge_1 hx_lt_p (Finset.mem_Icc.mp he_le_p).2 (Finset.mem_Icc.mp he_le_p).1 (fun y hy => he_min.symm ▸ Finset.min'_le E' y hy) h_neq_e (F_fin : Set (ZMod p)) h_E'_to_F_local h_cases_C
            rw [h_cases_C] at h2x_F_mem
            have h2x_in_set : (2 * (x : ZMod p)) = 0 ∨ (2 * (x : ZMod p)) = x := Set.mem_insert_iff.mp h2x_F_mem
            cases h2x_in_set with
            | inl h2x0 =>
              use p; constructor
              · rw [hE'_periodic, ha]; constructor
                · rw [Finset.mem_Icc]; exact ⟨hp.le, (Nat.le_mul_of_pos_right p hq.pos)⟩
                · use e, he_E'; apply (ZMod.natCast_eq_natCast_iff p e p).mp
                  rw [ZMod.natCast_self]
                  have heF_set : (e : ZMod p) ∈ ({0, (x : ZMod p)} : Set (ZMod p)) := by rw [← h_cases_C]; exact h_E'_to_F_local e he_E'
                  have he_0x : (e : ZMod p) = 0 ∨ (e : ZMod p) = x := Set.mem_insert_iff.mp heF_set
                  cases he_0x with
                  | inl h0 => exact h0.symm
                  | inr hx_eq =>
                    exfalso; absurd h_neq_e
                    have h_mod : e ≡ x [MOD p] := (ZMod.natCast_eq_natCast_iff e x p).mp hx_eq
                    apply (Nat.ModEq.eq_of_lt_of_lt h_mod ?_ hx_lt_p).symm
                    · have he_le_p_val : e ≤ p := (Finset.mem_Icc.mp he_le_p).2
                      by_cases he_p : e = p
                      · exfalso;
                        have h_eq : (x : ZMod p) = 0 := by rw [← hx_eq, he_p, ZMod.natCast_self]
                        have h_div : p ∣ x := (ZMod.natCast_eq_zero_iff x p).mp h_eq
                        have : x = p := by
                          have h_mem := (Finset.mem_inter.mp hx).2
                          have h_le := (Finset.mem_Icc.mp h_mem).2
                          have h_pos := (Finset.mem_Icc.mp h_mem).1
                          exact Nat.le_antisymm h_le (Nat.le_of_dvd h_pos h_div)
                        exact hxp this
                      · exact he_le_p_val.lt_of_ne he_p
              · apply (ZMod.natCast_eq_natCast_iff p (2 * x) p).mp
                rw [ZMod.natCast_self, Nat.cast_mul, Nat.cast_two, h2x0]
            | inr h2xx =>
              exfalso; absurd hxp
              have hx0 : (x : ZMod p) = 0 := by
                rw [two_mul] at h2xx
                have : (x : ZMod p) + (x : ZMod p) - (x : ZMod p) = (x : ZMod p) - (x : ZMod p) := by rw [h2xx]
                simpa using this
              have h_div : p ∣ x := (ZMod.natCast_eq_zero_iff x p).mp hx0
              have : x = p := by
                have h_mem := (Finset.mem_inter.mp hx).2
                have h_le := (Finset.mem_Icc.mp h_mem).2
                have h_pos := (Finset.mem_Icc.mp h_mem).1
                exact Nat.le_antisymm h_le (Nat.le_of_dvd h_pos h_div)
              exact this
          · -- Case A: F is a subgroup. Then 2x in F.
            have h2x_F : (2 * (x : ZMod p)) ∈ (F_fin : Set (ZMod p)) := by
              have hx_S : (x : ZMod p) ∈ S_sub := by rw [h_cases_A] at h_almost; exact h_almost.1
              rw [h_cases_A, two_mul]
              exact S_sub.add_mem hx_S hx_S
            obtain ⟨y_val, hyV, hy_eq⟩ := Finset.mem_image.mp (Finset.mem_coe.mp h2x_F)
            use y_val, (Finset.mem_inter.mp hyV).1
            apply (ZMod.natCast_eq_natCast_iff ..).mp
            rw [Nat.cast_mul, hy_eq]
            norm_cast
        obtain ⟨y, hy_E', hy_mod⟩ := h_2x_in_F
        -- Suppose there is no hit in E with residue 2x mod p.
        by_contra h_none
        push Not at h_none
        -- Consider the column of residues 2x mod p.
        let r' := (2 * x - 1) % p + 1
        have hr'_mod : r' ≡ 2 * x [MOD p] := by
          show r' % p = (2 * x) % p
          rw [Nat.add_mod, Nat.mod_mod, ← Nat.add_mod]
          congr; exact Nat.sub_add_cancel (by omega)
        let S := Finset.image (fun i => r' + i * p) (Finset.range q)
        have hS_card : S.card = q := by
          dsimp [S]; rw [Finset.card_image_of_injective, Finset.card_range]
          intro i j h_eq; simpa [show p ≠ 0 from by omega] using h_eq
        have hS_sub_E' : S ⊆ E' := by
          intro w hw
          · rw [hE'_periodic]
            obtain ⟨i, hi, h_wi⟩ := Finset.mem_image.mp hw
            constructor
            · rw [Finset.mem_Icc, ← h_wi]; constructor
              · have : 1 ≤ r' := by dsimp [r']; omega
                omega
              · have h_rp : r' ≤ p := by
                  dsimp [r']
                  have : (2 * x - 1) % p < p := Nat.mod_lt _ (by omega)
                  omega
                have h_iq : i ≤ q - 1 := by rw [Finset.mem_range] at hi; omega
                calc r' + i * p ≤ p + (q - 1) * p := Nat.add_le_add h_rp (Nat.mul_le_mul_right p h_iq)
                  _ = 1 * p + (q - 1) * p := by rw [Nat.one_mul]
                  _ = (1 + (q - 1)) * p := by rw [Nat.add_mul]
                  _ = q * p := by rw [Nat.add_sub_cancel' (by omega)]
                  _ = a := by rw [Nat.mul_comm, ha]
            · use y, hy_E'
              rw [← h_wi, Nat.ModEq, Nat.add_mul_mod_self_right, ← Nat.ModEq]
              exact hr'_mod.trans hy_mod.symm
        have hS_disjoint_E : Disjoint S E := by
          rw [Finset.disjoint_left]
          intro w hw hw_E
          obtain ⟨i, hi, h_wi⟩ := Finset.mem_image.mp hw
          have : w ≡ 2 * x [MOD p] := by
            rw [← h_wi, Nat.ModEq, Nat.add_mul_mod_self_right, ← Nat.ModEq]
            exact hr'_mod
          exact h_none w hw_E this
        have hS_sub : S ⊆ E' \ E := Finset.subset_sdiff.mpr ⟨hS_sub_E', hS_disjoint_E⟩
        have h_holes : (E' \ E).card ≤ q - 2 := by
          rw [Finset.card_sdiff_of_subset hE_sub]
          have : E.card ≤ E'.card := Finset.card_mono hE_sub
          omega
        have : q ≤ q - 2 := by
          calc q = S.card := hS_card.symm
               _ ≤ (E' \ E).card := Finset.card_mono hS_sub
               _ ≤ q - 2 := h_holes
        omega
      exact h_final_residue_in_F
lemma lemma_2_2_reconstruct_E' (p q a : ℕ) (ha : a = p * q) (hp : p > 1)
    (E' : Finset ℕ)
    (hE'_periodic : ∀ x, x ∈ E' ↔ (x ∈ Finset.Icc 1 a ∧ ∃ y ∈ E', x ≡ y [MOD p]))
    (R : Finset ℕ) (hR : R = E' ∩ Finset.Icc 1 p) :
    E' = Finset.biUnion R (fun r => Finset.image (fun i => r + i * p) (Finset.range q)) := by
  have hp0 : p ≠ 0 := by omega
  have hp_pos : 0 < p := by omega
  ext x
  constructor
  · intro hx
    have hx_range : x ∈ Finset.Icc 1 a := (hE'_periodic x).mp hx |>.1
    have hx1 : 1 ≤ x := (Finset.mem_Icc.mp hx_range).1
    let r := (x - 1) % p + 1
    have hr_mod : r ≡ x [MOD p] := by
      have : x - 1 ≡ (x - 1) % p [MOD p] := Nat.mod_modEq (x - 1) p |>.symm
      have h := Nat.ModEq.add_right 1 this
      rw [Nat.sub_add_cancel hx1] at h
      exact h.symm
    have hr_p : r ∈ Finset.Icc 1 p := by
      rw [Finset.mem_Icc]; constructor
      · omega
      · have : (x - 1) % p < p := Nat.mod_lt _ hp_pos
        omega
    have hr_E' : r ∈ E' := by
      rw [hE'_periodic]
      constructor
      · rw [Finset.mem_Icc]; constructor
        · exact (Finset.mem_Icc.mp hr_p).1
        · have hq_pos : 0 < q := by
            have h_a : 1 ≤ a := hx1.trans (Finset.mem_Icc.mp hx_range).2
            rw [ha] at h_a
            cases q with
            | zero => simp at h_a
            | succ q' => omega
          rw [ha]; exact (Finset.mem_Icc.mp hr_p).2.trans (Nat.le_mul_of_pos_right p hq_pos)
      · use x, hx, hr_mod
    have hr_R : r ∈ R := hR.symm ▸ Finset.mem_inter.mpr ⟨hr_E', hr_p⟩
    apply Finset.mem_biUnion.mpr; use r, hr_R
    apply Finset.mem_image.mpr
    let i := (x - r) / p
    use i
    constructor
    · rw [Finset.mem_range]
      apply Nat.div_lt_of_lt_mul
      have : r ≥ 1 := (Finset.mem_Icc.mp hr_p).1
      have : x ≤ a := (Finset.mem_Icc.mp hx_range).2
      omega
    · have h_xr : r ≤ x := by
        have : (x - 1) % p ≤ (x - 1) := Nat.mod_le (x - 1) p
        omega
      have h_div : p ∣ x - r := (Nat.modEq_iff_dvd' h_xr).mp hr_mod
      dsimp [i]
      rw [Nat.div_mul_cancel h_div, Nat.add_sub_cancel' h_xr]
  · intro hx
    obtain ⟨r, hr_R, hi_img⟩ := Finset.mem_biUnion.mp hx
    obtain ⟨i, hi_range, rfl⟩ := Finset.mem_image.mp hi_img
    have hr_inter := (hR ▸ hr_R)
    have hr_E' : r ∈ E' := (Finset.mem_inter.mp hr_inter).1
    have hr_p : r ∈ Finset.Icc 1 p := (Finset.mem_inter.mp hr_inter).2
    rw [hE'_periodic]
    constructor
    · rw [Finset.mem_Icc]; constructor
      · have : 1 ≤ r := (Finset.mem_Icc.mp hr_p).1
        omega
      · have hq_pos : 0 < q := by
          have := Finset.mem_range.mp hi_range
          omega
        calc r + i * p ≤ p + (q - 1) * p := by
               have : i ≤ q - 1 := Nat.le_pred_of_lt (Finset.mem_range.mp hi_range)
               have : i * p ≤ (q - 1) * p := Nat.mul_le_mul_right p this
               have : r ≤ p := (Finset.mem_Icc.mp hr_p).2
               omega
             _ = p + (q * p - p) := by rw [Nat.mul_sub_right_distrib, Nat.one_mul]
             _ = q * p := by
               have : p ≤ q * p := by rw [Nat.mul_comm]; exact Nat.le_mul_of_pos_right p hq_pos
               omega
             _ = a := by rw [Nat.mul_comm, ← ha]
    · use r, hr_E'; simp [Nat.ModEq]
lemma lemma_2_2_case_a (p q a e : ℕ) (ha : a = p * q) (hp : p > 1) (hq : q > 1)
    (E' : Finset ℕ) (hE'_nonempty : E'.Nonempty)
    (hE'_periodic : ∀ x, x ∈ E' ↔ (x ∈ Finset.Icc 1 a ∧ ∃ y ∈ E', x ≡ y [MOD p]))
    (he_min : e = E'.min' hE'_nonempty)
    (he_le_p : e ∈ Finset.Icc 1 p)
    (H : AddSubgroup (ZMod p))
    (h_F_to_H : (Finset.image (fun (x : ℕ) => (x : ZMod p)) (E' ∩ Finset.Icc (1 : ℕ) p) : Set (ZMod p)) = H) :
    E' = (Finset.image (fun i => i * e) (Finset.Icc 1 (a / e))).filter (· ∈ Finset.Icc 1 a) := by
  have he_pos : 0 < e := (Finset.mem_Icc.mp he_le_p).1
  have he_le : e ≤ p := (Finset.mem_Icc.mp he_le_p).2
  have hp_pos : 0 < p := by omega
  have hq_pos : 0 < q := by omega
  haveI : NeZero p := ⟨by omega⟩
  have he_H : (e : ZMod p) ∈ H := by
    change (e : ZMod p) ∈ (H : Set (ZMod p))
    rw [← h_F_to_H]
    apply Finset.mem_image.mpr
    use e
    refine ⟨Finset.mem_inter.mpr ⟨?_, he_le_p⟩, rfl⟩
    rw [he_min]
    apply E'.min'_mem
  have he_div_p : e ∣ p := by
    let r := p % e
    by_cases hr : r = 0
    · exact Nat.dvd_of_mod_eq_zero hr
    · exfalso
      have hr_pos : 0 < r := Nat.pos_of_ne_zero hr
      have hr_lt : r < e := Nat.mod_lt p he_pos
      have hr_H : (r : ZMod p) ∈ (H : Set (ZMod p)) := by
        have : (r : ZMod p) = -((p / e : ℕ) • (e : ZMod p)) := by
          apply add_eq_zero_iff_eq_neg.mp
          rw [nsmul_eq_mul, ← Nat.cast_mul, ← Nat.cast_add, Nat.mul_comm, Nat.mod_add_div p e, ZMod.natCast_self]
        rw [this]
        exact H.neg_mem (H.nsmul_mem he_H _)
      have h_r_H_set : (r : ZMod p) ∈ (H : Set (ZMod p)) := hr_H
      rw [← h_F_to_H] at h_r_H_set
      obtain ⟨r_val, hrV, hr_eq⟩ := Finset.mem_image.mp h_r_H_set
      have hr_val_E' : r_val ∈ E' := (Finset.mem_inter.mp hrV).1
      have r_eq_r_val : r = r_val := by
        have hr_lt_p : r < p := hr_lt.trans_le he_le
        have hr_val_le_p := (Finset.mem_Icc.mp (Finset.mem_inter.mp hrV).2).2
        have h_r_val_lt_p : r_val < p := by
          by_contra h_cases
          have : r_val = p := by omega
          rw [this] at hr_eq; simp at hr_eq
          have : (r : ZMod p) = 0 := hr_eq.symm
          have : p ∣ r := (ZMod.natCast_eq_zero_iff r p).mp this
          have : p ≤ r := Nat.le_of_dvd hr_pos this
          omega
        exact Nat.ModEq.eq_of_lt_of_lt ((ZMod.natCast_eq_natCast_iff r r_val p).mp hr_eq.symm) hr_lt_p h_r_val_lt_p
      have hr_val_mem : r_val ∈ E' := hr_val_E'
      have h_e_le_r_val : e ≤ r_val := he_min.symm ▸ E'.min'_le r_val hr_val_mem
      rw [r_eq_r_val] at hr_lt
      exact hr_lt.not_ge h_e_le_r_val
  let R := E' ∩ Finset.Icc 1 p
  have hR_char : R = (Finset.Icc 1 (p / e)).image (fun i => i * e) := by
    ext x
    constructor
    · intro hx
      obtain ⟨hx_E', hx_range_p⟩ := Finset.mem_inter.mp hx
      have hx_range := hx_range_p
      have hx_H : (x : ZMod p) ∈ (H : Set (ZMod p)) := by
        rw [← h_F_to_H]
        exact Finset.mem_image.mpr ⟨x, hx, rfl⟩
      have hxe : x % e = 0 := by
        let r' := x % e
        by_cases hr' : r' = 0
        · exact hr'
        · exfalso
          have hr'_pos : 0 < r' := Nat.pos_of_ne_zero hr'
          have hr'_lt : r' < e := Nat.mod_lt x he_pos
          have hr'_H : (r' : ZMod p) ∈ (H : Set (ZMod p)) := by
            have : (r' : ZMod p) = (x : ZMod p) - (x / e : ℕ) • (e : ZMod p) := by
              rw [eq_sub_iff_add_eq, nsmul_eq_mul, ← Nat.cast_mul, ← Nat.cast_add, Nat.mul_comm, Nat.mod_add_div x e]
            rw [this]
            exact H.sub_mem hx_H (H.nsmul_mem he_H _)
          have h_r'_H_set : (r' : ZMod p) ∈ (H : Set (ZMod p)) := hr'_H
          rw [← h_F_to_H] at h_r'_H_set
          obtain ⟨r'_val, hr'V, hr'_eq⟩ := Finset.mem_image.mp h_r'_H_set
          have hr'_val_E' : r'_val ∈ E' := (Finset.mem_inter.mp hr'V).1
          have r'_eq_r'_val : r' = r'_val := by
            have hr'_lt_p : r' < p := hr'_lt.trans_le he_le
            have hr'_val_le_p := (Finset.mem_Icc.mp (Finset.mem_inter.mp hr'V).2).2
            have h_r'_val_lt_p : r'_val < p := by
              by_contra h_cases
              have : r'_val = p := by omega
              rw [this] at hr'_eq; simp at hr'_eq
              have : (r' : ZMod p) = 0 := hr'_eq.symm
              have : p ∣ r' := (ZMod.natCast_eq_zero_iff r' p).mp this
              have : p ≤ r' := Nat.le_of_dvd hr'_pos this
              omega
            exact Nat.ModEq.eq_of_lt_of_lt ((ZMod.natCast_eq_natCast_iff r' r'_val p).mp hr'_eq.symm) hr'_lt_p h_r'_val_lt_p
          have : e ≤ r'_val := he_min.symm ▸ E'.min'_le r'_val hr'_val_E'
          omega
      obtain ⟨k, hk⟩ := Nat.dvd_of_mod_eq_zero hxe
      apply Finset.mem_image.mpr
      use k
      refine ⟨?_, by rw [Nat.mul_comm, hk]⟩
      rw [Finset.mem_Icc]
      constructor
      · rw [hk] at hx_E'
        have hx_range' := Finset.mem_Icc.mp hx_range
        have hx_pos : 0 < x := hx_range'.1
        have : 0 < e := he_pos
        rw [hk, Nat.mul_comm] at hx_pos
        exact Nat.pos_of_mul_pos_right hx_pos
      · have : x ≤ p := (Finset.mem_Icc.mp hx_range).2
        rw [hk] at this
        rw [Nat.mul_comm] at this
        exact (Nat.le_div_iff_mul_le he_pos).mpr this
    · intro hx
      obtain ⟨k, hk_range, rfl⟩ := Finset.mem_image.mp hx
      apply Finset.mem_inter.mpr
      constructor
      · have h_k_le : k ≤ p / e := (Finset.mem_Icc.mp hk_range).2
        have h_ke_le_p : k * e ≤ p := by
          have : k * e ≤ (p / e) * e := Nat.mul_le_mul_right e h_k_le
          exact this.trans (Nat.div_mul_le_self p e)
        have h_ke_le_a : k * e ≤ a := by
          have h_pa : p ≤ a := by rw [ha]; exact Nat.le_mul_of_pos_right p hq_pos
          exact h_ke_le_p.trans h_pa
        rw [hE'_periodic]
        constructor
        · rw [Finset.mem_Icc]
          constructor
          · have h_k_pos : 1 ≤ k := (Finset.mem_Icc.mp hk_range).1
            have h_e_pos : 1 ≤ e := he_pos
            exact Nat.mul_le_mul h_k_pos h_e_pos
          · exact h_ke_le_a
        · have h_ke_H : (k * e : ZMod p) ∈ (H : Set (ZMod p)) := by
            rw [← nsmul_eq_mul]
            exact H.nsmul_mem he_H k
          rw [← h_F_to_H] at h_ke_H
          obtain ⟨y, hy_R, hy_eq⟩ := Finset.mem_image.mp h_ke_H
          use y, (Finset.mem_inter.mp hy_R).1
          exact (ZMod.natCast_eq_natCast_iff (k * e) y p).mp (by rw [Nat.cast_mul]; exact hy_eq.symm)
      · have h_k_le : k ≤ p / e := (Finset.mem_Icc.mp hk_range).2
        have h_ke_le_p : k * e ≤ p := by
          have : k * e ≤ (p / e) * e := Nat.mul_le_mul_right e h_k_le
          exact this.trans (Nat.div_mul_le_self p e)
        rw [Finset.mem_Icc]
        constructor
        · have h_k_pos : 1 ≤ k := (Finset.mem_Icc.mp hk_range).1
          have h_e_pos : 1 ≤ e := he_pos
          exact Nat.mul_le_mul h_k_pos h_e_pos
        · exact h_ke_le_p
  rw [lemma_2_2_reconstruct_E' p q a ha hp E' hE'_periodic R rfl, hR_char]
  ext x_val
  constructor
  · intro hx_biU
    obtain ⟨r, hr_R_img, hi_img_prime⟩ := Finset.mem_biUnion.mp hx_biU
    obtain ⟨i_val, hi_range_prime, h_eq_prime⟩ := Finset.mem_image.mp hi_img_prime
    obtain ⟨k_val, hk_range_prime, rfl⟩ := Finset.mem_image.mp hr_R_img
    apply Finset.mem_filter.mpr
    constructor
    · apply Finset.mem_image.mpr
      use (k_val + i_val * (p / e))
      refine ⟨?_, ?_⟩
      · rw [Finset.mem_Icc]
        constructor
        · have : 1 ≤ k_val := (Finset.mem_Icc.mp hk_range_prime).1
          omega
        · have h_ae : a / e = q * (p / e) := by
            rw [ha, Nat.mul_comm p q, Nat.mul_div_assoc _ he_div_p]
          rw [h_ae]
          have h_k_le : k_val ≤ p / e := (Finset.mem_Icc.mp hk_range_prime).2
          have h_i_le : i_val ≤ q - 1 := Nat.le_pred_of_lt (Finset.mem_range.mp hi_range_prime)
          calc k_val + i_val * (p / e) ≤ p / e + i_val * (p / e) := by exact Nat.add_le_add_right h_k_le _
                 _ ≤ p / e + (q - 1) * (p / e) := by exact Nat.add_le_add_left (Nat.mul_le_mul_right (p / e) h_i_le) _
                 _ = (1 + (q - 1)) * (p / e) := by rw [Nat.add_mul, Nat.one_mul]
                 _ = q * (p / e) := by rw [Nat.add_sub_cancel' (by have := hq; omega)]
      · rw [← h_eq_prime, Nat.add_mul, Nat.mul_assoc, Nat.div_mul_cancel he_div_p]
    · rw [Finset.mem_Icc, ← h_eq_prime]
      constructor
      · have : 1 ≤ k_val * e := by
          have h_k_pos : 1 ≤ k_val := (Finset.mem_Icc.mp hk_range_prime).1
          exact Nat.mul_le_mul h_k_pos he_pos
        omega
      · have h_k_le : k_val ≤ p / e := (Finset.mem_Icc.mp hk_range_prime).2
        have h_i_le : i_val ≤ q - 1 := Nat.le_pred_of_lt (Finset.mem_range.mp hi_range_prime)
        calc k_val * e + i_val * p ≤ (p / e) * e + (q - 1) * p := by exact Nat.add_le_add (Nat.mul_le_mul_right e h_k_le) (Nat.mul_le_mul_right p h_i_le)
               _ = p + (q - 1) * p := by rw [Nat.div_mul_cancel he_div_p]
               _ = (1 + (q - 1)) * p := by rw [Nat.add_mul, Nat.one_mul]
               _ = q * p := by rw [Nat.add_sub_cancel' (by have := hq; omega)]
               _ = a := by rw [ha, Nat.mul_comm]
  · intro hx
    obtain ⟨hx_img, hx_range_a⟩ := Finset.mem_filter.mp hx
    obtain ⟨m, hm_range, rfl⟩ := Finset.mem_image.mp hx_img
    apply Finset.mem_biUnion.mpr
    let i := (m - 1) / (p / e)
    let k := (m - 1) % (p / e) + 1
    use k * e
    refine ⟨?_, ?_⟩
    · apply Finset.mem_image.mpr
      use k
      refine ⟨Finset.mem_Icc.mpr ⟨?_, ?_⟩, rfl⟩
      · have : 1 ≤ m := (Finset.mem_Icc.mp hm_range).1
        omega
      · have : p / e > 0 := Nat.div_pos he_le he_pos
        have := Nat.mod_lt (m - 1) this
        omega
    · apply Finset.mem_image.mpr
      use i
      refine ⟨Finset.mem_range.mpr ?_, ?_⟩
      · apply Nat.div_lt_of_lt_mul
        have h_ae : a / e = (p / e) * q := by
          have : p * q / e = p / e * q := by rw [Nat.mul_comm, Nat.mul_div_assoc _ he_div_p, Nat.mul_comm]
          rw [ha]; exact this
        have hq_pos' : 0 < q := by omega
        have hpe_pos : 0 < p / e := Nat.div_pos he_le he_pos
        have hm_le : m ≤ (p / e) * q := h_ae ▸ (Finset.mem_Icc.mp hm_range).2
        -- finished by Numina
        have hm_pos : 1 ≤ m := (Finset.mem_Icc.mp hm_range).1
        have : m - 1 < m := by omega
        calc m - 1 < m := by omega
          _ ≤ (p / e) * q := hm_le
      · -- finished by Numina
        have hpe_pos : 0 < p / e := Nat.div_pos he_le he_pos
        have hm_pos : 1 ≤ m := (Finset.mem_Icc.mp hm_range).1
        show k * e + i * p = m * e
        have hp_div_cancel : p = (p / e) * e := (Nat.div_mul_cancel he_div_p).symm
        have h_div_mod : (m - 1) = (p / e) * ((m - 1) / (p / e)) + (m - 1) % (p / e) :=
          (Nat.div_add_mod (m - 1) (p / e)).symm
        calc k * e + i * p
          = ((m - 1) % (p / e) + 1) * e + ((m - 1) / (p / e)) * p := by rfl
          _ = (m - 1) % (p / e) * e + e + ((m - 1) / (p / e)) * p := by ring
          _ = (m - 1) % (p / e) * e + ((m - 1) / (p / e)) * p + e := by ring
          _ = (m - 1) % (p / e) * e + ((m - 1) / (p / e)) * ((p / e) * e) + e := by rw [← hp_div_cancel]
          _ = (m - 1) % (p / e) * e + (m - 1) / (p / e) * (p / e) * e + e := by ring
          _ = ((m - 1) % (p / e) + (m - 1) / (p / e) * (p / e)) * e + e := by ring
          _ = ((p / e) * ((m - 1) / (p / e)) + (m - 1) % (p / e)) * e + e := by ring
          _ = (m - 1) * e + e := by
              congr 1
              rw [Nat.div_add_mod (m - 1) (p / e)]
          _ = ((m - 1) + 1) * e := by ring
          _ = m * e := by rw [Nat.sub_add_cancel hm_pos]
lemma lemma_2_2_case_1 (p q a e : ℕ) (ha : a = p * q) (hp : p > 1) (_hq : q > 1)
    (E E' : Finset ℕ) (hE_sub : E ⊆ E') (hE_add : ∀ x y, x ∈ E → y ∈ E → x + y ≤ a → x + y ∈ E)
    (hE'_periodic : ∀ x, x ∈ E' ↔ (x ∈ Finset.Icc (1 : ℕ) a ∧ ∃ y ∈ E', x ≡ y [MOD p]))
    (he_le_p : e ∈ Finset.Icc (1 : ℕ) p)
    (h_cases_C : (Finset.image (fun (x : ℕ) => (x : ZMod p)) (E' ∩ Finset.Icc (1 : ℕ) p) : Set (ZMod p)) = {0, (e : ZMod p)})
    (h_small : ∃ y ∈ E ∩ Finset.image (fun i => e + i * p) (Finset.range q), y ≤ a / 2)
    (he_in_E' : e ∈ E') (h_reps_double : (E' ∩ Finset.Icc (1 : ℕ) p) = {e, p})
    (h_E'_to_F : ∀ w ∈ E', (w : ZMod p) ∈ ({0, (e : ZMod p)} : Set (ZMod p)))
    (h_e0 : (e : ZMod p) ≠ 0) :
    E' = (Finset.image (fun i => i * e) (Finset.Icc (1 : ℕ) (a / e))).filter (· ∈ Finset.Icc (1 : ℕ) a) := by
  haveI : NeZero p := ⟨by omega⟩
  obtain ⟨y, hy_mem, hy_le⟩ := h_small
  have hy_mod_e : (y : ZMod p) = (e : ZMod p) := by
    obtain ⟨j, _, hj⟩ := Finset.mem_image.mp (Finset.mem_inter.mp hy_mem).2
    rw [← hj]; push_cast; simp
  have h2y_in_E' : 2 * y ∈ E' := by
    have : y + y ∈ E := hE_add y y (Finset.mem_inter.mp hy_mem).1 (Finset.mem_inter.mp hy_mem).1 (by omega)
    rw [← two_mul] at this
    exact hE_sub this
  have h2e_mod_zero : ((2 * e : ℕ) : ZMod p) = 0 := by
    have h2y_mod : ((2 * y : ℕ) : ZMod p) ∈ ({0, (e : ZMod p)} : Set (ZMod p)) := h_E'_to_F (2 * y) h2y_in_E'
    have hy_mod : (y : ZMod p) = (e : ZMod p) := hy_mod_e
    push_cast at h2y_mod
    rw [hy_mod] at h2y_mod
    simp at h2y_mod
    cases h2y_mod with
    | inl h0 => exact_mod_cast h0
    | inr he =>
      exfalso
      have : (e : ZMod p) = 0 := by
        rw [two_mul] at he
        exact add_left_cancel (he.trans (add_zero (e : ZMod p)).symm)
      exact h_e0 this
  have h2e_p : 2 * e = p := by
    have h_mod : ((2 * e : ℕ) : ZMod p) = 0 := h2e_mod_zero
    have : p ∣ 2 * e := (ZMod.natCast_eq_zero_iff (2 * e) p).mp h_mod
    obtain ⟨k, hk⟩ := this
    have he_pos : e > 0 := (Finset.mem_Icc.mp he_le_p).1
    have he_le : e < p := (Finset.mem_Icc.mp he_le_p).2.lt_of_ne (fun h => h_e0 (by rw [h, ZMod.natCast_self]))
    have h_k_lt : k < 2 := by
      have : k * p = 2 * e := by rw [mul_comm, hk.symm]
      nlinarith
    interval_cases k
    · rw [mul_zero] at hk; linarith
    · rw [mul_one] at hk; exact hk
  have he_div_p : e ∣ p := ⟨2, by rw [← h2e_p, mul_comm]⟩
  have h_reps_eq : E' ∩ Finset.Icc 1 p = (Finset.Icc 1 (p / e)).image (fun i => i * e) := by
    have he_pos : e > 0 := (Finset.mem_Icc.mp he_le_p).1
    have hqe : p / e = 2 := Nat.div_eq_of_eq_mul_left he_pos h2e_p.symm
    rw [hqe, h_reps_double]
    ext x; simp [Finset.mem_Icc, Finset.mem_image]
    constructor
    · rintro (rfl | rfl)
      · use 1; simp
      · use 2; simp [h2e_p]
    · rintro ⟨i, hi, rfl⟩
      rcases hi with ⟨_, hi_le⟩
      interval_cases i
      · left; simp
      · right; exact h2e_p
  rw [lemma_2_2_reconstruct_E' p q a ha hp E' hE'_periodic (E' ∩ Finset.Icc 1 p) rfl, h_reps_eq]
  ext x
  simp only [Finset.mem_image, Finset.mem_Icc, Finset.mem_biUnion, Finset.mem_range, Finset.mem_filter]
  constructor
  · intro hx
    obtain ⟨r, hrs, ⟨i, hiq, hrx⟩⟩ := hx
    obtain ⟨k, ⟨hk1, hkp_e⟩, rfl⟩ := hrs
    constructor
    · use k + i * (p / e)
      constructor
      · constructor
        · omega
        · have he_pos : 0 < e := (Finset.mem_Icc.mp he_le_p).1
          have hqe : p / e = 2 := Nat.div_eq_of_eq_mul_left he_pos h2e_p.symm
          have : p * q / e = 2 * q := by
            rw [← h2e_p, mul_comm 2 e, mul_assoc, Nat.mul_div_cancel_left _ he_pos]
          rw [ha, this, hqe]
          omega
      · rw [add_mul, mul_assoc, Nat.div_mul_cancel he_div_p, hrx]
    · constructor
      · rw [← hrx]
        apply Nat.lt_of_lt_of_le (Nat.mul_pos hk1 (Finset.mem_Icc.mp he_le_p).1)
        apply Nat.le_add_right
      · rw [← hrx, ha]
        have h1 : k * e ≤ p := Nat.le_trans (Nat.mul_le_mul_right e hkp_e) (Nat.div_mul_le_self p e)
        calc k * e + i * p ≤ p + i * p := Nat.add_le_add_right h1 (i * p)
          _ = (i + 1) * p := by rw [add_comm, ← add_one_mul]
          _ ≤ q * p := Nat.mul_le_mul_right p hiq
          _ = p * q := Nat.mul_comm q p
  · intro hx
    obtain ⟨⟨k, ⟨hk1, hka_e⟩, rfl⟩, h_range⟩ := hx
    let r_base := (k - 1) % (p / e) + 1
    let i_base := (k - 1) / (p / e)
    use r_base * e
    constructor
    · use r_base
      constructor
      · constructor
        · exact Nat.le_add_left 1 _
        · have he_pos : 0 < e := (Finset.mem_Icc.mp he_le_p).1
          have hqe : p / e = 2 := Nat.div_eq_of_eq_mul_left he_pos h2e_p.symm
          exact Nat.mod_lt _ (by omega) |> Nat.add_one_le_iff.mpr
      · rfl
    · use i_base
      constructor
      · have he_pos : 0 < e := (Finset.mem_Icc.mp he_le_p).1
        have hqe : p / e = 2 := Nat.div_eq_of_eq_mul_left he_pos h2e_p.symm
        have h_ae : a / e = 2 * q := by
          rw [ha, mul_comm, Nat.mul_div_assoc _ he_div_p, hqe, mul_comm]
        dsimp [i_base]
        rw [hqe]
        omega
      · have he_pos : 0 < e := (Finset.mem_Icc.mp he_le_p).1
        have hqe : p / e = 2 := Nat.div_eq_of_eq_mul_left he_pos h2e_p.symm
        have hp2e : p = 2 * e := h2e_p.symm
        dsimp [r_base, i_base]
        rw [hqe, hp2e, ← mul_assoc, ← add_mul, add_comm _ 1, add_assoc, mul_comm ((k - 1) / 2) 2, Nat.mod_add_div, Nat.add_sub_cancel' hk1]
lemma lemma_2_2_full (p q : ℕ) (a : ℕ) (ha : a = p * q) (hp : p > 1) (hq : q > 1)
  (E E' : Finset ℕ) (hE_sub : E ⊆ E') (hE_nonempty : E.Nonempty)
  (hE_card : E'.card ≤ E.card + q - 2)
  (hE_add : ∀ x y, x ∈ E → y ∈ E → x + y ≤ a → x + y ∈ E)
  (hE'_periodic : ∀ x, x ∈ E' ↔ (x ∈ Finset.Icc 1 a ∧ ∃ y ∈ E', x ≡ y [MOD p]))
  (e : ℕ) (he_min : e = Finset.min' E' (hE_nonempty.mono hE_sub)) :
  (E' = (Finset.image (fun i => i * e) (Finset.Icc 1 (a / e))).filter (· ∈ Finset.Icc 1 a)) ∨
  (∃ x : ℕ, x ∈ Finset.Icc 1 (p - 1) ∧ E' = Finset.image (fun i => x + i * p) (Finset.range q)) ∨
  (∃ x : ℕ, x ∈ Finset.Icc 1 (p - 1) ∧
    E' = (Finset.image (fun i => i * p) (Finset.Icc 1 q)) ∪ (Finset.image (fun i => x + i * p) (Finset.range q)) ∧
    (E ∩ Finset.image (fun i => x + i * p) (Finset.range q)).Nonempty ∧
    ∀ y ∈ E ∩ Finset.image (fun i => x + i * p) (Finset.range q), y > a / 2) := by
  haveI hp_ne : NeZero p := ⟨by omega⟩
  -- Step 1: Establish e is in [1, p] and identify representatives.
  have he_le_p : e ∈ Finset.Icc 1 p :=
    lemma_2_2_full_e_le_p p q hp hq E E' hE_sub hE_nonempty (ha ▸ hE'_periodic) e he_min
  have he_in_E' : e ∈ E' := he_min ▸ Finset.min'_mem E' (hE_nonempty.mono hE_sub)
  -- Step 2: Define F and prove it is an almost-subgroup.
  set reps : Finset ℕ := E' ∩ Finset.Icc 1 p with h_reps
  set F_fin : Finset (ZMod p) := reps.image (fun (x : ℕ) => (x : ZMod p)) with h_F_fin
  have he_in_reps : e ∈ reps := by
    simp [h_reps, Finset.mem_inter, Finset.mem_Icc]
    exact ⟨he_in_E', (Finset.mem_Icc.mp he_le_p).1, (Finset.mem_Icc.mp he_le_p).2⟩
  have he_in_F : (e : ZMod p) ∈ F_fin := by
    simp [h_F_fin]
    exact ⟨e, he_in_reps, rfl⟩
  -- Mapping utility: any element in E' has its residue in F_fin.
  have h_E'_to_F : ∀ w ∈ E', (w : ZMod p) ∈ F_fin := by
    intro w hw
    let r := if (w % p = 0) then p else w % p
    have hr_mod : r ≡ w [MOD p] := by
      dsimp [r]; split_ifs with h0
      · simp [Nat.ModEq, h0, Nat.mod_self p]
      · simp [Nat.ModEq]
    have hr_range : r ∈ Finset.Icc 1 p := by
      dsimp [r]; split_ifs with h0
      · exact Finset.mem_Icc.mpr ⟨Nat.pos_of_ne_zero (by linarith), le_rfl⟩
      · have h_pos : 0 < w % p := Nat.pos_of_ne_zero h0
        have h_lt : w % p < p := Nat.mod_lt _ (by linarith)
        exact Finset.mem_Icc.mpr ⟨h_pos, Nat.le_of_lt h_lt⟩
    have h_r_in_E' : r ∈ E' := by
      rw [hE'_periodic]
      obtain ⟨h_w_a, y, hy, h_wy_mod⟩ := (hE'_periodic w).mp hw
      refine ⟨Finset.mem_Icc.mpr ⟨(Finset.mem_Icc.mp hr_range).1, ?_⟩, y, hy, hr_mod.trans h_wy_mod⟩
      calc r ≤ p := (Finset.mem_Icc.mp hr_range).2
           _ ≤ p * q := by nlinarith [hq]
           _ = a := ha.symm
    have h_r_reps : r ∈ reps := by
      rw [h_reps]
      exact Finset.mem_inter.mpr ⟨h_r_in_E', hr_range⟩
    rw [h_F_fin]
    exact Finset.mem_image.mpr ⟨r, h_r_reps, ZMod.natCast_eq_natCast_iff .. |>.mpr hr_mod⟩
  have h_almost : IsAlmostSubgroup (F_fin : Set (ZMod p)) (e : ZMod p) := by
    refine ⟨by simp [he_in_F], ?_⟩
    intro f hf f' hf'
    obtain ⟨x, hx, rfl⟩ := Finset.mem_image.mp (Finset.mem_coe.mp hf)
    obtain ⟨y, hy, rfl⟩ := Finset.mem_image.mp (Finset.mem_coe.mp hf')
    by_cases h_eb0 : x = e ∧ y = e
    · left; simp [h_eb0]
    · right
      -- Goal: (x + y : ZMod p) ∈ F_fin
      by_cases hxy : x = y
      · -- Case x = y: needs same_sum (excluding x=e by h_eb0)
        have hxe : x ≠ e := fun h_eq => h_eb0 ⟨h_eq, hxy.symm.trans h_eq⟩
        obtain ⟨z, hzE, hz_mod⟩ := lemma_2_2_same_sum p q a ha hp hq E E' hE_sub hE_nonempty hE_card hE_add hE'_periodic e he_min x
          hx hxe
        have hz_in_E' : z ∈ E' := hE_sub hzE
        have h_z_mod : (z : ZMod p) = (x : ZMod p) + (y : ZMod p) := by
          conv_lhs => rw [ZMod.natCast_eq_natCast_iff .. |>.mpr hz_mod]
          simp only [two_mul, Nat.cast_add, hxy]
        rw [← h_z_mod]
        exact h_E'_to_F z hz_in_E'
      · -- Case x ≠ y: use lemma_2_2_disjoint_sum
        -- h_add in disjoint_sum wants: x' -> proof_x' -> y' -> proof_y' -> hle -> result
        -- hE_add in params is: x' -> y' -> proof_x' -> proof_y' -> hle -> result
        have h_add_pq : ∀ x' ∈ E, ∀ y' ∈ E, x' + y' ≤ p * q → x' + y' ∈ E :=
          fun x' hx' y' hy' hle => hE_add x' y' hx' hy' (ha.symm ▸ hle)
        have hE'_pq : ∀ x', x' ∈ E' ↔ (x' ∈ Finset.Icc 1 (p * q) ∧ ∃ y' ∈ E', x' ≡ y' [MOD p]) := ha ▸ hE'_periodic
        obtain ⟨z, hzE, hz_mod⟩ := lemma_2_2_disjoint_sum p q hp hq E E' hE_sub hE_card h_add_pq hE'_pq x y
          hx hy hxy
        have hz_in_E' : z ∈ E' := hE_sub hzE
        have h_z_mod : (z : ZMod p) = (x : ZMod p) + (y : ZMod p) := by
          rw [← Nat.cast_add]
          exact ZMod.natCast_eq_natCast_iff .. |>.mpr hz_mod
        rw [← h_z_mod]
        exact h_E'_to_F z hz_in_E'
  -- Step 3: Apply structural result for almost-subgroups.
  rcases lemma_2_1_general (F_fin : Set (ZMod p)) (e : ZMod p) h_almost.1 h_almost.2
    with h_cases_B | h_cases_C | ⟨H, h_cases_A⟩
  · -- Case B: F = {e}
    have h_reps_single : reps = {e} := by
      ext r_val
      constructor
      · intro hr
        have h_cast : (r_val : ZMod p) ∈ F_fin := Finset.mem_image.mpr ⟨r_val, hr, rfl⟩
        have h_cast_set : (r_val : ZMod p) ∈ (F_fin : Set (ZMod p)) := Finset.mem_coe.mpr h_cast
        rw [h_cases_B] at h_cast_set
        simp only [Set.mem_singleton_iff] at h_cast_set
        have h_modeq : r_val % p = e % p := (ZMod.natCast_eq_natCast_iff' ..).mp h_cast_set
        have hr_in_p : r_val ∈ Finset.Icc 1 p := (Finset.mem_inter.mp (h_reps ▸ hr)).2
        have he_in_p : e ∈ Finset.Icc 1 p := he_le_p
        obtain ⟨hr1, hrp_le⟩ := Finset.mem_Icc.mp hr_in_p
        obtain ⟨he1, hep_le⟩ := Finset.mem_Icc.mp he_in_p
        by_cases hrp_eq : r_val = p
        · have : e = p := by
            by_contra h_e_ne_p
            have : e < p := Nat.lt_of_le_of_ne hep_le h_e_ne_p
            rw [hrp_eq, Nat.mod_self, Nat.mod_eq_of_lt this] at h_modeq
            omega
          rw [hrp_eq, this]
          exact Finset.mem_singleton_self p
        · have hr_lt_p : r_val < p := Nat.lt_of_le_of_ne hrp_le hrp_eq
          rw [Nat.mod_eq_of_lt hr_lt_p] at h_modeq
          have he_lt_p : e < p := by
            by_contra h_e_ne_p
            have : e = p := by omega
            rw [this, Nat.mod_self] at h_modeq
            omega
          rw [Nat.mod_eq_of_lt he_lt_p] at h_modeq
          rw [Finset.mem_singleton]
          exact h_modeq
      · intro h; rw [Finset.mem_singleton] at h; subst h; exact he_in_reps
    have h_E'_eq : E' = Finset.biUnion {e} (fun r => Finset.image (fun i => r + i * p) (Finset.range q)) := by
      rw [lemma_2_2_reconstruct_E' p q a ha hp E' hE'_periodic reps h_reps]
      rw [h_reps_single]
    by_cases h_ep : e = p
    · -- Subcase e = p → Case 1
      left
      have h_final : E' = (Finset.image (fun i => i * e) (Finset.Icc 1 (a / e))).filter (· ∈ Finset.Icc 1 a) := by
        ext x
        rw [h_E'_eq, Finset.singleton_biUnion]
        simp only [Finset.mem_filter, Finset.mem_Icc, Finset.mem_image, Finset.mem_range]
        have ha_div_e : a / e = q := by
          rw [h_ep, ha, Nat.mul_div_cancel_left q (by omega)]
        constructor
        · intro ⟨i, hiq, hx⟩
          subst hx
          constructor
          · use i + 1
            refine ⟨⟨by omega, ?_⟩, ?_⟩
            · rw [ha_div_e]; exact hiq
            · rw [h_ep]; ring
          · constructor
            · rw [h_ep]; omega
            · rw [ha, h_ep, add_comm, ← Nat.succ_mul, mul_comm p q]
              exact Nat.mul_le_mul_right p (Nat.succ_le_of_lt hiq)
        · intro ⟨⟨j, ⟨hj1, hj_aq⟩, hx⟩, hx_range⟩
          subst hx
          use j - 1
          constructor
          · rw [ha_div_e] at hj_aq; omega
          · rw [h_ep, add_comm, ← Nat.succ_mul]
            congr
            omega
      exact h_final
    · -- Subcase e < p → Case 2
      right; left
      have he_1_p_1 : e ∈ Finset.Icc 1 (p - 1) := by
        obtain ⟨he1, hep⟩ := Finset.mem_Icc.mp he_le_p
        exact Finset.mem_Icc.mpr ⟨he1, Nat.le_pred_of_lt (Nat.lt_of_le_of_ne hep h_ep)⟩
      have h_final : E' = Finset.image (fun i => e + i * p) (Finset.range q) := by
        rw [h_E'_eq, Finset.singleton_biUnion]
      exact ⟨e, he_1_p_1, h_final⟩
  · -- Case C: F = {0, e}
    by_cases h_ep : e = p
    · -- Subcase e = p: E' = multiples of p
      left
      have h_reps_single : reps = {p} := by
        ext r; constructor
        · intro hr; have := h_E'_to_F r (Finset.mem_inter.mp (h_reps ▸ hr)).1
          rw [← Finset.mem_coe, h_cases_C, h_ep] at this; simp at this
          obtain ⟨r_pos, r_le_p⟩ := Finset.mem_Icc.mp (Finset.mem_inter.mp (h_reps ▸ hr)).2
          obtain ⟨k, hk⟩ := (ZMod.natCast_eq_zero_iff r p).mp this
          have : k = 1 := by nlinarith [hp, r_pos, r_le_p]
          rw [hk, this, mul_one, Finset.mem_singleton]
        · intro h; rw [Finset.mem_singleton] at h; subst h; rw [← h_ep]; exact he_in_reps
      have h_E'_eq : E' = Finset.biUnion {p} (fun r => Finset.image (fun i => r + i * p) (Finset.range q)) := by
        rw [lemma_2_2_reconstruct_E' p q a ha hp E' hE'_periodic reps h_reps, h_reps_single]
      ext x; rw [h_E'_eq, Finset.singleton_biUnion]
      simp only [Finset.mem_filter, Finset.mem_Icc, Finset.mem_image, Finset.mem_range]
      have ha_div_e : a / e = q := by rw [h_ep, ha, Nat.mul_div_cancel_left q (by omega)]
      constructor
      · intro ⟨i, hiq, hx⟩
        subst hx
        constructor
        · use i + 1
          refine ⟨⟨by omega, ha_div_e.symm ▸ (by omega)⟩, by rw [h_ep]; ring⟩
        · constructor
          · omega
          · rw [ha, add_comm, ← Nat.succ_mul, Nat.mul_comm p q]
            apply Nat.mul_le_mul_right
            omega
      · intro ⟨⟨j, ⟨hj1, hj_aq⟩, hx⟩, hx_range⟩
        subst hx
        use j - 1
        constructor
        · rw [ha_div_e] at hj_aq; omega
        · rw [h_ep, add_comm, ← Nat.succ_mul]
          congr; omega
    · -- Subcase e < p
      have h_e0 : (e : ZMod p) ≠ 0 := by
        intro he0
        have : p ∣ e := (ZMod.natCast_eq_zero_iff e p).mp he0
        have : e = p := by
          obtain ⟨he1, hep_le⟩ := Finset.mem_Icc.mp he_le_p
          obtain ⟨k, hk⟩ := this
          cases k
          · rw [mul_zero] at hk; linarith [he1]
          · case succ k =>
            have : k = 0 := by
              by_contra h_nz
              have : k ≥ 1 := Nat.succ_le_of_lt (Nat.pos_of_ne_zero h_nz)
              nlinarith
            subst this; simp at hk; exact hk
        exact h_ep this
      have h_reps_double : reps = {e, p} := by
        ext r_val
        constructor
        · intro hr
          have h_cast : (r_val : ZMod p) ∈ F_fin := h_F_fin ▸ Finset.mem_image.mpr ⟨r_val, hr, rfl⟩
          have h_cast_set : (r_val : ZMod p) ∈ (F_fin : Set (ZMod p)) := Finset.mem_coe.mpr h_cast
          rw [h_cases_C] at h_cast_set
          simp only [Set.mem_insert_iff, Set.mem_singleton_iff] at h_cast_set
          have hr_in_p : r_val ∈ Finset.Icc 1 p := (Finset.mem_inter.mp (h_reps ▸ hr)).2
          obtain ⟨hr1, hrp_le⟩ := Finset.mem_Icc.mp hr_in_p
          obtain ⟨he1, hep_le⟩ := Finset.mem_Icc.mp he_le_p
          rcases h_cast_set with (hz | he_cast)
          · -- r_val ≡ 0 [MOD p]
            have : r_val = p := by
              obtain ⟨k, hk⟩ := (ZMod.natCast_eq_zero_iff r_val p).mp hz
              cases k
              · rw [mul_zero] at hk; linarith [(Finset.mem_Icc.mp hr_in_p).1]
              · case succ k =>
                have h_k0 : k = 0 := by
                  by_contra h_nz
                  have : k ≥ 1 := Nat.succ_le_of_lt (Nat.pos_of_ne_zero h_nz)
                  have : p + p ≤ r_val := by
                    rw [hk, mul_add, mul_one]
                    have : p * k ≥ p * 1 := Nat.mul_le_mul_left p this
                    linarith
                  linarith [hp, hrp_le]
                rw [h_k0] at hk; simp at hk; exact hk
            rw [this]; exact Finset.mem_insert_of_mem (Finset.mem_singleton_self p)
          · -- r_val ≡ e [MOD p]
            have : r_val = e := by
              have h_modeq : r_val % p = e % p := (ZMod.natCast_eq_natCast_iff' ..).mp he_cast
              by_cases hrp : r_val = p
              · rw [hrp, Nat.mod_self] at h_modeq
                have : p ∣ e := by
                  obtain ⟨k, hk⟩ := Nat.dvd_iff_mod_eq_zero.mpr h_modeq.symm
                  exact ⟨k, hk⟩
                have : e = p := by
                  obtain ⟨k, hk⟩ := this
                  cases k
                  · rw [mul_zero] at hk; linarith [he1]
                  · case succ k =>
                    have h_k0 : k = 0 := by
                      by_contra h_nz
                      have : k ≥ 1 := Nat.succ_le_of_lt (Nat.pos_of_ne_zero h_nz)
                      have : p + p ≤ e := by
                        rw [hk, mul_add, mul_one]
                        have : p * k ≥ p * 1 := Nat.mul_le_mul_left p this
                        linarith
                      linarith [hp, hep_le]
                    rw [h_k0] at hk; simp at hk; exact hk
                rw [hrp, this]
              · have hr_lt_p : r_val < p := Nat.lt_of_le_of_ne hrp_le hrp
                rw [Nat.mod_eq_of_lt hr_lt_p] at h_modeq
                by_cases ep : e = p
                · rw [ep, Nat.mod_self] at h_modeq
                  linarith [hr1]
                · have he_lt_p : e < p := Nat.lt_of_le_of_ne hep_le ep
                  rw [Nat.mod_eq_of_lt he_lt_p] at h_modeq
                  exact h_modeq
            rw [this]; exact Finset.mem_insert_self e {p}
        · intro h
          rcases Finset.mem_insert.mp h with (r_eq_e | r_eq_p)
          · subst r_eq_e; exact he_in_reps
          · have : r_val = p := Finset.mem_singleton.mp r_eq_p
            rw [this]
            -- p \in E' because residue 0 \in F = image reps
            have h0 : (0 : ZMod p) ∈ (F_fin : Set (ZMod p)) := by rw [h_cases_C]; simp
            have : (0 : ZMod p) ∈ F_fin := Finset.mem_coe.mp h0
            obtain ⟨r, hr, hrz⟩ := Finset.mem_image.mp (h_F_fin ▸ this)
            have h_div : p ∣ r := (ZMod.natCast_eq_zero_iff r p).mp hrz
            have hr_in : r ∈ Finset.Icc 1 p := (Finset.mem_inter.mp (h_reps ▸ hr)).2
            have : r = p := by
              obtain ⟨k, hk⟩ := h_div
              cases k
              · rw [mul_zero] at hk; linarith [(Finset.mem_Icc.mp hr_in).1]
              · case succ k =>
                have h_k0 : k = 0 := by
                  by_contra h_nz
                  have : k ≥ 1 := Nat.succ_le_of_lt (Nat.pos_of_ne_zero h_nz)
                  have : p + p ≤ r := by
                    rw [hk, mul_add, mul_one]
                    have : p * k ≥ p * 1 := Nat.mul_le_mul_left p this
                    linarith
                  linarith [hp, (Finset.mem_Icc.mp hr_in).2]
                rw [h_k0] at hk; simp at hk; exact hk
            rwa [this] at hr
      have h_E'_eq : E' = (Finset.image (fun i => i * p) (Finset.Icc 1 q)) ∪ (Finset.image (fun i => e + i * p) (Finset.range q)) := by
        rw [lemma_2_2_reconstruct_E' p q a ha hp E' hE'_periodic reps h_reps]
        rw [h_reps_double, Finset.biUnion_insert, Finset.singleton_biUnion, Finset.union_comm]
        congr 1
        ext x
        simp only [Finset.mem_image, Finset.mem_range, Finset.mem_Icc]
        constructor
        · intro ⟨i, hiq, hx⟩
          use i + 1
          constructor
          · omega
          · rw [← hx, add_mul, one_mul, add_comm]
        · intro ⟨i, ⟨hi1, hiq⟩, hx⟩
          use i - 1
          constructor
          · omega
          · rw [← hx, add_comm, ← Nat.succ_mul, Nat.succ_eq_add_one, Nat.sub_add_cancel hi1]
      by_cases h_small : ∃ y ∈ E ∩ Finset.image (fun i => e + i * p) (Finset.range q), y ≤ a / 2
      · -- Sub-case: some element ≤ a/2 → Case 1
        left
        exact lemma_2_2_case_1 p q a e ha hp hq E E' hE_sub hE_add hE'_periodic he_le_p (by rw [← h_reps, ← h_F_fin, h_cases_C]) h_small he_in_E' (by rw [← h_reps, h_reps_double]) (by intro w hw; have := h_E'_to_F w hw; rw [← Finset.mem_coe, h_cases_C] at this; exact this) h_e0
      · -- Sub-case: all elements > a/2 → Case 3
        right; right
        have h_e_range : e ∈ Finset.Icc 1 (p - 1) := by
          obtain ⟨he1, hep_le⟩ := Finset.mem_Icc.mp he_le_p
          refine Finset.mem_Icc.mpr ⟨he1, Nat.le_pred_of_lt (Nat.lt_of_le_of_ne hep_le h_ep)⟩
        have h_inter_nonempty : (E ∩ Finset.image (fun i => e + i * p) (Finset.range q)).Nonempty := by
          by_contra h_empty
          rw [Finset.not_nonempty_iff_eq_empty] at h_empty
          have hE_sub_0 : E ⊆ Finset.image (fun i => i * p) (Finset.Icc 1 q) := by
            intro x hx
            have hxE' : x ∈ E' := hE_sub hx
            rw [h_E'_eq] at hxE'
            simp [Finset.mem_union, Finset.mem_image, Finset.mem_Icc, Finset.mem_range] at hxE'
            rcases hxE' with (h0 | he)
            · obtain ⟨i, ⟨hi₁, hi₂⟩, hxi⟩ := h0; exact Finset.mem_image.mpr ⟨i, Finset.mem_Icc.mpr ⟨hi₁, hi₂⟩, hxi⟩
            · exfalso
              obtain ⟨i, hi, hxi⟩ := he
              have : x ∈ E ∩ Finset.image (fun i => e + i * p) (Finset.range q) := Finset.mem_inter.mpr ⟨hx, Finset.mem_image.mpr ⟨i, Finset.mem_range.mpr hi, hxi⟩⟩
              rw [h_empty] at this
              exact Finset.notMem_empty x this
          have hE_card_le : E.card ≤ q := by
            have := Finset.card_le_card hE_sub_0
            have h_img_card : (Finset.image (fun i => i * p) (Finset.Icc 1 q)).card = q := by
              rw [Finset.card_image_of_injective]
              · simp
              · intro i j hij; dsimp at hij; nlinarith [hp]
            rw [h_img_card] at this
            exact this
          have hE'_card_eq : E'.card = 2 * q := by
            rw [h_E'_eq, Finset.card_union_of_disjoint, Finset.card_image_of_injective, Finset.card_image_of_injective]
            · simp; ring
            · intro i j hij; dsimp at hij; nlinarith [hp]
            · intro i j hij; dsimp at hij; nlinarith [hp]
            · rw [Finset.disjoint_iff_ne]
              intro x hx y hy hxy
              simp [Finset.mem_image, Finset.mem_Icc, Finset.mem_range] at hx hy
              obtain ⟨i, _, rfl⟩ := hx
              obtain ⟨j, _, rfl⟩ := hy
              have : (i * p : ZMod p) = ((e + j * p) : ZMod p) := by
                norm_cast; rw [hxy]
              simp at this
              exact h_e0 this.symm
          omega
        have h_all_large : ∀ y ∈ E ∩ Finset.image (fun i => e + i * p) (Finset.range q), y > a / 2 := by
          intro y hy; by_contra h_neg; push Not at h_neg
          exact h_small ⟨y, hy, h_neg⟩
        exact ⟨e, h_e_range, h_E'_eq, h_inter_nonempty, h_all_large⟩
  · -- Case A: F is a subgroup
    left
    have h_final : E' = (Finset.image (fun i => i * e) (Finset.Icc 1 (a / e))).filter (· ∈ Finset.Icc 1 a) := by
      exact lemma_2_2_case_a p q a e ha hp hq E' (hE_nonempty.mono hE_sub) hE'_periodic he_min he_le_p H (by rw [h_F_fin, h_reps] at h_cases_A; exact h_cases_A)
    exact h_final
-- proven by Numina
lemma lemma_3_1_case_3_gcd (p q x : ℕ) (E : Finset ℕ) (h_gcd : Finset.gcd E id = 1)
  (hE_sub : (E : Set ℕ) ⊆ (Finset.image (fun i => i * p) (Finset.Icc 1 q)) ∪ (Finset.image (fun i => x + i * p) (Finset.range q))) :
  Nat.gcd x p = 1 := by
  set d := Nat.gcd x p with hd
  have hdx : d ∣ x := Nat.gcd_dvd_left x p
  have hdp : d ∣ p := Nat.gcd_dvd_right x p
  have h_dvd_all : ∀ e ∈ E, d ∣ e := by
    intro e he
    have : e ∈ (Finset.image (fun i => i * p) (Finset.Icc 1 q) ∪
      Finset.image (fun i => x + i * p) (Finset.range q) : Set ℕ) := hE_sub he
    simp only [Finset.coe_image, Set.mem_union, Set.mem_image] at this
    rcases this with ⟨i, _, rfl⟩ | ⟨j, _, rfl⟩
    · exact Nat.dvd_trans hdp (Nat.dvd_mul_left p i)
    · exact Nat.dvd_add hdx (Nat.dvd_trans hdp (Nat.dvd_mul_left p j))
  have : d ∣ E.gcd id := by
    rw [Finset.dvd_gcd_iff]
    intro b hb
    simp only [id_eq]
    exact h_dvd_all b hb
  rw [h_gcd] at this
  exact Nat.eq_one_of_dvd_one this
-- L1: Multiples of an element in E are in S.
-- proven by Numina
lemma lemma_3_1_case_3_n_large_mul_in_S (x s₁ p : ℕ) (E : Finset ℕ) (m : ℕ) (hm : m ≥ 1)
  (hs1_in_E : x + s₁ * p ∈ E) :
  m * (x + s₁ * p) ∈ S (E : Set ℕ) := by
  have h_in_S : x + s₁ * p ∈ S (E : Set ℕ) := AddSubsemigroup.subset_closure hs1_in_E
  induction m with
  | zero => omega
  | succ m' ih =>
    cases m' with
    | zero => simp [h_in_S]
    | succ m'' =>
      rw [Nat.succ_mul]
      exact (S (E : Set ℕ)).add_mem (ih (by omega)) h_in_S
-- L2: Shifting an element in S by a multiple of `a` places it in S_k
lemma lemma_3_1_case_3_n_large_shift_in_Sk (a k z : ℕ) (ha : a > 0) (hk : k ≥ 1) (E : Finset ℕ)
  (hmax : a ∈ E) (hz_in_S : z ∈ S (E : Set ℕ)) (hz_le : z ≤ (k - 1) * a) :
  letI : NeZero a := ⟨ha.ne'⟩
  let Sk_bar := (fun n : ℕ => (n : ZMod a)) '' (S_k a (S (E : Set ℕ)) k)
  ((z : ℕ) : ZMod a) ∈ Sk_bar := by
  letI : NeZero a := ⟨ha.ne'⟩
  have ha_in_S : a ∈ S (E : Set ℕ) := AddSubsemigroup.subset_closure hmax
  -- We want to find t such that z + t * a lies in [(k-1)*a + 1, k*a].
  set diff := (k - 1) * a - z with h_diff
  set t := diff / a + 1 with h_t
  have hz_add : ∀ n : ℕ, z + n * a ∈ S (E : Set ℕ) := by
    intro n
    induction n with
    | zero =>
      have : z + 0 * a = z := by ring
      rw [this]
      exact hz_in_S
    | succ n' ih =>
      rw [Nat.succ_mul, ← add_assoc]
      exact (S (E : Set ℕ)).add_mem ih ha_in_S
  have h_bound_bot : (k - 1) * a + 1 ≤ z + t * a := by
    have h_z_diff : z + diff = (k - 1) * a := Nat.add_sub_cancel' hz_le
    have h_t_a : t * a = diff / a * a + a := by rw [h_t, Nat.add_mul, Nat.one_mul]
    have h_div_add_mod : diff = diff / a * a + diff % a := by
      rw [Nat.mul_comm, Nat.div_add_mod]
    have h_mod : diff % a < a := Nat.mod_lt diff ha
    omega
  have h_bound_top : z + t * a ≤ k * a := by
    have h_z_diff : z + diff = (k - 1) * a := Nat.add_sub_cancel' hz_le
    have h_t_a : t * a = diff / a * a + a := by rw [h_t, Nat.add_mul, Nat.one_mul]
    have h_diff_a : diff / a * a ≤ diff := Nat.div_mul_le_self diff a
    have h_k_a : k * a = (k - 1) * a + a := by
      conv_lhs => rw [← Nat.sub_add_cancel hk]
      rw [Nat.add_mul, Nat.one_mul]
    omega
  have h_in_Sk : z + t * a ∈ S_k a (S (E : Set ℕ)) k := by
    refine ⟨hz_add t, h_bound_bot, h_bound_top⟩
  -- Now we map to ZMod a
  use z + t * a
  refine ⟨h_in_Sk, ?_⟩
  push_cast
  rw [ZMod.natCast_self a, mul_zero, add_zero]
-- L3: Shifting away the p component inside ZMod a stays within G
lemma lemma_3_1_case_3_n_large_mod_p_in_G (a p q x s₁ m : ℕ) (ha : a > 0) (_ha_eq : a = p * q)
  (G : AddSubgroup (ZMod a)) (hG : G = AddSubgroup.closure {((p : ℕ) : ZMod a)}) :
  letI : NeZero a := ⟨ha.ne'⟩
  ((m * (x + s₁ * p) : ℕ) : ZMod a) - ((m * x : ℕ) : ZMod a) ∈ G := by
  letI : NeZero a := ⟨ha.ne'⟩
  -- Simplify: m*(x + s₁*p) - m*x = m*s₁*p
  have eq : (m * (x + s₁ * p) : ℕ) = m * x + m * s₁ * p := by ring
  have calc_eq : ((m * (x + s₁ * p) : ℕ) : ZMod a) - ((m * x : ℕ) : ZMod a) = (m * s₁) • ((p : ℕ) : ZMod a) := by
    calc ((m * (x + s₁ * p) : ℕ) : ZMod a) - ((m * x : ℕ) : ZMod a)
        = ((m * x + m * s₁ * p : ℕ) : ZMod a) - ((m * x : ℕ) : ZMod a) := by rw [eq]
      _ = ((m * x : ℕ) : ZMod a) + ((m * s₁ * p : ℕ) : ZMod a) - ((m * x : ℕ) : ZMod a) := by
          rw [Nat.cast_add]
      _ = ((m * s₁ * p : ℕ) : ZMod a) := by rw [add_sub_cancel_left]
      _ = ((m * s₁ : ℕ) : ZMod a) * ((p : ℕ) : ZMod a) := by rw [Nat.cast_mul]
      _ = (m * s₁) • ((p : ℕ) : ZMod a) := by rw [nsmul_eq_mul, Nat.cast_mul]
  rw [calc_eq, hG]
  have p_in_G : ((p : ℕ) : ZMod a) ∈ AddSubgroup.closure {((p : ℕ) : ZMod a)} :=
    AddSubgroup.subset_closure (Set.mem_singleton _)
  exact AddSubgroup.nsmul_mem _ p_in_G (m * s₁)
-- L4: The element 0 is trivially represented in Sk_bar (proven by Numina)
lemma lemma_3_1_case_3_n_large_0_in_Sk_bar (a k : ℕ) (ha : a > 0) (hk : k ≥ 1) (E : Finset ℕ) (hmax : a ∈ E) :
  letI : NeZero a := ⟨ha.ne'⟩
  let Sk_bar := (fun n : ℕ => (n : ZMod a)) '' (S_k a (S (E : Set ℕ)) k)
  (0 : ZMod a) ∈ Sk_bar := by
  intro inst
  let Sk_bar := (fun n : ℕ => (n : ZMod a)) '' (S_k a (S (E : Set ℕ)) k)
  -- We show that k * a ∈ S_k a (S (E : Set ℕ)) k and (k * a : ZMod a) = 0
  use k * a
  constructor
  · -- Show k * a ∈ S_k a (S (E : Set ℕ)) k
    unfold S_k
    constructor
    · -- Show k * a ∈ S (E : Set ℕ)
      unfold S
      have ha_in_E : a ∈ (E : Set ℕ) := hmax
      have ha_in_closure : a ∈ AddSubsemigroup.closure (E : Set ℕ) :=
        AddSubsemigroup.subset_closure ha_in_E
      -- Use induction on k to show k * a is in the closure
      cases' k with k
      · simp at hk
      · clear inst Sk_bar hk
        induction k with
        | zero =>
          simp
          exact ha_in_closure
        | succ k ih =>
          show (k + 2) * a ∈ AddSubsemigroup.closure (E : Set ℕ)
          have : (k + 2) * a = (k + 1) * a + a := by ring
          rw [this]
          exact AddSubsemigroup.add_mem (AddSubsemigroup.closure (E : Set ℕ)) ih ha_in_closure
    · -- Show k * a ∈ Set.Icc ((k - 1) * a + 1) (k * a)
      rw [Set.mem_Icc]
      constructor
      · -- (k - 1) * a + 1 ≤ k * a
        cases' k with k
        · simp at hk
        · simp
          have : 1 ≤ a := ha
          linarith
      · -- k * a ≤ k * a
        rfl
  · -- Show (k * a : ZMod a) = 0
    simp only [Nat.cast_mul]
    rw [ZMod.natCast_self, mul_zero]
-- L5: Spanning all cosets of G covers all of ZMod a (proven by Numina)
lemma lemma_3_1_case_3_n_large_cosets_eq_univ (a p x : ℕ) (ha : a > 0) (hp : p > 0)
  (G : AddSubgroup (ZMod a)) (hG : G = AddSubgroup.closure {((p : ℕ) : ZMod a)})
  (hx_gcd : Nat.gcd x p = 1) (Sk_bar : Set (ZMod a))
  (h_contains : ∀ m : ℕ, m < p → ((m * x : ℕ) : ZMod a) ∈ Sk_bar + (G : Set (ZMod a))) :
  Sk_bar + (G : Set (ZMod a)) = Set.univ := by
  haveI : NeZero a := ⟨ha.ne'⟩
  ext z
  simp only [Set.mem_univ, iff_true, Set.mem_add]
  -- Use that z has some representation, and use coprimality
  have hcoprime : Nat.Coprime x p := hx_gcd
  -- Since gcd(x,p) = 1, x is a unit in ZMod p
  haveI : NeZero p := ⟨hp.ne'⟩
  have hx_unit : IsUnit ((x : ℕ) : ZMod p) := (ZMod.isUnit_iff_coprime x p).mpr hcoprime
  -- For z : ZMod a, cast it to ZMod p to find the residue class
  let z_mod_p : ZMod p := (z.val : ZMod p)
  -- Since x is a unit mod p, we can find m such that m * x ≡ z.val (mod p)
  -- Specifically, m = z.val * x⁻¹ (mod p)
  obtain ⟨x_inv, hx_inv⟩ := hx_unit
  let m_val := (z_mod_p * x_inv.inv : ZMod p).val
  have hm_lt : m_val < p := (z_mod_p * x_inv.inv).val_lt
  -- Now m_val * x ≡ z.val (mod p)
  have hm_eq : ((m_val * x : ℕ) : ZMod p) = z_mod_p := by
    -- m_val is defined as (z_mod_p * x_inv.inv).val
    -- So (m_val : ZMod p) = z_mod_p * x_inv.inv
    have : (m_val : ZMod p) = z_mod_p * x_inv.inv := ZMod.natCast_zmod_val _
    calc
      ((m_val * x : ℕ) : ZMod p) = (m_val : ZMod p) * (x : ZMod p) := by simp [Nat.cast_mul]
      _ = (z_mod_p * x_inv.inv) * (x : ZMod p) := by rw [this]
      _ = z_mod_p * (x_inv.inv * (x : ZMod p)) := by ring
      _ = z_mod_p * (x_inv.inv * x_inv.val) := by rw [← hx_inv]
      _ = z_mod_p * 1 := by rw [x_inv.inv_val]
      _ = z_mod_p := by ring
  -- Apply h_contains to m_val
  have h_mx : ((m_val * x : ℕ) : ZMod a) ∈ Sk_bar + (G : Set (ZMod a)) := h_contains m_val hm_lt
  obtain ⟨s, hs_mem, g, hg_mem, hsum⟩ := h_mx
  -- Now we have s + g = (m_val * x : ZMod a)
  -- We need to show z = s + g' for some g' ∈ G
  -- Key: (m_val * x : ZMod p) = z_mod_p means z.val ≡ m_val * x (mod p)
  -- So z - (m_val * x : ZMod a) is a multiple of p, hence in G
  -- First, let's compute the difference
  let diff := z - ((m_val * x : ℕ) : ZMod a)
  -- Show that diff is in G (i.e., is a multiple of p in ZMod a)
  have hdiff_in_G : diff ∈ (G : Set (ZMod a)) := by
    rw [hG]
    apply AddSubgroup.mem_closure_singleton.mpr
    -- Need to show ∃ n : ℤ, diff = n • (p : ZMod a)
    -- We know that (m_val * x : ZMod p) = z_mod_p
    -- This means z.val ≡ m_val * x (mod p)
    -- Cast the equation hm_eq to understand the relationship
