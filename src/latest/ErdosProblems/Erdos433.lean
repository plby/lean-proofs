              have : (m + 1 + 1) * a_max = (m + 1) * a_max + a_max := by ring
              rw [this]
              exact AddSubsemigroup.add_mem (S (E : Set ℕ)) ih ha_max_in_S
          exact this
        · apply h_tail; simp; omega
      exact G_le_n_minus_1 (E : Set ℕ) ((k_max - 1) * a_max) hn hi_S
  have h_mono : (k_max - 1) * a_max ≤ (k - 1) * a := by
    -- proven by Numina
    have h_k_le : k_max ≤ k := by
      unfold k k_max
      apply Nat.ceil_le_ceil
      have hb_pos : (0 : ℝ) < b - 1 := by
        have : (1 : ℝ) < b := by norm_cast
        linarith
      apply monotone_div_right_of_nonneg (by linarith : (0 : ℝ) ≤ b - 1)
      have : (a_max : ℝ) - 1 ≤ (a : ℝ) - 1 := by
        have : (a_max : ℝ) ≤ (a : ℝ) := by exact_mod_cast ha_max_le
        linarith
      exact this
    apply Nat.mul_le_mul (by omega) ha_max_le
  have hk_pos : k ≥ 1 := by
    apply Nat.ceil_pos.mpr
    apply div_pos
    · have ha : 1 < a := by omega
      rw [sub_pos]; norm_cast
    · have hb : 1 < b := by omega
      rw [sub_pos]; norm_cast
  -- proven and stated by Numina
  obtain (h_k1 | h_k2) := eq_or_ne k_max 1
  · have hG_eq_0 : G (E : Set ℕ) = 0 := by
      rw [h_k1] at hG_bound
      simp at hG_bound
      omega
    calc (G (E : Set ℕ) : ℤ) = 0 := by rw [hG_eq_0]; norm_num
      _ ≤ (⌈(a - 1 : ℝ) / (b - 1 : ℝ)⌉ - 1) * a - 1 := by
        have h₀ : (0 : ℝ) ≤ (a - 1 : ℝ) / (b - 1 : ℝ) := by
          apply div_nonneg
          · have : (a : ℝ) ≥ 1 := by norm_cast; omega
            linarith
          · have : (b : ℝ) ≥ 1 := by norm_cast; omega
            linarith
        have hk_eq : (k : ℤ) = ⌈(a - 1 : ℝ) / (b - 1 : ℝ)⌉ := by
          simp only [k]
          have : ⌈(a - 1 : ℝ) / (b - 1 : ℝ)⌉₊ = ⌈(a - 1 : ℝ) / (b - 1 : ℝ)⌉.toNat := (Int.ceil_toNat _).symm
          rw [this]
          rw [Int.toNat_of_nonneg (Int.ceil_nonneg h₀)]
        have hk_ge : k ≥ 1 := hk_pos
        have ha_ge : a ≥ 1 := by omega
        have : (k - 1 : ℤ) * a ≥ 0 := by
          apply mul_nonneg <;> omega
        rw [← hk_eq]
        have hk_ne_1 : k ≠ 1 := by
          intro hk1
          rw [hk1] at hk_eq
          simp at hk_eq
          have : ⌈(a - 1 : ℝ) / (b - 1 : ℝ)⌉ = 1 := by omega
          have : (a - 1 : ℝ) / (b - 1 : ℝ) ≤ 1 := by
            have : ⌈(a - 1 : ℝ) / (b - 1 : ℝ)⌉ ≤ 1 := by omega
            have h_ceil : ⌈(a - 1 : ℝ) / (b - 1 : ℝ)⌉ ≤ (1 : ℤ) := this
            have h_mp := Int.ceil_le.mp h_ceil
            simp at h_mp
            exact h_mp
          have hb_pos : (0 : ℝ) < b - 1 := by
            have : (1 : ℝ) < b := by norm_cast
            linarith
          have : (a - 1 : ℝ) ≤ (b - 1 : ℝ) := (div_le_one hb_pos).mp this
          have : (a : ℝ) ≤ b := by linarith
          have : a ≤ b := by exact_mod_cast this
          omega
        have hk2 : k ≥ 2 := by omega
        have : (k - 1 : ℤ) ≥ 1 := by omega
        have : (a : ℤ) ≥ 1 := by omega
        have : (k - 1 : ℤ) * a ≥ 1 * 1 := by nlinarith
        omega
  · have hpos_prod : (k_max - 1) * a_max ≥ 1 := by
      have hk : k_max - 1 ≥ 1 := by omega
      have ha : a_max ≥ 2 := by omega
      calc (k_max - 1) * a_max ≥ 1 * 2 := Nat.mul_le_mul hk ha
        _ = 2 := by norm_num
        _ ≥ 1 := by omega
    have h₀ : (0 : ℝ) ≤ (a - 1 : ℝ) / (b - 1 : ℝ) := by
      apply div_nonneg
      · have : (a : ℝ) ≥ 1 := by norm_cast; omega
        linarith
      · have : (b : ℝ) ≥ 1 := by norm_cast; omega
        linarith
    have hk_eq : (k : ℤ) = ⌈(a - 1 : ℝ) / (b - 1 : ℝ)⌉ := by
      simp only [k]
      have : ⌈(a - 1 : ℝ) / (b - 1 : ℝ)⌉₊ = ⌈(a - 1 : ℝ) / (b - 1 : ℝ)⌉.toNat := (Int.ceil_toNat _).symm
      rw [this]
      rw [Int.toNat_of_nonneg (Int.ceil_nonneg h₀)]
    calc (G (E : Set ℕ) : ℤ) ≤ ((k_max - 1) * a_max - 1 : ℕ) := by norm_cast
      _ = (k_max - 1 : ℤ) * (a_max : ℤ) - 1 := by
        rw [Nat.cast_sub hpos_prod]
        norm_cast
      _ ≤ (k - 1 : ℤ) * a - 1 := by
        have h_m : ((k_max - 1) * a_max : ℤ) ≤ ((k - 1) * a : ℤ) := by norm_cast
        omega
      _ = (⌈(a - 1 : ℝ) / (b - 1 : ℝ)⌉ - 1) * a - 1 := by
        rw [← hk_eq]
/-- Helper for the lower bound of Theorem 1: There exists a set E achieving the lower bound. -/
lemma g_lower_bound_helper (a b : ℕ) (hb_ge_2 : b ≥ 2) (hb_lt_a : b < a) :
  ∃ E : Finset ℕ, (E : Set ℕ) ⊆ Set.Icc 1 a ∧ E.card = b ∧ E.gcd id = 1 ∧
  (G (E : Set ℕ) : ℤ) ≥ ⌊(a - 2 : ℝ) / (b - 1 : ℝ)⌋ * (a - b + 1) - 1 := by
  use lower_bound_set a b
  refine' ⟨lower_bound_set_mem a b hb_ge_2 hb_lt_a,
           lower_bound_set_card a b hb_ge_2 hb_lt_a,
           lower_bound_set_gcd a b hb_ge_2 hb_lt_a, _⟩
  simpa using lower_bound_G_val a b hb_ge_2 hb_lt_a
/-- The set of Frobenius numbers under consideration is non-empty.
proven by Aristotle -/
lemma g_nonempty (a b : ℕ) (hb_ge_2 : b ≥ 2) (hb_lt_a : b < a) :
  {G E | (E : Finset ℕ) (_hE_sub : (E : Set ℕ) ⊆ Set.Icc 1 a) (_hE_card : E.card = b) (_hE_gcd : Finset.gcd E id = 1)}.Nonempty := by
  -- By definition of $g$, we know that $g(a, b)$ is the supremum of $G(E)$ over all $E$ satisfying the conditions.
  apply Exists.intro (G (lower_bound_set a b)); exact ⟨lower_bound_set a b, lower_bound_set_mem a b hb_ge_2 hb_lt_a, lower_bound_set_card a b hb_ge_2 hb_lt_a, lower_bound_set_gcd a b hb_ge_2 hb_lt_a, rfl⟩
/-- The lower bound of Theorem 1. -/
lemma theorem_1_lower_bound (a b : ℕ) (hb_ge_2 : b ≥ 2) (hb_lt_a : b < a) :
  ⌊(a - 2 : ℝ) / (b - 1 : ℝ)⌋ * (a - b + 1) - 1 ≤ g b a := by
  rw [g]
  obtain ⟨E, hE_sub, hE_card, hE_gcd, hE_G⟩ := g_lower_bound_helper a b hb_ge_2 hb_lt_a
  apply le_trans hE_G
  norm_cast
  apply le_csSup
  · apply Set.Finite.bddAbove
    let f : Finset ℕ → ℕ := fun E => G ↑E
    let s : Set (Finset ℕ) := {E | ↑E ⊆ Set.Icc 1 a}
    have h_fin : s.Finite := (Set.finite_mem_finset (Finset.powerset (Finset.Icc 1 a))).subset
      (fun E h_sub => Finset.mem_powerset.mpr (Finset.coe_subset.mp (by simpa [Finset.coe_Icc] using h_sub)))
    exact (h_fin.image f).subset (fun x ⟨E, h_sub, _, _, hx⟩ => ⟨E, h_sub, hx⟩)
  · exact ⟨E, hE_sub, hE_card, hE_gcd, rfl⟩
/-- The upper bound of Theorem 1. -/
lemma theorem_1_upper_bound (a b : ℕ) (hb_ge_2 : b ≥ 2) (hb_lt_a : b < a) :
  g b a ≤ (⌈(a - 1 : ℝ) / (b - 1 : ℝ)⌉ - 1) * a - 1 := by
  rw [g]
  have h_nse := g_nonempty a b hb_ge_2 hb_lt_a
  let S_val := {G ↑E | (E : Finset ℕ) (_ : ↑E ⊆ Set.Icc 1 a) (_ : E.card = b) (_ : E.gcd id = 1)}
  have h_bdd : BddAbove S_val := by
    apply Set.Finite.bddAbove
    let f : Finset ℕ → ℕ := fun E => G ↑E
    let s : Set (Finset ℕ) := {E | ↑E ⊆ Set.Icc 1 a}
    have : s.Finite := (Set.finite_mem_finset (Finset.powerset (Finset.Icc 1 a))).subset
      (fun E h_sub => Finset.mem_powerset.mpr (Finset.coe_subset.mp (by simpa [Finset.coe_Icc] using h_sub)))
    exact (this.image f).subset (fun x ⟨E, hE_sub, _, _, hx⟩ => ⟨E, hE_sub, hx⟩)
  obtain ⟨E, hE_sub, hE_card, hE_gcd, hE_val⟩ := Nat.sSup_mem h_nse h_bdd
  rw [← hE_val]
  show (G (E : Set ℕ) : ℤ) ≤ (⌈(a - 1 : ℝ) / (b - 1 : ℝ)⌉ - 1) * a - 1
  exact g_upper_bound_helper a b hb_ge_2 hb_lt_a E hE_sub hE_card hE_gcd
/-- Theorem 1: Main bounds on g(b, a). -/
theorem theorem_1 (a b : ℕ) (hb_ge_2 : b ≥ 2) (hb_lt_a : b < a) :
  ⌊(a - 2 : ℝ) / (b - 1 : ℝ)⌋ * (a - b + 1) - 1 ≤ g b a ∧
  g b a ≤ (⌈(a - 1 : ℝ) / (b - 1 : ℝ)⌉ - 1) * a - 1 := by
  constructor
  · exact theorem_1_lower_bound a b hb_ge_2 hb_lt_a
  · exact theorem_1_upper_bound a b hb_ge_2 hb_lt_a
-- 'theorem_1' depends on axioms: [propext, Classical.choice, Finset.add_kneser, Quot.sound]
#print axioms theorem_1
