  have h_mz_in_S : m * (x + s₁ * p) ∈ (S (E : Set ℕ) : Set ℕ) := by
    have h_elem_in_S : x + s₁ * p ∈ (S (E : Set ℕ) : Set ℕ) := by
      apply AddSubsemigroup.subset_closure
      exact h_s1_in_E
    have h_nsmul : ∀ k : ℕ, k ≥ 1 → k * (x + s₁ * p) ∈ (S (E : Set ℕ) : Set ℕ) := by
