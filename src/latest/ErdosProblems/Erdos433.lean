-- proven by project Numina
/-- If S contains [n, ∞) and n ≥ 1, then G(E) ≤ n - 1. -/
lemma G_le_n_minus_1 (E : Set ℕ) (n : ℕ) (hn : n ≥ 1) (h_subset : Set.Ici n ⊆ S E) :
  G E ≤ n - 1 := by
  unfold G
  by_cases h : ∃ m, m ∉ S E
  · rw [Nat.sSup_def]
    · apply Nat.find_le
      intro m hm
      by_cases hcase : m < n
      · omega
      · push Not at hcase
        have : m ∈ S E := h_subset hcase
        contradiction
    · use n - 1
      intro m hm
      by_cases hcase : m < n
      · omega
      · push Not at hcase
        have : m ∈ S E := h_subset hcase
        contradiction
  · push Not at h
    have : {m | m ∉ S E} = ∅ := by
      ext m
      simp only [Set.mem_setOf_eq, Set.mem_empty_iff_false, iff_false]
      intro hm
      exact hm (h m)
    rw [this]
    rw [Nat.sSup_def]
    · apply Nat.find_le
      simp
    · use 0
      simp
/-- If S contains [(k-1)a+1, ka] and a ∈ S, then S contains [(k-1)a+1, ∞), assuming k ≥ 1.
proven by project Numina -/
lemma S_contains_tail_of_interval (a : ℕ) (ha' : a ≥ 2) (E : Set ℕ) (k : ℕ) (hk : k ≥ 1) (ha : a ∈ S E)
  (h_interval : Set.Icc ((k - 1) * a + 1) (k * a) ⊆ S E) :
  Set.Ici ((k - 1) * a + 1) ⊆ S E := by
  intro n hn
  simp [Set.mem_Ici] at hn
  -- Write n = (k-1)*a + 1 + m and use strong induction on m
  obtain ⟨m, rfl⟩ := Nat.exists_eq_add_of_le hn
  clear hn
  -- Strong induction on m
  induction m using Nat.strong_induction_on with
  | _ m ih =>
    -- Goal: (k-1)*a + 1 + m ∈ S E
    by_cases h : m < a
    · -- Case: m < a, so (k-1)*a + 1 + m ≤ (k-1)*a + (a-1) + 1 = (k-1)*a + a = k*a
      apply h_interval
      simp only [Set.mem_Icc]
      constructor
      · -- Lower bound: (k-1)*a + 1 ≤ (k-1)*a + 1 + m
        omega
      · -- Upper bound: (k-1)*a + 1 + m ≤ k*a
        calc (k - 1) * a + 1 + m ≤ (k - 1) * a + a := by omega
          _ = k * a := by
            cases k with
            | zero => omega
            | succ k' =>
              simp [Nat.add_mul]
    · -- Case: m ≥ a
      -- Write m = (m - a) + a, then (k-1)*a + 1 + m = ((k-1)*a + 1 + (m-a)) + a
      have h_ge : m ≥ a := Nat.ge_of_not_lt h
      have h_pos : 0 < m := by omega
      have h_a_pos : 0 < a := by omega
