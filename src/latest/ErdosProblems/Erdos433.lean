    rw [ show S_k a ( S E : Set ℕ ) k = Set.Icc ( ( k - 1 ) * a + 1 ) ( k * a ) from ?_ ];
    · norm_num [ Set.ncard_eq_toFinset_card' ];
      exact Or.inl ( Nat.le_sub_of_add_le ( by nlinarith only [ hk, Nat.sub_add_cancel hk ] ) );
    · ext; simp [S_k];
