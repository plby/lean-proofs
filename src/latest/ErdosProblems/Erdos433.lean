/-- Lemma 3.2: Inductive proof for the case max E = a.
proven by Aristotle -/
lemma lemma_3_2 (a b : ℕ) (E : Finset ℕ) (hE_sub : (E : Set ℕ) ⊆ Set.Icc 1 a)
  (hE_card : E.card = b) (hE_max : a ∈ E) (hE_gcd : Finset.gcd E id = 1) (k : ℕ) (hk : k ≥ 1) :
  (S_k a (S E : Set ℕ) k).ncard ≥ min a (k * b - k + 1) := by
  induction hk <;> simp_all +decide [ S_k ];
  · right
    have h_subset : (E : Set ℕ) ⊆ (S (E : Set ℕ) : Set ℕ) ∩ Set.Icc 1 a :=
      fun x hx => ⟨AddSubsemigroup.subset_closure hx, hE_sub hx⟩
    have hb_le : b ≤ ((S (E : Set ℕ) : Set ℕ) ∩ Set.Icc 1 a).ncard := by
      simpa [Set.ncard_coe_finset, hE_card] using Set.ncard_le_ncard h_subset
    have hb_pos : 0 < b := by
      rw [← hE_card]
      exact Finset.card_pos.mpr ⟨a, hE_max⟩
    omega
  · rename_i k hk ih;
    have := lemma_3_1 a b E hE_sub hE_card hE_max hE_gcd k hk;
    grind
/-- Theorem 2: Lower bound on the cardinality of S ∩ [(k-1)a+1, ka].
proven by Aristotle -/
theorem theorem_2 (a b : ℕ) (E : Finset ℕ) (hE_sub : (E : Set ℕ) ⊆ Set.Icc 1 a)
  (hE_card : E.card = b) (hE_gcd : Finset.gcd E id = 1) (k : ℕ) (hk : k ≥ 1) :
  (S_k a (S E : Set ℕ) k).ncard ≥ min a (k * b - k + 1) := by
  -- Let $m = \max E$. Since $E \subseteq [1, a]$, we have $m \le a$. Also $m \in E$ and $\gcd(E)=1$.
  obtain ⟨m, hm⟩ : ∃ m ∈ E, ∀ x ∈ E, x ≤ m := by
    exact ⟨ Finset.max' E ( Finset.card_pos.mp ( by rw [ hE_card ] ; exact Nat.pos_of_ne_zero ( by aesop_cat ) ) ), Finset.max'_mem _ _, fun x hx => Finset.le_max' _ _ hx ⟩
  have hm_le_a : m ≤ a := by
    exact hE_sub hm.1 |>.2
  have hm_mem : m ∈ E := by
    exact hm.1
  have hm_gcd : (Finset.gcd E id) = 1 := by
    exact hE_gcd;
  -- Apply `lemma_3_2` with parameters $a=m$, $b=b$, $E=E$ (since $m \in E$) to get:
  have h_card_m : (S_k m (S E : Set ℕ) k).ncard ≥ min m (k * b - k + 1) := by
    apply_rules [ lemma_3_2 ];
    exact fun x hx => ⟨ hE_sub hx |>.1, hm.2 x hx ⟩;
  by_cases h_case : k * b - k + 1 ≤ m;
  · have h_card_a : (S_k a (S E : Set ℕ) k).ncard ≥ (S_k m (S E : Set ℕ) k).ncard := by
      -- Apply `lemma_card_ineq` with the chosen parameters.
      have h_card_ineq : ((Finset.Icc ((k - 1) * m + 1) (k * m)).filter (fun x => x ∈ S E)).card ≤ ((Finset.Icc ((k - 1) * a + 1) (k * a)).filter (fun x => x ∈ S E)).card := by
        convert lemma_card_ineq ( S E ) ( ( k - 1 ) * m + 1 ) ( m - 1 ) ( ( k - 1 ) * a + 1 ) ( a - 1 ) ?_ ?_ ?_ ?_ ?_ using 1;
        any_goals omega;
        · rw [ show ( k - 1 ) * m + 1 + ( m - 1 ) = k * m by nlinarith only [ Nat.sub_add_cancel ( by linarith : 1 ≤ k ), Nat.sub_add_cancel ( by linarith [ Set.mem_Icc.mp ( hE_sub hm_mem ) ] : 1 ≤ m ) ] ];
        · rw [ show ( k - 1 ) * a + 1 + ( a - 1 ) = k * a by nlinarith only [ Nat.sub_add_cancel ( by linarith : 1 ≤ k ), Nat.sub_add_cancel ( by linarith [ Set.mem_Icc.mp ( hE_sub hm_mem ) ] : 1 ≤ a ) ] ];
        · exact Nat.succ_le_succ ( Nat.mul_le_mul_left _ hm_le_a );
        · rw [ Nat.sub_add_cancel ( by linarith [ Set.mem_Icc.mp ( hE_sub hm_mem ) ] ) ] ; exact AddSubsemigroup.subset_closure hm_mem;
      unfold S_k; rw [ Set.ncard_eq_toFinset_card', Set.ncard_eq_toFinset_card' ] ; aesop;
    grind;
  · -- Since $k * b - k + 1 > m$, we have $[(k-1)m+1, km] \subseteq S(E)$.
    have h_subset_m : Set.Icc ((k - 1) * m + 1) (k * m) ⊆ S E := by
      have h_subset_m : (S_k m (S E : Set ℕ) k).ncard = m := by
        refine' le_antisymm _ _;
        · refine' le_trans ( Set.ncard_le_ncard <| show S_k m ( S E ) k ⊆ Set.Icc ( ( k - 1 ) * m + 1 ) ( k * m ) from fun x hx => hx.2 ) _;
          norm_num [ Set.ncard_eq_toFinset_card' ];
          cases k <;> norm_num at * ; nlinarith;
        · grind;
      have h_subset_m : (S_k m (S E : Set ℕ) k) = Set.Icc ((k - 1) * m + 1) (k * m) := by
        apply Set.eq_of_subset_of_ncard_le;
        · exact fun x hx => hx.2;
        · simp_all +decide [ Set.ncard_eq_toFinset_card' ];
          cases k <;> norm_num at * ; linarith;
        · exact Set.finite_Icc _ _;
      exact h_subset_m ▸ Set.inter_subset_left;
    -- Since $[(k-1)m+1, km] \subseteq S(E)$, we have $[(k-1)a+1, ka] \subseteq S(E)$.
    have h_subset_a : Set.Icc ((k - 1) * a + 1) (k * a) ⊆ S E := by
      have h_subset_a : ∀ n ≥ (k - 1) * m + 1, n ∈ S E := by
        intro n hn
        have h_periodic : ∀ x ∈ S E, x + m ∈ S E := by
          intro x hx; exact (by
          exact AddSubsemigroup.add_mem _ hx ( AddSubsemigroup.subset_closure hm_mem ));
