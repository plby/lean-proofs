/-- The lower bound construction set E' = {a-b+1, ..., a}. -/
def lower_bound_set (a b : ℕ) : Finset ℕ := Finset.Icc (a - b + 1) a

-- proven by project Numina
lemma lower_bound_set_mem (a b : ℕ) (_hb_ge_2 : b ≥ 2) (_hb_lt_a : b < a) :
  (lower_bound_set a b : Set ℕ) ⊆ Set.Icc 1 a := by
  intro x hx
  simp [lower_bound_set, Set.mem_Icc] at hx ⊢
  constructor
  · omega
  · omega
