  (hm_cases : m = n + 1 ∨ m = n + 2)
  (hm_gt : (k - 1) * a < m * (x + s₁ * p))
  (hm_gap : m * (x + s₁ * p) - ((k - 1) * a + 1) ≥ p * (q - s₁ - 1))
  (hm_leka : m * (x + s₁ * p) ≤ k * a)
